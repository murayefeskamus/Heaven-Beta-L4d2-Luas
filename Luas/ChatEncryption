                )
            end
        end
    end

    return get_exact_remaining_width()
end

local function get_utf8_character_ends(text)
    local positions = {}
    local index = 1
    local length = #text

    while index <= length do
        local first_byte =
            text:byte(index)

        local character_length = 1

        if first_byte
            and first_byte >= 0xF0 then

            character_length = 4
        elseif first_byte
            and first_byte >= 0xE0 then

            character_length = 3
        elseif first_byte
            and first_byte >= 0xC0 then

            character_length = 2
        end

        local end_index =
            math.min(
                length,
                index +
                character_length -
                1
            )

        positions[
            #positions + 1
        ] = end_index

        index =
            end_index + 1
    end

    return positions
end

local function find_fitting_byte_end(
    text,
    maximum_width
)
    local positions =
        get_utf8_character_ends(
            text
        )

    if #positions == 0 then
        return 0
    end

    local low = 1
    local high = #positions
    local best = 0

    while low <= high do
        local middle =
            math.floor(
                (low + high) / 2
            )

        local byte_end =
            positions[middle]

        local candidate =
            text:sub(
                1,
                byte_end
            )

        if get_text_width(
            candidate
        ) <= maximum_width then

            best = byte_end
            low = middle + 1
        else
            high = middle - 1
        end
    end

    if best == 0 then
        best = positions[1]
    end

    return best
end

local function take_line_for_width(
    text,
    maximum_width
)
    text =
        tostring(text or "")

    if text == "" then
        return "",
            ""
    end

    maximum_width =
        math.max(
            18.0,
            tonumber(maximum_width)
                or 220.0
        )

    local contains_whitespace =
        text:find(
            "%s"
        ) ~= nil

    if not contains_whitespace then
        maximum_width =
            math.max(
                18.0,
                maximum_width - 4.0
            )
    end

    if get_text_width(
        text
    ) <= maximum_width then

        return text,
            ""
    end

    local byte_end =
        find_fitting_byte_end(
            text,
            maximum_width
        )

    local fitting_part =
        text:sub(
            1,
            byte_end
        )

    local consumed =
        byte_end

    local whitespace_position =
        fitting_part:match(
            ".*()%s"
        )

    if whitespace_position
        and whitespace_position > 1 then

        local word_boundary_part =
            fitting_part:sub(
                1,
                whitespace_position - 1
            )

        local boundary_fill =
            get_text_width(
                word_boundary_part
            ) / maximum_width

        -- Avoid producing unnecessarily short lines. Use the
        -- word boundary only when it still fills most of the row.
        if boundary_fill >=
            CHAT_WRAP_WORD_BREAK_MIN_FILL then

            fitting_part =
                word_boundary_part

            consumed =
                whitespace_position
        end
    end

    if fitting_part == "" then
        fitting_part =
            text:sub(
                1,
                byte_end
            )

        consumed =
            byte_end
    end

    local remaining =
        text:sub(
            consumed + 1
        ):gsub(
            "^%s+",
            ""
        )

    return fitting_part,
        remaining
end

