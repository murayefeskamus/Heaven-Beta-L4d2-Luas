        end

        if success
            and timestamp then

            return tostring(timestamp)
        end
    end

    return config.show_timestamp_seconds
        and "--:--:--"
        or "--:--"
end

local function get_message_age(
    entry,
    now
)
    now =
        tonumber(now) or os.clock()

    local created_clock =
        tonumber(
            entry and
            entry.created_clock
        ) or now

    local elapsed =
        math.max(
            0,
            math.floor(
                now -
                created_clock
            )
        )

    if elapsed < 60 then
        return tostring(elapsed) ..
            "s"
    end

    if elapsed < 3600 then
        return tostring(
            math.floor(
                elapsed / 60
            )
        ) ..
        "m"
    end

    return tostring(
        math.floor(
            elapsed / 3600
        )
    ) ..
    "h"
end

local function cleanup_recent_message_fingerprints(now)
    while #state.recent_message_order > 0 do
        local oldest =
            state.recent_message_order[1]

        if not oldest
            or now - oldest.time
                <= RECENT_FINGERPRINT_RETENTION then

            break
        end

        table.remove(
            state.recent_message_order,
            1
        )

        if state.recent_message_fingerprints[
            oldest.key
        ] == oldest.time then

            state.recent_message_fingerprints[
                oldest.key
            ] = nil
        end
    end
end

local function make_history_fingerprint(
    sender,
    plaintext,
    team_chat,
    chat_scope,
    session_id
)
    return table.concat(
        {
            tostring(sender or ""),
            team_chat and "T" or "A",
            tostring(chat_scope or "open"),
            tostring(session_id or ""),
            tostring(plaintext or "")
        },
        "\31"
    )
end

local function get_history_limit()
    return math.max(
        1,
        math.floor(
            tonumber(
                config.history_limit
            ) or DEFAULT_HISTORY_LIMIT
        )
    )
end

local function trim_history_to_limit()
    local history_limit =
        get_history_limit()

    while #state.history >
        history_limit do

        table.remove(
            state.history,
            1
        )
    end
end

local function add_history_message(
    sender,
    plaintext,
    team_chat,
    is_mention,
    name_color_index,
    message_color_index,
    chat_scope,
    session_name,
    session_id
)
    chat_scope =
        chat_scope == "private"
        and "private"
        or "open"

    if chat_scope == "private" then
        session_name =
            state.sanitize_session_name(
                session_name or
                state.auth_session.session_name
            )

        session_id =
            tostring(
                session_id or
                state.auth_session.fingerprint or ""
            )
    else
        session_name = "Open Chat"
        session_id = ""
    end

    sender =
        sanitize_display_text(
            sender
        )

    plaintext =
        sanitize_display_text(
            plaintext
        )

    local now =
        os.clock()

    cleanup_recent_message_fingerprints(
        now
    )

    local fingerprint =
        make_history_fingerprint(
            sender,
            plaintext,
            team_chat,
            chat_scope,
            session_id
        )

    local previous_time =
        state.recent_message_fingerprints[
            fingerprint
        ]

    if previous_time
        and now - previous_time
            <= DUPLICATE_MESSAGE_WINDOW then

        return false
    end

    state.recent_message_fingerprints[
        fingerprint
    ] = now

    table.insert(
        state.recent_message_order,
        {
            key = fingerprint,
            time = now
        }
    )

    state.history_sequence =
        state.history_sequence + 1

    state.latest_history_sequence =
        state.history_sequence

    state.total_message_count =
        state.total_message_count + 1

    table.insert(
        state.history,
        {
            sender = sender,
            text = plaintext,
            team_chat =
                team_chat == true,
            is_mention =
                is_mention == true,
            name_color_index =
                normalize_color_option_index(
                    name_color_index,
                    NAME_COLOR_OPTIONS
                ),
            message_color_index =
                normalize_color_option_index(
                    message_color_index,
                    MESSAGE_COLOR_OPTIONS
                ),
            chat_scope = chat_scope,
            session_name = session_name,
            session_id = session_id,
            sent_time =
                os.time() or 0,
            created_clock =
                now,
            sequence =
                state.history_sequence,
            highlight_until =
                now +
                NEWEST_MESSAGE_HIGHLIGHT_SECONDS
        }
    )

    trim_history_to_limit()

    return true
end

local function get_sender_name(userid)
