function state.record_insight(
    kind,
    detail,
    severity
)
    kind = tostring(kind or "SYSTEM"):upper()
    detail = tostring(detail or ""):gsub("[\r\n]", " ")
    severity = tostring(severity or "info")

    if severity == "error"
        or severity == "warning" then

        state.insights.last_problem_at = os.clock()
    end

    local timestamp = "--:--:--"

    if type(os) == "table"
        and type(os.date) == "function" then

        local ok,
            value =
                pcall(
                    os.date,
                    "%H:%M:%S"
                )

        if ok and value then
            timestamp = tostring(value)
        end
    end

    table.insert(
        state.insights.events,
        1,
        {
            time = timestamp,
            kind = kind,
            detail = detail,
            severity = severity
        }
    )

    while #state.insights.events > 30 do
        table.remove(
            state.insights.events
        )
    end
end

function state.notify_important(
    kind,
    message,
    unique_key,
    lifetime
)
    if not config.smart_notifications then
        return false
    end

    local now = os.clock()
    unique_key = tostring(unique_key or message or kind or "alert")

    local previous =
        state.smart_alert.cooldowns[
            unique_key
        ] or 0.0

    if now - previous < 8.0 then
        return false
    end

    state.smart_alert.cooldowns[
        unique_key
    ] = now

    state.smart_alert.text =
        tostring(message or "Important chat event.")

    state.smart_alert.kind =
        tostring(kind or "info")

    state.smart_alert.expires_at =
        now + (tonumber(lifetime) or 7.0)

    if not state.standalone_window_focused then
        state.smart_alert.unread_count =
            state.smart_alert.unread_count + 1
    end

    state.record_insight(
        "ALERT",
        state.smart_alert.text,
        state.smart_alert.kind
    )

    return true
end

function state.update_smart_alert()
    if state.smart_alert.text == "" then
        return
    end

    if os.clock() >=
        (tonumber(state.smart_alert.expires_at) or 0.0) then

        state.smart_alert.text = ""
        state.smart_alert.kind = "info"
        state.smart_alert.expires_at = 0.0
    end
end

function state.draw_smart_alert()
    state.update_smart_alert()

    if state.smart_alert.text == "" then
        return
    end

    local role = "info"

    if state.smart_alert.kind == "error" then
        role = "danger"
    elseif state.smart_alert.kind == "warning" then
        role = "warning"
    elseif state.smart_alert.kind == "success" then
        role = "success"
    elseif state.smart_alert.kind == "mention" then
        role = "purple"
    end

    local colors =
        state.get_theme_role_colors(
            role
        )

    imgui.text_colored(
        colors.normal[1],
        colors.normal[2],
        colors.normal[3],
        1.0,
        "IMPORTANT: " ..
        tostring(state.smart_alert.text)
    )

    imgui.separator()
    imgui.spacing()
end

