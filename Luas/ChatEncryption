local function estimate_history_line_count(
    entry,
    row_width
)
    local continuation_width =
        math.max(
            18.0,
            tonumber(row_width)
                or 220.0
        )

    local first_line_width =
        continuation_width -
        get_history_metadata_width(
            entry
        ) -
        CHAT_WRAP_INLINE_SAFETY

    if first_line_width <
        CHAT_WRAP_MIN_INLINE_WIDTH then

        first_line_width =
            continuation_width
    end

    first_line_width =
        math.max(
            18.0,
            first_line_width
        )

    local remaining =
        tostring(
            entry.text or ""
        )

    local line_count = 0
    local first_line = true

    repeat
        local available_width =
            first_line
            and first_line_width
            or continuation_width

        local unused_line

        unused_line,
        remaining =
            take_line_for_width(
                remaining,
                available_width
            )

        line_count =
            line_count + 1

        first_line = false
    until remaining == ""

    return math.max(
        1,
        line_count
    )
end

local function calculate_auto_history_height(
    search_text
)
    if #state.history == 0 then
        return HISTORY_AUTO_MIN_HEIGHT
    end

    local row_width =
        get_row_available_width()

    local cache_key =
        table.concat(
            {
                tostring(#state.history),
                tostring(state.latest_history_sequence or 0),
                tostring(state.chat_view or "open"),
                tostring(search_text or ""),
                tostring(math.floor(row_width + 0.5)),
                config.show_message_time and "1" or "0",
                config.show_message_age and "1" or "0",
                config.show_chat_type and "1" or "0",
                config.highlight_mentions and "1" or "0"
            },
            "|"
        )

    state.history_layout_cache =
        type(state.history_layout_cache) == "table"
        and state.history_layout_cache
        or {}

    if state.history_layout_cache.key == cache_key then
        return tonumber(
            state.history_layout_cache.height
        ) or HISTORY_AUTO_MIN_HEIGHT
    end

    local calculated_height =
        HISTORY_CHILD_PADDING

    for index =
        #state.history,
        1,
        -1 do

        local entry =
            state.history[index]

        if history_entry_matches_search(
            entry,
            search_text
        ) then
            local line_count =
                estimate_history_line_count(
                    entry,
                    row_width
                )

            calculated_height =
                calculated_height +
                line_count *
                    HISTORY_LINE_HEIGHT +
                HISTORY_MESSAGE_SPACING
        end
    end

    local result =
        math.max(
            HISTORY_AUTO_MIN_HEIGHT,
            math.min(
                HISTORY_AUTO_MAX_HEIGHT,
                calculated_height
            )
        )

    state.history_layout_cache.key =
        cache_key

    state.history_layout_cache.height =
        result

    return result
end

local function draw_decrypted_history(
    child_id,
    height,
    allow_message_search
)
    local palette =
        state.get_standalone_theme_palette()

    local _,
        standalone_disabled =
            state.get_standalone_foreground_colors()

    local disabled_text =
        state.rendering_standalone == true
        and standalone_disabled
        or (
            palette
            and palette.text_disabled
            or { 0.7, 0.7, 0.7 }
        )

    local message_search_active =
        allow_message_search == true
        and config.enable_message_search

    local active_chat_message_count =
        state.get_active_chat_message_count()

    if message_search_active
        and active_chat_message_count > 0 then

        draw_history_search(
            child_id
        )
    elseif not config.enable_message_search
        and state.history_search_text ~= "" then

        state.history_search_text = ""
    end

    local search_text =
        message_search_active
        and state.history_search_text
        or ""

    local filtered_message_count =
        count_filtered_history_messages(
            search_text
        )

    local resolved_height

    if height == "auto" then
        resolved_height =
            calculate_auto_history_height(
                search_text
            )
    else
        resolved_height =
            tonumber(height) or 220
    end

    local history_style_pushed = 0

    if state.rendering_standalone == true
        and type(imgui.push_style_color)
            == "function" then

        local palette =
            state.get_standalone_theme_palette()
            or {}

        local accent =
            type(palette.accent) == "table"
            and palette.accent
            or type(palette.border) == "table"
            and palette.border
            or { 0.25, 0.85, 1.00 }

        imgui.push_style_color(
            5,
            tonumber(accent[1]) or 0.25,
            tonumber(accent[2]) or 0.85,
            tonumber(accent[3]) or 1.00,
            1.0
        )

        history_style_pushed = 1
    end

    local history_open =
        imgui.begin_child(
            child_id,
            0,
            resolved_height,
            true,
            0
        )

    if history_open then
        if active_chat_message_count == 0 then
            imgui.text_colored(
                disabled_text[1],
                disabled_text[2],
                disabled_text[3],
                1.0,
                "No messages in this chat yet."
            )
        elseif filtered_message_count == 0 then
            imgui.text_colored(
                disabled_text[1],
                disabled_text[2],
                disabled_text[3],
                1.0,
                "No messages found."
            )
        else
            for index =
                #state.history,
                1,
                -1 do

                local entry =
                    state.history[
                        index
                    ]

                if history_entry_matches_search(
                    entry,
                    search_text
                ) then
                    local row_start_x =
                        get_cursor_position_x()

                    local row_available_width =
                        get_row_available_width()

                    local current_clock =
                        os.clock()

                    local timestamp =
                        get_history_timestamp(
                            entry.sent_time
                        )

                    local message_age =
                        get_message_age(
                            entry,
                            current_clock
                        )

                    local metadata_drawn =
                        false

                    if config.show_message_time then
                        colored_button(
                            make_fixed_timestamp_label(
                                timestamp,
                                entry.sequence
                            ),
                            1.0, 1.0, 1.0,
                            0.22, 0.22, 0.22
                        )

                        metadata_drawn = true
                    end

                    if config.show_message_age then
                        if metadata_drawn then
                            imgui.same_line()
                        end

                        colored_button(
                            make_fixed_message_age_label(
                                message_age,
                                entry.sequence
                            ),
                            0.0, 0.0, 0.0,
                            1.0, 1.0, 1.0
                        )

                        metadata_drawn = true
                    end

                    local mention_highlighted =
                        config.highlight_mentions
                        and entry.is_mention == true

                    if mention_highlighted then
                        if metadata_drawn then
                            imgui.same_line()
                        end

                        colored_button(
                            "MENTION##MentionBadge" ..
                            tostring(entry.sequence),
                            1.0, 1.0, 1.0,
                            0.72, 0.10, 0.58
                        )

                        metadata_drawn = true
                    end

                    if config.show_chat_type then
                        if metadata_drawn then
                            imgui.same_line()
                        end

                        if entry.team_chat then
                            colored_sized_button(
                                make_equal_chat_badge_label(
                                    "TEAM",
                                    entry.sequence
                                ),
                                CHAT_TYPE_BADGE_WIDTH,
                                1.0, 1.0, 1.0,
                                0.10, 0.35, 0.72
                            )
                        else
                            colored_sized_button(
                                make_equal_chat_badge_label(
                                    "ALL",
                                    entry.sequence
                                ),
                                CHAT_TYPE_BADGE_WIDTH,
                                1.0, 1.0, 1.0,
                                0.12, 0.52, 0.20
                            )
                        end

                        metadata_drawn = true
                    end

                    if metadata_drawn then
                        imgui.same_line()
                    end

                    local sender_r,
                        sender_g,
                        sender_b =
                            get_user_name_color(
                                entry.sender,
                                entry.name_color_index
                            )

                    draw_bold_colored_text(
                        sender_r,
                        sender_g,
                        sender_b,
                        1.0,
                        entry.sender .. ":"
                    )

                    imgui.same_line()

                    local message_start_x =
                        get_cursor_position_x()

                    local consumed_width = 0.0

                    if row_start_x
                        and message_start_x then

                        consumed_width =
                            math.max(
                                0.0,
                                message_start_x -
                                row_start_x
                            )
                    end

                    local continuation_width =
                        math.max(
                            18.0,
                            row_available_width
                        )

                    local first_line_width =
                        math.max(
                            18.0,
                            row_available_width -
                            consumed_width -
                            CHAT_WRAP_INLINE_SAFETY
                        )

                    if first_line_width <
                        CHAT_WRAP_MIN_INLINE_WIDTH then

                        local moved_to_new_line =
                            false

                        if type(imgui.new_line)
                            == "function" then

                            moved_to_new_line =
                                pcall(
                                    imgui.new_line
                                )
                        end

                        if not moved_to_new_line then
                            imgui.text("")
                        end

                        if row_start_x then
                            set_cursor_position_x(
                                row_start_x
                            )
                        end

                        first_line_width =
                            continuation_width
                    end

                    local highlight_message =
                        entry.sequence ==
                            state.latest_history_sequence
                        and current_clock <
                            (
                                entry.highlight_until
                                or 0.0
                            )

                    draw_responsive_inline_message(
                        entry.text,
                        highlight_message,
                        entry.message_color_index,
                        first_line_width,
                        continuation_width,
                        row_start_x
                    )

                    imgui.spacing()
                end
            end
        end
    end

    imgui.end_child()

    if history_style_pushed > 0
        and type(imgui.pop_style_color)
            == "function" then

        for _ = 1,
            history_style_pushed do

            pcall(
                imgui.pop_style_color
            )
        end
    end

    return true
end

