function state.get_short_elapsed_label(
    clock_value,
    now
)
    now = tonumber(now) or os.clock()

    local value =
        tonumber(clock_value) or 0.0

    if value <= 0.0 then
        return "never"
    end

    local elapsed =
        math.max(
            0,
            math.floor(
                now - value
            )
        )

    if elapsed <= 1 then
        return "now"
    end

    if elapsed < 60 then
        return tostring(elapsed) .. "s ago"
    end

    if elapsed < 3600 then
        return tostring(
            math.floor(
                elapsed / 60
            )
        ) .. "m ago"
    end

    return tostring(
        math.floor(
            elapsed / 3600
        )
    ) .. "h ago"
end

