local function get_current_script_directory()
    if type(debug) ~= "table"
        or type(debug.getinfo) ~= "function" then

        return nil
    end

    local success,
        information =
            pcall(
                debug.getinfo,
                1,
                "S"
            )

    if not success
        or not information
        or type(information.source) ~= "string" then

        return nil
    end

    local source_path =
        information.source

    if source_path:sub(
        1,
        1
    ) == "@" then

        source_path =
            source_path:sub(
