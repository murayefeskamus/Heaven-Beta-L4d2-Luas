local function set_status(
    message,
    kind,
    lifetime
)
    state.status =
        tostring(message or "Ready")

    state.status_kind =
        kind or "info"

    if state.status == "Ready" then
        state.status_expires_at = 0.0
        return
    end

    state.status_expires_at =
        os.clock() +
        (
            tonumber(lifetime)
            or STATUS_LIFETIME_SECONDS
        )
end

local function update_status_expiration()
    local expires_at =
        tonumber(
            state.status_expires_at
        ) or 0.0

    if expires_at <= 0.0
        or os.clock() < expires_at then

        return
    end

    state.status = "Ready"
    state.status_kind = "info"
    state.status_expires_at = 0.0
end

