local function get_user_name_color(
    sender,
    selected_color_index
)
    selected_color_index =
        normalize_color_option_index(
            selected_color_index,
            NAME_COLOR_OPTIONS
        )

    local selected_option =
        NAME_COLOR_OPTIONS[
            selected_color_index
        ]

    if selected_option
        and selected_option.red
        and selected_option.green
        and selected_option.blue then

        return state.make_theme_readable_text_color(
            selected_option.red,
            selected_option.green,
            selected_option.blue
        )
    end

    sender =
        tostring(sender or "Unknown")

    local hash = 0

    for index = 1, #sender do
        hash =
            (
                hash * 33 +
                sender:byte(index)
            ) % 2147483647
    end

    local color_index =
        (hash % #USER_NAME_COLORS) + 1

    local color =
        USER_NAME_COLORS[
            color_index
        ]

    return state.make_theme_readable_text_color(
        color[1],
        color[2],
        color[3]
    )
end

