local function send_protocol_packet(
    packet_type,
    message_id,
    body,
    team_chat,
    part_index,
    part_count,
    key_material
)
    if not engine.is_in_game()
        or not engine.is_connected() then

        return false,
            "Not connected."
    end

    local protocol_text =
        build_protocol_packet(
            packet_type,
            message_id,
            body,
            team_chat,
            part_index,
            part_count
        )

    local encrypted,
        encrypt_error =
            encrypt_message(
                protocol_text,
                key_material
            )

    if not encrypted then
        return false,
            encrypt_error or
            "Encryption failed."
    end

    send_raw_chat(
        encrypted,
        team_chat
    )

    state.insights.packets_sent =
        state.insights.packets_sent + 1

    return true
end

