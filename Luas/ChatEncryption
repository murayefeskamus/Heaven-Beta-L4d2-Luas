local function is_valid_initial_name(name)
    name =
        sanitize_display_text(
            name
        )

    return name ~= ""
        and name ~= "Unknown"
        and name ~= "You"
end

local function get_initial_local_player_name()
    local remembered_name =
        sanitize_display_text(
            config.remembered_name
        ):gsub(
            "^%s+",
            ""
        ):gsub(
            "%s+$",
            ""
        )

    if is_valid_initial_name(
        remembered_name
    ) then
        return remembered_name
    end

    if is_valid_initial_name(
        state.local_initial_name
    ) then
        return state.local_initial_name
    end

    local current_name =
        sanitize_display_text(
            get_local_player_name()
        )

    if is_valid_initial_name(
        current_name
    ) then
        -- This remains fixed for the complete lifetime of the Lua.
        -- Name-stealer changes cannot replace the captured value.
        state.local_initial_name =
            current_name

        return state.local_initial_name
    end

    return current_name ~= ""
        and current_name
        or "You"
end

local function get_initial_sender_name(userid)
    local key =
        tostring(userid or "")

    if key ~= "" then
        local cached_name =
            state.initial_user_names[
                key
            ]

        if is_valid_initial_name(
            cached_name
        ) then
            return cached_name
        end
    end

    local current_name =
        sanitize_display_text(
            get_sender_name(
                userid
            )
        )

    if key ~= ""
        and is_valid_initial_name(
            current_name
        ) then

        state.initial_user_names[
            key
        ] = current_name
    end

    return current_name ~= ""
        and current_name
        or "Unknown"
end

local MAX_LOCAL_MENTION_ALIASES = 12

local LOCAL_PLAYER_INFO_ID_FIELDS = {
    "userid",
    "user_id",
    "userID",
    "friendsID",
    "friends_id",
    "steamID",
    "steam_id",
    "xuid"
}

local PLAYER_INFO_USERID_FIELDS = {
    "userid",
    "user_id",
    "userID"
}

local function get_player_info_userid(player_info)
    if not player_info then
        return nil
    end

    for _,
        field_name in ipairs(
            PLAYER_INFO_USERID_FIELDS
        ) do

        local field_ok,
            field_value =
                pcall(
                    function()
                        return player_info[
                            field_name
                        ]
                    end
                )

        local numeric_value =
            field_ok
            and tonumber(field_value)
            or nil

        if numeric_value
            and numeric_value > 0 then

            return math.floor(
                numeric_value
            )
        end
    end

    return nil
end

local function capture_initial_lobby_names()
    if not engine.is_in_game()
        or not engine.is_connected() then

        return
    end

    local local_player =
        client.get_local_player()

    local local_index =
        local_player
        and local_player:get_index()
        or nil

    local max_clients_ok,
        max_clients =
            pcall(
                engine.get_max_clients
            )

    if not max_clients_ok
        or not max_clients then

        return
    end

    for player_index = 1,
        max_clients do

        local info_ok,
            player_info =
                pcall(
                    engine.get_player_info,
                    player_index
                )

        if info_ok
            and player_info
            and player_info.name then

            local current_name =
                sanitize_display_text(
                    player_info.name
                )

            if player_index ==
                local_index then

                get_initial_local_player_name()
            elseif is_valid_initial_name(
                current_name
            ) then
                local userid =
                    get_player_info_userid(
                        player_info
                    )

                local key =
                    userid
                    and tostring(userid)
                    or nil

                if key
                    and not is_valid_initial_name(
                        state.initial_user_names[
                            key
                        ]
                    ) then

                    state.initial_user_names[
                        key
                    ] = current_name
                end
            end
        end
    end
end

local function remember_local_mention_alias(name)
    name =
        sanitize_display_text(
            name
        )

    local normalized_name =
        name:lower()

    if normalized_name == ""
        or normalized_name == "you"
        or #normalized_name < 2
        or state.local_mention_aliases[
            normalized_name
        ] then

        return
    end

    state.local_mention_aliases[
        normalized_name
    ] = true

    table.insert(
        state.local_mention_alias_order,
        normalized_name
    )

    while #state.local_mention_alias_order >
        MAX_LOCAL_MENTION_ALIASES do

        local oldest_alias =
            table.remove(
                state.local_mention_alias_order,
                1
            )

        state.local_mention_aliases[
            oldest_alias
        ] = nil
    end
end

local function add_local_mention_identifier(
    identifiers,
    value
)
    if value == nil then
        return
    end

    local identifier =
        tostring(value)
            :gsub(
                "^%s+",
                ""
            )
            :gsub(
                "%s+$",
                ""
            )
            :lower()

    if identifier == ""
        or identifier == "0"
        or #identifier > 64 then

        return
    end

    identifiers[
        identifier
    ] = true
end

local function refresh_local_mention_identity()
    local aliases = {}
    local identifiers = {}

    local effective_name =
        sanitize_display_text(
            get_initial_local_player_name()
        ):lower()

    if effective_name ~= ""
        and effective_name ~= "you" then

        aliases[effective_name] = true
    end

    local local_player =
        client.get_local_player()

    if local_player then
        local player_index =
            local_player:get_index()

        if player_index then
            local info_ok,
                player_info =
                    pcall(
                        engine.get_player_info,
                        player_index
                    )

            if info_ok
                and player_info then

                local userid =
                    get_player_info_userid(
                        player_info
                    )

                if userid
                    and userid > 0 then

                    identifiers[
                        tostring(userid)
                    ] = true
                end
            end
        end
    end

    state.local_mention_aliases =
        aliases

    state.local_mention_alias_order = {}

    for alias in pairs(aliases) do
        state.local_mention_alias_order[1] =
            alias
        break
    end

    state.local_mention_identifiers =
        identifiers
end

local function message_contains_at_mention(
    message_text,
    target
)
    message_text =
        tostring(message_text or "")
            :lower()

    target =
        tostring(target or "")
            :lower()

    if target == "" then
        return false
    end

    local needle =
        "@" .. target

    local search_start = 1

    while true do
        local position =
            message_text:find(
                needle,
                search_start,
                true
            )

        if not position then
            return false
        end

        local character_after =
            message_text:sub(
                position + #needle,
                position + #needle
            )

        if character_after == ""
            or not character_after:match(
                "[%w_]"
            ) then

            return true
        end

        search_start =
            position + 1
    end
end

local function is_local_player_mentioned(
    message_text
)
    refresh_local_mention_identity()

    for alias in pairs(
        state.local_mention_aliases
    ) do
        if message_contains_at_mention(
            message_text,
            alias
        ) then
            return true
        end
    end

    for identifier in pairs(
        state.local_mention_identifiers
    ) do
        if message_contains_at_mention(
            message_text,
            identifier
        ) then
            return true
        end
    end

    return false
end

local function ensure_local_compatible_user()
    if not engine.is_in_game()
        or not engine.is_connected() then

        state.compatible_users[
            "__local_user"
        ] = nil

        state.compatible_user_name_colors[
            "__local_user"
        ] = nil

        state.compatible_user_last_seen[
            "__local_user"
        ] = nil

        return
    end

    local local_name =
        get_initial_local_player_name()

    if local_name
        and local_name ~= ""
        and local_name ~= "You" then

        state.compatible_users[
            "__local_user"
        ] = local_name

        state.compatible_user_name_colors[
            "__local_user"
        ] =
            normalize_color_option_index(
                config.name_color_index,
                NAME_COLOR_OPTIONS
            )

        state.compatible_user_last_seen[
            "__local_user"
        ] = os.clock()
    end
end

local function mark_compatible_user(
    userid,
    sender,
    name_color_index
)
    local key =
        tostring(userid or "")

    sender =
        sanitize_display_text(
            sender
        )

    if key == ""
        or sender == ""
        or sender == "Unknown" then

        return
    end

    if not state.compatible_users[
        key
    ] then
        state.compatible_users[
            key
        ] = sender
    end

    state.compatible_user_name_colors[
        key
    ] =
        normalize_color_option_index(
            name_color_index,
            NAME_COLOR_OPTIONS
        )

    state.compatible_user_last_seen[
        key
    ] = os.clock()
end

local function remember_message_id(
    message_id
)
    message_id =
        tostring(message_id or "")

    if message_id == "" then
        return false
    end

    if state.seen_message_ids[
        message_id
    ] then
        state.insights.duplicate_packets =
            state.insights.duplicate_packets + 1

        return false
    end

    state.seen_message_ids[
        message_id
    ] = true

    table.insert(
        state.seen_message_order,
        message_id
    )

    while #state.seen_message_order >
        MAX_SEEN_MESSAGE_IDS do

        local oldest_id =
            table.remove(
                state.seen_message_order,
                1
            )

        state.seen_message_ids[
            oldest_id
        ] = nil
    end

    return true
end

local function get_current_lobby_userid_set()
    local active_userids = {}

    if not engine.is_in_game()
        or not engine.is_connected() then

        return active_userids
    end

    local max_clients_ok,
        max_clients =
            pcall(
                engine.get_max_clients
            )

    if not max_clients_ok
        or not max_clients then

        return active_userids
    end

    for player_index = 1, max_clients do
        local info_ok,
            player_info =
                pcall(
                    engine.get_player_info,
                    player_index
                )

        if info_ok
            and player_info then

            local userid =
                get_player_info_userid(
                    player_info
                )

            if userid
                and userid > 0 then

                active_userids[
                    tostring(userid)
                ] = true
            end
        end
    end

    return active_userids
end

local function refresh_compatible_users(
    clear_remote,
    show_status,
    active_userids_override
)
    if not engine.is_in_game()
        or not engine.is_connected() then

        state.compatible_users = {}
        state.compatible_user_name_colors = {}
        state.compatible_user_last_seen = {}

        if show_status then
            set_status(
                "Not connected.",
                "error"
            )
        end

        return
    end

    local active_userids =
        type(active_userids_override) == "table"
        and active_userids_override
        or get_current_lobby_userid_set()

    local now =
        os.clock()

    for key in pairs(
        state.compatible_users
    ) do
        if key ~= "__local_user" then
            local last_seen =
                state.compatible_user_last_seen[
                    key
                ] or 0.0

            local currently_present =
                active_userids[
                    tostring(key)
                ] == true

            if not currently_present then
                local numeric_userid =
                    tonumber(key)

                if numeric_userid
                    and numeric_userid > 0 then

                    local index_ok,
                        player_index =
                            pcall(
                                engine.get_player_for_userid,
                                numeric_userid
                            )

                    currently_present =
                        index_ok
                        and player_index
                        and player_index > 0
                end
            end

            -- Presence is keyed by userid, so changing a visible name can
            -- never remove a compatible user or replace the initial name.
            local remove_entry =
                clear_remote
                or (
                    not currently_present
                    and now - last_seen >
                        COMPATIBLE_USER_TIMEOUT
                )

            if remove_entry then
                state.compatible_users[key] = nil
                state.compatible_user_name_colors[key] = nil
                state.compatible_user_last_seen[key] = nil
            elseif currently_present then
                state.compatible_user_last_seen[key] =
                    now
            end
        end
    end

    ensure_local_compatible_user()

    if show_status then
        set_status(
            "Compatible users refreshed.",
            "success"
        )
    end
end

local function reset_compatible_session(
    clear_initial_user_names
)
    state.compatible_users = {}
    state.compatible_user_name_colors = {}
    state.compatible_user_last_seen = {}

    -- Preserve first-seen names across map changes. Clear remote
    -- identities only after a real disconnect, where user IDs may be
    -- reused by an entirely different lobby. The local initial name
    -- remains fixed for the complete lifetime of the loaded Lua.
    if clear_initial_user_names then
        state.initial_user_names = {}
    end

    if type(state.reset_authorized_users) == "function" then
        state.reset_authorized_users()
    end

    state.last_roster_check = 0.0
end

local function get_session_identifier()
    local candidates = {
        "get_level_name",
        "get_level_name_short",
        "get_map_name"
    }

    for _,
        function_name in ipairs(
            candidates
        ) do

        local candidate =
            engine[
                function_name
            ]

        if type(candidate) ==
            "function" then

            local success,
                value =
                    pcall(
                        candidate
                    )

            if success
                and value
                and tostring(value) ~= "" then

                return tostring(value)
            end
        end
    end

    return nil
end

local function update_compatible_session_state()
    local active =
        engine.is_in_game()
        and engine.is_connected()

    if not active then
        if state.session_was_active
            or next(
                state.compatible_users
            ) ~= nil then

            reset_compatible_session(
                true
            )
        end

        state.session_was_active =
            false

        state.session_identifier =
            nil

        state.next_session_state_check = 0.0
        state.next_lobby_name_scan = 0.0
        state.roster_dirty = true

        return false
    end

    local now =
        os.clock()

    -- Connection state is still checked every frame, but map/session and
    -- player-info work is limited to twice per second.
    if state.session_was_active
        and now <
            (tonumber(state.next_session_state_check) or 0.0) then

        return true
    end

    state.next_session_state_check =
        now +
        math.max(
            0.20,
            tonumber(state.session_state_check_interval) or 0.50
        )

    local current_identifier =
        get_session_identifier()

    local session_changed =
        not state.session_was_active

    if current_identifier
        and state.session_identifier
        and current_identifier ~=
            state.session_identifier then

        session_changed = true
    end

    if session_changed then
        reset_compatible_session(
            false
        )

        state.next_lobby_name_scan = 0.0
        state.roster_dirty = true
    end

    state.session_was_active =
        true

    if current_identifier then
        state.session_identifier =
            current_identifier
    end

    get_initial_local_player_name()
    ensure_local_compatible_user()

    if state.roster_dirty == true
        or now >=
            (tonumber(state.next_lobby_name_scan) or 0.0) then

        capture_initial_lobby_names()
        refresh_local_mention_identity()

        state.next_lobby_name_scan =
            now +
            math.max(
                1.00,
                tonumber(state.lobby_name_scan_interval) or 5.00
            )
    end

    return true
end

local function is_local_userid(userid)
    local local_player =
        client.get_local_player()

    if not local_player then
        return false
    end

    local local_index =
        local_player:get_index()

    if not local_index then
        return false
    end

    local player_index =
        engine.get_player_for_userid(
            userid
        )

    return player_index
        and player_index > 0
        and player_index == local_index
end

-- =========================================================
-- COMPACT PROTOCOL
--
-- Mxxxxxxxx|A|text = encrypted all-chat message
-- Mxxxxxxxx|T|text = encrypted team-chat message
--
-- Normal encrypted messages create no automatic replies. Private-session
-- invite-key discovery uses small automatic control packets in All Chat.
-- =========================================================

local function make_message_id()
    state.message_counter =
        state.message_counter + 1

    local source =
        pack_u32_be(
            u32(
                os.time() or 0
            )
        ) ..
        pack_u32_be(
            u32(
                client.get_tick_count()
            )
        ) ..
        pack_u32_be(
            u32(
                math.random(
                    0,
                    0x7FFFFFFF
                )
            )
        ) ..
        pack_u32_be(
            u32(
                state.message_counter
            )
        )

    return bytes_to_hex(
        sha256_binary(
            source
        ):sub(
            1,
            4
        )
    )
end

local function build_protocol_packet(
    packet_type,
    message_id,
    body,
    team_chat,
    part_index,
    part_count
)
    local channel_code =
        team_chat
        and "T"
        or "A"

    if tostring(packet_type) == "S" then
        return "S" ..
            tostring(message_id) ..
            "|" ..
            channel_code ..
            "|" ..
            string.format(
                "%02X",
                math.floor(
                    tonumber(part_index) or 0
                )
            ) ..
            "|" ..
            string.format(
                "%02X",
                math.floor(
                    tonumber(part_count) or 0
                )
            ) ..
            "|" ..
            tostring(body or "")
    end

    return tostring(packet_type) ..
        tostring(message_id) ..
        "|" ..
        channel_code ..
        "|" ..
        tostring(body or "")
end

local function parse_protocol_packet(plaintext)
    plaintext =
        tostring(plaintext or "")

    local packet_type,
        message_id,
        channel_code,
        body =
            plaintext:match(
                "^([MHP])([0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f])|([AT])|(.*)$"
            )

    if packet_type
        and message_id
        and channel_code then

        return packet_type,
            message_id:upper(),
            body or "",
            channel_code == "T",
            nil,
            nil
    end

    local split_type,
        split_message_id,
        split_channel,
        part_hex,
        count_hex,
        split_body =
            plaintext:match(
                "^(S)([0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f])|([AT])|([0-9A-Fa-f][0-9A-Fa-f])|([0-9A-Fa-f][0-9A-Fa-f])|(.*)$"
            )

    if not split_type
        or not split_message_id
        or not split_channel then

        return nil
    end

    local part_index =
        tonumber(part_hex, 16)

    local part_count =
        tonumber(count_hex, 16)

    if not part_index
        or not part_count
        or part_index < 1
        or part_count < 2
        or part_count > config.max_split_parts
        or part_index > part_count then

        return nil
    end

    return split_type,
        split_message_id:upper(),
        split_body or "",
        split_channel == "T",
        part_index,
        part_count
end

