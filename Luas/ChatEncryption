local function send_current_encrypted_message()
    if state.input_contains_session_secret(
        config.input_text
    ) then
        set_status(
            "Access key detected. Sending is disabled.",
            "error"
        )

        return false
    end

    if not config.enabled then
        set_status(
            "Encryption disabled.",
            "error"
        )

        return false
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        set_status(
            "Not connected.",
            "error"
        )

        return false
    end

    local selected_private_id =
        state.get_selected_private_session_id()

    local sending_private =
        selected_private_id ~= nil

    if sending_private
        and not state.is_selected_private_session_active() then

        set_status(
            "This private-session tab is read-only.",
            "warning"
        )

        return false
    end

    local send_key_material =
        sending_private
        and state.auth_session.key_material
        or KEY_MATERIAL

    if #state.outgoing_packets > 0 then
        set_status(
            "Previous split message is still sending.",
            "warning"
        )

        return false
    end

    local plaintext =
        sanitize_plaintext(
            config.input_text
        )

    if plaintext == "" then
        set_status(
            "Message is empty.",
            "warning"
        )

        return false
    end

    local character_count =
        state.utf8_character_count(
            plaintext
        )

    if character_count >
        config.max_encrypted_message_characters then

        set_status(
            string.format(
                "Encrypted message is too long (%d/%d characters).",
                character_count,
                config.max_encrypted_message_characters
            ),
            "error"
        )

        return false
    end

    local message_id =
        make_message_id()

    local team_chat =
        config.chat_mode == 1

    if #plaintext <=
        MAX_ENCRYPTED_MESSAGE_BYTES then

        local sent,
            send_error =
                send_protocol_packet(
                    "M",
                    message_id,
                    plaintext,
                    team_chat,
                    nil,
                    nil,
                    send_key_material
                )

        if not sent then
            local failure_text =
                send_error or
                "Send failed."

            set_status(
                failure_text,
                "error"
            )

            state.record_insight(
                "DELIVERY",
                failure_text,
                "error"
            )

            state.notify_important(
                "error",
                failure_text,
                "message-send-failed",
                8.0
            )

            return false
        end

        remember_message_id(
            message_id
        )

        set_status(
            "Encrypted message sent.",
            "success"
        )
    else
        local chunks =
            state.split_utf8_by_bytes(
                plaintext,
                config.max_split_chunk_bytes
            )

        if #chunks > config.max_split_parts then
            set_status(
                "Message needs too many encrypted parts.",
                "error"
            )

            return false
        end

        for part_index,
            chunk in ipairs(chunks) do

            state.outgoing_packets[
                #state.outgoing_packets + 1
            ] = {
                message_id = message_id,
                body = chunk,
                team_chat = team_chat,
                part_index = part_index,
                part_count = #chunks,
                key_material = send_key_material,
                chat_scope =
                    sending_private
                    and "private"
                    or "open",
                session_name =
                    sending_private
                    and state.auth_session.session_name
                    or "Open Chat",
                session_id =
                    sending_private
                    and state.auth_session.fingerprint
                    or ""
            }
        end

        state.outgoing_send_context = {
            message_id = message_id,
            part_count = #chunks,
            chat_scope =
                sending_private
                and "private"
                or "open",
            session_id =
                sending_private
                and state.auth_session.fingerprint
                or ""
        }

        state.next_outgoing_send_time = 0.0

        set_status(
            "Sending encrypted message (" ..
            tostring(#chunks) ..
            " parts)...",
            "success",
            math.max(
                STATUS_LIFETIME_SECONDS,
                #chunks *
                    config.split_packet_send_interval +
                    1.0
            )
        )

        -- Send the first part immediately; remaining parts are paced by
        -- on_paint to avoid flooding Source chat in one frame.
        state.process_outgoing_packets(
            true
        )
    end

    ensure_local_compatible_user()

    add_history_message(
        get_initial_local_player_name(),
        plaintext,
        team_chat,
        is_local_player_mentioned(
            plaintext
        ),
        config.name_color_index,
        config.message_color_index,
        sending_private
            and "private"
            or "open",
        sending_private
            and state.auth_session.session_name
            or "Open Chat",
        sending_private
            and state.auth_session.fingerprint
            or ""
    )

    state.insights.messages_sent =
        state.insights.messages_sent + 1

    if sending_private
        and state.auth_session.active then

        state.mark_authorized_user(
            "__local_user",
            get_initial_local_player_name(),
            state.auth_session.role,
            config.name_color_index,
            true
        )
    end

    clear_message_input()

    return true
end

