        return nil
    end

    return bridge
end

function state.resolve_dst_palette(
    settings
)
    if type(settings) ~= "table"
        or type(settings.appearance) ~= "table" then

        return nil,
            1.0
    end

    local appearance =
        settings.appearance

    local function clamp(
        value
    )
        return math.max(
            0.0,
            math.min(
                1.0,
                tonumber(value) or 0.0
            )
        )
    end

    local function copy_palette(
        source_palette
    )
        local result = {}

        for key, value in pairs(
            source_palette or {}
        ) do
            if type(value) == "table" then
                result[key] =
                    state.copy_style_color(
                        value
                    )
            else
                result[key] =
                    value
            end
        end

        return result
    end

    local function mix(
        first,
        second,
        amount
    )
        amount =
            clamp(amount)

        return {
            clamp(
                first[1] +
                (
                    second[1] -
                    first[1]
                ) * amount
            ),
            clamp(
                first[2] +
                (
                    second[2] -
                    first[2]
                ) * amount
            ),
            clamp(
                first[3] +
                (
                    second[3] -
                    first[3]
                ) * amount
            )
        }
    end

    local function lighten(
        color,
        amount
    )
        return mix(
            color,
            { 1.0, 1.0, 1.0 },
            amount
        )
    end

    local function darken(
        color,
        amount
    )
        return mix(
            color,
            { 0.0, 0.0, 0.0 },
            amount
        )
    end

    local function contrast_text(
        color
    )
        local luminance =
            color[1] * 0.2126 +
            color[2] * 0.7152 +
            color[3] * 0.0722

        if luminance >= 0.58 then
            return {
                0.020,
                0.025,
                0.032
            }
        end

        return {
            1.0,
            1.0,
            1.0
        }
    end

    local saved_theme_name =
        tostring(
            appearance.theme_name or ""
        )

    local theme_name =
        state.dst_theme_name_aliases[
            saved_theme_name
        ] or saved_theme_name

    -- Prefer the saved name when it matches the current catalog. If a
    -- future rename is not yet known to this Lua, fall back to the saved
    -- zero-based index instead of silently applying Obsidian Gold.
    if theme_name == ""
        or state.dst_theme_cores[
            theme_name
        ] == nil then

        local index =
            math.floor(
                tonumber(
                    appearance.theme_index
                ) or 0
            ) + 1

        theme_name =
            state.dst_theme_order[index] or
            state.dst_theme_order[1]
    end

    local preset =
        state.dst_theme_cores[
            theme_name
        ] or
        state.dst_theme_cores[
            state.dst_theme_order[1]
        ]

    local palette = nil

    if preset.custom == true then
        local custom =
            type(appearance.custom) == "table"
            and appearance.custom
            or {}

        local custom_background =
            state.copy_style_color(
                custom.background or
                {
                    0.07,
                    0.07,
                    0.08
                }
            )

        local custom_child =
            state.copy_style_color(
                custom.table or
                {
                    0.12,
                    0.12,
                    0.14
                }
            )

        local custom_button =
            state.copy_style_color(
                custom.button or
                {
                    0.12,
                    0.34,
                    0.42
                }
            )

        local custom_text =
            state.copy_style_color(
                custom.text or
                {
                    0.95,
                    0.95,
                    0.95
                }
            )

        local luminance =
            custom_background[1] * 0.2126 +
            custom_background[2] * 0.7152 +
            custom_background[3] * 0.0722

        local is_light =
            luminance >= 0.62

        palette = {
            name = preset.name,
            description = preset.description,
            family = preset.family,
            light = is_light,
            accent =
                state.copy_style_color(
                    custom.accent or
                    {
                        1.0,
                        0.8,
                        0.0
                    }
                ),
            background =
                custom_background,
            child =
                custom_child,
            popup =
                lighten(
                    custom_child,
                    is_light
                        and 0.035
                        or 0.065
                ),
            frame =
                custom_child,
            button =
                custom_button,
            text =
                custom_text,
            text_disabled =
                is_light
                and darken(
                    custom_text,
                    0.42
                )
                or lighten(
                    custom_text,
                    0.42
                ),
            border =
                is_light
                and darken(
                    custom_child,
                    0.24
                )
                or lighten(
                    custom_child,
                    0.26
                )
        }
    else
        palette =
            copy_palette(
                preset
            )

        local overrides =
            appearance.overrides

        local override =
            type(overrides) == "table"
            and overrides[theme_name]
            or nil

        -- Old DSTsettings files may still store an override under the
        -- previous display name even after the selected theme is normalized.
        if type(override) ~= "table"
            and type(overrides) == "table" then

            for legacy_name,
                current_name in pairs(
                    state.dst_theme_name_aliases
                ) do

                if current_name == theme_name
                    and type(
                        overrides[legacy_name]
                    ) == "table" then

                    override =
                        overrides[legacy_name]

                    break
                end
            end
        end

        if type(override) == "table" then
            for _, field_name in ipairs({
                "accent",
                "background",
                "child",
                "button",
                "text"
            }) do
                if type(
                    override[field_name]
                ) == "table" then

                    palette[field_name] =
                        state.copy_style_color(
                            override[field_name]
                        )
                end
            end

            -- Match DST: regenerate every interaction color from
            -- customized core colors.
            palette.frame = nil
            palette.frame_hovered = nil
            palette.frame_active = nil
            palette.button_hovered = nil
            palette.button_active = nil
            palette.header = nil
            palette.header_hovered = nil
            palette.header_active = nil
            palette.combo = nil
            palette.combo_hovered = nil
            palette.combo_active = nil
            palette.title = nil
            palette.title_active = nil
            palette.menubar = nil
            palette.scrollbar_bg = nil
            palette.scrollbar_grab = nil
            palette.scrollbar_hovered = nil
            palette.scrollbar_active = nil
            palette.section_button = nil
            palette.active_tab = nil
            palette.active_tab_text = nil
            palette.inactive_tab = nil
            palette.inactive_tab_text = nil
            palette.button_text = nil
        end
    end

    palette.popup =
        palette.popup or
        palette.child

    palette.frame =
        palette.frame or
        mix(
            palette.child,
            palette.background,
            palette.light
                and 0.36
                or 0.28
        )

    palette.frame_hovered =
        palette.frame_hovered or
        mix(
            palette.frame,
            palette.accent,
            palette.light
                and 0.16
                or 0.22
        )

    palette.frame_active =
        palette.frame_active or
        mix(
            palette.frame,
            palette.accent,
            palette.light
                and 0.30
                or 0.38
        )

    palette.button_hovered =
        palette.button_hovered or
        mix(
            palette.button,
            palette.accent,
            palette.light
                and 0.18
                or 0.26
        )

    palette.button_active =
        palette.button_active or
        mix(
            palette.button,
            palette.accent,
            palette.light
                and 0.34
                or 0.44
        )

    palette.header =
        palette.header or
        mix(
            palette.child,
            palette.accent,
            palette.light
                and 0.10
                or 0.17
        )

    palette.header_hovered =
        palette.header_hovered or
        mix(
            palette.header,
            palette.accent,
            palette.light
                and 0.20
                or 0.30
        )

    palette.header_active =
        palette.header_active or
        mix(
            palette.header,
            palette.accent,
            palette.light
                and 0.36
                or 0.46
        )

    palette.combo =
        palette.combo or
        palette.frame

    palette.combo_hovered =
        palette.combo_hovered or
        palette.frame_hovered

    palette.combo_active =
        palette.combo_active or
        palette.frame_active

    palette.border =
        palette.border or
        (
            palette.light
            and darken(
                palette.child,
                0.24
            )
            or lighten(
                palette.child,
                0.22
            )
        )

    palette.title =
        palette.title or
        mix(
            palette.background,
            palette.child,
            0.55
        )

    palette.title_active =
        palette.title_active or
        mix(
            palette.title,
            palette.accent,
            palette.light
                and 0.10
                or 0.18
        )

    palette.menubar =
        palette.menubar or
        palette.child

    palette.scrollbar_bg =
        palette.scrollbar_bg or
        palette.background

    palette.scrollbar_grab =
        palette.scrollbar_grab or
        mix(
            palette.frame,
            palette.accent,
            palette.light
                and 0.20
                or 0.30
        )

    palette.scrollbar_hovered =
        palette.scrollbar_hovered or
        mix(
            palette.scrollbar_grab,
            palette.accent,
            0.36
        )

    palette.scrollbar_active =
        palette.scrollbar_active or
        mix(
            palette.scrollbar_grab,
            palette.accent,
            0.58
        )

    palette.checkmark =
        palette.checkmark or
        palette.accent

    palette.slider =
        palette.slider or
        palette.accent

    palette.slider_active =
        palette.slider_active or
        lighten(
            palette.accent,
            palette.light
                and 0.06
                or 0.15
        )

    palette.separator =
        palette.separator or
        palette.border

    palette.separator_hovered =
        palette.separator_hovered or
        palette.accent

    palette.separator_active =
        palette.separator_active or
        palette.slider_active

    palette.resize =
        palette.resize or
        palette.frame

    palette.resize_hovered =
        palette.resize_hovered or
        palette.accent

    palette.resize_active =
        palette.resize_active or
        palette.slider_active

    palette.tab =
        palette.tab or
        palette.button

    palette.tab_hovered =
        palette.tab_hovered or
        palette.button_hovered

    palette.tab_active =
        palette.tab_active or
        palette.accent

    palette.tab_unfocused =
        palette.tab_unfocused or
        palette.frame

    palette.tab_unfocused_active =
        palette.tab_unfocused_active or
        palette.header

    palette.section_text =
        palette.section_text or
        palette.accent

    palette.section_button =
        palette.section_button or
        palette.frame

    palette.section_button_text =
        palette.section_button_text or
        palette.text

    palette.active_tab =
        palette.active_tab or
        palette.accent

    palette.active_tab_text =
        palette.active_tab_text or
        contrast_text(
            palette.active_tab
        )

    palette.inactive_tab =
        palette.inactive_tab or
        palette.button

    palette.inactive_tab_text =
        palette.inactive_tab_text or
        palette.text

    palette.button_text =
        palette.button_text or
        contrast_text(
            palette.button
        )

    local font_scale = 1.0

    local font_preset =
        math.floor(
            tonumber(
                appearance.font_preset_index
            ) or 0
        )

    if font_preset == 1 then
        font_scale = 0.88
    elseif font_preset == 2 then
        font_scale = 1.18
    elseif font_preset == 3 then
        font_scale =
            math.max(
                0.70,
                math.min(
                    1.50,
                    tonumber(
                        appearance.font_scale
                    ) or 1.0
                )
            )
    end

    return palette,
        font_scale
end

function state.refresh_dst_style(
    force
)
    if not config.inherit_dst_style then
        state.dst_style.palette = nil
        state.dst_style.font_scale = 1.0
        state.dst_style.loaded = false
        state.dst_style.source = "Disabled"
        state.dst_style.bridge_signature = ""
        return false
    end

    local live_bridge =
        _G.__DARK_SIDE_TOOLS_THEME_BRIDGE

    if type(live_bridge) == "table"
        and type(live_bridge.palette) == "table" then

        local live_signature =
            tostring(
                live_bridge.signature or
                live_bridge.theme_name or
                ""
            )

        if force
            or state.dst_style.loaded ~= true
            or state.dst_style.source ~= "Live DST"
            or state.dst_style.bridge_signature ~= live_signature then

            if state.apply_dst_theme_bridge(
                live_bridge,
                "Live DST"
            ) then

                state.dst_style.last_check =
                    os.clock()

                return true
            end
        else
            return true
        end
    end

    local now = os.clock()

    if not force
        and now - state.dst_style.last_check <
            state.dst_style.refresh_interval then

        return state.dst_style.loaded
    end

    state.dst_style.last_check = now

    local bridge_file =
        state.read_dst_theme_bridge_file()

    if type(bridge_file) == "table"
        and state.apply_dst_theme_bridge(
            bridge_file,
            "DSTThemeBridge"
        ) then

        return true
    end

    if type(loadfile) ~= "function" then
        return state.dst_style.loaded
    end

    local load_ok,
        chunk =
            pcall(
                loadfile,
                state.dst_style.path
            )

    if not load_ok
        or type(chunk) ~= "function" then

        return state.dst_style.loaded
    end

    local run_ok,
        settings =
            pcall(chunk)

    if not run_ok
        or type(settings) ~= "table" then

        return state.dst_style.loaded
    end

    local palette,
        font_scale =
            state.resolve_dst_palette(
                settings
            )

    if not palette then
        return state.dst_style.loaded
    end

    state.dst_style.palette = palette
    state.dst_style.font_scale = font_scale
    state.dst_style.loaded = true
    state.dst_style.source = "DSTsettings fallback"
    state.dst_style.bridge_signature = ""

    return true
end

function state.push_dst_style()
    state.refresh_dst_style(false)

    local palette =
        state.dst_style.palette

    if not config.inherit_dst_style
        or type(palette) ~= "table"
        or type(imgui.push_style_color) ~= "function"
        or type(imgui.pop_style_color) ~= "function" then

        return 0
    end

    local colors = {
        { 0, palette.text },
        { 1, palette.text_disabled },
        { 2, palette.background },
        { 3, palette.child },
        { 4, palette.popup },
        { 5, palette.border },
        { 6, { 0.0, 0.0, 0.0, 0.0 } },
        { 7, palette.frame },
        { 8, palette.frame_hovered },
        { 9, palette.frame_active },
        { 10, palette.title },
        { 11, palette.title_active },
        { 12, palette.title },
        { 13, palette.menubar },
        { 14, palette.scrollbar_bg },
        { 15, palette.scrollbar_grab },
        { 16, palette.scrollbar_hovered },
        { 17, palette.scrollbar_active },
        { 18, palette.checkmark },
        { 19, palette.slider },
        { 20, palette.slider_active },
        { 21, palette.button },
        { 22, palette.button_hovered },
        { 23, palette.button_active },
        { 24, palette.header },
        { 25, palette.header_hovered },
        { 26, palette.header_active },
        { 27, palette.separator },
        { 28, palette.separator_hovered },
        { 29, palette.separator_active },
        { 30, palette.resize },
        { 31, palette.resize_hovered },
        { 32, palette.resize_active },
        { 33, palette.tab },
        { 34, palette.tab_hovered },
        { 35, palette.tab_active },
        { 36, palette.tab_unfocused },
        { 37, palette.tab_unfocused_active }
    }

    local pushed = 0

    for _, entry in ipairs(colors) do
        local color = entry[2]

        local ok =
            pcall(
                imgui.push_style_color,
                entry[1],
                color[1],
                color[2],
                color[3],
                color[4] or 1.0
            )

        if ok then
            pushed = pushed + 1
        end
    end

    return pushed
end

function state.pop_dst_style(
    count
)
    count =
        math.max(
            0,
            math.floor(
                tonumber(count) or 0
            )
        )

    -- Pop once per push for compatibility with Heaven builds that silently
    -- ignore the numeric pop count. This prevents Chat Encryption styling from
    -- escaping into Heaven's surrounding menu.
    if count > 0
        and type(imgui.pop_style_color) == "function" then

        for _ = 1, count do
            pcall(
                imgui.pop_style_color
            )
        end
    end

    if type(imgui.set_window_font_scale) == "function" then
        pcall(
            imgui.set_window_font_scale,
            1.0
        )
    end
end

-- Matches Dark Side Tools standalone-window opacity: window, child, button,
-- frame, tab and scrollbar surfaces fade together, while all foreground text
-- stays fully opaque. The outer border is hidden and input fields receive a
-- separate clear-fill/accent-border treatment while they are drawn.
function state.push_standalone_window_opacity()
    state.refresh_dst_style(false)

    local opacity =
        math.max(
            0.0,
            math.min(
                1.0,
                tonumber(
                    config.standalone_window_opacity
                ) or 1.0
            )
        )

    config.standalone_window_opacity =
        opacity

    if type(imgui.push_style_color)
            ~= "function"
        or type(imgui.pop_style_color)
            ~= "function" then

        return 0
    end

    local palette =
        state.get_standalone_theme_palette()

    if type(palette) ~= "table" then
        palette = {
            background = { 0.055, 0.058, 0.066 },
            child = { 0.075, 0.079, 0.090 },
            popup = { 0.085, 0.090, 0.102 },
            frame = { 0.105, 0.110, 0.125 },
            frame_hovered = { 0.145, 0.155, 0.175 },
            frame_active = { 0.185, 0.200, 0.225 },
            button = { 0.120, 0.130, 0.150 },
            button_hovered = { 0.165, 0.180, 0.205 },
            button_active = { 0.205, 0.225, 0.255 },
            header = { 0.120, 0.135, 0.160 },
            header_hovered = { 0.165, 0.190, 0.225 },
            header_active = { 0.205, 0.240, 0.285 },
            menubar = { 0.070, 0.074, 0.084 },
            scrollbar_bg = { 0.045, 0.048, 0.055 },
            scrollbar_grab = { 0.220, 0.235, 0.260 },
            scrollbar_hovered = { 0.300, 0.325, 0.360 },
            scrollbar_active = { 0.390, 0.420, 0.465 },
            checkmark = { 0.25, 0.85, 1.00 },
            slider = { 0.25, 0.85, 1.00 },
            slider_active = { 0.40, 0.92, 1.00 },
            separator = { 0.230, 0.245, 0.275 },
            separator_hovered = { 0.25, 0.85, 1.00 },
            separator_active = { 0.40, 0.92, 1.00 },
            resize = { 0.105, 0.110, 0.125 },
            resize_hovered = { 0.25, 0.85, 1.00 },
            resize_active = { 0.40, 0.92, 1.00 },
            tab = { 0.120, 0.130, 0.150 },
            tab_hovered = { 0.165, 0.180, 0.205 },
            tab_active = { 0.25, 0.85, 1.00 },
            accent = { 0.25, 0.85, 1.00 }
        }
    end

    local pushed = 0

    local function push_surface(
        color_index,
        source_color,
        forced_alpha
    )
        source_color =
            type(source_color) == "table"
            and source_color
            or { 0.0, 0.0, 0.0, 1.0 }

        local alpha =
            forced_alpha

        if alpha == nil then
            alpha =
                (tonumber(source_color[4]) or 1.0) *
                opacity
        end

        imgui.push_style_color(
            color_index,
            tonumber(source_color[1]) or 0.0,
            tonumber(source_color[2]) or 0.0,
            tonumber(source_color[3]) or 0.0,
            math.max(
                0.0,
                math.min(
                    1.0,
                    tonumber(alpha) or 0.0
                )
            )
        )

        pushed = pushed + 1
    end

    local theme_title =
        palette.title_active or
        palette.accent or
        palette.title or
        palette.background

    local invisible_border = {
        0.0,
        0.0,
        0.0,
        0.0
    }

    -- Foreground stays fully opaque. Light themes switch to white/light gray
    -- only while the standalone background is almost or fully transparent.
    local foreground_text,
        foreground_disabled =
            state.get_standalone_foreground_colors()

    push_surface(0, foreground_text, 1.0)
    push_surface(1, foreground_disabled, 1.0)

    -- The same surface-only opacity approach used by the DST overlays.
    push_surface(2, palette.background)
    -- The responsive body and its internal panels are child windows. Keep
    -- ChildBg transparent so Encrypted Chat uses one clean window surface,
    -- matching Game & Net instead of adding a second theme-colored layer.
    push_surface(3, palette.background, 0.0)
    push_surface(4, palette.popup or palette.child or palette.background)

    -- Hide the outer window border and border shadow. Input widgets apply
    -- their own local accent treatment while they are drawn.
    push_surface(5, invisible_border, 0.0)
    push_surface(6, invisible_border, 0.0)

    push_surface(7, palette.frame or palette.child)
    push_surface(8, palette.frame_hovered or palette.frame)
    push_surface(9, palette.frame_active or palette.frame)
    push_surface(10, theme_title)
    push_surface(11, theme_title)
    push_surface(12, theme_title)
    push_surface(13, palette.menubar or palette.child)
    push_surface(14, palette.scrollbar_bg or palette.background)
    push_surface(15, palette.scrollbar_grab or palette.frame)
    push_surface(16, palette.scrollbar_hovered or palette.scrollbar_grab)
    push_surface(17, palette.scrollbar_active or palette.scrollbar_grab)
    push_surface(18, palette.checkmark or palette.accent)
    push_surface(19, palette.slider or palette.accent)
    push_surface(20, palette.slider_active or palette.accent)
    push_surface(21, palette.button or palette.frame)
    push_surface(22, palette.button_hovered or palette.button or palette.frame)
    push_surface(23, palette.button_active or palette.button or palette.frame)
    push_surface(24, palette.header or palette.child)
    push_surface(25, palette.header_hovered or palette.header or palette.child)
    push_surface(26, palette.header_active or palette.header or palette.child)
    push_surface(27, palette.separator or palette.accent)
    push_surface(28, palette.separator_hovered or palette.accent)
    push_surface(29, palette.separator_active or palette.accent)
    push_surface(30, palette.resize or palette.frame)
    push_surface(31, palette.resize_hovered or palette.accent)
    push_surface(32, palette.resize_active or palette.accent)
    push_surface(33, palette.tab or palette.button or palette.frame)
    push_surface(34, palette.tab_hovered or palette.button_hovered or palette.accent)
    push_surface(35, palette.tab_active or palette.accent)
    push_surface(36, palette.tab_unfocused or palette.frame)
    push_surface(37, palette.tab_unfocused_active or palette.header)

    return pushed
end

function state.pop_standalone_window_opacity(
    count
)
    count =
        math.max(
            0,
            math.floor(
                tonumber(count) or 0
            )
        )

    if count <= 0
        or type(imgui.pop_style_color)
            ~= "function" then

        return
    end

    -- The current Heaven build already supports these style operations.
    -- Avoid one protected call per color on every rendered frame.
    for _ = 1,
        count do

        imgui.pop_style_color()
    end
end

function state.apply_dst_font_scale()
    if type(imgui.set_window_font_scale) ~= "function" then
        return
    end

    local scale =
        config.inherit_dst_style
        and state.dst_style.loaded
        and state.dst_style.font_scale
        or 1.0

    pcall(
        imgui.set_window_font_scale,
        tonumber(scale) or 1.0
    )
end

function state.get_standalone_theme_palette()
    if config.inherit_dst_style == true
        and state.dst_style.loaded == true
        and type(
            state.dst_style.palette
        ) == "table" then

        return state.dst_style.palette
    end

    return nil
end

-- Light DST themes normally use dark foreground text. That is correct while
-- their light window surfaces are visible, but it becomes unreadable when the
-- standalone opacity is reduced to zero over the game. At low opacity, switch
-- only the standalone foreground to fully opaque white/light gray.
function state.get_standalone_foreground_colors()
    local palette =
        state.get_standalone_theme_palette()

    local text_color =
        type(palette) == "table"
        and type(palette.text) == "table"
        and palette.text
        or { 0.96, 0.97, 0.99 }

    local disabled_color =
        type(palette) == "table"
        and type(palette.text_disabled) == "table"
        and palette.text_disabled
        or { 0.72, 0.75, 0.80 }

    if state.rendering_standalone == true
        and type(palette) == "table"
        and palette.light == true then

        local opacity =
            math.max(
                0.0,
                math.min(
                    1.0,
                    tonumber(
                        config.standalone_window_opacity
                    ) or 1.0
                )
            )

        if opacity <= 0.45 then
            text_color = { 1.0, 1.0, 1.0 }
            disabled_color = { 0.82, 0.86, 0.92 }
        end
    end

    return text_color,
        disabled_color
end

function state.use_low_opacity_standalone_borders_only()
    if state.rendering_standalone ~= true then
        return false
    end

    local opacity =
        math.max(
            0.0,
            math.min(
                1.0,
                tonumber(
                    config.standalone_window_opacity
                ) or 1.0
            )
        )

    return opacity <= 0.45
end

function state.get_theme_contrast_text(
    color
)
    color =
        type(color) == "table"
        and color
        or {
            0.0,
            0.0,
            0.0
        }

    local luminance =
        (tonumber(color[1]) or 0.0) * 0.2126 +
        (tonumber(color[2]) or 0.0) * 0.7152 +
        (tonumber(color[3]) or 0.0) * 0.0722

    if luminance >= 0.58 then
        return {
            0.020,
            0.025,
            0.032
        }
    end

    return {
        1.0,
        1.0,
        1.0
    }
end

function state.make_theme_readable_text_color(
    red,
    green,
    blue
)
    red = math.max(0.0, math.min(1.0, tonumber(red) or 1.0))
    green = math.max(0.0, math.min(1.0, tonumber(green) or 1.0))
    blue = math.max(0.0, math.min(1.0, tonumber(blue) or 1.0))

    local palette =
        state.get_standalone_theme_palette()

    if not palette
        or palette.light ~= true then

        return red,
            green,
            blue
    end

    if state.rendering_standalone == true then
        local opacity =
            math.max(
                0.0,
                math.min(
                    1.0,
                    tonumber(
                        config.standalone_window_opacity
                    ) or 1.0
                )
            )

        -- Do not darken White/Cyan/etc. for a light theme after the light
        -- background has become transparent. This keeps message text visible
        -- directly over the game at zero opacity.
        if opacity <= 0.45 then
            return red,
                green,
                blue
        end
    end

    local maximum =
        math.max(
            red,
            green,
            blue
        )

    local minimum =
        math.min(
            red,
            green,
            blue
        )

    local luminance =
        red * 0.2126 +
        green * 0.7152 +
        blue * 0.0722

    if maximum - minimum <= 0.08
        and luminance >= 0.68
        and type(palette.text) == "table" then

        return palette.text[1],
            palette.text[2],
            palette.text[3]
    end

    if luminance > 0.56 then
        local scale =
            0.40 /
            math.max(
                0.01,
                luminance
            )

        return math.max(0.0, math.min(1.0, red * scale)),
            math.max(0.0, math.min(1.0, green * scale)),
            math.max(0.0, math.min(1.0, blue * scale))
    end

    return red,
        green,
        blue
end


function state.get_theme_role_colors(
    role
)
    role = tostring(role or "neutral")

    local palette =
        state.get_standalone_theme_palette()

    if not palette then
        local fallbacks = {
            primary = { 0.12, 0.42, 0.76 },
            secondary = { 0.38, 0.32, 0.62 },
            success = { 0.10, 0.52, 0.20 },
            info = { 0.10, 0.38, 0.70 },
            warning = { 0.72, 0.38, 0.05 },
            danger = { 0.72, 0.12, 0.08 },
            purple = { 0.62, 0.18, 0.68 },
            neutral = { 0.18, 0.18, 0.18 },
            inactive = { 0.18, 0.18, 0.18 },
            section = { 0.14, 0.14, 0.14 }
        }

        local normal =
            fallbacks[role] or
            fallbacks.neutral

        return {
            text =
                state.get_theme_contrast_text(
                    normal
                ),
            normal = normal,
            hovered =
                state.mix_style_color(
                    normal,
                    { 1.0, 1.0, 1.0 },
                    0.10
                ),
            active =
                state.mix_style_color(
                    normal,
                    { 0.0, 0.0, 0.0 },
                    0.10
                )
        }
    end

    local normal = nil
    local text_color = nil

    if role == "primary" then
        normal = palette.accent
    elseif role == "secondary" then
        normal =
            state.mix_style_color(
                palette.button,
                palette.accent,
                0.48
            )
    elseif role == "success" then
        normal =
            state.mix_style_color(
                palette.button,
                { 0.08, 0.64, 0.24 },
                0.68
            )
    elseif role == "info" then
        normal =
            state.mix_style_color(
                palette.button,
                { 0.08, 0.43, 0.86 },
                0.68
            )
    elseif role == "warning" then
        normal =
            state.mix_style_color(
                palette.button,
                { 0.92, 0.53, 0.06 },
                0.70
            )
    elseif role == "danger" then
        normal =
            state.mix_style_color(
                palette.button,
                { 0.82, 0.10, 0.08 },
                0.72
            )
    elseif role == "purple" then
        normal =
            state.mix_style_color(
                palette.button,
                { 0.62, 0.18, 0.78 },
                0.68
            )
    elseif role == "inactive" then
        normal =
            palette.inactive_tab or
            palette.button

        text_color =
            palette.inactive_tab_text or
            palette.text
    elseif role == "section" then
        normal =
            palette.section_button or
            palette.frame

        text_color =
            palette.section_button_text or
            palette.text
    else
        normal = palette.button

        text_color =
            palette.button_text or
            palette.text
    end

    local hovered = nil
    local active = nil

    if role == "neutral" then
        hovered = palette.button_hovered
        active = palette.button_active
    elseif role == "inactive" then
        hovered = palette.tab_hovered
        active = palette.tab_active
    elseif role == "section" then
        hovered =
            state.mix_style_color(
                normal,
                palette.accent,
                0.18
            )

        active =
            state.mix_style_color(
                normal,
                palette.accent,
                0.32
            )
    else
        hovered =
            state.mix_style_color(
                normal,
                palette.light
                    and { 0.0, 0.0, 0.0 }
                    or { 1.0, 1.0, 1.0 },
                0.10
            )

        active =
            state.mix_style_color(
                normal,
                { 0.0, 0.0, 0.0 },
                palette.light
                    and 0.14
                    or 0.10
            )
    end

    return {
        text =
            text_color or
            state.get_theme_contrast_text(
                normal
            ),
        normal = normal,
        hovered = hovered,
        active = active
    }
end

function state.get_button_role(
    label,
    button_r,
    button_g,
    button_b
)
    label = tostring(label or "")

    if label:find(
        "##ChatEncryptionSection",
        1,
        true
    ) then
        return "section"
    end

    if label:find(
        "MessageTimestamp",
        1,
        true
    ) then
        return "neutral"
    end

    if label:find(
        "MessageAge",
        1,
        true
    ) then
        return "secondary"
    end

    if label:find(
        "MentionBadge",
        1,
        true
    ) then
        return "purple"
    end

    if label:find(
        "ChatType",
        1,
        true
    ) then
        if label:find(
            "TEAM",
            1,
            true
        ) then
            return "info"
        end

        return "success"
    end

    local maximum =
        math.max(
            tonumber(button_r) or 0.0,
            tonumber(button_g) or 0.0,
            tonumber(button_b) or 0.0
        )

    local minimum =
        math.min(
            tonumber(button_r) or 0.0,
            tonumber(button_g) or 0.0,
            tonumber(button_b) or 0.0
        )

    if maximum - minimum <= 0.08 then
        return "inactive"
    end

    if label:find("Send Encrypted", 1, true) then
        return "primary"
    elseif label:find("Send Normal", 1, true) then
        return "success"
    elseif label:find("All Chat", 1, true) then
        return "success"
    elseif label:find("Team Chat", 1, true) then
        return "info"
    elseif label:find("Refresh Users", 1, true) then
        return "info"
    elseif label:find("Copy Message", 1, true) then
        return "info"
    elseif label:find("Copy Search", 1, true) then
        return "secondary"
    elseif label:find("Clear Search", 1, true) then
        return "neutral"
    elseif label:find("ConfirmClear", 1, true) then
        return "danger"
    elseif label:find("Cancel", 1, true) then
        return "neutral"
    elseif label:find("Clear##", 1, true) then
        -- The first-stage Clear Chat button uses the selected
        -- theme's primary accent. Confirm Clear stays destructive.
        return "primary"
    elseif label:find("Clear", 1, true) then
        return "warning"
    end

    if button_r >= 0.55
        and button_g <= 0.25
        and button_b <= 0.25 then

        return "danger"
    end

    if button_r >= 0.55
        and button_g >= 0.25
        and button_g <= 0.65
        and button_b <= 0.25 then

        return "warning"
    end

    if button_g > button_r
        and button_g > button_b then

        return "success"
    end

    if button_b > button_r
        and button_b >= button_g then

        return "info"
    end

    if button_r > button_g
        and button_b > button_g then

        return "purple"
    end

    return "primary"
end

function state.push_input_theme()
    local palette =
        state.get_standalone_theme_palette()

    if type(palette) ~= "table" then
        if state.rendering_standalone ~= true then
            return 0
        end

        palette = {
            light = false,
            text = { 0.96, 0.97, 0.99 },
            text_disabled = { 0.58, 0.61, 0.66 },
            border = { 0.25, 0.85, 1.00 },
            accent = { 0.25, 0.85, 1.00 },
            background = { 0.055, 0.058, 0.066 },
            frame = { 0.105, 0.110, 0.125 },
            frame_hovered = { 0.145, 0.155, 0.175 },
            frame_active = { 0.185, 0.200, 0.225 }
        }
    end

    if type(imgui.push_style_color)
            ~= "function"
        or type(imgui.pop_style_color)
            ~= "function" then

        return 0
    end

    local pushed = 0

    local function try_push(
        index,
        color
    )
        color =
            type(color) == "table"
            and color
            or { 1.0, 1.0, 1.0, 1.0 }

        imgui.push_style_color(
            index,
            tonumber(color[1]) or 1.0,
            tonumber(color[2]) or 1.0,
            tonumber(color[3]) or 1.0,
            tonumber(color[4]) or 1.0
        )

        pushed = pushed + 1
    end

    local foreground_text,
        foreground_disabled =
            state.get_standalone_foreground_colors()

    try_push(
        0,
        state.rendering_standalone == true
        and foreground_text
        or palette.text
    )

    try_push(
        1,
        state.rendering_standalone == true
        and foreground_disabled
        or palette.text_disabled
    )

    if state.rendering_standalone == true then
        local accent =
            type(palette.accent) == "table"
            and palette.accent
            or palette.border
            or { 0.25, 0.85, 1.00 }

        local base_frame =
            type(palette.frame) == "table"
            and palette.frame
            or palette.background
            or { 0.10, 0.11, 0.13 }

        local normal =
            state.mix_style_color(
                base_frame,
                accent,
                palette.light == true
                    and 0.06
                    or 0.10
            )

        local hovered =
            state.mix_style_color(
                base_frame,
                accent,
                palette.light == true
                    and 0.13
                    or 0.20
            )

        local active =
            state.mix_style_color(
                base_frame,
                accent,
                palette.light == true
                    and 0.21
                    or 0.30
            )

        local surface_opacity =
            math.max(
                0.0,
                math.min(
                    1.0,
                    tonumber(
                        config.standalone_window_opacity
                    ) or 1.0
                )
            )

        local borders_only =
            state.use_low_opacity_standalone_borders_only()

        -- At low standalone opacity the field keeps only an accent border so
        -- the game remains visible behind it while the text stays readable.
        try_push(
            5,
            {
                tonumber(accent[1]) or 0.25,
                tonumber(accent[2]) or 0.85,
                tonumber(accent[3]) or 1.00,
                0.95
            }
        )

        try_push(
            7,
            {
                normal[1],
                normal[2],
                normal[3],
                borders_only
                    and 0.0
                    or (0.18 * surface_opacity)
            }
        )

        try_push(
            8,
            {
                hovered[1],
                hovered[2],
                hovered[3],
                borders_only
                    and 0.0
                    or (0.28 * surface_opacity)
            }
        )

        try_push(
            9,
            {
                active[1],
                active[2],
                active[3],
                borders_only
                    and 0.0
                    or (0.38 * surface_opacity)
            }
        )
    else
        local normal =
            state.mix_style_color(
                palette.frame,
                palette.accent,
                palette.light
                    and 0.035
                    or 0.055
            )

        try_push(5, palette.border)
        try_push(7, normal)
        try_push(8, palette.frame_hovered)
        try_push(9, palette.frame_active)
    end

    return pushed
end

function state.pop_input_theme(
    count
)
    count =
        math.max(
            0,
            math.floor(
                tonumber(count) or 0
            )
        )

    if count <= 0
        or type(imgui.pop_style_color)
            ~= "function" then

        return
    end

    for _ = 1,
        count do

        imgui.pop_style_color()
    end
end

-- =========================================================
-- 32-BIT HELPERS
-- =========================================================

local function u32(value)
    return value & 0xFFFFFFFF
end

local function rotate_right(value, amount)
    value = u32(value)

    return u32(
        (value >> amount) |
        (value << (32 - amount))
    )
end

local function pack_u32_be(value)
    value = u32(value)

    return string.char(
        (value >> 24) & 0xFF,
        (value >> 16) & 0xFF,
        (value >> 8) & 0xFF,
        value & 0xFF
    )
end

-- =========================================================
-- SHA-256
-- =========================================================

local SHA256_K = {
    0x428A2F98, 0x71374491, 0xB5C0FBCF, 0xE9B5DBA5,
    0x3956C25B, 0x59F111F1, 0x923F82A4, 0xAB1C5ED5,
    0xD807AA98, 0x12835B01, 0x243185BE, 0x550C7DC3,
    0x72BE5D74, 0x80DEB1FE, 0x9BDC06A7, 0xC19BF174,
    0xE49B69C1, 0xEFBE4786, 0x0FC19DC6, 0x240CA1CC,
    0x2DE92C6F, 0x4A7484AA, 0x5CB0A9DC, 0x76F988DA,
    0x983E5152, 0xA831C66D, 0xB00327C8, 0xBF597FC7,
    0xC6E00BF3, 0xD5A79147, 0x06CA6351, 0x14292967,
    0x27B70A85, 0x2E1B2138, 0x4D2C6DFC, 0x53380D13,
    0x650A7354, 0x766A0ABB, 0x81C2C92E, 0x92722C85,
    0xA2BFE8A1, 0xA81A664B, 0xC24B8B70, 0xC76C51A3,
    0xD192E819, 0xD6990624, 0xF40E3585, 0x106AA070,
    0x19A4C116, 0x1E376C08, 0x2748774C, 0x34B0BCB5,
    0x391C0CB3, 0x4ED8AA4A, 0x5B9CCA4F, 0x682E6FF3,
    0x748F82EE, 0x78A5636F, 0x84C87814, 0x8CC70208,
    0x90BEFFFA, 0xA4506CEB, 0xBEF9A3F7, 0xC67178F2
}

local function sha256_binary(message)
    message = tostring(message or "")

    local bytes = {
        message:byte(
            1,
            #message
        )
    }

    local bit_length =
        #bytes * 8

    table.insert(
        bytes,
        0x80
    )

    while #bytes % 64 ~= 56 do
        table.insert(
            bytes,
            0
        )
    end

    local high_length =
        math.floor(
            bit_length /
            4294967296
        )

    local low_length =
        bit_length %
        4294967296

    for shift = 24, 0, -8 do
        table.insert(
            bytes,
            (high_length >> shift) &
            0xFF
        )
    end

    for shift = 24, 0, -8 do
        table.insert(
            bytes,
            (low_length >> shift) &
            0xFF
        )
    end

    local h0 = 0x6A09E667
    local h1 = 0xBB67AE85
    local h2 = 0x3C6EF372
    local h3 = 0xA54FF53A
    local h4 = 0x510E527F
    local h5 = 0x9B05688C
    local h6 = 0x1F83D9AB
    local h7 = 0x5BE0CD19

    for chunk_start = 1, #bytes, 64 do
        local words = {}

        for index = 0, 15 do
            local offset =
                chunk_start +
                index * 4

            words[index + 1] =
                u32(
                    bytes[offset] *
                    0x1000000 +
                    bytes[offset + 1] *
                    0x10000 +
                    bytes[offset + 2] *
                    0x100 +
                    bytes[offset + 3]
                )
        end

        for index = 17, 64 do
            local word_15 =
                words[index - 15]

            local word_2 =
                words[index - 2]

            local sigma_0 =
                rotate_right(
                    word_15,
                    7
                ) ~
                rotate_right(
                    word_15,
                    18
                ) ~
                (word_15 >> 3)

            local sigma_1 =
                rotate_right(
                    word_2,
                    17
                ) ~
                rotate_right(
                    word_2,
                    19
                ) ~
                (word_2 >> 10)

            words[index] =
                u32(
                    words[index - 16] +
                    sigma_0 +
                    words[index - 7] +
                    sigma_1
                )
        end

        local a = h0
        local b = h1
        local c = h2
        local d = h3
        local e = h4
        local f = h5
        local g = h6
        local h = h7

        for index = 1, 64 do
            local sum_1 =
                rotate_right(
                    e,
                    6
                ) ~
                rotate_right(
                    e,
                    11
                ) ~
                rotate_right(
                    e,
                    25
                )

            local choice =
                (e & f) ~
                ((~e) & g)

            local temp_1 =
                u32(
                    h +
                    sum_1 +
                    choice +
                    SHA256_K[index] +
                    words[index]
                )

            local sum_0 =
                rotate_right(
                    a,
                    2
                ) ~
                rotate_right(
                    a,
                    13
                ) ~
                rotate_right(
                    a,
                    22
                )

            local majority =
                (a & b) ~
                (a & c) ~
                (b & c)

            local temp_2 =
                u32(
                    sum_0 +
                    majority
                )

            h = g
            g = f
            f = e
            e = u32(
                d +
                temp_1
            )
            d = c
            c = b
            b = a
            a = u32(
                temp_1 +
                temp_2
            )
        end

        h0 = u32(h0 + a)
        h1 = u32(h1 + b)
        h2 = u32(h2 + c)
        h3 = u32(h3 + d)
        h4 = u32(h4 + e)
        h5 = u32(h5 + f)
        h6 = u32(h6 + g)
        h7 = u32(h7 + h)
    end

    return
        pack_u32_be(h0) ..
        pack_u32_be(h1) ..
        pack_u32_be(h2) ..
        pack_u32_be(h3) ..
        pack_u32_be(h4) ..
        pack_u32_be(h5) ..
        pack_u32_be(h6) ..
        pack_u32_be(h7)
end

-- =========================================================
-- BASE64
-- =========================================================

local BASE64_ALPHABET =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ..
    "abcdefghijklmnopqrstuvwxyz" ..
    "0123456789+/"

local BASE64_DECODE = {}

for index = 1, #BASE64_ALPHABET do
    BASE64_DECODE[
        BASE64_ALPHABET:sub(
            index,
            index
        )
    ] = index - 1
end

local function base64_encode(data)
    local output = {}

    for index = 1, #data, 3 do
        local byte_1 =
            data:byte(index) or 0

        local byte_2 =
            data:byte(index + 1) or 0

        local byte_3 =
            data:byte(index + 2) or 0

        local combined =
            byte_1 * 0x10000 +
            byte_2 * 0x100 +
            byte_3

        local remaining =
            #data - index + 1

        output[#output + 1] =
            BASE64_ALPHABET:sub(
                ((combined >> 18) & 0x3F) + 1,
                ((combined >> 18) & 0x3F) + 1
            )

        output[#output + 1] =
            BASE64_ALPHABET:sub(
                ((combined >> 12) & 0x3F) + 1,
                ((combined >> 12) & 0x3F) + 1
            )

        if remaining >= 2 then
            output[#output + 1] =
                BASE64_ALPHABET:sub(
                    ((combined >> 6) & 0x3F) + 1,
                    ((combined >> 6) & 0x3F) + 1
                )
        else
            output[#output + 1] = "="
        end

        if remaining >= 3 then
            output[#output + 1] =
                BASE64_ALPHABET:sub(
                    (combined & 0x3F) + 1,
                    (combined & 0x3F) + 1
                )
        else
            output[#output + 1] = "="
        end
    end

    return table.concat(output)
end

local function base64_decode(data)
    data =
        tostring(data or "")
            :gsub(
                "%s",
                ""
            )

    if data == ""
        or #data % 4 ~= 0 then

        return nil
    end

    local output = {}

    for index = 1, #data, 4 do
        local char_1 =
            data:sub(index, index)

        local char_2 =
            data:sub(index + 1, index + 1)

        local char_3 =
            data:sub(index + 2, index + 2)

        local char_4 =
            data:sub(index + 3, index + 3)

        local value_1 =
            BASE64_DECODE[char_1]

        local value_2 =
            BASE64_DECODE[char_2]

        local value_3 =
            char_3 == "="
            and 0
            or BASE64_DECODE[char_3]

        local value_4 =
            char_4 == "="
            and 0
            or BASE64_DECODE[char_4]

        if value_1 == nil
            or value_2 == nil
            or value_3 == nil
            or value_4 == nil then

            return nil
        end

        local combined =
            value_1 * 0x40000 +
            value_2 * 0x1000 +
            value_3 * 0x40 +
            value_4

        output[#output + 1] =
            string.char(
                (combined >> 16) &
                0xFF
            )

        if char_3 ~= "=" then
            output[#output + 1] =
                string.char(
                    (combined >> 8) &
                    0xFF
                )
        end

        if char_4 ~= "=" then
            output[#output + 1] =
                string.char(
                    combined &
                    0xFF
                )
        end
    end

    return table.concat(output)
end

local function color_option_index_to_code(
    index,
    options
)
    index =
        normalize_color_option_index(
            index,
            options
        )

    return CHAT_PREFIX_DIGITS:sub(
        index,
        index
    )
end

local function color_option_code_to_index(
    code,
    options
)
    code =
        tostring(code or "")

    local position =
        CHAT_PREFIX_DIGITS:find(
            code,
            1,
            true
        )

    if not position
        or position > #(options or {}) then

        return nil
    end

    return position
end

function state.initialize_prefix_sequence()
    if prefix_sequence_position ~= nil then
        return
    end

    prefix_sequence_position =
        (
            (os.time() or 0) * 131 +
            client.get_tick_count() * 17 +
            math.random(
                0,
                0x7FFFFFFF
            )
        ) %
        0x7FFFFFFF
end

function state.get_chat_prefix_wrapper_index(
    wrapper
)
    wrapper =
        tostring(wrapper or "")

    for index,
        candidate in ipairs(
            CHAT_PREFIX_WRAPPERS
        ) do

        if candidate == wrapper then
            return index
        end
    end

    return nil
end

function state.get_chat_prefix_alphabet_index(
    character
)
    character =
        tostring(character or "")

    return CHAT_PREFIX_UNIQUE_ALPHABET:find(
        character,
        1,
        true
    )
end

function state.is_valid_chat_prefix_body(
    body
)
    body =
        tostring(body or "")

    if #body <
        CHAT_PREFIX_V3_MIN_BODY_WIDTH
        or #body >
        CHAT_PREFIX_V3_MAX_BODY_WIDTH then

        return false
    end

    for index = 1,
        #body do

        if not state.get_chat_prefix_alphabet_index(
            body:sub(index, index)
        ) then

            return false
        end
    end

    return true
end

function state.get_next_free_prefix_body_position(
    position,
    body_width,
    excluded
)
    position =
        (
            math.floor(
                tonumber(position) or 1
            ) - 1
        ) %
        body_width +
        1

    for _ = 1,
        body_width do

        if not excluded[position] then
            return position
        end

        position =
            position %
            body_width +
            1
    end

    return 1
end

function state.get_v3_prefix_layout(
    opening_wrapper_index,
    closing_wrapper_index,
    body_width
)
    local name_position =
        (
            opening_wrapper_index * 3 +
            closing_wrapper_index * 5 +
            body_width * 7
        ) %
        body_width +
        1

    local message_position =
        (
            opening_wrapper_index * 7 +
            closing_wrapper_index * 11 +
            body_width * 3
        ) %
        body_width +
        1

    if message_position ==
        name_position then

        message_position =
            message_position %
            body_width +
            1
    end

    local excluded = {
        [name_position] = true,
        [message_position] = true
    }

    local name_anchor =
        state.get_next_free_prefix_body_position(
            opening_wrapper_index +
            closing_wrapper_index +
            body_width,
            body_width,
            excluded
        )

    excluded[name_anchor] = true

    local message_anchor =
        state.get_next_free_prefix_body_position(
            opening_wrapper_index * 2 +
            closing_wrapper_index * 3 +
            body_width * 5,
            body_width,
            excluded
        )

    return name_position,
        message_position,
        name_anchor,
        message_anchor
end

function state.encode_v3_prefix_colors(
    body,
    opening_wrapper_index,
    closing_wrapper_index,
    name_color_index,
    message_color_index
)
    local body_characters = {}

    for index = 1,
        #body do

        body_characters[index] =
            body:sub(index, index)
    end

    local body_width =
        #body_characters

    local name_position,
        message_position,
        name_anchor,
        message_anchor =
            state.get_v3_prefix_layout(
                opening_wrapper_index,
                closing_wrapper_index,
                body_width
            )

    local name_anchor_value =
        (
            state.get_chat_prefix_alphabet_index(
                body_characters[name_anchor]
            ) or 1
        ) - 1

    local message_anchor_value =
        (
            state.get_chat_prefix_alphabet_index(
                body_characters[message_anchor]
            ) or 1
        ) - 1

    local alphabet_size =
        #CHAT_PREFIX_UNIQUE_ALPHABET

    local name_mask =
        (
            opening_wrapper_index * 13 +
            closing_wrapper_index * 17 +
            body_width * 19 +
            name_anchor_value * 7 +
            message_anchor_value * 3
        ) %
        alphabet_size

    local message_mask =
        (
            opening_wrapper_index * 23 +
            closing_wrapper_index * 29 +
            body_width * 31 +
            name_anchor_value * 5 +
            message_anchor_value * 11
        ) %
        alphabet_size

    name_color_index =
        normalize_color_option_index(
            name_color_index,
            NAME_COLOR_OPTIONS
        )

    message_color_index =
        normalize_color_option_index(
            message_color_index,
            MESSAGE_COLOR_OPTIONS
        )

    local encoded_name_value =
        (
            name_color_index - 1 +
            name_mask
        ) %
        alphabet_size +
        1

    local encoded_message_value =
        (
            message_color_index - 1 +
            message_mask
        ) %
        alphabet_size +
        1

    body_characters[name_position] =
        CHAT_PREFIX_UNIQUE_ALPHABET:sub(
            encoded_name_value,
            encoded_name_value
        )

    body_characters[message_position] =
        CHAT_PREFIX_UNIQUE_ALPHABET:sub(
            encoded_message_value,
            encoded_message_value
        )

    return table.concat(
        body_characters
    )
end

function state.decode_v3_prefix_colors(
    body,
    opening_wrapper_index,
    closing_wrapper_index
)
    if not state.is_valid_chat_prefix_body(
        body
    ) then

        return nil
    end

    local body_width =
        #body

    local name_position,
        message_position,
        name_anchor,
        message_anchor =
            state.get_v3_prefix_layout(
                opening_wrapper_index,
                closing_wrapper_index,
                body_width
            )

    local name_anchor_value =
        (
            state.get_chat_prefix_alphabet_index(
                body:sub(
                    name_anchor,
                    name_anchor
                )
            ) or 1
        ) - 1

    local message_anchor_value =
        (
            state.get_chat_prefix_alphabet_index(
                body:sub(
                    message_anchor,
                    message_anchor
                )
            ) or 1
        ) - 1

    local alphabet_size =
        #CHAT_PREFIX_UNIQUE_ALPHABET

    local name_mask =
        (
            opening_wrapper_index * 13 +
            closing_wrapper_index * 17 +
            body_width * 19 +
            name_anchor_value * 7 +
            message_anchor_value * 3
        ) %
        alphabet_size

    local message_mask =
        (
            opening_wrapper_index * 23 +
            closing_wrapper_index * 29 +
            body_width * 31 +
            name_anchor_value * 5 +
            message_anchor_value * 11
        ) %
        alphabet_size

    local encoded_name_value =
        (
            state.get_chat_prefix_alphabet_index(
                body:sub(
                    name_position,
                    name_position
                )
            ) or 1
        ) - 1

    local encoded_message_value =
        (
            state.get_chat_prefix_alphabet_index(
                body:sub(
                    message_position,
                    message_position
                )
            ) or 1
        ) - 1

    local decoded_name_value =
        (
            encoded_name_value -
            name_mask
        ) %
        alphabet_size

    local decoded_message_value =
        (
            encoded_message_value -
            message_mask
        ) %
        alphabet_size

    if decoded_name_value >=
        #NAME_COLOR_OPTIONS
        or decoded_message_value >=
        #MESSAGE_COLOR_OPTIONS then

        return nil
    end

    return decoded_name_value + 1,
        decoded_message_value + 1
end

function state.get_prefix_visual_distance(
    first,
    second
)
    first =
        tostring(first or "")

    second =
        tostring(second or "")

    if first == ""
        or second == "" then

        return math.max(
            #first,
            #second
        )
    end

    local shared_length =
        math.min(
            #first,
            #second
        )

    local distance =
        math.abs(
            #first -
            #second
        )

    for index = 1,
        shared_length do

        if first:sub(index, index) ~=
            second:sub(index, index) then

            distance =
                distance + 1
        end
    end

    return distance
end

function state.build_v3_prefix_candidate(
    entropy,
    attempt
)
    local digest_primary =
        sha256_binary(
            "ChatEncryption-Prefix-V3-Primary\0" ..
            tostring(entropy or "") ..
            "\0" ..
            tostring(os.time() or 0) ..
            "\0" ..
            tostring(os.clock()) ..
            "\0" ..
            tostring(client.get_tick_count()) ..
            "\0" ..
            tostring(prefix_sequence_position or 0) ..
            "\0" ..
            tostring(attempt or 0) ..
            "\0" ..
            tostring(
                math.random(
                    0,
                    0x7FFFFFFF
                )
            )
        )

    local digest_secondary =
        sha256_binary(
            "ChatEncryption-Prefix-V3-Secondary\0" ..
            digest_primary ..
            "\0" ..
            tostring(
                math.random(
                    0,
                    0x7FFFFFFF
                )
            )
        )

    local width_range =
        CHAT_PREFIX_V3_MAX_BODY_WIDTH -
        CHAT_PREFIX_V3_MIN_BODY_WIDTH +
        1

    local body_width =
        CHAT_PREFIX_V3_MIN_BODY_WIDTH +
        (
            (digest_primary:byte(1) or 0) %
            width_range
        )

    local opening_wrapper_index =
        (
            (digest_primary:byte(2) or 0) %
            #CHAT_PREFIX_WRAPPERS
        ) + 1

    if CHAT_PREFIX_WRAPPERS[
        opening_wrapper_index
    ] == last_chat_prefix_wrapper then

        opening_wrapper_index =
            (
                opening_wrapper_index +
                (digest_primary:byte(3) or 0) %
                (#CHAT_PREFIX_WRAPPERS - 1)
            ) %
            #CHAT_PREFIX_WRAPPERS +
            1
    end

    local closing_wrapper_index =
        (
            (digest_primary:byte(4) or 0) %
            #CHAT_PREFIX_WRAPPERS
        ) + 1

    while closing_wrapper_index ==
        opening_wrapper_index
        or CHAT_PREFIX_WRAPPERS[
            closing_wrapper_index
        ] ==
            last_chat_prefix_closing_wrapper do

        closing_wrapper_index =
            closing_wrapper_index %
            #CHAT_PREFIX_WRAPPERS +
            1
    end

    local body_characters = {}
    local alphabet_size =
        #CHAT_PREFIX_UNIQUE_ALPHABET

    for index = 1,
        body_width do

        local primary_byte =
            digest_primary:byte(
                (
                    (index + 3) %
                    #digest_primary
                ) + 1
            ) or 0

        local secondary_byte =
            digest_secondary:byte(
                (
                    (index * 3 + 5) %
                    #digest_secondary
                ) + 1
            ) or 0

        local alphabet_index =
            (
                primary_byte * 257 +
                secondary_byte * 17 +
                index * 43 +
                (prefix_sequence_position or 0)
            ) %
            alphabet_size +
            1

        body_characters[index] =
            CHAT_PREFIX_UNIQUE_ALPHABET:sub(
                alphabet_index,
                alphabet_index
            )
    end

    return opening_wrapper_index,
        closing_wrapper_index,
        table.concat(
            body_characters
        )
end

function state.choose_chat_prefix(
    name_color_index,
    message_color_index,
    entropy
)
    state.initialize_prefix_sequence()

    for attempt = 1,
        96 do

        prefix_sequence_position =
            (
                (prefix_sequence_position or 0) +
                1
            ) %
            0x7FFFFFFF

        local opening_wrapper_index,
            closing_wrapper_index,
            random_body =
                state.build_v3_prefix_candidate(
                    entropy,
                    attempt
                )

        local encoded_body =
            state.encode_v3_prefix_colors(
                random_body,
                opening_wrapper_index,
                closing_wrapper_index,
                name_color_index,
                message_color_index
            )

        local opening_wrapper =
            CHAT_PREFIX_WRAPPERS[
                opening_wrapper_index
            ]

        local closing_wrapper =
            CHAT_PREFIX_WRAPPERS[
                closing_wrapper_index
            ]

        local prefix =
            opening_wrapper ..
            encoded_body ..
            closing_wrapper

        local required_distance =
            last_chat_prefix
            and math.min(
                12,
                math.max(
                    8,
                    math.floor(
                        math.min(
                            #prefix,
                            #last_chat_prefix
                        ) *
                        0.62
                    )
                )
            )
            or 0

        if not used_chat_prefixes[
            prefix
        ]
            and state.get_prefix_visual_distance(
                prefix,
                last_chat_prefix
            ) >=
                required_distance then

            used_chat_prefixes[
                prefix
            ] = true

            last_chat_prefix =
                prefix

            last_chat_prefix_wrapper =
                opening_wrapper

            last_chat_prefix_closing_wrapper =
                closing_wrapper

            return prefix
        end
    end

    -- Extremely unlikely fallback: continue generating until an unused
    -- prefix is found. Exact repetition is still prevented.
    local fallback_attempt = 97

    while true do
        prefix_sequence_position =
            (
                (prefix_sequence_position or 0) +
                1
            ) %
            0x7FFFFFFF

        local opening_wrapper_index,
            closing_wrapper_index,
            random_body =
                state.build_v3_prefix_candidate(
                    tostring(entropy or "") ..
                    "\0fallback",
                    fallback_attempt
                )

        local encoded_body =
            state.encode_v3_prefix_colors(
                random_body,
                opening_wrapper_index,
                closing_wrapper_index,
                name_color_index,
                message_color_index
            )

        local opening_wrapper =
            CHAT_PREFIX_WRAPPERS[
                opening_wrapper_index
            ]

        local closing_wrapper =
            CHAT_PREFIX_WRAPPERS[
                closing_wrapper_index
            ]

        local prefix =
            opening_wrapper ..
            encoded_body ..
            closing_wrapper

        if not used_chat_prefixes[
            prefix
        ] then

            used_chat_prefixes[
                prefix
            ] = true

            last_chat_prefix =
                prefix

            last_chat_prefix_wrapper =
                opening_wrapper

            last_chat_prefix_closing_wrapper =
                closing_wrapper

            return prefix
        end

        fallback_attempt =
            fallback_attempt + 1
    end
end

function state.get_matching_chat_prefix(
    chat_text
)
    chat_text =
        tostring(chat_text or "")

    -- Version 3: variable-length alphanumeric body, different opening and
    -- closing wrappers, and masked color metadata. The body contains no
    -- wrapper characters, so the closing wrapper can be found safely.
    if #chat_text >=
        CHAT_PREFIX_V3_MIN_BODY_WIDTH + 2 then

        local opening_wrapper =
            chat_text:sub(1, 1)

        local opening_wrapper_index =
            state.get_chat_prefix_wrapper_index(
                opening_wrapper
            )

        if opening_wrapper_index then
            local minimum_closing_position =
                CHAT_PREFIX_V3_MIN_BODY_WIDTH + 2

            local maximum_closing_position =
                math.min(
                    #chat_text,
                    CHAT_PREFIX_V3_MAX_BODY_WIDTH + 2
                )

            for closing_position =
                minimum_closing_position,
                maximum_closing_position do

                local closing_wrapper =
                    chat_text:sub(
                        closing_position,
                        closing_position
                    )

                local closing_wrapper_index =
                    state.get_chat_prefix_wrapper_index(
                        closing_wrapper
                    )

                if closing_wrapper_index
                    and closing_wrapper_index ~=
                        opening_wrapper_index then

                    local body =
                        chat_text:sub(
                            2,
                            closing_position - 1
                        )

                    if state.is_valid_chat_prefix_body(
                        body
                    ) then

                        local name_color_index,
                            message_color_index =
                                state.decode_v3_prefix_colors(
                                    body,
                                    opening_wrapper_index,
                                    closing_wrapper_index
                                )

                        if name_color_index
                            and message_color_index then

                            return chat_text:sub(
                                1,
                                closing_position
                            ),
                                name_color_index,
                                message_color_index
                        end
                    end
                end
            end
        end
    end

    -- Version 2 / previous current format:
    -- wrapper + two visible color digits + eight-character token + wrapper.
    local previous_prefix_length =
        CHAT_PREFIX_UNIQUE_WIDTH + 4

    if #chat_text >=
        previous_prefix_length then

        local prefix =
            chat_text:sub(
                1,
                previous_prefix_length
            )

        local wrapper =
            prefix:sub(
                1,
                1
            )

        local closing_wrapper =
            prefix:sub(
                previous_prefix_length,
                previous_prefix_length
            )

        local name_color_code =
            prefix:sub(
                2,
                2
            )

        local message_color_code =
            prefix:sub(
                3,
                3
            )

        local unique_token =
            prefix:sub(
                4,
                previous_prefix_length - 1
            )

        local valid_unique_token =
            #unique_token ==
                CHAT_PREFIX_UNIQUE_WIDTH

        if valid_unique_token then
            for index = 1,
                #unique_token do

                local character =
                    unique_token:sub(
                        index,
                        index
                    )

                if not CHAT_PREFIX_LETTER_SET[
                    character
                ]
                    and not CHAT_PREFIX_DIGIT_SET[
                        character
                    ] then

                    valid_unique_token =
                        false

                    break
                end
            end
        end

        local name_color_index =
            color_option_code_to_index(
                name_color_code,
                NAME_COLOR_OPTIONS
            )

        local message_color_index =
            color_option_code_to_index(
                message_color_code,
                MESSAGE_COLOR_OPTIONS
            )

        if wrapper == closing_wrapper
            and CHAT_PREFIX_WRAPPER_SET[
                wrapper
            ]
            and name_color_index
            and message_color_index
            and valid_unique_token then

            return prefix,
                name_color_index,
                message_color_index
        end
    end

    -- Legacy 4-character prefix format.
    if #chat_text < 4 then
        return nil
    end

    local legacy_prefix =
        chat_text:sub(
            1,
            4
        )

    local wrapper =
        legacy_prefix:sub(
            1,
            1
        )

    local letter =
        legacy_prefix:sub(
            2,
            2
        )

    local digit =
        legacy_prefix:sub(
            3,
            3
        )

    local closing_wrapper =
        legacy_prefix:sub(
            4,
            4
        )

    if wrapper ~= closing_wrapper
        or not CHAT_PREFIX_WRAPPER_SET[
            wrapper
        ]
        or not CHAT_PREFIX_LETTER_SET[
            letter
        ]
        or not CHAT_PREFIX_DIGIT_SET[
            digit
        ] then

        return nil
    end

    return legacy_prefix,
        1,
        1
end

local function bytes_to_hex(data)
    local output = {}

    for index = 1, #data do
        output[#output + 1] =
            string.format(
                "%02X",
                data:byte(index)
            )
    end

    return table.concat(output)
end

