local function open_windows_clipboard_with_retry()
    local attempts = 12

    for attempt = 1, attempts do
        if clipboard_user32.OpenClipboard(
            nil
        ) ~= 0 then

            return true
        end

        if clipboard_kernel32
            and clipboard_kernel32.Sleep then

            clipboard_kernel32.Sleep(
                15
            )
        end
    end

    return false
end

local function copy_text_with_windows_ffi(
    text_to_copy
)
    if not initialize_clipboard_ffi() then
        return false,
            "Windows clipboard FFI unavailable."
    end

    local CP_UTF8 = 65001
    local GMEM_MOVEABLE = 0x0002
    local GMEM_ZEROINIT = 0x0040
    local CF_UNICODETEXT = 13

    local required_characters =
        clipboard_kernel32.MultiByteToWideChar(
            CP_UTF8,
            0,
            text_to_copy,
            #text_to_copy,
            nil,
            0
        )

    if required_characters <= 0 then
        return false,
            "UTF-8 conversion failed."
    end

    local memory =
        clipboard_kernel32.GlobalAlloc(
            GMEM_MOVEABLE |
            GMEM_ZEROINIT,
            (required_characters + 1) * 2
        )

    if memory == nil then
        return false,
            "Clipboard memory allocation failed."
    end

    local locked_memory =
        clipboard_kernel32.GlobalLock(
            memory
        )

    if locked_memory == nil then
        clipboard_kernel32.GlobalFree(
            memory
        )

        return false,
            "Clipboard memory lock failed."
    end

    local wide_buffer =
        clipboard_ffi.cast(
            "unsigned short*",
            locked_memory
        )

    local converted_characters =
        clipboard_kernel32.MultiByteToWideChar(
            CP_UTF8,
            0,
            text_to_copy,
            #text_to_copy,
            wide_buffer,
            required_characters
        )

    if converted_characters <= 0 then
        clipboard_kernel32.GlobalUnlock(
            memory
        )

        clipboard_kernel32.GlobalFree(
            memory
        )

        return false,
            "Clipboard text conversion failed."
    end

    wide_buffer[
        converted_characters
    ] = 0

    clipboard_kernel32.GlobalUnlock(
        memory
    )

    if not open_windows_clipboard_with_retry() then
        clipboard_kernel32.GlobalFree(
            memory
        )

        return false,
            "Windows clipboard is busy."
    end

    if clipboard_user32.EmptyClipboard() == 0 then
        clipboard_user32.CloseClipboard()

        clipboard_kernel32.GlobalFree(
            memory
        )

        return false,
            "Could not clear Windows clipboard."
    end

    local clipboard_handle =
        clipboard_user32.SetClipboardData(
            CF_UNICODETEXT,
            memory
        )

    clipboard_user32.CloseClipboard()

    if clipboard_handle == nil then
        clipboard_kernel32.GlobalFree(
            memory
        )

        return false,
            "SetClipboardData failed."
    end

    -- Windows owns this memory after SetClipboardData succeeds.
    return true
end

local function os_execute_succeeded(
    first,
    second,
    third
)
    if first == true then
        return true
    end

    if type(first) == "number" then
        return first == 0
