local function copy_text_with_powershell(
    text_to_copy
)
    if type(io) ~= "table"
        or type(io.open) ~= "function"
        or type(os) ~= "table"
        or type(os.execute) ~= "function" then

        return false,
            "PowerShell clipboard fallback unavailable."
    end

    local open_ok,
        file =
            pcall(
                io.open,
                CLIPBOARD_TEMP_FILE_PATH,
                "wb"
            )

    if not open_ok
        or not file then

        return false,
            "Could not create clipboard temporary file."
    end

    local write_ok =
        pcall(
            function()
                -- UTF-8 BOM keeps Windows PowerShell decoding reliable.
                file:write(
                    string.char(
                        0xEF,
                        0xBB,
                        0xBF
                    )
                )

                file:write(
                    text_to_copy
                )

                file:flush()
                file:close()
            end
        )

    if not write_ok then
        pcall(
            function()
                file:close()
            end
        )

        pcall(
            os.remove,
            CLIPBOARD_TEMP_FILE_PATH
        )

        return false,
            "Could not write clipboard temporary file."
    end

    local escaped_path =
        CLIPBOARD_TEMP_FILE_PATH:gsub(
            "'",
            "''"
        )

    local powershell_script =
        "$ErrorActionPreference='Stop'; " ..
        "$text=[System.IO.File]::ReadAllText('" ..
        escaped_path ..
        "',[System.Text.Encoding]::UTF8); " ..
        "Add-Type -AssemblyName System.Windows.Forms; " ..
        "[System.Windows.Forms.Clipboard]::SetText($text)"

    local powershell_command =
        'powershell.exe -NoProfile -NonInteractive -STA ' ..
        '-ExecutionPolicy Bypass -Command "' ..
        powershell_script ..
        '" >nul 2>&1'

    local execute_ok,
        first,
        second,
        third =
            pcall(
                os.execute,
                powershell_command
            )

    pcall(
        os.remove,
        CLIPBOARD_TEMP_FILE_PATH
    )

    if not execute_ok then
        return false,
            "PowerShell clipboard command failed."
    end

    if os_execute_succeeded(
        first,
        second,
        third
    ) then
        return true
    end

    return false,
        "PowerShell could not update the clipboard."
end

local function copy_text_to_clipboard(
    text_to_copy
)
    text_to_copy =
        tostring(text_to_copy or "")

    if text_to_copy == "" then
        return false,
            "Message is empty."
    end

    local copied,
        copy_error =
            copy_text_with_imgui(
                text_to_copy
            )

    if copied then
        return true
    end

    copied,
        copy_error =
            copy_text_with_windows_ffi(
                text_to_copy
            )

    if copied then
        return true
    end

    local ffi_error =
        copy_error

    copied,
        copy_error =
            copy_text_with_powershell(
                text_to_copy
            )

    if copied then
        return true
    end

    return false,
        copy_error or
        ffi_error or
        "Clipboard copy failed."
end

