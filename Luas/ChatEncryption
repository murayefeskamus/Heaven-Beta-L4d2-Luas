local function normalize_color_option_index(
    value,
    options
)
    local option_count =
        #(options or {})

    if option_count <= 0 then
        return 1
    end

    local index =
        math.floor(
            tonumber(value) or 1
        )

    return math.max(
        1,
        math.min(
            option_count,
            index
        )
    )
end

