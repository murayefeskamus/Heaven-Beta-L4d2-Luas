local function draw_message_input(id_suffix)
    local widget_key =
        tostring(id_suffix or "Chat")

    state.input_widget_revisions =
        state.input_widget_revisions or {}

    state.input_widget_generations =
        state.input_widget_generations or {}

    local widget_resynced = false

    if state.input_widget_revisions[widget_key] ~=
        state.input_revision then

        widget_resynced = true

        state.input_widget_generations[widget_key] =
            (state.input_widget_generations[widget_key] or 0) + 1

        state.input_widget_revisions[widget_key] =
            state.input_revision
    end

    local message_available_width =
        get_exact_remaining_width()

    local clear_button_width =
        math.max(
            46.0,
            get_text_width("Clear") + 20.0
        )

    local clear_button_spacing = 8.0

    local maximum_input_width =
        math.max(
            60.0,
            message_available_width -
            clear_button_width -
            clear_button_spacing
        )

    local message_input_width =
        math.max(
            60.0,
            math.min(
                620.0,
                message_available_width * 0.72,
                maximum_input_width
            )
        )

    local input_border_style_pushed = 0
    local input_border_child_started = false
    local input_border_child_open = true

    if state.rendering_standalone == true then
        local palette =
            state.get_standalone_theme_palette()
            or {}

        local accent =
            type(palette.accent) == "table"
            and palette.accent
            or type(palette.border) == "table"
            and palette.border
            or { 0.25, 0.85, 1.00 }

        if type(imgui.push_style_color)
            == "function" then

            local border_ok,
                border_result =
                    pcall(
                        imgui.push_style_color,
                        5,
                        tonumber(accent[1]) or 0.25,
                        tonumber(accent[2]) or 0.85,
                        tonumber(accent[3]) or 1.00,
                        1.0
                    )

            if border_ok
                and border_result ~= false then

                input_border_style_pushed = 1
            end
        end

        if type(imgui.begin_child)
            == "function" then

            local child_ok,
                child_result =
                    pcall(
                        imgui.begin_child,
                        "ChatEncryptionInputBorder##" ..
                        widget_key,
                        message_input_width,
                        28,
                        true,
                        0
                    )

            if child_ok then
                input_border_child_started = true
                input_border_child_open =
                    child_result ~= false
            end
        end
    end

    imgui.push_item_width(
        input_border_child_started
        and math.max(
            1,
            message_input_width - 8
        )
        or message_input_width
    )

    local input_colors =
        state.push_input_theme()

    local changed_input = false
    local input_value =
        config.input_text

    local input_id =
        "##Message" ..
        widget_key ..
        "##Generation" ..
        tostring(
            state.input_generation
        ) ..
        "##WidgetGeneration" ..
        tostring(
            state.input_widget_generations[widget_key] or 0
        )

    if input_border_child_open then
        changed_input,
            input_value =
                imgui.input_text(
                    input_id,
                    config.input_text,
                    config.max_encrypted_input_bytes
                )
    end

    local input_active = false

    if type(imgui.is_item_active)
        == "function" then

        local active_ok,
            active_value =
                pcall(
                    imgui.is_item_active
                )

        input_active =
            active_ok
            and active_value == true
    end

    if not input_active
        and type(imgui.is_item_focused)
            == "function" then

        local focused_ok,
            focused_value =
                pcall(
                    imgui.is_item_focused
                )

        input_active =
            focused_ok
            and focused_value == true
    end

    state.pop_input_theme(
        input_colors
    )

    imgui.pop_item_width()

    if input_border_child_started
        and type(imgui.end_child)
            == "function" then

        pcall(
            imgui.end_child
        )
    end

    if input_border_style_pushed > 0
        and type(imgui.pop_style_color)
            == "function" then

        pcall(
            imgui.pop_style_color
        )
    end

    if changed_input
        and input_value ~= nil
        and (
            input_active
            or not widget_resynced
        ) then

        config.input_text =
            tostring(
                input_value
            )

        state.input_revision =
            (tonumber(state.input_revision) or 0) + 1

        state.input_widget_revisions[widget_key] =
            state.input_revision

        state.secret_input_blocked =
            state.input_contains_session_secret(
                config.input_text
            )

        if not state.secret_input_blocked
            and state.status ==
                "Access key detected. Sending is disabled." then

            state.status = "Ready"
            state.status_kind = "info"
            state.status_expires_at = 0.0
        end
    end

    local has_message_input =
        tostring(
            config.input_text or ""
