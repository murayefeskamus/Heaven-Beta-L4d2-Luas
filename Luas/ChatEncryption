local function push_button_colors(
    label,
    text_r,
    text_g,
    text_b,
    button_r,
    button_g,
    button_b
)
    if type(imgui.push_style_color)
        ~= "function"
        or type(imgui.pop_style_color)
        ~= "function" then

        return 0
    end

    local hovered_r =
        math.min(
            1.0,
            button_r + 0.10
        )

    local hovered_g =
        math.min(
            1.0,
            button_g + 0.10
        )

    local hovered_b =
        math.min(
            1.0,
            button_b + 0.10
        )

    local active_r =
        math.max(
            0.0,
            button_r - 0.08
        )

    local active_g =
        math.max(
            0.0,
            button_g - 0.08
        )

    local active_b =
        math.max(
            0.0,
            button_b - 0.08
        )

    local palette =
        state.get_standalone_theme_palette()

    if palette then
        local role =
            state.get_button_role(
                label,
                button_r,
                button_g,
                button_b
            )

        local role_colors =
            state.get_theme_role_colors(
                role
            )

        text_r = role_colors.text[1]
        text_g = role_colors.text[2]
        text_b = role_colors.text[3]

        button_r = role_colors.normal[1]
        button_g = role_colors.normal[2]
        button_b = role_colors.normal[3]

        hovered_r = role_colors.hovered[1]
        hovered_g = role_colors.hovered[2]
        hovered_b = role_colors.hovered[3]

        active_r = role_colors.active[1]
        active_g = role_colors.active[2]
        active_b = role_colors.active[3]
    end

    local button_surface_alpha = 1.0

    if state.rendering_standalone == true then
        button_surface_alpha =
            math.max(
                0.0,
                math.min(
                    1.0,
                    tonumber(
                        config.standalone_window_opacity
                    ) or 1.0
                )
            )

        if palette
            and palette.light == true
            and button_surface_alpha <= 0.45 then

            local foreground_text =
                state.get_standalone_foreground_colors()

            text_r = foreground_text[1]
            text_g = foreground_text[2]
            text_b = foreground_text[3]
        end
    end

    local pushed = 0

    local function try_push(
        index,
        red,
        green,
        blue,
        alpha
    )
        local success =
            pcall(
                imgui.push_style_color,
                index,
                red,
                green,
                blue,
                alpha
            )

        if success then
            pushed = pushed + 1
        end
    end

    try_push(0, text_r, text_g, text_b, 1.0)
    try_push(21, button_r, button_g, button_b, button_surface_alpha)
    try_push(22, hovered_r, hovered_g, hovered_b, button_surface_alpha)
    try_push(23, active_r, active_g, active_b, button_surface_alpha)

    return pushed
end

local function pop_button_colors(count)
    count = math.max(0, math.floor(tonumber(count) or 0))

    if count > 0
        and type(imgui.pop_style_color)
            == "function" then

        for _ = 1, count do
            pcall(imgui.pop_style_color)
        end
    end
end

