function state.copy_style_color(
    color
)
    return {
        tonumber(color and color[1]) or 0.0,
        tonumber(color and color[2]) or 0.0,
        tonumber(color and color[3]) or 0.0
    }
end

function state.mix_style_color(
    first,
    second,
    amount
)
    amount =
        math.max(
            0.0,
            math.min(
                1.0,
                tonumber(amount) or 0.0
            )
        )

    return {
        first[1] + (second[1] - first[1]) * amount,
        first[2] + (second[2] - first[2]) * amount,
        first[3] + (second[3] - first[3]) * amount
    }
end


function state.copy_dst_bridge_palette(
    source_palette
)
    if type(source_palette) ~= "table" then
        return nil
    end

    local copied = {}

    for key,
        value in pairs(source_palette) do

        if type(value) == "table" then
            copied[key] = {}

            for nested_key,
                nested_value in pairs(value) do

                copied[key][nested_key] =
                    nested_value
            end
        else
            copied[key] = value
        end
    end

    if type(copied.background) ~= "table"
        or type(copied.child) ~= "table"
        or type(copied.text) ~= "table"
        or type(copied.accent) ~= "table" then

        return nil
    end

    return copied
end

function state.apply_dst_theme_bridge(
    bridge,
    source_name
)
    if type(bridge) ~= "table" then
        return false
    end

    local palette =
        state.copy_dst_bridge_palette(
            bridge.palette
