local function make_nonce()
    state.nonce_counter =
        state.nonce_counter + 1

    -- Mix all changing entropy into all eight nonce bytes. The previous
    -- layout placed Unix time first, causing Base64 payloads sent during the
    -- same second to share several visible starting characters.
    local entropy =
        sha256_binary(
            "ChatEncryption-Nonce-V2\0" ..
            tostring(os.time() or 0) ..
            "\0" ..
            tostring(os.clock()) ..
            "\0" ..
            tostring(client.get_tick_count()) ..
            "\0" ..
            tostring(state.nonce_counter) ..
            "\0" ..
            tostring(
                math.random(
                    0,
                    0x7FFFFFFF
                )
            ) ..
            "\0" ..
            tostring(
                math.random(
                    0,
                    0x7FFFFFFF
                )
            )
        )

    return entropy:sub(
        1,
        8
    )
end

local function xor_with_keystream(
    data,
    nonce,
    key_material
)
    local output = {}
    local offset = 1
    local counter = 0

    key_material =
        type(key_material) == "string"
        and key_material
        or state.get_active_key_material()

    while offset <= #data do
        local stream_block =
            sha256_binary(
                key_material ..
                nonce ..
                pack_u32_be(counter)
            )

        local available =
            math.min(
                32,
                #data - offset + 1
            )

        for index = 1, available do
            local source_byte =
                data:byte(
                    offset + index - 1
                )

            local stream_byte =
                stream_block:byte(index)

            output[#output + 1] =
                string.char(
                    (
                        source_byte ~
                        stream_byte
                    ) & 0xFF
                )
        end

        offset =
            offset + available

        counter =
            counter + 1
    end

    return table.concat(output)
end

local function secure_equals(
    first,
    second
)
    if #first ~= #second then
        return false
    end

    local difference = 0

    for index = 1, #first do
        difference =
            difference |
            (
                first:byte(index) ~
                second:byte(index)
            )
    end

    return difference == 0
end

local function sanitize_plaintext(text)
    text = tostring(text or "")

    text =
        text:gsub(
            "[\r\n]",
            " "
        )

    return text
end

local function encrypt_message(
    plaintext,
    key_material
)
    plaintext =
        sanitize_plaintext(
            plaintext
        )

    if plaintext == "" then
        return nil,
            "Message is empty."
    end

    if #plaintext >
        MAX_PLAINTEXT_BYTES then

        return nil,
            string.format(
                "Message is too long (%d/%d bytes).",
                #plaintext,
                MAX_PLAINTEXT_BYTES
            )
    end

    local nonce =
        make_nonce()

    key_material =
        type(key_material) == "string"
        and key_material
        or state.get_active_key_material()

    local ciphertext =
        xor_with_keystream(
            plaintext,
            nonce,
            key_material
        )

    local authentication_tag =
        sha256_binary(
            key_material ..
            nonce ..
            ciphertext
        ):sub(
            1,
            6
        )

    local payload =
        nonce ..
        authentication_tag ..
        ciphertext

    return
        state.choose_chat_prefix(
            config.name_color_index,
            config.message_color_index,
            nonce
        ) ..
        base64_encode(payload)
end

local function decrypt_message(
    chat_text,
    key_material
)
    chat_text =
        tostring(chat_text or "")

    local matched_prefix,
        name_color_index,
        message_color_index =
            state.get_matching_chat_prefix(
                chat_text
            )

    if not matched_prefix then
        return nil,
            "Not an encrypted message."
    end

    local encoded =
        chat_text:sub(
            #matched_prefix + 1
        )

    local payload =
        base64_decode(
            encoded
        )

    if not payload
        or #payload < 14 then

        return nil,
            "Invalid encrypted payload."
    end

    local nonce =
        payload:sub(
            1,
            8
        )

    local received_tag =
        payload:sub(
            9,
            14
        )

    local ciphertext =
        payload:sub(
            15
        )

    key_material =
        type(key_material) == "string"
        and key_material
        or state.get_active_key_material()

    local expected_tag =
        sha256_binary(
            key_material ..
            nonce ..
            ciphertext
        ):sub(
            1,
            6
        )

    if not secure_equals(
        received_tag,
        expected_tag
    ) then
        return nil,
            "Unable to decrypt: wrong key or damaged message."
    end

    return xor_with_keystream(
        ciphertext,
        nonce,
        key_material
    ),
        nil,
        name_color_index,
        message_color_index
end


