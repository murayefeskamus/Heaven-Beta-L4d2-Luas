function on_end_scene()
    enforce_simple_open_chat_mode()
    state.rendering_standalone = false

    if not config.show_floating_window then
        return
    end

    state.rendering_standalone = true

    local standalone_opacity_colors =
        state.push_standalone_window_opacity()

    local standalone_title =
        "Encrypted Chat [" ..
        _G.__CHAT_ENCRYPTION_WINDOW_KEYS.get_name(
            config.standalone_toggle_key
        ) ..
        ": ON/OFF]"

    if state.is_selected_private_session_active() then
        standalone_title =
            standalone_title ..
            " — " ..
            tostring(state.auth_session.session_name)
    elseif state.get_selected_private_session_id() then
        standalone_title =
            standalone_title ..
            " — " ..
            state.get_selected_chat_label() ..
            " (History)"
    end

    local notification_summary =
        state.get_chat_notification_summary()

    if notification_summary ~= "" then
        standalone_title =
            standalone_title ..
            " (" ..
            notification_summary ..
            ")"
    end

    -- Keep one fixed internal window ID even while the visible title gains
    -- a session name or notification count. The ID after ### exactly matches
    -- the old open-chat label, preserving the geometry users already saved.
    standalone_title =
        standalone_title ..
        "###Encrypted Chat##ChatEncryptionV29"

    if type(imgui.set_next_window_size)
        == "function" then

        -- 380x430 is used only when Heaven has no saved geometry.
        -- The final argument is ImGuiCond_FirstUseEver.
        pcall(
            imgui.set_next_window_size,
            380,
            430,
            4
        )
    end

    -- Use the exact same theme-derived title treatment as the DST standalone
    -- windows. The text color is recalculated for every light, dark, custom or
    -- future palette and remains fully opaque while the title surface fades.
    local standalone_title_text_pushed = false

    if type(imgui.push_style_color) == "function" then
        local standalone_palette =
            state.get_standalone_theme_palette()

        local standalone_title_background =
            type(standalone_palette) == "table"
            and (
                standalone_palette.title_active or
                standalone_palette.accent or
                standalone_palette.title or
                standalone_palette.background
            )
            or { 0.055, 0.058, 0.066 }

        local standalone_title_text =
            state.get_theme_contrast_text(
                standalone_title_background
            )

        imgui.push_style_color(
            0,
            standalone_title_text[1],
            standalone_title_text[2],
            standalone_title_text[3],
            1.0
        )

        standalone_title_text_pushed = true
    end

    local window_open =
        imgui.begin(
            standalone_title,
            STANDALONE_WINDOW_FLAGS
        )

    if standalone_title_text_pushed
        and type(imgui.pop_style_color) == "function" then

        imgui.pop_style_color()
    end

    if window_open then
        state.apply_dst_font_scale()

        local window_focused = false

        if type(imgui.is_window_focused) == "function" then
            local focused_ok,
                focused_value =
                    pcall(
                        imgui.is_window_focused
                    )

            if not focused_ok then
                focused_ok,
                    focused_value =
                        pcall(
                            imgui.is_window_focused,
                            0
                        )
            end

            window_focused =
                focused_ok
                and focused_value == true
        end

        state.standalone_window_focused =
            window_focused

        if window_focused then
            state.clear_unread_counts()
        end

        -- Width and height of zero use the outer window's actual
        -- visible content region for reliable text wrapping.
        local body_open =
            imgui.begin_child(
                "EncryptedChatResponsiveBody",
                0,
                0,
                false,
                0
            )

        if body_open then
            state.apply_dst_font_scale()

            local draw_ok,
                draw_error =
                    pcall(
                        draw_chat_controls,
                        "FloatingWindow",
                        -42,
                        false
                    )

            if not draw_ok then
                local error_text =
                    tostring(
                        draw_error or
                        "Unknown standalone drawing error"
                    )

                if state.standalone_draw_error ~= error_text then
                    state.standalone_draw_error =
                        error_text

                    _G.__CHAT_ENCRYPTION_CONSOLE(
                        "Standalone window error: " ..
                        error_text
                    )
                end

                if type(imgui.text_colored) == "function" then
                    pcall(
                        imgui.text_colored,
                        1.0,
                        0.35,
                        0.35,
                        1.0,
                        "Chat window drawing error. Check the Heaven console."
                    )
                end
            else
                state.standalone_draw_error = nil
            end
        end

        imgui.end_child()
    else
        state.standalone_window_focused =
            false
    end

    imgui["end"]()

    state.pop_standalone_window_opacity(
        standalone_opacity_colors
    )


    state.rendering_standalone = false
end
