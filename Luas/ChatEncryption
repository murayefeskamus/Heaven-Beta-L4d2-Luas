local function draw_compatible_users()
    local compatible_entries =
        get_sorted_compatible_user_entries()

    local palette =
        state.get_standalone_theme_palette()

    local title_color =
        palette
        and palette.text
        or { 1.0, 1.0, 1.0 }

    local count_color =
        palette
        and palette.accent
        or { 0.25, 0.85, 1.0 }

    imgui.text_colored(
        title_color[1],
        title_color[2],
        title_color[3],
        1.0,
        "Compatible users"
    )

    imgui.same_line()

    imgui.text_colored(
        count_color[1],
        count_color[2],
        count_color[3],
        1.0,
        "(" .. tostring(#compatible_entries) .. "):"
    )

    if #compatible_entries > 0 then
        local line_start_x =
            get_cursor_position_x()

        local row_width =
            get_exact_remaining_width()

        local spacing_width =
            math.max(
                8.0,
                get_text_width(" ")
            )

        local used_width = 0.0

        for index, entry in ipairs(compatible_entries) do
            local label =
                entry.name ..
                (index < #compatible_entries and "," or "")

            local name_r, name_g, name_b =
                get_user_name_color(
                    entry.name,
                    entry.color_index
                )

            local remaining_label =
                tostring(label)

            repeat
                local available_width = row_width

                if used_width > 0.0 then
                    available_width =
                        row_width -
                        used_width -
                        spacing_width
                end

                local label_width =
                    get_text_width(
                        remaining_label
                    )

                if used_width > 0.0
                    and label_width <= available_width then

                    imgui.same_line()
                elseif used_width > 0.0 then
                    if line_start_x then
                        set_cursor_position_x(
                            line_start_x
                        )
                    end

                    used_width = 0.0
                    available_width = row_width
                end

                local segment =
                    remaining_label

                if get_text_width(segment) >
                    available_width then

                    segment,
                        remaining_label =
                            take_line_for_width(
                                remaining_label,
                                available_width
                            )
                else
                    remaining_label = ""
                end

                imgui.text_colored(
                    name_r,
                    name_g,
                    name_b,
                    1.0,
                    segment
                )

                used_width =
                    get_text_width(segment)

                if remaining_label ~= "" then
                    if line_start_x then
                        set_cursor_position_x(
                            line_start_x
                        )
                    end

                    used_width = 0.0
                end
            until remaining_label == ""
        end
    else
        imgui.same_line()
        state.draw_hint("None detected")
    end

    if colored_button(
        "Refresh Users",
        1.0, 1.0, 1.0,
        0.12, 0.38, 0.68
    ) then
        update_compatible_session_state()

        refresh_compatible_users(
            false,
            true
        )
    end
end

local function normalize_history_search(
    search_text
)
    return tostring(
        search_text or ""
    ):lower()
end

local function history_entry_matches_search(
    entry,
    search_text
)
    if not state.history_entry_matches_active_chat(
        entry
    ) then
        return false
    end

    local normalized_search =
        normalize_history_search(
            search_text
        )

    if normalized_search == "" then
        return true
    end

    return tostring(
        entry and entry.text or ""
    ):lower():find(
        normalized_search,
        1,
        true
    ) ~= nil
end

local function count_filtered_history_messages(
    search_text
)
    local count = 0

    for _,
        entry in ipairs(
            state.history
        ) do

        if history_entry_matches_search(
            entry,
            search_text
        ) then
            count =
                count + 1
        end
    end

    return count
end

local function get_unique_filtered_history_match(
    search_text
)
    local normalized_search =
        normalize_history_search(
            search_text
        )

    if normalized_search == "" then
        return nil
    end

    local copy_match = nil

    for index =
        #state.history,
        1,
        -1 do

        local entry =
            state.history[
                index
            ]

        if history_entry_matches_search(
            entry,
            normalized_search
        ) then
            if not copy_match then
                copy_match =
                    entry
            else
                -- Repeated results are still safely copyable when they
                -- represent the same displayed message. Any difference
                -- keeps the result ambiguous.
                local same_sender =
                    tostring(
                        entry.sender or ""
                    ) ==
                    tostring(
                        copy_match.sender or ""
                    )

                local same_text =
                    tostring(
                        entry.text or ""
                    ) ==
                    tostring(
                        copy_match.text or ""
                    )

                local same_channel =
                    (entry.team_chat == true) ==
                    (copy_match.team_chat == true)

                if not same_sender
                    or not same_text
                    or not same_channel then

                    return nil
                end
            end
        end
    end

    return copy_match
end

local clipboard_ffi = nil
local clipboard_kernel32 = nil
local clipboard_user32 = nil
local clipboard_ffi_checked = false

local CLIPBOARD_TEMP_FILE_PATH =
    "C:\\Heaven-L4D2\\scripts\\ChatEncryptionClipboard.tmp"

local function initialize_clipboard_ffi()
    if clipboard_ffi_checked then
        return clipboard_ffi ~= nil
            and clipboard_kernel32 ~= nil
            and clipboard_user32 ~= nil
    end

    clipboard_ffi_checked = true

    if type(require) ~= "function" then
        return false
    end

    local ffi_ok,
        ffi_module =
            pcall(
                require,
                "ffi"
            )

    if not ffi_ok
        or not ffi_module then

        return false
    end

    pcall(
        ffi_module.cdef,
        [[
            void* GlobalAlloc(
                unsigned int uFlags,
                size_t dwBytes
            );

            void* GlobalLock(
                void* hMem
            );

            int GlobalUnlock(
                void* hMem
            );

            void* GlobalFree(
                void* hMem
            );

            int MultiByteToWideChar(
                unsigned int CodePage,
                unsigned long dwFlags,
                const char* lpMultiByteStr,
                int cbMultiByte,
                unsigned short* lpWideCharStr,
                int cchWideChar
            );

            int OpenClipboard(
                void* hWndNewOwner
            );

            int EmptyClipboard(void);

            void* SetClipboardData(
                unsigned int uFormat,
                void* hMem
            );

            int CloseClipboard(void);

            void Sleep(
                unsigned long dwMilliseconds
            );
        ]]
    )

    local kernel_ok,
        kernel32 =
            pcall(
                ffi_module.load,
                "kernel32"
            )

    local user_ok,
        user32 =
            pcall(
                ffi_module.load,
                "user32"
            )

    if not kernel_ok
        or not user_ok then

        return false
    end

    clipboard_ffi =
        ffi_module

    clipboard_kernel32 =
        kernel32

    clipboard_user32 =
        user32

    return true
end

