local function draw_chat_controls(
    id_suffix,
    history_height,
    allow_message_search
)
    local suffix =
        tostring(id_suffix or "")

    if not state.is_selected_history_session() then
        state.draw_smart_alert()
    end

    local composer_key =
        suffix == "FloatingWindow"
        and "floating_composer"
        or "main_composer"

    local summary_parts = {}

    local visible_message_count =
        state.get_active_chat_message_count()

    if visible_message_count > 0 then
        summary_parts[#summary_parts + 1] =
            tostring(visible_message_count) ..
            (visible_message_count == 1
                and " message"
                or " messages")
    end

    if state.unread_message_count > 0 then
        summary_parts[#summary_parts + 1] =
            tostring(state.unread_message_count) ..
            " unread"
    end

    if not state.draw_collapsible_section(
        "CHAT",
        composer_key,
        "MessageComposer" .. suffix,
        true,
        table.concat(summary_parts, ", ")
    ) then
        state.clear_chat_confirmation = false
        return
    end

    state.draw_chat_scope_tabs(
        suffix
    )

    if state.is_selected_history_session() then
        state.clear_chat_confirmation = false

        state.draw_history_session_controls(
            suffix
        )

        imgui.spacing()
        imgui.separator()
        imgui.spacing()

        draw_decrypted_history(
            "ChatEncryptionHistory##" .. suffix,
            history_height,
            allow_message_search
        )

        return
    end

    state.history_close_confirmation_id = ""

    draw_chat_mode_tabs(suffix)

    if suffix ~= "FloatingWindow" then
        state.draw_inline_session_manager(
            suffix
        )
    else
        state.draw_compact_session_controls(
            suffix
        )
    end

    draw_message_input(suffix)

    local encrypted_text =
        sanitize_plaintext(
            config.input_text
        )

    local normal_text =
        tostring(
            config.input_text or ""
        )

    local input_empty =
        encrypted_text == ""

    local contains_secret =
        state.input_contains_session_secret(
            config.input_text
        )

    local was_secret_blocked =
        state.secret_input_blocked == true

    state.secret_input_blocked =
        contains_secret

    if contains_secret then
        local warning_color =
            state.get_theme_role_colors(
                "danger"
            ).normal

        imgui.text_colored(
            warning_color[1],
            warning_color[2],
            warning_color[3],
            1.0,
            "Access key detected. Sending is disabled."
        )
    elseif was_secret_blocked then
        if state.status ==
            "Access key detected. Sending is disabled." then

            state.status = "Ready"
            state.status_kind = "info"
            state.status_expires_at = 0.0
        end
    end

    local selected_private_tab =
        state.get_selected_private_session_id()
            ~= nil

    local encrypted_available =
        config.enabled
        and not input_empty
        and not contains_secret
        and (
            not selected_private_tab
            or state.is_selected_private_session_active()
        )
        and #state.outgoing_packets == 0
        and state.utf8_character_count(
            encrypted_text
        ) <=
            config.max_encrypted_message_characters

    local normal_available =
        not input_empty
        and not contains_secret
        and #normal_text <=
            MAX_NORMAL_BYTES

    local send_encrypted =
        disabled_colored_button(
            "Send Encrypted##" .. suffix,
            encrypted_available,
            1.0, 1.0, 1.0,
            0.10, 0.36, 0.78
        )

    imgui.same_line()

    local send_normal =
        disabled_colored_button(
            "Send Normal##" .. suffix,
            normal_available,
            1.0, 1.0, 1.0,
            0.10, 0.58, 0.22
        )

    imgui.same_line()
    state.draw_character_counter()

    if consume_enter_press() then
        if input.is_key_down(keys.SHIFT) then
            if normal_available then
                send_normal = true
            end
        elseif encrypted_available then
            send_encrypted = true
        end
    end

    if send_encrypted then
        send_current_encrypted_message()
    elseif send_normal then
        send_current_normal_message()
    end

    draw_status_line()

    imgui.spacing()

    draw_compatible_users()

    imgui.spacing()
    imgui.separator()
    imgui.spacing()

    draw_decrypted_history(
        "ChatEncryptionHistory##" .. suffix,
        history_height,
        allow_message_search
    )

    local has_chat_messages =
        state.get_active_chat_message_count() > 0

    if not has_chat_messages then
        state.clear_chat_confirmation = false
    end

    if not state.clear_chat_confirmation then
        if disabled_colored_button(
            "Clear##" .. suffix,
            has_chat_messages,
            1.0, 1.0, 1.0,
            0.72, 0.32, 0.04
        ) then
            state.clear_chat_confirmation = true

            set_status(
                "Confirm clear chat.",
                "warning"
            )
        end
    else
        if colored_button(
            "Clear##ConfirmClear" .. suffix,
            1.0, 1.0, 1.0,
            0.78, 0.12, 0.08
        ) then
            local kept_history = {}
            local latest_sequence = 0

            for _,
                entry in ipairs(
                    state.history
                ) do

                if not state.history_entry_matches_active_chat(
                    entry
                ) then
                    kept_history[
                        #kept_history + 1
                    ] = entry

                    latest_sequence =
                        math.max(
                            latest_sequence,
                            tonumber(
                                entry.sequence
                            ) or 0
                        )
                end
            end

            state.history = kept_history
            state.total_message_count =
                #kept_history
            state.unread_message_count = 0
            state.unread_mention_count = 0
            state.history_search_text = ""
            state.latest_history_sequence =
                latest_sequence
            state.recent_message_fingerprints = {}
            state.recent_message_order = {}
            state.clear_chat_confirmation = false

            set_status(
                state.get_selected_chat_label() ..
                " history cleared.",
                "success"
            )
        end

        imgui.same_line()

        if colored_button(
            "Cancel##ClearChat" .. suffix,
            1.0, 1.0, 1.0,
            0.28, 0.28, 0.28
        ) then
            state.clear_chat_confirmation = false

            set_status(
                "Clear cancelled.",
                "info"
            )
        end
    end
end

local function get_color_preview(
    option
)
    if option
        and option.red
        and option.green
        and option.blue then

        return state.make_theme_readable_text_color(
            option.red,
            option.green,
            option.blue
        )
    end

    return 0.32,
        0.32,
        0.32
end

local function get_contrasting_text_color(
    red,
    green,
    blue
)
    local luminance =
        red * 0.299 +
        green * 0.587 +
        blue * 0.114

    if luminance >= 0.68 then
        return 0.0,
            0.0,
            0.0
    end

    return 1.0,
        1.0,
        1.0
end

local function draw_noninteractive_color_preview(
    label,
    width,
    text_r,
    text_g,
    text_b,
    button_r,
    button_g,
    button_b
)
    local pushed = 0

    local function try_push(
        index,
        red,
        green,
        blue
    )
        if type(imgui.push_style_color)
            ~= "function" then

            return
        end

        local success =
            pcall(
                imgui.push_style_color,
                index,
                red,
                green,
                blue,
                1.0
            )

        if success then
            pushed = pushed + 1
        end
    end

    try_push(0, text_r, text_g, text_b)
    try_push(21, button_r, button_g, button_b)
    try_push(22, button_r, button_g, button_b)
    try_push(23, button_r, button_g, button_b)

    pcall(
        imgui.button,
        label,
        tonumber(width) or 44,
        0
    )

    if pushed > 0
        and type(imgui.pop_style_color)
            == "function" then

        for _ = 1, pushed do
            pcall(imgui.pop_style_color)
        end
    end
end

local function draw_color_selector(
    label,
    options,
    config_key,
    id_suffix
)
    local current_index =
        normalize_color_option_index(
            config[config_key],
            options
        )

    local option_names = {}

    for _, option in ipairs(options) do
        option_names[#option_names + 1] =
            tostring(option.name)
    end

    local row_start_x =
        get_cursor_position_x()

    local row_width =
        get_exact_remaining_width()

    local label_text =
        tostring(label) .. ":"

    imgui.text(
        label_text
    )

    imgui.same_line()

    local controls_width =
        150 + 8 + 42

    local minimum_controls_x =
        row_start_x +
        get_text_width(label_text) +
        10

    local preferred_controls_x =
        row_start_x + 120

    local maximum_controls_x =
        row_start_x +
        math.max(
            0,
            row_width - controls_width
        )

    set_cursor_position_x(
        math.max(
            minimum_controls_x,
            math.min(
                preferred_controls_x,
                maximum_controls_x
            )
        )
    )

    imgui.push_item_width(150)

    local input_colors =
        state.push_input_theme()

    local changed,
        selected_zero_index =
            imgui.combo(
                "##ColorSelector" ..
                tostring(id_suffix or ""),
                current_index - 1,
                option_names
            )

    state.pop_input_theme(
        input_colors
    )

    imgui.pop_item_width()

    local selected_index =
        current_index

    if changed then
        selected_index =
            math.max(
                1,
                math.min(
                    #options,
                    math.floor(
                        tonumber(selected_zero_index) or 0
                    ) + 1
                )
            )
    end

    imgui.same_line()

    local option =
        options[selected_index]

    local preview_r,
        preview_g,
        preview_b =
            get_color_preview(option)

    local preview_text = "●"

    if not option.red then
        local palette =
            state.get_standalone_theme_palette()

        if palette then
            preview_r = palette.button[1]
            preview_g = palette.button[2]
            preview_b = palette.button[3]
        end

        preview_text = "A"
    end

    local text_r,
        text_g,
        text_b =
            get_contrasting_text_color(
                preview_r,
                preview_g,
                preview_b
            )

    draw_noninteractive_color_preview(
        preview_text ..
        "##ColorSwatch" ..
        tostring(id_suffix or ""),
        42,
        text_r,
        text_g,
        text_b,
        preview_r,
        preview_g,
        preview_b
    )

    if changed
        and selected_index ~= current_index then

        config[config_key] =
            selected_index

        local saved =
            save_preferences()

        if config_key ==
            "name_color_index" then

            ensure_local_compatible_user()
        end

        set_status(
            saved
            and (
                tostring(label) ..
                " set to " ..
                tostring(
                    options[selected_index].name
                ) ..
                "."
            )
            or (
                tostring(label) ..
                " changed, but settings could not be saved."
            ),
            saved
            and "success"
            or "error"
        )
    end
end

