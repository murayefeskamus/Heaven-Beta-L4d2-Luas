    state.handle_standalone_window_hotkey()

    if #state.outgoing_packets > 0 then
        state.process_outgoing_packets(false)
    end

    local now =
        os.clock()

    if now <
        (tonumber(state.next_background_update) or 0.0) then

        return
    end

    state.next_background_update =
        now + state.background_update_interval

    update_status_expiration()
    state.refresh_dst_style(false)
    state.cleanup_incoming_fragments()
    state.update_smart_alert()

    local current_input =
        tostring(config.input_text or "")

    if state.last_secret_scan_text ~= current_input then
        state.last_secret_scan_text =
            current_input

        state.secret_input_blocked =
            state.input_contains_session_secret(
                current_input
            )
    end

    state.maybe_announce_invite_identity()

    local session_active =
        update_compatible_session_state()

    if not session_active then
        return
    end

    if not state.roster_dirty
        and now - state.last_roster_check <
            COMPATIBLE_USER_REFRESH_INTERVAL then

        return
    end

    state.last_roster_check =
        now

    local active_userids =
        get_current_lobby_userid_set()

    refresh_compatible_users(
        false,
        false,
        active_userids
    )

    state.refresh_authorized_users(
        active_userids,
        false
    )

    state.roster_dirty = false
end

