local function get_window_content_right_screen_x()
    if type(imgui.get_window_pos)
        == "function" then

        local position_ok,
            position_first,
            position_second =
                pcall(
                    imgui.get_window_pos
                )

        if position_ok then
            local window_x =
                get_vector_x(
                    position_first,
                    position_second
                )

            local region_function =
                imgui.get_window_content_region_max
                or imgui.get_content_region_max

            if window_x
                and type(region_function)
                    == "function" then

                local region_ok,
                    region_first,
                    region_second =
                        pcall(
                            region_function
                        )

                if region_ok then
                    local region_max_x =
                        get_vector_x(
                            region_first,
                            region_second
                        )

                    if region_max_x then
                        return window_x +
                            region_max_x
                    end
                end
            end
        end
    end

    local cursor_screen_x =
        get_cursor_screen_x()

    if cursor_screen_x
        and type(imgui.get_content_region_avail)
            == "function" then

        local success,
            first,
            second =
                pcall(
                    imgui.get_content_region_avail
                )

        if success then
            local available_x =
                get_vector_x(
                    first,
                    second
                )

            if available_x then
                return cursor_screen_x +
                    available_x
            end
        end
    end

    return nil
end

local function get_exact_remaining_width()
    local cursor_screen_x =
        get_cursor_screen_x()

    local right_screen_x =
        get_window_content_right_screen_x()

    if cursor_screen_x
        and right_screen_x then

        return math.max(
            18.0,
            right_screen_x -
            cursor_screen_x -
            CHAT_WRAP_RIGHT_MARGIN
        )
    end

    if type(imgui.get_content_region_avail)
        == "function" then

        local success,
            first,
            second =
                pcall(
                    imgui.get_content_region_avail
                )

        if success then
            local width =
                get_vector_x(
                    first,
                    second
                )

            if width
                and width > 0 then

                return math.max(
                    18.0,
                    width -
                    CHAT_WRAP_RIGHT_MARGIN
                )
            end
        end
    end

    return 220.0
end

