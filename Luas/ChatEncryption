function config.encode_preference_text(
    value
)
    value = tostring(value or "")

    return (
        value:gsub(
            ".",
            function(character)
                return string.format(
                    "%02X",
                    string.byte(character)
                )
            end
        )
    )
end

function config.decode_preference_text(
    value
)
    value = tostring(value or "")

    if #value % 2 ~= 0
        or not value:match(
            "^[0-9A-Fa-f]*$"
        ) then

        return nil
    end

    return (
        value:gsub(
            "(%x%x)",
            function(pair)
                return string.char(
                    tonumber(pair, 16)
                )
            end
        )
    )
end

local function open_file_from_paths(
    paths,
    mode,
    remember_as_active
)
    if type(io) ~= "table"
        or type(io.open) ~= "function" then

        return nil
    end

    local attempted_paths = {}

    local function try_path(path)
        if not path
            or path == ""
            or attempted_paths[path] then

            return nil
        end

        attempted_paths[path] = true

        local open_ok,
            file =
                pcall(
                    io.open,
                    path,
                    mode
                )

        if open_ok
            and file then

            if remember_as_active then
                active_preferences_file_path =
                    path
            end

            return file
        end

        return nil
    end

    if remember_as_active then
        local active_file =
            try_path(
                active_preferences_file_path
            )

        if active_file then
            return active_file
        end
    end

    for _,
        path in ipairs(
            paths or {}
        ) do

        local file =
            try_path(
                path
            )

        if file then
            return file
        end
    end

    return nil
end

local function open_preferences_file(
