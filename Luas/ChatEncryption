function state.process_outgoing_packets(
    force
)
    if #state.outgoing_packets == 0 then
        return false
    end

    local now = os.clock()

    if not force
        and now < state.next_outgoing_send_time then

        return false
    end

    local packet =
        table.remove(
            state.outgoing_packets,
            1
        )

    if not packet then
        return false
    end

    local dedup_key =
        "S:" ..
        tostring(packet.message_id) ..
        ":" ..
        tostring(packet.part_index)

    remember_message_id(
        dedup_key
    )

    local sent,
        send_error =
            send_protocol_packet(
                "S",
                packet.message_id,
                packet.body,
                packet.team_chat,
                packet.part_index,
                packet.part_count,
                packet.key_material
            )

    if not sent then
        state.outgoing_packets = {}
        state.outgoing_send_context = nil

        local failure_text =
            send_error or
            "Split-message send failed."

        set_status(
            failure_text,
            "error"
        )

        state.record_insight(
            "DELIVERY",
            failure_text,
            "error"
        )

        state.notify_important(
            "error",
            failure_text,
            "split-send-failed",
            8.0
        )

        return false
    end

    state.next_outgoing_send_time =
        now + config.split_packet_send_interval

    if #state.outgoing_packets == 0 then
        local part_count =
            state.outgoing_send_context
            and state.outgoing_send_context.part_count
            or packet.part_count

        state.outgoing_send_context = nil

        set_status(
            "Encrypted sent (" ..
            tostring(part_count) ..
            " parts).",
            "success"
        )
    end

    return true
end

function state.cleanup_incoming_fragments()
    if next(
        state.incoming_fragments
    ) == nil then

        return
    end

    local now = os.clock()

    if now <
        (tonumber(state.next_fragment_cleanup) or 0.0) then

        return
    end

    state.next_fragment_cleanup =
        now +
        math.max(
            0.25,
            tonumber(state.fragment_cleanup_interval) or 1.0
        )

    for fragment_key,
        fragment in pairs(
            state.incoming_fragments
        ) do

        if now -
            (fragment.updated_at or now) >
            config.split_packet_timeout then

            state.incoming_fragments[
                fragment_key
            ] = nil

            state.insights.split_timeouts =
                state.insights.split_timeouts + 1

            state.notify_important(
                "warning",
                "An encrypted split message could not be completed.",
                "split-timeout",
                8.0
            )
        end
    end
end

function state.store_incoming_fragment(
    userid,
    message_id,
    team_chat,
    part_index,
    part_count,
    body,
    chat_scope,
    session_id
)
    local fragment_key =
        tostring(userid or "") ..
        "|" ..
        tostring(message_id or "") ..
        "|" ..
        (team_chat and "T" or "A") ..
        "|" ..
        tostring(chat_scope or "open") ..
        "|" ..
        tostring(session_id or "")

    local fragment =
        state.incoming_fragments[
            fragment_key
        ]

    if not fragment
        or fragment.part_count ~= part_count then

        fragment = {
            part_count = part_count,
            received_count = 0,
            parts = {},
            updated_at = os.clock()
        }

        state.incoming_fragments[
            fragment_key
        ] = fragment
    end

    if fragment.parts[part_index] == nil then
        fragment.parts[part_index] =
            tostring(body or "")

        fragment.received_count =
            fragment.received_count + 1
    end

    fragment.updated_at = os.clock()

    if fragment.received_count <
        fragment.part_count then

        return nil,
            fragment.received_count,
            fragment.part_count
    end

    local complete = {}

    for index = 1,
        fragment.part_count do

        if fragment.parts[index] == nil then
            return nil,
                fragment.received_count,
                fragment.part_count
        end

        complete[index] =
            fragment.parts[index]
    end

    state.incoming_fragments[
        fragment_key
    ] = nil

    return table.concat(complete),
        fragment.part_count,
        fragment.part_count
end

local function sanitize_normal_message(text)
    text =
        tostring(text or "")
            :gsub(
                "[\r\n]",
                " "
            )
            :gsub(
                '"',
                "'"
            )

    if #text > MAX_NORMAL_BYTES then
        text =
            text:sub(
                1,
                MAX_NORMAL_BYTES
            )
    end

    return text
end

