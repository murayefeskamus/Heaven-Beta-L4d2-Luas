-- =========================================================
-- UTF-8 CHARACTER HELPERS
-- =========================================================

function state.utf8_sequence_length(
    text,
    index
)
    text = tostring(text or "")
    index = math.max(1, tonumber(index) or 1)

    local first = text:byte(index)

    if not first then
        return 0
    end

    local expected = 1

    if first >= 0xC2 and first <= 0xDF then
        expected = 2
    elseif first >= 0xE0 and first <= 0xEF then
        expected = 3
    elseif first >= 0xF0 and first <= 0xF4 then
        expected = 4
    end

    if expected == 1
        or index + expected - 1 > #text then

        return 1
    end

    for offset = 1, expected - 1 do
        local continuation =
            text:byte(index + offset)

        if not continuation
            or continuation < 0x80
            or continuation > 0xBF then

            return 1
        end
    end

    return expected
end

function state.utf8_character_count(
    text
)
    text = tostring(text or "")

    local count = 0
    local index = 1

    while index <= #text do
        local length =
            state.utf8_sequence_length(
                text,
                index
            )

        if length <= 0 then
            break
        end

        count = count + 1
        index = index + length
    end

    return count
end

function state.split_utf8_by_bytes(
    text,
    maximum_bytes
)
    text = tostring(text or "")
    maximum_bytes =
        math.max(
            1,
            math.floor(
                tonumber(maximum_bytes) or 1
            )
        )

    local chunks = {}
    local current = {}
    local current_bytes = 0
    local index = 1

    while index <= #text do
        local length =
            state.utf8_sequence_length(
                text,
                index
            )

        if length <= 0 then
            break
        end

        local character =
            text:sub(
                index,
                index + length - 1
            )

        if current_bytes > 0
            and current_bytes + #character >
                maximum_bytes then

            chunks[#chunks + 1] =
                table.concat(current)

            current = {}
            current_bytes = 0
        end

        current[#current + 1] =
            character

        current_bytes =
            current_bytes + #character

        index = index + length
    end

    if #current > 0 then
        chunks[#chunks + 1] =
            table.concat(current)
    end

    if #chunks == 0 then
        chunks[1] = ""
    end

    return chunks
end

