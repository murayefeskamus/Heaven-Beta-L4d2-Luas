function state.cancel_standalone_window_key_capture()
    state.standalone_key_capture_active = false
    state.standalone_key_capture_waiting_release = false
end

function state.begin_standalone_window_key_capture()
    state.standalone_key_capture_active = true

    local now = os.clock()

    state.standalone_key_capture_started_at = now
    state.standalone_key_capture_ready_at = now + 0.08
    state.standalone_key_capture_waiting_release = true

    set_status(
        "Press a key. Esc cancels.",
        "info"
    )
end

function state.capture_standalone_window_key()
    if state.standalone_key_capture_active ~= true then
        return
    end

    if type(input) ~= "table"
        or type(input.is_key_pressed) ~= "function" then

        return
    end

    local now = os.clock()

    if now -
        (
            tonumber(
                state.standalone_key_capture_started_at
            ) or now
        ) >=
        math.max(
            2.0,
            tonumber(
                state.standalone_key_capture_timeout
            ) or 10.0
        ) then

        state.cancel_standalone_window_key_capture()

        set_status(
            "Key binding timed out.",
            "error"
        )

        return
    end

    if state.standalone_key_capture_waiting_release == true then
        if type(input.is_key_down) == "function" then
            local mouse_ok,
                mouse_down =
                    pcall(
                        input.is_key_down,
                        0x01
                    )

            if mouse_ok
                and mouse_down == true then

                return
            end
        end

        state.standalone_key_capture_waiting_release = false
        state.standalone_key_capture_ready_at = now + 0.04
        return
    end

    if now <
        (
            tonumber(
                state.standalone_key_capture_ready_at
            ) or 0.0
        ) then

        return
    end

    for _, key_value in ipairs(
        _G.__CHAT_ENCRYPTION_WINDOW_KEYS.bindable
    ) do
        local pressed_ok,
            pressed =
                pcall(
                    input.is_key_pressed,
                    key_value
                )

        if pressed_ok
            and pressed == true then

            if key_value == 0x1B then
                state.cancel_standalone_window_key_capture()

                set_status(
                    "Key binding cancelled.",
                    "info"
                )

                return
            end

            config.standalone_toggle_key =
                math.max(
                    1,
                    math.min(
                        255,
                        math.floor(
                            tonumber(key_value) or 0x75
                        )
                    )
                )

            state.last_window_toggle_tick =
                client.get_tick_count()

            state.cancel_standalone_window_key_capture()
            persist_preferences_after_change()

            set_status(
                "Standalone key: " ..
                _G.__CHAT_ENCRYPTION_WINDOW_KEYS.get_name(
                    config.standalone_toggle_key
                ),
                "success"
            )

            return
        end
    end
end

function state.handle_standalone_window_hotkey()
    if state.standalone_key_capture_active == true then
        return
    end

    if type(input) ~= "table"
        or type(input.is_key_pressed) ~= "function" then

        return
    end

    local toggle_key =
        math.max(
            1,
            math.min(
                255,
                math.floor(
                    tonumber(
                        config.standalone_toggle_key
                    ) or 0x75
                )
            )
        )

    if not input.is_key_pressed(
        toggle_key
    ) then

        return
    end

    local current_tick =
        client.get_tick_count()

    if state.last_window_toggle_tick ==
        current_tick then

        return
    end

    state.last_window_toggle_tick =
        current_tick

    config.show_floating_window =
        not config.show_floating_window

    set_status(
        config.show_floating_window
        and "Standalone window shown."
        or "Standalone window hidden.",
        "success"
    )
end


