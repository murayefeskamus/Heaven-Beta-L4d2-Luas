    )
end

local function parse_saved_boolean(value)
    value =
        tostring(value or "")
            :lower()
            :gsub(
                "^%s+",
                ""
            )
            :gsub(
                "%s+$",
                ""
            )

    if value == "1"
        or value == "true"
        or value == "yes"
        or value == "on" then

        return true
    end

    if value == "0"
        or value == "false"
        or value == "no"
        or value == "off" then

        return false
    end

    return nil
end

local function read_preferences_file(file)
    if not file then
        return false
    end

    local read_ok,
        contents =
            pcall(
                function()
                    return file:read("*a")
                end
            )

    pcall(
        function()
            file:close()
        end
    )

    if not read_ok
        or type(contents) ~= "string" then

        return false
    end

    local loaded_any_preference = false

    for line in contents:gmatch(
        "[^\r\n]+"
    ) do
        local key,
            value =
                line:match(
                    "^([%w_]+)%s*=%s*(.-)%s*$"
                )

        if key then
            local decimal_value =
                tonumber(value)

            local numeric_value =
                math.floor(
                    decimal_value or 0
                )

            if key == "name_color_index"
                and numeric_value >= 1
                and numeric_value <=
                    #NAME_COLOR_OPTIONS then

                config.name_color_index =
                    numeric_value

                loaded_any_preference =
                    true
            elseif key == "message_color_index"
                and numeric_value >= 1
                and numeric_value <=
                    #MESSAGE_COLOR_OPTIONS then

                config.message_color_index =
                    numeric_value

                loaded_any_preference =
                    true
            elseif key == "standalone_toggle_key"
                and numeric_value >= 1
                and numeric_value <= 255 then

                config.standalone_toggle_key =
                    numeric_value

                loaded_any_preference =
                    true
            elseif key == "standalone_window_opacity"
                and decimal_value ~= nil then

                config.standalone_window_opacity =
                    math.max(
                        0.0,
                        math.min(
                            1.0,
                            decimal_value
                        )
                    )

                loaded_any_preference =
                    true
            elseif key == "remembered_name_hex" then
                local decoded_name =
                    config.decode_preference_text(
                        value
                    )

                if decoded_name ~= nil then
                    config.remembered_name =
                        decoded_name
                            :gsub("[\r\n]", " ")

                    loaded_any_preference =
                        true
                end
            else
                local boolean_value =
                    parse_saved_boolean(
                        value
                    )

                if boolean_value ~= nil then
                    if key == "show_message_time" then
                        config.show_message_time =
                            boolean_value

                        loaded_any_preference =
                            true
                    elseif key ==
                        "show_timestamp_seconds" then

                        config.show_timestamp_seconds =
                            boolean_value

                        loaded_any_preference =
                            true
                    elseif key == "show_message_age" then
                        config.show_message_age =
                            boolean_value

                        loaded_any_preference =
                            true
                    elseif key == "show_chat_type" then
                        config.show_chat_type =
                            boolean_value

                        loaded_any_preference =
                            true
                    elseif key == "highlight_mentions" then
                        config.highlight_mentions =
                            boolean_value

                        loaded_any_preference =
                            true
                    elseif key ==
                        "enable_message_search" then

                        config.enable_message_search =
                            boolean_value

                        loaded_any_preference =
                            true
                    elseif key ==
                        "inherit_dst_style" then

                        config.inherit_dst_style =
                            boolean_value

                        loaded_any_preference =
                            true
                    elseif key ==
                        "smart_notifications" then

                        config.smart_notifications =
                            boolean_value

                        loaded_any_preference =
                            true
                    end
                end
            end
        end
    end

    return loaded_any_preference
end

local function load_saved_preferences()
    local preferences_file =
        open_preferences_file(
            "r"
        )

    if preferences_file then
        return read_preferences_file(
            preferences_file
        ),
            false
    end

    local previous_preferences_file =
        open_file_from_paths(
            PREVIOUS_PREFERENCES_FILE_PATHS,
            "r",
            false
        )

    if previous_preferences_file then
        return read_preferences_file(
            previous_preferences_file
        ),
            true
    end

    local legacy_file =
        open_file_from_paths(
            LEGACY_PREFERENCES_FILE_PATHS,
            "r",
            false
        )

    if legacy_file then
        return read_preferences_file(
            legacy_file
        ),
            true
    end

    return false,
        false
end

