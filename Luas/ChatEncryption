local function draw_responsive_inline_message(
    text,
    highlighted,
    message_color_index,
    first_line_width,
    continuation_width,
    continuation_x
)
    local remaining =
        tostring(text or "")

    local first_line = true

    first_line_width =
        math.max(
            18.0,
            tonumber(first_line_width)
                or 18.0
        )

    continuation_width =
        math.max(
            18.0,
            tonumber(continuation_width)
                or first_line_width
        )

    repeat
        if not first_line
            and continuation_x then

            set_cursor_position_x(
                continuation_x
