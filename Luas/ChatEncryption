state.invite_prime = 2147483647
state.invite_generator = 5

function state.invite_mod_multiply(
    first,
    second,
    modulus
)
    first =
        math.floor(
            tonumber(first) or 0
        ) % modulus

    second =
        math.floor(
            tonumber(second) or 0
        )

    local result = 0

    while second > 0 do
        if second % 2 == 1 then
            result =
                (result + first) %
                modulus
        end

        first =
            (first + first) %
            modulus

        second =
            math.floor(
                second / 2
            )
    end

    return result
end

function state.invite_mod_power(
    base,
    exponent,
    modulus
)
    base =
        math.floor(
            tonumber(base) or 0
        ) % modulus

    exponent =
        math.floor(
            tonumber(exponent) or 0
        )

    local result = 1

    while exponent > 0 do
        if exponent % 2 == 1 then
            result =
                state.invite_mod_multiply(
                    result,
                    base,
                    modulus
                )
        end

        base =
            state.invite_mod_multiply(
                base,
                base,
                modulus
            )

        exponent =
            math.floor(
                exponent / 2
            )
    end

    return result
end

