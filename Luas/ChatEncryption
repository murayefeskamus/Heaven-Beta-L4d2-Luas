local function get_sorted_compatible_user_entries()
    local entries = {}
    local secured =
        state.is_selected_private_session_active()

    local users =
        secured
        and state.auth_session.authorized_users
        or state.compatible_users

    local colors =
        secured
        and state.auth_session.authorized_name_colors
        or state.compatible_user_name_colors

    local roles =
        secured
        and state.auth_session.authorized_roles
        or {}

    for key, name in pairs(users or {}) do
        entries[#entries + 1] = {
            key = tostring(key),
            name = tostring(name),
            role = tostring(roles[key] or "member"),
            is_local = tostring(key) == "__local_user",
            color_index =
                normalize_color_option_index(
                    colors[key] or 1,
                    NAME_COLOR_OPTIONS
                )
        }
    end

    table.sort(
        entries,
        function(first, second)
            if first.role ~= second.role then
                return first.role == "host"
            end

            if first.is_local ~= second.is_local then
                return first.is_local
            end

            local first_name = first.name:lower()
            local second_name = second.name:lower()

            if first_name == second_name then
                return first.key < second.key
            end

            return first_name < second_name
        end
    )

    return entries
end

local CHAT_WRAP_RIGHT_MARGIN = 12.0
local CHAT_WRAP_INLINE_SAFETY = 10.0
local CHAT_WRAP_MIN_INLINE_WIDTH = 70.0
local CHAT_WRAP_WORD_BREAK_MIN_FILL = 0.72

local function get_vector_x(
    first,
    second
)
    if type(first) == "number" then
        return first
    end

    if type(second) == "number" then
        return second
    end

    if type(first) == "table" then
        return tonumber(
            first.x or
            first.X or
            first[1]
        )
    end

    local success,
        value =
            pcall(
                function()
                    return first.x
                end
            )

    if success then
        return tonumber(value)
    end

    return nil
end

local function count_utf8_characters(text)
    text =
        tostring(text or "")

    local count = 0
    local index = 1
    local length = #text

    while index <= length do
        local first_byte =
            text:byte(index)

        local character_length = 1

        if first_byte
            and first_byte >= 0xF0 then

            character_length = 4
        elseif first_byte
            and first_byte >= 0xE0 then

            character_length = 3
        elseif first_byte
            and first_byte >= 0xC0 then

            character_length = 2
        end

        index =
            index +
            character_length

        count =
            count + 1
    end

    return count
end

local function get_text_width(text)
    text =
        tostring(text or "")

    local measured_width = nil

    if type(draw) == "table"
        and type(draw.get_text_width)
            == "function"
        and type(fonts) == "table"
        and fonts.MENU_TAHOMA then

        local success,
            width =
                pcall(
                    draw.get_text_width,
                    fonts.MENU_TAHOMA,
                    text
                )

        if success
            and type(width) == "number"
            and width >= 0 then

            measured_width =
                width
        end
    end

    local average_character_width =
        6.0

    if type(draw) == "table"
        and type(draw.get_font_height)
            == "function"
        and type(fonts) == "table"
        and fonts.MENU_TAHOMA then

        local success,
            font_height =
                pcall(
                    draw.get_font_height,
                    fonts.MENU_TAHOMA
                )

        if success
            and type(font_height) == "number"
            and font_height > 0 then

            average_character_width =
                font_height * 0.52
        end
    end

    local estimated_width =
        count_utf8_characters(
            text
        ) *
        average_character_width

    if measured_width then
        return math.max(
            measured_width,
            estimated_width
        )
    end

    return estimated_width
end

