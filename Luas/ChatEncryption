local function get_history_timestamp(
    sent_time
)
    if type(os) == "table"
        and type(os.date) == "function" then

        local format =
            config.show_timestamp_seconds
            and "%H:%M:%S"
            or "%H:%M"

        local success,
            timestamp =
                pcall(
                    os.date,
                    format,
                    tonumber(sent_time)
                )

        if not success then
            success,
                timestamp =
                    pcall(
                        os.date,
