        end

        local available_width =
            first_line
            and first_line_width
            or continuation_width

        local line

        line,
        remaining =
            take_line_for_width(
                remaining,
                available_width
            )

        draw_message_line(
            line,
            highlighted,
            message_color_index
        )

        first_line = false
    until remaining == ""
end

