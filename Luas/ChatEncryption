function on_game_event(
    event_name,
    event
)
    if event_name == "player_connect"
        or event_name == "player_disconnect"
        or event_name == "player_changename"
        or event_name == "player_team"
        or event_name == "player_bot_replace"
        or event_name == "bot_player_replace"
        or event_name == "round_start" then

        state.roster_dirty = true
        state.next_session_state_check = 0.0

        if event_name ~= "player_say" then
            return
        end
    end

    if event_name ~= "player_say"
        or not event
        or not config.enabled then

        return
    end

    local text_ok,
        chat_text =
            pcall(
                function()
                    return event:get_string(
                        "text"
                    )
                end
            )

    if not text_ok
        or not chat_text then

        return
    end

    chat_text =
        tostring(chat_text)

    if #chat_text >
        MAX_ENCRYPTED_CHAT_BYTES then

        return
    end

    if not state.get_matching_chat_prefix(
        chat_text
    ) then
        return
    end

    local userid_ok,
        userid =
            pcall(
                function()
                    return event:get_int(
                        "userid"
                    )
                end
            )

    if not userid_ok then
        return
    end

    local from_local_player =
        is_local_userid(
            userid
        )

    local sender =
        from_local_player
        and get_initial_local_player_name()
        or get_initial_sender_name(
            userid
        )

    local prefix,
        targeted_name_color =
            state.get_matching_chat_prefix(
                chat_text
            )

    if state.parse_targeted_invite_chat(
        chat_text
    ) then
        state.handle_targeted_invite_packet(
            userid,
            sender,
            chat_text,
            targeted_name_color,
            from_local_player
        )

        return
    end

    local decrypt_ok = true
    local plaintext = nil
    local decrypt_error = nil
    local name_color_index = nil
    local message_color_index = nil
    local message_scope = "open"
    local message_session_name = "Open Chat"
    local message_session_id = ""

    if state.auth_session.active
        and type(
            state.auth_session.key_material
        ) == "string" then

        local private_ok,
            private_plaintext,
            private_error,
            private_name_color,
            private_message_color =
                pcall(
                    decrypt_message,
                    chat_text,
                    state.auth_session.key_material
                )

        if private_ok
            and private_plaintext then

            plaintext = private_plaintext
            decrypt_error = private_error
            name_color_index =
                private_name_color
            message_color_index =
                private_message_color
            message_scope = "private"
            message_session_name =
                tostring(
                    state.auth_session.session_name
                )
            message_session_id =
                tostring(
                    state.auth_session.fingerprint
                )
        else
            local open_ok,
                open_plaintext,
                open_error,
                open_name_color,
                open_message_color =
                    pcall(
                        decrypt_message,
                        chat_text,
                        KEY_MATERIAL
                    )

            decrypt_ok = open_ok
            plaintext = open_plaintext
            decrypt_error = open_error
            name_color_index =
                open_name_color
            message_color_index =
                open_message_color
        end
    else
        local open_ok,
            open_plaintext,
            open_error,
            open_name_color,
            open_message_color =
                pcall(
                    decrypt_message,
                    chat_text,
                    KEY_MATERIAL
                )

        decrypt_ok = open_ok
        plaintext = open_plaintext
        decrypt_error = open_error
        name_color_index =
            open_name_color
        message_color_index =
            open_message_color
    end

    if not decrypt_ok then
        set_status(
            "Decrypt error.",
            "error"
        )

        return
    end

    if not plaintext then
        state.insights.decrypt_failures =
            state.insights.decrypt_failures + 1

        -- Another group may be using a different private session in the
        -- same lobby. Ignore traffic that does not match this user's active
        -- session instead of treating normal concurrent sessions as errors.
        return
    end

    local packet_type,
        message_id,
        body,
        team_chat,
        part_index,
        part_count =
            parse_protocol_packet(
                plaintext
            )

    if not packet_type
        or not message_id then

        return
    end

    state.insights.packets_received =
        state.insights.packets_received + 1

    if not from_local_player then
        mark_compatible_user(
            userid,
            sender,
            name_color_index
        )
    else
        ensure_local_compatible_user()
    end

    if packet_type == "P" then
        if message_scope ~= "open" then
            return
        end

        if not from_local_player then
            state.handle_invite_identity_packet(
                userid,
                sender,
                body,
                name_color_index
            )
        end

        return
    end

    if packet_type == "H" then
        if message_scope ~= "private" then
            return
        end

        if not from_local_player then
            state.handle_auth_control_packet(
                userid,
                sender,
                body,
                name_color_index
            )
        end

        return
    end

    if message_scope == "private"
        and state.auth_session.active then

        state.mark_authorized_user(
            from_local_player and "__local_user" or userid,
            sender,
            from_local_player and state.auth_session.role or "member",
            name_color_index,
            from_local_player
        )
    end

    local completed_body = nil
    local dedup_key = nil

    if packet_type == "M" then
        dedup_key =
            (
                message_scope == "private"
                and (
                    "P:" ..
                    tostring(
                        message_session_id
                    ) ..
                    ":"
                )
                or "O:"
            ) ..
            (
                from_local_player
                and tostring(message_id)
                or (
                    tostring(userid) ..
                    ":M:" ..
                    tostring(message_id)
                )
            )

        if remember_message_id(
            dedup_key
        ) then
            completed_body = body
        end
    elseif packet_type == "S"
        and part_index
        and part_count then

        dedup_key =
            (
                message_scope == "private"
                and (
                    "P:" ..
                    tostring(
                        message_session_id
                    ) ..
                    ":"
                )
                or "O:"
            ) ..
            (
                from_local_player
                and (
                    "S:" ..
                    tostring(message_id) ..
                    ":" ..
                    tostring(part_index)
                )
                or (
                    tostring(userid) ..
                    ":S:" ..
                    tostring(message_id) ..
                    ":" ..
                    tostring(part_index)
                )
            )

        if remember_message_id(
            dedup_key
        ) then
            completed_body =
                state.store_incoming_fragment(
                    userid,
                    message_id,
                    team_chat,
                    part_index,
                    part_count,
                    body,
                    message_scope,
                    message_session_id
                )
        end
    end

    if completed_body == nil then
        return
    end

    local is_mention =
        not from_local_player
        and is_local_player_mentioned(
            completed_body
        )

    local added_message =
        add_history_message(
            sender,
            completed_body,
            team_chat,
            is_mention,
            name_color_index,
            message_color_index,
            message_scope,
            message_session_name,
            message_session_id
        )

    if added_message
        and not from_local_player then

        state.insights.messages_received =
            state.insights.messages_received + 1

        state.unread_message_count =
            state.unread_message_count + 1

        if is_mention
            and config.highlight_mentions then

            state.unread_mention_count =
                state.unread_mention_count + 1

            state.notify_important(
                "mention",
                sender ..
                " mentioned you.",
                "mention:" ..
                tostring(message_id),
                9.0
            )
        end
    end

    set_status(
        "Received from " ..
        sender ..
        ".",
        "success"
    )

end

