if client.get_shared_bool("XQD7_PL9", nil) == nil then
    client.set_shared_bool("XQD7_PL9", false)
end

function on_create_move_prediction(cmd, local_player)
    if not cmd or not local_player then
        return
    end

    if not local_player:is_alive() then
        return
    end

    local OPK1 = 4
    local ZJDA = cmd:get_buttons()

    if client.get_shared_bool("XQD7_PL9", false) then
        ZJDA = ZJDA | OPK1
        cmd:set_buttons(ZJDA)
    end
end

menu.add_main_tab("Movement Utilities", function()
    imgui.text("Movement Utilities")
    imgui.separator()

    local changed, val = imgui.checkbox("Always Duck", client.get_shared_bool("XQD7_PL9", false))
    if changed then 
        client.set_shared_bool("XQD7_PL9", val) 
    end

    imgui.separator()
    imgui["end"]()
end)
