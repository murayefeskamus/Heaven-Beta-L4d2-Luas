function name_stealer.get_saved_names_gui_cache()
    if type(name_stealer.saved_names_gui_cache) ~= "table" then
        name_stealer.saved_names_gui_cache = {}
    end

    local cache = name_stealer.saved_names_gui_cache

    cache.filtered_names =
        type(cache.filtered_names) == "table"
        and cache.filtered_names
        or {}

    cache.lobby_lookup =
        type(cache.lobby_lookup) == "table"
        and cache.lobby_lookup
        or {}

    cache.row_data =
        type(cache.row_data) == "table"
        and cache.row_data
        or {}

    return cache
end

function name_stealer.invalidate_saved_names_gui_cache()
    name_stealer.saved_names_gui_revision =
        math.max(
            0,
            math.floor(
                tonumber(
                    name_stealer.saved_names_gui_revision
                ) or 0
            )
        ) + 1

    local cache =
        name_stealer.get_saved_names_gui_cache()

    cache.filtered_signature = ""
    cache.filtered_names = {}
    cache.lobby_lookup_signature = ""
    cache.lobby_lookup = {}
    cache.row_data = {}
    cache.unknown_dates_signature = ""
    cache.unknown_dates = 0

    name_stealer.saved_name_date_cache = {}
end

function name_stealer.get_saved_names_lobby_lookup()
    local lobby_matches = {}

    if type(ui.network) == "table"
        and type(
            ui.network.get_stolen_lobby_name_matches
        ) == "function" then

        local matches_ok,
            matches_value =
                pcall(
                    ui.network.get_stolen_lobby_name_matches
                )

        if matches_ok
            and type(matches_value) == "table" then

            lobby_matches = matches_value
        end
    end

    local cache =
        name_stealer.get_saved_names_gui_cache()

    local lookup_signature =
        tostring(
            type(ui.network) == "table"
            and ui.network.stolen_lobby_name_cache_key
            or ""
        ) .. ":" ..
        tostring(#lobby_matches)

    if cache.lobby_lookup_signature ==
        lookup_signature
        and type(cache.lobby_lookup) == "table" then

        return cache.lobby_lookup,
            lookup_signature
    end

    local lookup = {}

    for _, lobby_name in ipairs(
        lobby_matches
    ) do
        local normalized_key =
            normalize_candidate_name_for_filter(
                lobby_name
            )

        if normalized_key ~= "" then
            lookup[normalized_key] = true
        end
    end

    cache.lobby_lookup_signature =
        lookup_signature

    cache.lobby_lookup = lookup

    return lookup,
        lookup_signature
end

function name_stealer.get_saved_name_gui_row_data(
    saved_name
)
    saved_name = tostring(saved_name or "")

    local normalized_key =
        normalize_candidate_name_for_filter(
            saved_name
        )

    local metadata =
        get_saved_name_metadata(
            saved_name
        )

    local saved_at =
        math.max(
            0,
            math.floor(
                tonumber(metadata.saved_at) or 0
            )
        )

    local source =
        tostring(
            metadata.source or "Legacy"
        )

    local cache_key =
        normalized_key ~= ""
        and normalized_key
        or saved_name

    local row_signature =
        saved_name .. "\31" ..
        tostring(saved_at) .. "\31" ..
        source

    local cache =
        name_stealer.get_saved_names_gui_cache()

    local cached_row =
        cache.row_data[cache_key]

    if type(cached_row) == "table"
        and cached_row.signature ==
            row_signature then

        return cached_row
    end

    local row_data = {
        signature = row_signature,
        name = saved_name,
        lower_name = saved_name:lower(),
        normalized_key = normalized_key,
        saved_at = saved_at,
        date_text = format_saved_name_date(saved_at),
        source = source,
        source_lower = source:lower()
    }

    cache.row_data[cache_key] = row_data

    return row_data
end

function name_stealer.get_unknown_saved_name_date_count()
    local cache =
        name_stealer.get_saved_names_gui_cache()

    local signature =
        tostring(
            name_stealer.saved_names_gui_revision
            or 0
        ) .. ":" ..
        tostring(
            #(
                type(name_stealer.saved_names) == "table"
                and name_stealer.saved_names
                or {}
            )
        )

    if cache.unknown_dates_signature ==
        signature then

        return math.max(
            0,
            math.floor(
                tonumber(cache.unknown_dates) or 0
            )
        )
    end

    local unknown_dates = 0

    for _, saved_name in ipairs(
        name_stealer.saved_names or {}
    ) do
        local row_data =
            name_stealer.get_saved_name_gui_row_data(
                saved_name
            )

        if row_data.saved_at <= 0 then
            unknown_dates = unknown_dates + 1
        end
    end

    cache.unknown_dates_signature = signature
    cache.unknown_dates = unknown_dates

    return unknown_dates
end

function sort_saved_names_for_gui(
    names
)
    table.sort(
        names,
        function(a, b)
            local a_text =
                tostring(a or "")

            local b_text =
                tostring(b or "")

            local a_lower =
                a_text:lower()

            local b_lower =
                b_text:lower()

            if a_lower == b_lower then
                return a_text < b_text
            end

            return a_lower < b_lower
        end
    )

    return names
end

function get_filtered_saved_names()
    local filter_text =
        tostring(
            name_stealer.saved_name_filter
            or ""
        )

    filter_text =
        filter_text:gsub(
            "^%s+",
            ""
        ):gsub(
            "%s+$",
            ""
        )

    local scope =
        math.max(
            0,
            math.min(
                8,
                math.floor(
                    tonumber(
                        name_stealer.saved_name_scope
                    ) or 0
                )
            )
        )

    name_stealer.saved_name_scope = scope

    local lobby_match_lookup = {}
    local lobby_signature = "not-needed"

    if scope == 1
        or scope == 2 then

        lobby_match_lookup,
            lobby_signature =
                name_stealer.get_saved_names_lobby_lookup()
    end

    local today_key = ""

    if scope == 8
        and type(os) == "table"
        and type(os.date) == "function" then

        local today_ok,
            today_value =
                pcall(
                    os.date,
                    "%Y-%m-%d"
                )

        if today_ok then
            today_key =
                tostring(
                    today_value or ""
                )
        end
    end

    local cache =
        name_stealer.get_saved_names_gui_cache()

    local filter_signature =
        tostring(
            name_stealer.saved_names_gui_revision
            or 0
        ) .. "\31" ..
        filter_text .. "\31" ..
        tostring(scope) .. "\31" ..
        lobby_signature .. "\31" ..
        today_key

    if cache.filtered_signature ==
        filter_signature
        and type(cache.filtered_names) == "table" then

        return cache.filtered_names
    end

    local lowered_filter =
        filter_text:lower()

    local displayed_names = {}

    for _, saved_name in ipairs(
        name_stealer.saved_names or {}
    ) do
        local row_data =
            name_stealer.get_saved_name_gui_row_data(
                saved_name
            )

        local in_lobby =
            lobby_match_lookup[
                row_data.normalized_key
            ] == true

        local saved_today = false

        if scope == 8
            and row_data.saved_at > 0
            and today_key ~= ""
            and type(os) == "table"
            and type(os.date) == "function" then

            local date_ok,
                saved_date =
                    pcall(
                        os.date,
                        "%Y-%m-%d",
                        row_data.saved_at
                    )

            saved_today =
                date_ok
                and tostring(
                    saved_date or ""
                ) == today_key
        end

        local scope_matches =
            scope == 0
            or (scope == 1 and in_lobby)
            or (scope == 2 and not in_lobby)
            or (
                scope == 3
                and row_data.source_lower == "manual"
            )
            or (
                scope == 4
                and row_data.source_lower == "automatic"
            )
            or (
                scope == 5
                and row_data.source_lower == "legacy"
            )
            or (
                scope == 6
                and row_data.saved_at > 0
            )
            or (
                scope == 7
                and row_data.saved_at <= 0
            )
            or (
                scope == 8
                and saved_today
            )

        local text_matches =
            lowered_filter == ""
            or row_data.lower_name:find(
                lowered_filter,
                1,
                true
            ) ~= nil

        if scope_matches
            and text_matches then

            displayed_names[
                #displayed_names + 1
            ] = saved_name
        end
    end

    sort_saved_names_for_gui(
        displayed_names
    )

    cache.filtered_signature =
        filter_signature

    cache.filtered_names =
        displayed_names

    return displayed_names
end


function ui.draw_saved_names_library_table(
    saved_names,
    selected_index
)
    saved_names =
        type(saved_names) == "table"
        and saved_names
        or {}

    selected_index =
        math.max(
            0,
            math.min(
                math.max(
                    0,
                    #saved_names - 1
                ),
                math.floor(
                    tonumber(selected_index) or 0
                )
            )
        )

    local columns = {
        { offset = 0,   width = 34,  label = "#" },
        { offset = 34,  width = 224, label = "NAME" },
        { offset = 258, width = 148, label = "DATE" },
        { offset = 406, width = 92,  label = "METHOD" },
        { offset = 498, width = 74,  label = "LOBBY" }
    }

    local table_width = 572
    local row_height = 21

    local table_height =
        math.max(
            54,
            math.min(
                236,
                31 +
                #saved_names * row_height
            )
        )

    local lobby_match_lookup =
        name_stealer.get_saved_names_lobby_lookup()

    local table_open =
        imgui.begin_child(
            "DarkSideSavedNamesTable",
            table_width + 8,
            table_height,
            true,
            0
        )

    if table_open then
        local start_x =
            ui.lobby.get_cursor_x()

        local function draw_cell(
            column_index,
            value,
            r,
            g,
            b,
            first_item
        )
            local column =
                columns[column_index]

            ui.lobby.draw_table_text(
                start_x,
                column.offset,
                column.width,
                tostring(value or ""),
                r or 1.0,
                g or 1.0,
                b or 1.0,
                first_item == true
            )

            local next_column =
                columns[column_index + 1]

            if next_column then
                imgui.same_line()

                ui.lobby.set_cursor_x(
                    start_x +
                    next_column.offset -
                    3
                )

                theme_text_colored(
                    0.42, 0.42, 0.44, 1.0,
                    "|"
                )
            end
        end

        local header_r,
            header_g,
            header_b =
                ui.get_theme_table_header_color()

        for column_index, column in ipairs(
            columns
        ) do
            draw_cell(
                column_index,
                column.label,
                header_r,
                header_g,
                header_b,
                column_index == 1
            )
        end

        imgui.separator()

        if #saved_names == 0 then
            imgui.text(
                "No saved names match the current view."
            )
        else
            local rows_start_y =
                ui.lobby.get_cursor_y()

            local first_index = 1
            local last_index = #saved_names
            local virtualized = false

            if #saved_names > 12
                and type(imgui.get_scroll_y) == "function"
                and type(imgui.set_cursor_pos_y) == "function" then

                local scroll_ok,
                    scroll_y =
                        pcall(
                            imgui.get_scroll_y
                        )

                if scroll_ok
                    and type(scroll_y) == "number" then

                    local visible_height =
                        math.max(
                            row_height,
                            table_height - 31
                        )

                    first_index =
                        math.max(
                            1,
                            math.floor(
                                math.max(
                                    0,
                                    scroll_y -
                                    rows_start_y
                                ) /
                                row_height
                            ) - 1
                        )

                    last_index =
                        math.min(
                            #saved_names,
                            first_index +
                            math.ceil(
                                visible_height /
                                row_height
                            ) + 3
                        )

                    virtualized =
                        first_index > 1
                        or last_index <
                            #saved_names

                    if virtualized then
                        ui.lobby.set_cursor_y(
                            rows_start_y +
                            (first_index - 1) *
                            row_height
                        )
                    end
                end
            end

            local row_palette =
                ui.enhancements.theme_palette()

            local row_accent =
                type(row_palette.accent) == "table"
                and row_palette.accent
                or {
                    0.20,
                    0.85,
                    1.00,
                    1.0
                }

            local accent_r =
                math.max(
                    0.0,
                    math.min(
                        1.0,
                        tonumber(row_accent[1]) or 0.20
                    )
                )

            local accent_g =
                math.max(
                    0.0,
                    math.min(
                        1.0,
                        tonumber(row_accent[2]) or 0.85
                    )
                )

            local accent_b =
                math.max(
                    0.0,
                    math.min(
                        1.0,
                        tonumber(row_accent[3]) or 1.00
                    )
                )

            local accent_luminance =
                accent_r * 0.2126 +
                accent_g * 0.7152 +
                accent_b * 0.0722

            local selected_text_r =
                accent_luminance >= 0.58
                and 0.04
                or 1.00

            local selected_text_g =
                accent_luminance >= 0.58
                and 0.04
                or 1.00

            local selected_text_b =
                accent_luminance >= 0.58
                and 0.05
                or 1.00

            local function push_style_color_safe(
                color_index,
                r,
                g,
                b,
                a
            )
                if type(imgui.push_style_color) ~= "function" then
                    return 0
                end

                local pushed_ok =
                    pcall(
                        imgui.push_style_color,
                        color_index,
                        r, g, b, a
                    )

                return pushed_ok
                    and 1
                    or 0
            end

            for index = first_index,
                last_index do

                local saved_name =
                    saved_names[index]

                local row_x =
                    ui.lobby.get_cursor_x()

                local row_y =
                    ui.lobby.get_cursor_y()

                local selected =
                    index ==
                    selected_index + 1

                local row_data =
                    name_stealer.get_saved_name_gui_row_data(
                        saved_name
                    )

                local in_lobby =
                    lobby_match_lookup[
                        row_data.normalized_key
                    ] == true

                local pushed = 0

                pushed = pushed +
                    push_style_color_safe(
                        0,
                        1.0, 1.0, 1.0, 0.0
                    )

                if selected then
                    pushed = pushed +
                        push_style_color_safe(
                            21,
                            accent_r,
                            accent_g,
                            accent_b,
                            0.94
                        )

                    pushed = pushed +
                        push_style_color_safe(
                            22,
                            math.min(
                                1.0,
                                accent_r * 1.08 + 0.04
                            ),
                            math.min(
                                1.0,
                                accent_g * 1.08 + 0.04
                            ),
                            math.min(
                                1.0,
                                accent_b * 1.08 + 0.04
                            ),
                            0.98
                        )

                    pushed = pushed +
                        push_style_color_safe(
                            23,
                            accent_r * 0.82,
                            accent_g * 0.82,
                            accent_b * 0.82,
                            0.98
                        )
                else
                    pushed = pushed +
                        push_style_color_safe(
                            21,
                            0.0, 0.0, 0.0, 0.0
                        )

                    pushed = pushed +
                        push_style_color_safe(
                            22,
                            0.20, 0.20, 0.24, 0.75
                        )

                    pushed = pushed +
                        push_style_color_safe(
                            23,
                            0.16, 0.16, 0.20, 0.75
                        )
                end

                local clicked =
                    ui.heaven_configs.draw_sized_button(
                        "##SavedNameTableRow_" ..
                        tostring(index),
                        table_width - 4
                    )

                if pushed > 0
                    and type(imgui.pop_style_color) == "function" then

                    for _ = 1, pushed do
                        pcall(imgui.pop_style_color)
                    end
                end

                if clicked then
                    selected_index =
                        index - 1

                    selected = true
                end

                ui.lobby.set_cursor_x(
                    row_x
                )

                ui.lobby.set_cursor_y(
                    row_y
                )

                draw_cell(
                    1,
                    tostring(index),
                    selected
                        and selected_text_r
                        or 1.0,
                    selected
                        and selected_text_g
                        or 1.0,
                    selected
                        and selected_text_b
                        or 1.0,
                    true
                )

                draw_cell(
                    2,
                    truncate_preview(
                        row_data.name,
                        31
                    ),
                    selected
                        and selected_text_r
                        or 1.0,
                    selected
                        and selected_text_g
                        or 1.0,
                    selected
                        and selected_text_b
                        or 1.0,
                    false
                )

                draw_cell(
                    3,
                    row_data.date_text,
                    selected
                        and selected_text_r
                        or (
                            row_data.saved_at > 0
                            and 0.82
                            or 0.65
                        ),
                    selected
                        and selected_text_g
                        or (
                            row_data.saved_at > 0
                            and 0.90
                            or 0.65
                        ),
                    selected
                        and selected_text_b
                        or (
                            row_data.saved_at > 0
                            and 1.00
                            or 0.65
                        ),
                    false
                )

                draw_cell(
                    4,
                    row_data.source,
                    selected
                        and selected_text_r
                        or (
                            row_data.source == "Automatic"
                            and 0.35
                            or 0.90
                        ),
                    selected
                        and selected_text_g
                        or (
                            row_data.source == "Automatic"
                            and 1.00
                            or 0.90
                        ),
                    selected
                        and selected_text_b
                        or (
