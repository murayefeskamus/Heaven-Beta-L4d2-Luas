function ui.control.get_aim_v2_smart_context(
    local_player,
    settings
)
    local neutral = {
        class_id = 0,
        class_name = "Neutral",
        profile_name = "Off",
        fov_multiplier = 1.0,
        distance_multiplier = 1.0,
        smoothing_multiplier = 1.0,
        prediction_multiplier = 1.0
    }

    if not settings
        or settings.smart_response ~= true then

        return neutral
    end

    local class_id =
        ui.control.get_local_infected_class(
            local_player
        )

    local profiles = {
        [1] = { "Smoker", 0.92, 1.08, 1.08, 1.12 },
        [2] = { "Boomer", 1.06, 0.74, 0.90, 0.84 },
        [3] = { "Hunter", 1.12, 0.80, 0.82, 0.90 },
        [4] = { "Spitter", 0.96, 1.06, 1.04, 1.08 },
        [5] = { "Jockey", 1.14, 0.74, 0.80, 0.88 },
        [6] = { "Charger", 1.15, 0.78, 0.78, 0.84 },
        [8] = { "Tank", 1.00, 0.92, 0.95, 0.92 }
    }

    local profile =
        settings.class_aware_tuning == true
        and profiles[class_id]
        or nil

    if not profile then
        profile = { "Neutral", 1.0, 1.0, 1.0, 1.0 }
    end

    local strength =
        ui.control.clamp(
            settings.smart_response_strength,
            0.0,
            1.0
        )

    local function blend(multiplier)
        return 1.0 +
            ((tonumber(multiplier) or 1.0) - 1.0) *
            strength
    end

    return {
        class_id = class_id,
        class_name = tostring(profile[1] or "Neutral"),
        profile_name = strength >= 0.78 and "Aggressive"
            or (strength >= 0.42 and "Balanced" or "Precision"),
        fov_multiplier = blend(profile[2]),
        distance_multiplier = blend(profile[3]),
        smoothing_multiplier = blend(profile[4]),
        prediction_multiplier = blend(profile[5])
    }
end

function ui.control.get_aim_v2_range_response(
    settings,
    distance,
    maximum_distance
)
    if not settings
        or settings.smart_response ~= true
        or settings.range_adaptation ~= true then

        return 1.0,
            1.0
    end

    local ratio =
        ui.control.clamp(
            (tonumber(distance) or 0.0) /
            math.max(
                tonumber(maximum_distance) or 1.0,
                1.0
            ),
            0.0,
            1.0
        )

    local strength =
        ui.control.clamp(
            settings.smart_response_strength,
            0.0,
            1.0
        )

    local centered = (ratio - 0.40) / 0.60
    local smoothing =
        1.0 +
        ui.control.clamp(centered, -0.40, 0.55) *
        0.30 * strength

    local prediction =
        1.0 +
        ui.control.clamp(centered, -0.45, 0.65) *
        0.26 * strength

    return ui.control.clamp(smoothing, 0.78, 1.20),
        ui.control.clamp(prediction, 0.78, 1.22)
end

function ui.control.filter_prediction_velocity(
    player,
    raw_velocity,
    settings
)
    if not raw_velocity
        or settings.prediction_stabilizer ~= true then

        return raw_velocity,
            1.0
    end

    local player_index =
        tonumber(
            ui.lobby.call_method(
                player,
                "get_index"
            )
        ) or 0

    if player_index <= 0 then
        return raw_velocity,
            1.0
    end

    ui.control.runtime.prediction_velocity_cache =
        type(ui.control.runtime.prediction_velocity_cache) == "table"
        and ui.control.runtime.prediction_velocity_cache
        or {}

    local cache =
        ui.control.runtime.prediction_velocity_cache[
            player_index
        ]

    if type(cache) ~= "table" then
        cache = {
            x = tonumber(raw_velocity.x) or 0.0,
            y = tonumber(raw_velocity.y) or 0.0,
            z = tonumber(raw_velocity.z) or 0.0,
            updated_at = get_time()
        }

        ui.control.runtime.prediction_velocity_cache[
            player_index
        ] = cache

        return vector.new(
            cache.x,
            cache.y,
            cache.z
        ),
            1.0
    end

    local raw_x = tonumber(raw_velocity.x) or 0.0
    local raw_y = tonumber(raw_velocity.y) or 0.0
    local raw_z = tonumber(raw_velocity.z) or 0.0

    local delta_x = raw_x - (tonumber(cache.x) or 0.0)
    local delta_y = raw_y - (tonumber(cache.y) or 0.0)
    local delta_z = raw_z - (tonumber(cache.z) or 0.0)

    local delta_magnitude =
        math.sqrt(
            delta_x * delta_x +
            delta_y * delta_y +
            delta_z * delta_z
        )

    local spike_limit =
        ui.control.clamp(
            settings.prediction_spike_limit,
            80.0,
            1200.0
        )

    local confidence = 1.0

    if delta_magnitude > spike_limit
        and delta_magnitude > 0.0001 then

        local scale = spike_limit / delta_magnitude
        delta_x = delta_x * scale
        delta_y = delta_y * scale
        delta_z = delta_z * scale

        confidence =
            ui.control.clamp(
                spike_limit / delta_magnitude,
                0.20,
                1.0
            )
    end

    local retention =
        ui.control.clamp(
            settings.prediction_velocity_smoothing,
            0.0,
            0.92
        )

    local raw_speed =
        math.sqrt(
            raw_x * raw_x +
            raw_y * raw_y +
            raw_z * raw_z
        )

    retention =
        retention *
        (
            1.0 -
            ui.control.clamp(
                raw_speed / 650.0,
                0.0,
                0.28
            )
        )

    local response = 1.0 - retention

    cache.x =
        (tonumber(cache.x) or 0.0) +
        delta_x * response

    cache.y =
        (tonumber(cache.y) or 0.0) +
        delta_y * response

    cache.z =
        (tonumber(cache.z) or 0.0) +
        delta_z * response

    cache.updated_at = get_time()

    return vector.new(
        cache.x,
        cache.y,
        cache.z
    ),
        confidence
end

function ui.control.get_prediction_time(
    player,
    local_player,
    settings,
    distance,
    smart_prediction_multiplier
)
    if settings.prediction ~= true then
        return 0.0,
            nil,
            1.0
    end

    local target_velocity =
        ui.lobby.call_method(
            player,
            "get_velocity"
        )

    if not target_velocity then
        return 0.0,
            nil,
            0.0
    end

    local velocity_x =
        tonumber(target_velocity.x) or 0.0

    local velocity_y =
        tonumber(target_velocity.y) or 0.0

    local velocity_z =
        tonumber(target_velocity.z) or 0.0

    if settings.relative_prediction
        and local_player then

        local local_velocity =
            ui.lobby.call_method(
                local_player,
                "get_velocity"
            )

        if local_velocity then
            velocity_x =
                velocity_x -
                (tonumber(local_velocity.x) or 0.0)

            velocity_y =
                velocity_y -
                (tonumber(local_velocity.y) or 0.0)

            velocity_z =
                velocity_z -
                (tonumber(local_velocity.z) or 0.0)
        end
    end

    if settings.vertical_prediction ~= true then
        velocity_z = 0.0
    end

    local prediction_time =
        tonumber(
            settings.prediction_time
        ) or 0.08

    prediction_time =
        prediction_time *
        ui.control.clamp(
            tonumber(smart_prediction_multiplier) or 1.0,
            0.65,
            1.40
        )

    if settings.adaptive_prediction then
        local horizontal_speed =
            math.sqrt(
                velocity_x * velocity_x +
                velocity_y * velocity_y
            )

        local speed_factor =
            ui.control.clamp(
                horizontal_speed / 260.0,
                0.35,
                1.55
            )

        local distance_factor =
            ui.control.clamp(
                (tonumber(distance) or 0.0) / 1400.0,
                0.65,
                1.35
            )

        local adaptive_scale =
            speed_factor * distance_factor

        local strength =
            ui.control.clamp(
                settings.prediction_strength,
                0.0,
                1.5
            )

        prediction_time =
            prediction_time *
            (
                1.0 +
                (adaptive_scale - 1.0) * strength
            )
    end

    local filtered_velocity,
        prediction_confidence =
            ui.control.filter_prediction_velocity(
                player,
                vector.new(
                    velocity_x,
                    velocity_y,
                    velocity_z
                ),
                settings
            )

    prediction_confidence =
        ui.control.clamp(
            prediction_confidence,
            0.20,
            1.0
        )

    prediction_time =
        prediction_time *
        (
            0.45 +
            prediction_confidence * 0.55
        )

    prediction_time =
        ui.control.clamp(
            prediction_time,
            0.0,
            tonumber(
                settings.prediction_max_time
            ) or 0.16
        )

    return prediction_time,
        filtered_velocity,
        prediction_confidence
end

function ui.control.get_target_position(
    player,
    local_player,
    settings,
    distance,
    incapacitated,
    smart_prediction_multiplier
)
    local base_position =
        ui.control.get_target_point_position(
            player,
            settings.target_point,
            incapacitated,
            settings
        )

    if not base_position then
        return nil,
            0.0,
            nil,
            0.0
    end

    local prediction_time,
        velocity,
        prediction_confidence =
            ui.control.get_prediction_time(
                player,
                local_player,
                settings,
                distance,
                smart_prediction_multiplier
            )

    if prediction_time <= 0.0
        or not velocity then

        return base_position,
            0.0,
            base_position,
            prediction_confidence or 1.0
    end

    return vector.new(
        base_position.x +
            velocity.x * prediction_time,
        base_position.y +
            velocity.y * prediction_time,
        base_position.z +
            velocity.z * prediction_time
    ),
        prediction_time,
        base_position,
        prediction_confidence or 1.0
end

function ui.control.is_target_visible(
    local_player,
    target_player,
    start_position,
    end_position,
    target_index
)
    if type(trace) ~= "table"
        or type(trace.line) ~= "function" then

        return true
    end

    local mask = nil

    if type(trace_mask) == "table" then
        mask =
            trace_mask.VISIBLE
            or trace_mask.SHOT
            or trace_mask.SOLID
    end

    mask = mask or 0x4600400B

    local trace_ok,
        trace_result =
            pcall(
                trace.line,
                start_position,
                end_position,
                mask,
                local_player
            )

    if not trace_ok then
        trace_ok,
            trace_result =
                pcall(
                    trace.line,
                    start_position,
                    end_position,
                    mask,
                    ui.lobby.call_method(
                        local_player,
                        "get_index"
                    )
                )
    end

    if not trace_ok
        or trace_result == nil then

        return true
    end

    if type(trace_result) ~= "table" then
        return trace_result ~= false
    end

    local hit_index =
        tonumber(
            trace_result.entity_index
            or trace_result.hit_entity_index
            or trace_result.entindex
        )

    if hit_index
        and hit_index == tonumber(target_index) then

        return true
    end

    local hit_entity =
        trace_result.entity
        or trace_result.hit_entity

    if hit_entity
        and tonumber(
            ui.lobby.call_method(
                hit_entity,
                "get_index"
            )
        ) == tonumber(target_index) then

        return true
    end

    local fraction =
        tonumber(
            trace_result.fraction
        )

    if fraction ~= nil then
        return fraction >= 0.97
    end

    return true
end

function ui.control.get_effective_smoothing(
    settings,
    target
)
    local smoothing =
        math.max(
            1.0,
            tonumber(settings.smooth) or 1.0
        )

    local settle_multiplier = 1.0

    if settings.dynamic_smoothing == true
        and target then

        local normalized_fov =
            ui.control.clamp(
                (tonumber(target.fov) or 0.0) /
                math.max(
                    tonumber(target.effective_fov)
                    or tonumber(settings.fov)
                    or 1.0,
                    1.0
                ),
                0.0,
                1.0
            )

        settle_multiplier =
            1.0 +
            (1.0 - normalized_fov) *
            ui.control.clamp(
                settings.dynamic_smoothing_strength,
                0.0,
                1.5
            )
    end

    local smart_multiplier =
        target
        and ui.control.clamp(
            tonumber(target.smart_smoothing_multiplier) or 1.0,
            0.65,
            1.40
        )
        or 1.0

    local result =
        ui.control.clamp(
            smoothing * settle_multiplier * smart_multiplier,
            1.0,
            40.0
        )

    ui.control.runtime.effective_smoothing = result

    return result
end

function ui.control.get_best_target_v1(
    local_player,
    settings
)


    local eye_position =
        local_player:get_eye_position()

    local view_angles =
        local_player:get_eye_angles()

    local best_target = nil
    local best_fov =
        tonumber(settings.fov) or 180.0

    local local_index =
        local_player:get_index()

    local maximum_clients =
        engine.get_max_clients()

    for player_index = 1,
        maximum_clients do

        local player =
            entity.get_by_index(
                player_index
            )

        if ui.control.is_valid_survivor(
            player,
            local_index
        ) then
            local target_origin =
                player:get_origin()

            local distance =
                vector.distance(
                    eye_position,
                    target_origin
                )

            if distance <=
                (tonumber(settings.max_distance) or 8192.0) then

                local aim_position =
                    settings.target_head
                    and player:get_eye_position()
                    or target_origin

                local aim_angle =
                    ui.control.calculate_angle(
                        eye_position,
                        aim_position
                    )

                local target_fov =
                    ui.control.get_fov(
                        view_angles,
                        aim_angle
                    )

                if target_fov < best_fov then
                    best_fov = target_fov
                    best_target = {
                        player = player,
                        index = player_index,
                        aim_position = aim_position,
                        aim_angle = aim_angle,
                        distance = distance,
                        fov = target_fov
                    }
                end
            end
        end
    end

    return best_target
end

function ui.control.build_v2_candidate(
    local_player,
    target_index,
    settings,
    eye_position,
    view_angles,
    fov_multiplier,
    smart_context,
    hard_lock
)
    local player =
        entity.get_by_index(
            target_index
        )

    local local_index =
        local_player:get_index()

    local valid_target = false
    local incapacitated = false
    local hanging = false

    if hard_lock == true then
        if player then
            local player_index = tonumber(
                ui.lobby.call_method(player, "get_index")
            )

            local team = tonumber(
                ui.lobby.call_method(player, "get_team")
            )

            valid_target =
                player_index == tonumber(target_index)
                and player_index ~= tonumber(local_index)
                and team == 2

            incapacitated, hanging =
                ui.control.get_survivor_state(player)
        end
    else
        valid_target,
            incapacitated,
            hanging =
                ui.control.is_valid_survivor(
                    player,
                    local_index,
                    settings.target_incapacitated == true,
                    settings.target_hanging == true
                )
    end

    if not valid_target then
        return nil
    end

    local target_origin =
        ui.lobby.call_method(
            player,
            "get_origin"
        )

    if not target_origin then
        return nil
    end

    local distance =
        vector.distance(
            eye_position,
            target_origin
        )

    smart_context =
        type(smart_context) == "table"
        and smart_context
        or ui.control.get_aim_v2_smart_context(
            local_player,
            settings
        )

    local effective_max_distance =
        ui.control.clamp(
            (tonumber(settings.max_distance) or 8192.0) *
            (tonumber(smart_context.distance_multiplier) or 1.0),
            250.0,
            8192.0
        )

    if distance > effective_max_distance
        and hard_lock ~= true then

        return nil
    end

    local range_smoothing,
        range_prediction =
            ui.control.get_aim_v2_range_response(
                settings,
                distance,
                effective_max_distance
            )

    local smart_smoothing_multiplier =
        (tonumber(smart_context.smoothing_multiplier) or 1.0) *
        range_smoothing

    local smart_prediction_multiplier =
        (tonumber(smart_context.prediction_multiplier) or 1.0) *
        range_prediction

    local aim_position,
        prediction_time,
        visibility_position,
        prediction_confidence =
            ui.control.get_target_position(
                player,
                local_player,
                settings,
                distance,
                incapacitated,
                smart_prediction_multiplier
            )

    if not aim_position then
        return nil
    end

    if settings.visible_only
        and hard_lock ~= true
        and not ui.control.is_target_visible(
            local_player,
            player,
            eye_position,
            visibility_position or aim_position,
            target_index
        ) then

        return nil
    end

    local aim_angle =
        ui.control.calculate_angle(
            eye_position,
            aim_position
        )

    if not aim_angle then
        return nil
    end

    local target_fov =
        ui.control.get_fov(
            view_angles,
            aim_angle
        )

    local effective_fov =
        ui.control.clamp(
            (tonumber(settings.fov) or 180.0) *
            (tonumber(smart_context.fov_multiplier) or 1.0),
            1.0,
            180.0
        )

    if target_fov >
        effective_fov *
        (tonumber(fov_multiplier) or 1.0)
        and hard_lock ~= true then

        return nil
    end

    local distance_ratio =
        distance /
        math.max(
            effective_max_distance,
            1.0
        )

    local priority_mode =
        math.max(
            0,
            math.min(
                2,
                math.floor(
                    tonumber(
                        settings.priority_mode
                    ) or 1
                )
            )
        )

    local score = target_fov

    if priority_mode == 1 then
        score =
            target_fov +
            distance_ratio *
            (
                tonumber(
                    settings.distance_weight
                ) or 2.0
            )
    elseif priority_mode == 2 then
        score =
            distance_ratio * 100.0 +
            target_fov * 0.25
    end

    if settings.prefer_standing_targets == true
        and (incapacitated == true or hanging == true) then

        score =
            score +
            (tonumber(settings.disabled_target_penalty) or 8.0)
    end

    local angular_confidence =
        1.0 -
        ui.control.clamp(
            target_fov /
            math.max(effective_fov, 1.0),
            0.0,
            1.0
        ) * 0.20

    local confidence =
        ui.control.clamp(
            (tonumber(prediction_confidence) or 1.0) *
            angular_confidence,
            0.15,
            1.0
        )

    if settings.confidence_lock == true then
        score =
            score +
            (1.0 - confidence) *
            ui.control.clamp(
                settings.confidence_weight,
                0.0,
                20.0
            ) * 0.35
    end

    return {
        player = player,
        index = target_index,
        aim_position = aim_position,
        aim_angle = aim_angle,
        distance = distance,
        fov = target_fov,
        score = score,
        prediction_time = prediction_time,
        prediction_confidence = prediction_confidence or 1.0,
        confidence = confidence,
        effective_fov = effective_fov,
        effective_max_distance = effective_max_distance,
        smart_smoothing_multiplier = smart_smoothing_multiplier,
        smart_prediction_multiplier = smart_prediction_multiplier,
        smart_class = smart_context.class_name or "Neutral",
        smart_profile = smart_context.profile_name or "Off",
        incapacitated = incapacitated == true,
        hanging = hanging == true,
        held = hard_lock == true
    }
end

function ui.control.get_best_target_v2(
    local_player,
    settings,
    view_angles
)
    local eye_position =
        local_player:get_eye_position()

    local smart_context =
        ui.control.get_aim_v2_smart_context(
            local_player,
            settings
        )

    ui.control.runtime.smart_class =
        tostring(smart_context.class_name or "Neutral")

    ui.control.runtime.smart_profile =
        tostring(smart_context.profile_name or "Off")

    local locked_candidate = nil

    local session_target_index =
        math.floor(
            tonumber(ui.control.runtime.lock_session_target_index) or 0
        )

    if settings.hold_lock_until_release == true
        and ui.control.runtime.lock_session_active == true
        and session_target_index > 0 then

        local held_candidate =
            ui.control.build_v2_candidate(
                local_player,
                session_target_index,
                settings,
                eye_position,
                view_angles,
                999.0,
                smart_context,
                true
            )

        if held_candidate then
            ui.control.runtime.lock_session_lost_since = 0.0
            ui.control.runtime.lock_session_status = "Held until key release"
            return held_candidate
        end

        if (tonumber(ui.control.runtime.lock_session_lost_since) or 0.0) <= 0.0 then
            ui.control.runtime.lock_session_lost_since = get_time()
        end

        local snapshot = ui.control.runtime.last_valid_target

        if type(snapshot) == "table"
            and tonumber(snapshot.index) == session_target_index then

            ui.control.runtime.lock_session_status = "Held - cached world position"
            return {
                player = snapshot.player,
                index = snapshot.index,
                aim_position = snapshot.aim_position,
                aim_angle = snapshot.aim_angle,
                distance = snapshot.distance,
                fov = snapshot.fov,
                score = snapshot.score,
                prediction_time = snapshot.prediction_time,
                prediction_confidence = snapshot.prediction_confidence or 1.0,
                confidence = snapshot.confidence or 1.0,
                effective_fov = snapshot.effective_fov,
                effective_max_distance = snapshot.effective_max_distance,
                smart_smoothing_multiplier = snapshot.smart_smoothing_multiplier,
                smart_prediction_multiplier = snapshot.smart_prediction_multiplier,
                smart_class = snapshot.smart_class,
                smart_profile = snapshot.smart_profile,
                incapacitated = snapshot.incapacitated,
                hanging = snapshot.hanging,
                grace = true,
                held = true
            }
        end

        ui.control.runtime.lock_session_status =
            "Held - waiting for target data"
        return nil
    end

    if settings.sticky_lock
        and ui.control.runtime.locked_target_index > 0 then

        locked_candidate =
            ui.control.build_v2_candidate(
                local_player,
                ui.control.runtime.locked_target_index,
                settings,
                eye_position,
                view_angles,
                settings.lock_fov_multiplier,
                smart_context
            )
    end

    local best_candidate = nil
    local maximum_clients =
        engine.get_max_clients()

    for target_index = 1,
        maximum_clients do

        local candidate =
            ui.control.build_v2_candidate(
                local_player,
                target_index,
                settings,
                eye_position,
                view_angles,
                1.0,
                smart_context
            )

        if candidate
            and (
                not best_candidate
                or candidate.score <
                    best_candidate.score
            ) then

            best_candidate = candidate
        end
    end

    if not locked_candidate
        and settings.sticky_lock == true
        and ui.control.runtime.locked_target_index > 0 then

        local snapshot =
            ui.control.runtime.last_valid_target

        local grace_time =
            tonumber(settings.lock_grace_time) or 0.0

        if type(snapshot) == "table"
            and tonumber(snapshot.index) ==
                tonumber(
                    ui.control.runtime.locked_target_index
                )
            and get_time() -
                (tonumber(
                    ui.control.runtime.last_valid_target_time
                ) or 0.0) <= grace_time then

            return {
                player = snapshot.player,
                index = snapshot.index,
                aim_position = snapshot.aim_position,
                aim_angle = snapshot.aim_angle,
                distance = snapshot.distance,
                fov = snapshot.fov,
                score = snapshot.score,
                prediction_time = snapshot.prediction_time,
                prediction_confidence = snapshot.prediction_confidence or 1.0,
                confidence = snapshot.confidence or 1.0,
                effective_fov = snapshot.effective_fov,
                effective_max_distance = snapshot.effective_max_distance,
                smart_smoothing_multiplier = snapshot.smart_smoothing_multiplier,
                smart_prediction_multiplier = snapshot.smart_prediction_multiplier,
                smart_class = snapshot.smart_class,
                smart_profile = snapshot.smart_profile,
                incapacitated = snapshot.incapacitated,
                hanging = snapshot.hanging,
                grace = true
            }
        end
    end

    if locked_candidate then
        local switch_delay =
            tonumber(
                settings.switch_delay
            ) or 0.0

        if get_time() -
            (
                tonumber(
                    ui.control.runtime.last_target_switch_time
                ) or 0.0
            ) < switch_delay then

            return locked_candidate
        end

        local required_margin =
            tonumber(settings.switch_margin) or 4.0

        if settings.confidence_lock == true
            and best_candidate
            and best_candidate.index ~= locked_candidate.index then

            required_margin =
                required_margin +
                (
                    (tonumber(locked_candidate.confidence) or 1.0) -
                    (tonumber(best_candidate.confidence) or 1.0)
                ) *
                ui.control.clamp(
                    settings.confidence_weight,
                    0.0,
                    20.0
                )
        end

        required_margin = math.max(0.0, required_margin)

        if not best_candidate
            or best_candidate.index == locked_candidate.index
            or best_candidate.fov + required_margin >= locked_candidate.fov then

            return locked_candidate
        end
    end

    return best_candidate
end

function ui.control.reset_pursuit_runtime(full_reset)
    local runtime = ui.control.runtime

    runtime.pursuit_active = false
    runtime.pursuit_status = "Ready"
    runtime.pursuit_distance = 0.0
    runtime.pursuit_clearance = 1.0
    runtime.pursuit_heading_offset = 0.0
    runtime.pursuit_chosen_yaw = 0.0
    runtime.pursuit_committed_side = 0
    runtime.pursuit_commit_until = 0.0
    runtime.pursuit_target_speed = 0.0
    runtime.pursuit_target_lead_used = 0.0
    runtime.pursuit_last_target_yaw = 0.0
    runtime.pursuit_next_scan_time = 0.0
    runtime.pursuit_last_origin = nil
    runtime.pursuit_last_sample_time = 0.0
    runtime.pursuit_stuck_time = 0.0
    runtime.pursuit_recovery_started = 0.0
    runtime.pursuit_recovery_until = 0.0

    if full_reset == true then
        runtime.pursuit_last_side = 0
        runtime.pursuit_recovery_side = 1
        runtime.pursuit_recovery_attempts = 0
        runtime.pursuit_last_jump_time = 0.0
    end
end

function ui.control.is_pursuit_key_down(settings)
    settings = settings or ui.control.aim.v2

    if settings.pursuit_use_shared_key ~= false then
        return ui.control.is_action_key_down()
    end

    if type(input) ~= "table"
        or type(input.is_key_down) ~= "function" then

        return false
    end

    local ok, down =
        pcall(
            input.is_key_down,
            math.floor(
                tonumber(settings.pursuit_key)
                or (keys.MOUSE4 or 0x05)
            )
        )

    return ok and down == true
end

function ui.control.is_aim_v2_session_key_down(settings)
    settings = settings or ui.control.aim.v2

    if ui.control.is_action_key_down() then
        return true
    end

    return settings.pursuit_enabled == true
        and ui.control.is_pursuit_key_down(settings)
end

function ui.control.is_aim_v2_session_hold_active(settings)
    settings = settings or ui.control.aim.v2

    local runtime = ui.control.runtime
    local raw_down = ui.control.is_aim_v2_session_key_down(settings)

    if raw_down then
        runtime.lock_session_release_pending_at = 0.0
        return true
    end

    if runtime.lock_session_active ~= true then
        runtime.lock_session_release_pending_at = 0.0
        return false
    end

    local now = get_time()
    local pending_at =
        tonumber(runtime.lock_session_release_pending_at) or 0.0

    if pending_at <= 0.0 then
        pending_at = now
        runtime.lock_session_release_pending_at = now
    end

    return now - pending_at <
        ui.control.clamp(
            settings.hold_lock_release_debounce,
            0.03,
            0.35
        )
end

function ui.control.pursuit_trace(
    start_position,
    end_position,
    local_player,
    target_index
)
    if type(trace) ~= "table"
        or type(trace.line) ~= "function" then

        return 1.0, false, nil
    end

    local mask = nil

    if type(trace_mask) == "table" then
        mask =
            trace_mask.SOLID
            or trace_mask.VISIBLE
            or trace_mask.SHOT
    end

    mask = mask or 0x4600400B

    local ok, result =
        pcall(
            trace.line,
            start_position,
            end_position,
            mask,
            local_player
        )

    if not ok then
        ok, result =
            pcall(
                trace.line,
                start_position,
                end_position,
                mask,
                ui.lobby.call_method(
                    local_player,
                    "get_index"
                )
            )
    end

    if not ok or result == nil then
        return 1.0, false, nil
    end

    if type(result) == "boolean" then
        return result and 1.0 or 0.0, true, result
    end

    if type(result) == "number" then
        return ui.control.clamp(result, 0.0, 1.0), true, result
    end

    if type(result) ~= "table" then
        return 1.0, false, result
    end

    local hit_index =
        tonumber(
            result.entity_index
            or result.hit_entity_index
            or result.entindex
        )

    if hit_index
        and target_index
        and hit_index == tonumber(target_index) then

        return 1.0, true, result
    end

    local hit_entity =
        result.entity
        or result.hit_entity

    if hit_entity and target_index then
        local entity_index =
            tonumber(
                ui.lobby.call_method(
                    hit_entity,
                    "get_index"
                )
            )

        if entity_index == tonumber(target_index) then
            return 1.0, true, result
        end
    end

    if result.start_solid == true
        or result.all_solid == true then

        return 0.0, true, result
    end

    local fraction =
        tonumber(result.fraction)

    if fraction ~= nil then
        return ui.control.clamp(fraction, 0.0, 1.0), true, result
    end

    return 1.0, false, result
end

function ui.control.pursuit_ground_supported(
    position,
    local_player
)
    local start_position =
        vector.new(
            position.x,
            position.y,
            position.z + 34.0
        )

    local end_position =
        vector.new(
            position.x,
            position.y,
            position.z - 112.0
        )

    local fraction, known =
        ui.control.pursuit_trace(
            start_position,
            end_position,
            local_player,
            nil
        )

    return not known or fraction < 0.985,
        fraction,
        known
end

function ui.control.pursuit_try_jump(
    command,
    settings
)
    if settings.pursuit_auto_jump ~= true
        or get_time() -
            (tonumber(ui.control.runtime.pursuit_last_jump_time) or 0.0)
            < 0.45 then

        return false
    end

    local buttons_ok, buttons =
        pcall(
            function()
                return command:get_buttons()
            end
        )

    if not buttons_ok then
        ui.control.runtime.pursuit_jump_supported = "Unavailable"
        return false
    end

    local set_ok =
        pcall(
            function()
                command:set_buttons(
                    (math.floor(tonumber(buttons) or 0)) | 2
                )
            end
        )

    if set_ok then
        ui.control.runtime.pursuit_last_jump_time = get_time()
        ui.control.runtime.pursuit_jump_supported = "Available"
        return true
    end

    ui.control.runtime.pursuit_jump_supported = "Unavailable"
    return false
end

function ui.control.pursuit_update_stuck_state(
    origin,
    move_scale,
    settings
)
    local runtime = ui.control.runtime
    local now = get_time()
    local sample_time =
        tonumber(runtime.pursuit_last_sample_time) or 0.0

    if sample_time <= 0.0 then
        runtime.pursuit_last_origin =
            vector.new(origin.x, origin.y, origin.z)
        runtime.pursuit_last_sample_time = now
        runtime.pursuit_stuck_time = 0.0
        return
    end

    local elapsed = now - sample_time

    if elapsed < 0.14 then
        return
    end

    local last = runtime.pursuit_last_origin
    local moved = 999.0

    if last then
        local dx = origin.x - last.x
        local dy = origin.y - last.y
        moved = math.sqrt(dx * dx + dy * dy)
    end

    if move_scale > 0.35 and moved < 4.5 then
        runtime.pursuit_stuck_time =
            (tonumber(runtime.pursuit_stuck_time) or 0.0) + elapsed
    else
        runtime.pursuit_stuck_time = 0.0
    end

    runtime.pursuit_last_origin =
        vector.new(origin.x, origin.y, origin.z)
    runtime.pursuit_last_sample_time = now

    if settings.pursuit_auto_unstuck == true
        and runtime.pursuit_stuck_time >= 0.58
        and now >=
            (tonumber(runtime.pursuit_recovery_until) or 0.0) then

        runtime.pursuit_recovery_attempts =
            (tonumber(runtime.pursuit_recovery_attempts) or 0) + 1

        local previous_side =
            tonumber(runtime.pursuit_last_side) or 0

        if previous_side == 0 then
            previous_side =
                runtime.pursuit_recovery_attempts % 2 == 0
                and -1
                or 1
        else
            previous_side = -previous_side
        end

        runtime.pursuit_recovery_side = previous_side
        runtime.pursuit_recovery_started = now
        runtime.pursuit_recovery_until = now + 0.78
        runtime.pursuit_stuck_time = 0.0
    end
end

function ui.control.apply_pursuit_bot(
    command,
    local_player
)
    local settings = ui.control.aim.v2
    local runtime = ui.control.runtime

    if settings.pursuit_enabled ~= true then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Disabled"
        return false
    end

    if ui.control.aim.enabled ~= true
        or tonumber(ui.control.aim.mode) ~= 1 then

        runtime.pursuit_active = false
        runtime.pursuit_status = "Aim V2 required"
        return false
    end

    if not ui.control.is_pursuit_key_down(settings) then
        runtime.pursuit_active = false
        runtime.pursuit_status =
            "Ready - hold " ..
            ui.control.get_key_name(
                settings.pursuit_use_shared_key ~= false
                and ui.control.action_key
                or settings.pursuit_key
            )
        runtime.pursuit_stuck_time = 0.0
        runtime.pursuit_recovery_until = 0.0
        return false
    end

    if settings.pursuit_manual_override == true
        and ui.control.movement_key_count() > 0 then

        runtime.pursuit_active = false
        runtime.pursuit_status = "Manual movement override"
        runtime.pursuit_stuck_time = 0.0
        return false
    end

    local session_target_index =
        tonumber(runtime.lock_session_target_index) or 0

    local target_index =
        math.floor(
            session_target_index > 0
            and session_target_index
            or (tonumber(runtime.locked_target_index) or 0)
        )

    if target_index <= 0 then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Waiting for Aim V2 lock"
        return false
    end

    local target_player =
        entity.get_by_index(target_index)

    if not target_player then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Target unavailable"
        return false
    end

    local origin =
        ui.lobby.call_method(local_player, "get_origin")
    local target_origin =
        ui.lobby.call_method(target_player, "get_origin")

    if not origin or not target_origin then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Position unavailable"
        return false
    end

    local raw_dx = target_origin.x - origin.x
    local raw_dy = target_origin.y - origin.y
    local raw_distance =
        math.sqrt(raw_dx * raw_dx + raw_dy * raw_dy)

    local target_velocity =
        ui.lobby.call_method(target_player, "get_velocity")

    local target_speed = 0.0
    local lead_time = 0.0

    if target_velocity then
        local tvx = tonumber(target_velocity.x) or 0.0
        local tvy = tonumber(target_velocity.y) or 0.0
        target_speed = math.sqrt(tvx * tvx + tvy * tvy)

        if settings.pursuit_target_lead ~= false then
            local lead_blend =
                ui.control.clamp(
                    (raw_distance - 96.0) / 260.0,
                    0.0,
                    1.0
                )

            lead_time =
                ui.control.clamp(
                    (tonumber(settings.pursuit_target_lead_time) or 0.18) +
                    ui.control.clamp(raw_distance / 5000.0, 0.0, 0.12),
                    0.0,
                    0.45
                ) * lead_blend

            target_origin =
                vector.new(
                    target_origin.x + tvx * lead_time,
                    target_origin.y + tvy * lead_time,
                    target_origin.z
                )
        end
    end

    runtime.pursuit_target_speed = target_speed
    runtime.pursuit_target_lead_used = lead_time

    local dx = target_origin.x - origin.x
    local dy = target_origin.y - origin.y
    local horizontal_distance =
        math.sqrt(dx * dx + dy * dy)

    runtime.pursuit_distance = horizontal_distance

    local stop_distance =
        ui.control.clamp(
            settings.pursuit_stop_distance,
            35.0,
            400.0
        )

    if settings.pursuit_glue_mode ~= true
        and horizontal_distance <= stop_distance then

        command:set_forwardmove(0.0)
        command:set_sidemove(0.0)
        runtime.pursuit_active = true
        runtime.pursuit_status = "Holding configured range"
        runtime.pursuit_clearance = 1.0
        runtime.pursuit_heading_offset = 0.0
        runtime.pursuit_stuck_time = 0.0
        return true
    end

    local desired_yaw

    if horizontal_distance <= 6.0 then
        desired_yaw =
            tonumber(runtime.pursuit_last_target_yaw) or 0.0
    else
        desired_yaw = math.deg(math.atan(dy, dx))
        runtime.pursuit_last_target_yaw = desired_yaw
    end

    local velocity =
        ui.lobby.call_method(local_player, "get_velocity")

    local current_speed = 0.0

    if velocity then
        local vx = tonumber(velocity.x) or 0.0
        local vy = tonumber(velocity.y) or 0.0
        current_speed = math.sqrt(vx * vx + vy * vy)
    end

    local lookahead =
        ui.control.clamp(
            (tonumber(settings.pursuit_lookahead) or 150.0) +
            current_speed *
            ui.control.clamp(
                settings.pursuit_speed_lookahead,
                0.0,
                0.60
            ),
            64.0,
            420.0
        )

    local now = get_time()

    if now >=
        (tonumber(runtime.pursuit_next_scan_time) or 0.0) then

        runtime.pursuit_next_scan_time = now + 0.05

        local scan_angle =
            ui.control.clamp(
                settings.pursuit_scan_angle,
                35.0,
                140.0
            )

        local offsets = {
            0.0,
            -scan_angle * 0.16,
            scan_angle * 0.16,
            -scan_angle * 0.34,
            scan_angle * 0.34,
            -scan_angle * 0.58,
            scan_angle * 0.58,
            -scan_angle,
            scan_angle
        }

        local best_score = -1000000.0
        local best_offset = 0.0
        local best_clearance = 0.0
        local best_side = 0

        for _, offset in ipairs(offsets) do
            local candidate_yaw = desired_yaw + offset
            local radians = math.rad(candidate_yaw)
            local dir_x = math.cos(radians)
            local dir_y = math.sin(radians)

            local low_start =
                vector.new(
                    origin.x,
                    origin.y,
                    origin.z + 18.0
                )

            local high_start =
                vector.new(
                    origin.x,
                    origin.y,
                    origin.z + 48.0
                )

            local low_end =
                vector.new(
                    low_start.x + dir_x * lookahead,
                    low_start.y + dir_y * lookahead,
                    low_start.z
                )

            local high_end =
                vector.new(
                    high_start.x + dir_x * lookahead,
                    high_start.y + dir_y * lookahead,
                    high_start.z
                )

            local low_fraction =
                ui.control.pursuit_trace(
                    low_start,
                    low_end,
                    local_player,
                    target_index
                )

            local high_fraction =
                ui.control.pursuit_trace(
                    high_start,
                    high_end,
                    local_player,
                    target_index
                )

            local clearance =
                math.min(
                    tonumber(low_fraction) or 1.0,
                    tonumber(high_fraction) or 1.0
                )

            local ground_safe = true

            if settings.pursuit_ledge_safety == true then
                local middle_point =
                    vector.new(
                        origin.x + dir_x * lookahead * 0.48,
                        origin.y + dir_y * lookahead * 0.48,
                        origin.z
                    )

                local far_point =
                    vector.new(
                        origin.x + dir_x * lookahead * 0.82,
                        origin.y + dir_y * lookahead * 0.82,
                        origin.z
                    )

                local middle_safe =
                    ui.control.pursuit_ground_supported(
                        middle_point,
                        local_player
                    )

                local far_safe =
                    ui.control.pursuit_ground_supported(
                        far_point,
                        local_player
                    )

                ground_safe = middle_safe and far_safe
            end

            local progress = math.cos(math.rad(offset))
            local angle_cost = math.abs(offset) / 180.0
            local side =
                offset < -0.5 and -1
                or (offset > 0.5 and 1 or 0)

            local memory_bonus = 0.0

            if side ~= 0
                and side == (tonumber(runtime.pursuit_last_side) or 0) then

                memory_bonus = 0.12
            end

            local committed_side =
                tonumber(runtime.pursuit_committed_side) or 0
            local commitment_active =
                now < (tonumber(runtime.pursuit_commit_until) or 0.0)

            if commitment_active and side ~= 0 then
                if side == committed_side then
                    memory_bonus = memory_bonus + 0.20
                elseif committed_side ~= 0 then
                    memory_bonus = memory_bonus - 0.65
                end
            end

            local score =
                progress * 2.20 +
                clearance * 1.85 -
                angle_cost * 0.52 +
                memory_bonus

            if clearance < 0.18 then
                score = score - 5.0
            elseif clearance < 0.42 then
                score = score - 1.25
            end

            if not ground_safe then
                score = score - 8.0
            end

            if score > best_score then
                best_score = score
                best_offset = offset
                best_clearance = clearance
                best_side = side
            end
        end

        runtime.pursuit_heading_offset = best_offset
        runtime.pursuit_chosen_yaw = desired_yaw + best_offset
        runtime.pursuit_clearance = best_clearance

        if best_side ~= 0 then
            runtime.pursuit_last_side = best_side

            if now >= (tonumber(runtime.pursuit_commit_until) or 0.0)
                or tonumber(runtime.pursuit_committed_side) == 0 then

                runtime.pursuit_committed_side = best_side
                runtime.pursuit_commit_until =
                    now +
                    ui.control.clamp(
                        settings.pursuit_corner_commit_time,
                        0.0,
                        0.80
                    )
            end
        elseif best_clearance > 0.78 then
            runtime.pursuit_committed_side = 0
            runtime.pursuit_commit_until = 0.0
        end
    end

    local movement_yaw =
        tonumber(runtime.pursuit_chosen_yaw) or desired_yaw

    local angles_ok, command_angles =
        pcall(
            function()
                return command:get_viewangles()
            end
        )

    if not angles_ok or not command_angles then
        command_angles =
            ui.lobby.call_method(local_player, "get_eye_angles")
    end

    if not command_angles then
        runtime.pursuit_active = false
        runtime.pursuit_status = "View direction unavailable"
        return false
    end

    local delta_yaw =
        ui.control.normalize_angle(
            movement_yaw -
            (tonumber(command_angles.y) or 0.0)
        )

    local move_scale = 1.0

    if settings.pursuit_glue_mode == true then
        move_scale =
            ui.control.clamp(
                settings.pursuit_contact_pressure,
                0.55,
                1.0
            )
    else
        local slow_distance =
            math.max(
                stop_distance + 25.0,
                tonumber(settings.pursuit_slow_distance) or 300.0
            )

        if horizontal_distance < slow_distance then
            move_scale =
                ui.control.clamp(
                    (horizontal_distance - stop_distance) /
                    math.max(slow_distance - stop_distance, 1.0),
                    0.16,
                    1.0
                )
        end
    end

    local clearance =
        ui.control.clamp(
            runtime.pursuit_clearance,
            0.0,
            1.0
        )

    if clearance < 0.50 then
        move_scale = move_scale *
            ui.control.clamp(
                clearance / 0.50,
                settings.pursuit_glue_mode == true and 0.70 or 0.24,
                1.0
            )
    end

    if settings.pursuit_glue_mode == true
        and horizontal_distance <= 72.0 then

        runtime.pursuit_stuck_time = 0.0
        runtime.pursuit_recovery_until = 0.0
    else
        ui.control.pursuit_update_stuck_state(
            origin,
            move_scale,
            settings
        )
    end

    local recovering =
        now <
        (tonumber(runtime.pursuit_recovery_until) or 0.0)

    local move_speed =
        ui.control.clamp(
            settings.pursuit_move_speed,
            80.0,
            450.0
        )

    local forward_move
    local side_move

    if recovering then
        local recovery_elapsed =
            now -
            (tonumber(runtime.pursuit_recovery_started) or now)

        local recovery_side =
            tonumber(runtime.pursuit_recovery_side) or 1

        if recovery_elapsed < 0.22 then
            forward_move = -move_speed * 0.42
            side_move = move_speed * recovery_side
        else
            forward_move = move_speed * 0.62
            side_move = move_speed * recovery_side
        end

        ui.control.pursuit_try_jump(command, settings)
        runtime.pursuit_status = "Recovering from obstruction"
    else
        local radians = math.rad(delta_yaw)

        forward_move =
            math.cos(radians) *
            move_speed *
            move_scale

        side_move =
            -math.sin(radians) *
            move_speed *
            move_scale

        if clearance < 0.32 then
            ui.control.pursuit_try_jump(command, settings)
        end

        if settings.pursuit_glue_mode == true
            and horizontal_distance <= 72.0 then

            runtime.pursuit_status = "Glued to locked target"
        elseif math.abs(runtime.pursuit_heading_offset) < 1.0 then
            runtime.pursuit_status = "Direct pursuit"
        else
            runtime.pursuit_status =
                string.format(
                    "Avoiding obstacle: %+.0f deg",
                    tonumber(runtime.pursuit_heading_offset) or 0.0
                )
        end
    end

    command:set_forwardmove(forward_move)
    command:set_sidemove(side_move)

    runtime.pursuit_active = true

    return true
end

function ui.control.apply_aim_infected(
    command,
    local_player
)
    local action_down =
        ui.control.is_action_key_down()

    local mode =
        tonumber(ui.control.aim.mode) == 1
        and 1
        or 0

    local session_key_down =
        mode == 1
        and ui.control.is_aim_v2_session_hold_active(ui.control.aim.v2)
        or action_down

    if not ui.control.aim.enabled then
        if mode == 1 then
            ui.control.reset_aim_v2_tracking(true)
        end
        return false
    end

    if not session_key_down then
        if mode == 1
            and (ui.control.runtime.lock_session_active == true
                or tonumber(ui.control.runtime.locked_target_index) > 0) then

            ui.control.reset_aim_v2_tracking(true)
            ui.control.runtime.lock_session_status = "Released"
        end
        return false
    end

    if mode == 1
        and ui.control.runtime.lock_session_active ~= true then

        ui.control.reset_aim_v2_tracking(true)
        ui.control.runtime.lock_session_active = true
        ui.control.runtime.lock_session_started_at = get_time()
        ui.control.runtime.lock_session_status = "Searching"
    end

    local team =
        tonumber(
            ui.lobby.call_method(
                local_player,
                "get_team"
            )
        )

    if team ~= 3 then
        ui.control.runtime.status = "Infected only"
        ui.control.reset_aim_v2_tracking(true)
        ui.control.runtime.target_fov = 0.0
        ui.control.runtime.target_distance = 0.0
        ui.control.runtime.prediction_time_used = 0.0
        ui.control.runtime.target_state = "None"
        return false
    end

    local settings =
        mode == 1
        and ui.control.aim.v2
        or ui.control.aim.v1

    local current_ok,
        current_angles =
            pcall(
                function()
                    return command:get_viewangles()
                end
            )

    if not current_ok
        or not current_angles then

        ui.control.runtime.status = "View angles unavailable"
        return false
    end

    local target = nil

    if mode == 0 then
        local target_ok,
            target_value =
                pcall(
                    ui.control.get_best_target_v1,
                    local_player,
                    settings
                )

        if target_ok then
            target = target_value
        end
    else
        local target_ok,
            target_value =
                pcall(
                    ui.control.get_best_target_v2,
                    local_player,
                    settings,
                    current_angles
                )

        if target_ok then
            target = target_value
        end
    end

    if not target then
        if mode == 1
            and ui.control.aim.v2.hold_lock_until_release == true
            and ui.control.runtime.lock_session_active == true
            and tonumber(ui.control.runtime.lock_session_target_index) > 0 then

            ui.control.runtime.locked_target_index =
                ui.control.runtime.lock_session_target_index

            local held_name = tostring(
                ui.control.runtime.lock_session_target_name or "None"
            )

            if held_name == "None" or held_name == "" then
                held_name = ui.control.get_target_name(
                    ui.control.runtime.lock_session_target_index
                )
                ui.control.runtime.lock_session_target_name = held_name
            end

            ui.control.runtime.target_name = held_name
            ui.control.runtime.status = "Holding exact target - waiting for live data"
            ui.control.runtime.target_state = "Held"
        else
            ui.control.runtime.status = "No valid survivor"
            ui.control.runtime.target_name = "None"
            ui.control.runtime.target_fov = 0.0
            ui.control.runtime.target_distance = 0.0
            ui.control.runtime.prediction_time_used = 0.0
            ui.control.runtime.target_state = "None"

            if mode == 1 then
                ui.control.reset_aim_v2_tracking(true)
            end
        end

        return false
    end

    local final_angles = nil

    if mode == 0 then
        final_angles =
            ui.control.smooth_angles_v1(
                current_angles,
                target.aim_angle,
                settings.smooth
            )

        final_angles.x =
            ui.control.normalize_angle(
                final_angles.x
            )

        final_angles.y =
            ui.control.normalize_angle(
                final_angles.y
            )
    else
        local previous_target =
            tonumber(
                ui.control.runtime.locked_target_index
            ) or 0

        if target.index ~= previous_target then
            ui.control.runtime.last_target_switch_time =
                get_time()

            ui.control.reset_aim_v2_tracking(false)
        end

        final_angles =
            ui.control.stabilize_aim_v2_angles(
                current_angles,
                target,
                settings
            )

        ui.control.runtime.locked_target_index =
            target.index

        if settings.hold_lock_until_release == true
            and ui.control.runtime.lock_session_active == true then

            if tonumber(ui.control.runtime.lock_session_target_index) <= 0 then
                ui.control.runtime.lock_session_target_index = target.index
                ui.control.runtime.lock_session_target_name =
                    ui.control.get_target_name(target.index)
            end

            ui.control.runtime.lock_session_status = "Held until key release"

            if target.grace ~= true then
                ui.control.runtime.lock_session_last_live_at = get_time()
                ui.control.runtime.lock_session_lost_since = 0.0
            end
        end

        if target.grace ~= true then
            ui.control.runtime.last_valid_target = {
                player = target.player,
                index = target.index,
                aim_position = target.aim_position,
                aim_angle = vector.new(
                    target.aim_angle.x,
                    target.aim_angle.y,
                    0.0
                ),
                distance = target.distance,
                fov = target.fov,
                score = target.score,
                prediction_time = target.prediction_time,
                prediction_confidence = target.prediction_confidence or 1.0,
                confidence = target.confidence or 1.0,
                effective_fov = target.effective_fov,
                effective_max_distance = target.effective_max_distance,
                smart_smoothing_multiplier = target.smart_smoothing_multiplier,
                smart_prediction_multiplier = target.smart_prediction_multiplier,
                smart_class = target.smart_class,
                smart_profile = target.smart_profile,
                incapacitated = target.incapacitated,
                hanging = target.hanging
            }

            ui.control.runtime.last_valid_target_time =
                get_time()
        end
    end

    command:set_viewangles(
        final_angles
    )

    if not settings.silent_aim then
        engine.set_view_angles(
            final_angles
        )
    end

    ui.control.runtime.target_name =
        ui.control.get_target_name(
            target.index
        )

    if mode == 1
        and ui.control.runtime.lock_session_active == true
        and tonumber(ui.control.runtime.lock_session_target_index) == tonumber(target.index) then

        ui.control.runtime.lock_session_target_name =
            ui.control.runtime.target_name
    end

    ui.control.runtime.target_fov =
        tonumber(target.fov) or 0.0

    ui.control.runtime.target_distance =
        tonumber(target.distance) or 0.0

    ui.control.runtime.prediction_time_used =
        tonumber(target.prediction_time) or 0.0

    ui.control.runtime.prediction_confidence =
        tonumber(target.prediction_confidence) or 1.0

    ui.control.runtime.target_confidence =
        tonumber(target.confidence) or 1.0

    ui.control.runtime.smart_class =
        tostring(target.smart_class or ui.control.runtime.smart_class or "Neutral")

    ui.control.runtime.smart_profile =
        tostring(target.smart_profile or ui.control.runtime.smart_profile or "Off")

    ui.control.runtime.effective_fov =
        tonumber(target.effective_fov) or tonumber(settings.fov) or 0.0

    ui.control.runtime.effective_max_distance =
        tonumber(target.effective_max_distance) or tonumber(settings.max_distance) or 0.0

    ui.control.runtime.prediction_confidence =
        tonumber(target.prediction_confidence) or 1.0

    if target.hanging then
        ui.control.runtime.target_state =
            "Hanging"
    elseif target.incapacitated then
        ui.control.runtime.target_state =
            "Incapacitated"
    else
        ui.control.runtime.target_state =
            "Standing"
    end

    ui.control.mark_engaged(
        string.format(
            "Locked: %s | %.1f deg | %.0f u",
            ui.control.runtime.target_name,
            ui.control.runtime.target_fov,
            ui.control.runtime.target_distance
        )
    )

    return true
end

function ui.control.should_show_overlay(
    compact
)
    if not ui.control.is_active_enabled() then
        return false
    end

    if compact then
        return ui.control.show_compact_status == true
    end

    return ui.control.show_detailed_status == true
end

function ui.control.get_overlay_status_text()
    local status_text =
        tostring(
            ui.control.runtime.status or "Ready"
        )

    if ui.control.is_engaged() then
        if ui.control.active_mode == 0 then
            return "Limiting"
        end

        if ui.control.aim.mode == 1 then
            local target_name =
                sanitize_name(
                    ui.control.runtime.target_name
                ):gsub(
                    "^%s+",
                    ""
                ):gsub(
                    "%s+$",
                    ""
                )

            if target_name ~= ""
                and target_name ~= "None" then

                return "Locked: " .. target_name
            end
        end

        return "Locked"
    end

    if status_text:find(
        "Within limit",
        1,
        true
    )
        or status_text == "Monitoring speed" then

        return "Monitoring"
    end

    if status_text == "Searching target" then
        return "Searching"
    elseif status_text == "No valid survivor" then
        return "No target"
    elseif status_text:find(
        "Ready - hold",
        1,
        true
    ) then
        return "Ready"
    elseif status_text == "Waiting for game"
        or status_text == "Waiting for player" then

        return "Waiting"
    elseif status_text == "Player is dead" then
        return "Player dead"
    elseif status_text == "Velocity unavailable"
        or status_text == "Movement command unavailable" then

        return "Unavailable"
    end

    return status_text
end

