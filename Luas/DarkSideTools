function chat_spammer.get_heaven_newline_message_body(
    message,
    use_invisible_symbol,
    use_vertical_text
)
    if use_invisible_symbol == true then
        return DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX
    end

    local sanitized_message =
        chat_spammer.sanitize_heaven_newline_message(
            message,
            chat_spammer.get_newline_spam_message_limit(
                use_vertical_text
            )
        )

    if sanitized_message == ""
        or use_vertical_text ~= true then

        return sanitized_message
    end


    return table.concat(
        split_utf8_characters(
            sanitized_message
        ),
        "\r"
    )
end

function chat_spammer.send_heaven_newline_message(
    message,
    use_invisible_symbol,
    team_only,
    prefix_count,
    use_vertical_text
)
    if not engine.is_in_game()
        or not engine.is_connected() then

        return false
    end

    local body =
        chat_spammer.get_heaven_newline_message_body(
            message,
            use_invisible_symbol,
            use_vertical_text
        )

    if body == "" then
        return false
    end

    prefix_count =
        math.max(
            1,
            math.min(
                500,
                math.floor(
                    tonumber(prefix_count) or 100
                )
            )
        )

    local command =
        team_only == true
        and "say_team"
        or "say"


    client.execnormal(
        command ..
        ' "' ..
        string.rep(
            "\r",
            prefix_count
        ) ..
        body ..
        '"'
    )

    return true
end


