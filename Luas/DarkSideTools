function spammer_cfg.draw_layout_name_fields(
    vertical,
    spammer_controls_x
)
    local layout_name =
        vertical
        and "Vertical"
        or "Horizontal"

    local layout_id =
        vertical
        and "Vertical"
        or "Horizontal"

    local character_limit =
        vertical
        and DARKSIDE_CONFIG.MAX_VERTICAL_NAME_CHARACTERS
        or DARKSIDE_CONFIG.MAX_NAME_CHARACTERS

    local indices =
        spammer_cfg.get_name_indices_for_layout(
            vertical
        )

    if #indices <= 0 then
        disabled_button(
            "Select All##" ..
            layout_id ..
            "SpammerNames"
        )

        theme_text_colored(
            0.70, 0.70, 0.70, 1.0,
            "No " ..
            layout_name:lower() ..
            " name fields."
        )
    elseif spammer_cfg.are_all_layout_names_enabled(
        vertical
    ) then
        if colored_button(
            "Deselect All##" ..
            layout_id ..
            "SpammerNames",
            1.0, 1.0, 1.0,
            0.55, 0.08, 0.08
        ) then
            spammer_cfg.set_all_layout_names_enabled(
                vertical,
                false
            )
        end
    elseif colored_button(
        "Select All##" ..
        layout_id ..
        "SpammerNames",
        1.0, 1.0, 1.0,
        0.08, 0.42, 0.12
    ) then
        spammer_cfg.set_all_layout_names_enabled(
            vertical,
            true
        )
    end

    draw_compact_gap()

    for layout_position, index in ipairs(indices) do
        local field_enabled =
            spammer_cfg.is_name_enabled(
                index
            )

        local configured_name =
            sanitize_name(
                get_spammer_name(
                    index
                )
            )

        local limited_name,
            character_count =
                spammer_cfg.limit_name_characters(
                    configured_name,
                    character_limit
                )

        if limited_name ~= configured_name then
            configured_name =
                limited_name

            set_spammer_name(
                index,
                configured_name
            )
        end

        local changed_enabled,
            enabled_value =
                imgui.checkbox(
                    "##SpammerNameEnabled" ..
                    tostring(index),
                    field_enabled
                )

        if changed_enabled then
            spammer_cfg.set_name_enabled(
                index,
                enabled_value
            )
        end

        imgui.same_line()

        imgui.text(
            "Name " ..
            tostring(layout_position) ..
            ":"
        )

        imgui.same_line()

        ui.lobby.set_cursor_x(
            spammer_controls_x
        )

        imgui.push_item_width(185)

        local changed_name,
            name_value =
                imgui.input_text(
                    "##SpammerName" ..
                    tostring(index),
                    configured_name,
                    character_limit + 1
                )

        imgui.pop_item_width()

        if changed_name then
            configured_name,
                character_count =
                    spammer_cfg.limit_name_characters(
                        name_value,
                        character_limit
                    )

            set_spammer_name(
                index,
                configured_name
            )

            spammer_cfg.recalculate_smart_limits(
                true
            )

            if vertical then
                if configured_name ~= "" then
                    spammer_preview_selection =
                        spammer_cfg.get_preview_selection_for_name_index(
                            index
                        )
                else
                    spammer_preview_selection = 0
                end
            end
        end

        imgui.same_line()

        if configured_name ~= "" then
            if colored_button(
                "Clear##SpammerName" ..
                tostring(index),
                1.0, 1.0, 1.0,
                0.34, 0.12, 0.12
            ) then
                set_spammer_name(
                    index,
                    ""
                )

                spammer_cfg.recalculate_smart_limits(
                    true
                )

                configured_name = ""
                character_count = 0

                if vertical then
                    spammer_preview_selection = 0
                end
            end
        else
            disabled_button(
                "Clear##SpammerName" ..
                tostring(index)
            )
        end

        imgui.same_line()

        local apply_button_label =
            "Apply " ..
            layout_name ..
            "##SpammerNameApply" ..
            layout_id ..
            tostring(index)

        local action_available =
            configured_name ~= ""
            and character_count <=
                character_limit

        local action_clicked = false

        if not action_available then
            disabled_button(
                apply_button_label
            )
        elseif vertical then
            action_clicked =
                colored_button(
                    apply_button_label,
                    1.0, 1.0, 1.0,
                    0.30, 0.20, 0.48
                )
        else
            action_clicked =
                colored_button(
                    apply_button_label,
                    0.15, 1.0, 1.0,
                    0.05, 0.30, 0.34
                )
        end

        if action_clicked then
            stop_name_spammer()
            stop_name_stealer()

            local applied =
                apply_specific_spammer_name(
                    configured_name,
                    "Name " .. tostring(layout_position),
                    false,
                    vertical
                )

            if applied then
                spammer_runtime.status =
                    "Name " ..
                    tostring(layout_position) ..
                    " - " ..
                    layout_name

                if vertical then
                    spammer_preview_selection =
                        spammer_cfg.get_preview_selection_for_name_index(
                            index
                        )
                end
            end
        end

        imgui.same_line()

        local length_text =
            string.format(
                "Length: %d/%d",
                character_count,
                character_limit
            )

        if character_count >= character_limit then
            theme_text_colored(
                1.0, 0.20, 0.20, 1.0,
                length_text
            )
        else
            imgui.text(
                length_text
            )
        end
    end

    local can_add =
        #indices <
            DARKSIDE_CONFIG.MAX_SPAMMER_NAMES_PER_LAYOUT
        and get_spammer_name_count() <
            DARKSIDE_CONFIG.MAX_SPAMMER_NAMES

    local add_label =
        "Add Field##Add" ..
        layout_id ..
        "SpammerField"

    if can_add then
        if colored_button(
            add_label,
            vertical
                and 1.0
                or 0.15,
            1.0,
            1.0,
            vertical
                and 0.30
                or 0.05,
            vertical
                and 0.20
                or 0.30,
            vertical
                and 0.48
                or 0.34
        ) then
            add_spammer_name_field(
                vertical
            )
        end
    else
        disabled_button(
            add_label
        )
    end

    imgui.same_line()

    local remove_label =
        "Remove Last Field##Remove" ..
        layout_id ..
        "SpammerField"

    if #indices > 2 then

        if colored_button(
            remove_label,
            1.0, 1.0, 1.0,
            0.55, 0.08, 0.08
        ) then
            if spammer_cfg.remove_last_name_field_for_layout(
                vertical
            ) then
                local preview_options =
                    build_spammer_preview_options()

                if spammer_preview_selection >
                    #preview_options - 1 then

                    spammer_preview_selection =
                        math.max(
                            0,
                            #preview_options - 1
                        )
                end
            end
        end
    else
        disabled_button(
            remove_label
        )
    end
end


