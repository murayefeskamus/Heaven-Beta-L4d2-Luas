            local standalone_width = 220

            local function truncate_overlay_text_to_width(
                value,
                maximum_width
            )
                value =
                    tostring(value or "")

                maximum_width =
                    math.max(
                        0,
                        tonumber(maximum_width) or 0
                    )

                if maximum_width <= 0 then
                    return ""
                end

                if ui.lobby.measure_text_width(
                    value
                ) <= maximum_width then

                    return value
                end

                local ellipsis = "..."

                if ui.lobby.measure_text_width(
                    ellipsis
                ) > maximum_width then

                    return ""
                end

                local characters = {}
                local index = 1

                while index <= #value do
                    local first_byte =
                        value:byte(index)

                    local character_length = 1

                    if first_byte >= 0xC2
                        and first_byte <= 0xDF then

                        character_length = 2
                    elseif first_byte >= 0xE0
                        and first_byte <= 0xEF then

                        character_length = 3
                    elseif first_byte >= 0xF0
                        and first_byte <= 0xF4 then

                        character_length = 4
                    end

                    if index + character_length - 1 >
                        #value then

                        character_length = 1
                    end

                    characters[
                        #characters + 1
                    ] =
                        value:sub(
                            index,
                            index + character_length - 1
                        )

                    index =
                        index + character_length
                end

                while #characters > 0 do
                    local candidate =
                        table.concat(
                            characters
                        ) ..
                        ellipsis

                    if ui.lobby.measure_text_width(
                        candidate
                    ) <= maximum_width then

                        return candidate
                    end

                    table.remove(
                        characters
                    )
                end

                return ellipsis
            end

            local function draw_overlay_table(
                unique_id,
                rows,
                maximum_height,
                maximum_label_width
            )
                local label_width = 0

                for _,
                    row in ipairs(
                        rows
                    ) do

                    label_width =
                        math.max(
                            label_width,
                            ui.lobby.measure_text_width(
                                tostring(
                                    row.label or ""
                                )
                            )
                        )
                end

                maximum_label_width =
                    math.max(
                        64,
                        math.min(
                            standalone_width - 64,
                            tonumber(
                                maximum_label_width
                            ) or 94
                        )
                    )

                label_width =
                    math.max(
                        64,
                        math.min(
                            maximum_label_width,
                            label_width + 12
                        )
                    )

                local divider_offset =
                    label_width

                local value_x_offset =
                    divider_offset + 10

                local table_height =
                    8 +
                    #rows * 21

                maximum_height =
                    tonumber(
                        maximum_height
                    ) or 0

                if maximum_height > 0 then
                    table_height =
                        math.min(
                            table_height,
                            maximum_height
                        )
                end

                local table_open =
                    imgui.begin_child(
                        unique_id,
                        standalone_width,
                        table_height,
                        false,
                        0
                    )

                if table_open then
                    local start_x =
                        ui.lobby.get_cursor_x()

                    local divider_x =
                        start_x +
                        divider_offset

                    local value_x =
                        start_x +
                        value_x_offset

                    local function draw_pipe()
                        imgui.same_line()

                        ui.lobby.set_cursor_x(
                            divider_x
                        )

                        theme_text_colored(
                            palette.text_disabled[1],
                            palette.text_disabled[2],
                            palette.text_disabled[3],
                            1.0,
                            "|"
                        )
                    end

                    for _,
                        row in ipairs(
                            rows
                        ) do

                        local rendered_label =
                            truncate_overlay_text_to_width(
                                row.label,
                                math.max(
                                    0,
                                    divider_offset - 6
                                )
                            )

                        theme_text_colored(
                            palette.text_disabled[1],
                            palette.text_disabled[2],
                            palette.text_disabled[3],
                            1.0,
                            rendered_label
                        )

                        draw_pipe()
                        imgui.same_line()

                        ui.lobby.set_cursor_x(
                            value_x
                        )

                        local default_value_color =
                            palette.light == true
                            and (
                                palette.accent
                                or palette.section_text
                                or palette.text
                            )
                            or palette.text

                        local value_r =
                            default_value_color[1]

                        local value_g =
                            default_value_color[2]

                        local value_b =
                            default_value_color[3]

                        if row.special ==
                            "status" then

                            local live_status =
                                tostring(
                                    row.value or ""
                                )

                            value_r,
                                value_g,
                                value_b =
                                    ui.quotes.get_status_color(
                                        live_status,
                                        palette
                                    )
                        elseif row.special ==
                            "queue" then

                            value_r,
                                value_g,
                                value_b =
                                    ui.quotes.get_queue_color()
                        end

                        theme_text_colored(
                            value_r,
                            value_g,
                            value_b,
                            1.0,
                            tostring(
                                row.value or ""
                            )
                        )

                        imgui.separator()
                    end
                end

                imgui.end_child()
            end

            local function draw_detected_quotes(
                detected_override
            )
                local detected =
                    type(detected_override) == "table"
                    and detected_override
                    or ui.quotes.get_detected_players()

                local detected_player_count =
                    #detected

                ui.quotes.draw_overlay_section(
                    "DETECTED - " ..
                    tostring(
                        detected_player_count
                    ) ..
                    " " ..
                    (
                        detected_player_count == 1
                        and "player"
                        or "players"
                    )
                )

                local detected_rows = {}

                if #detected == 0 then
                    detected_rows[1] = {
                        label = "None",
                        value = "-"
                    }
                else
                    for _,
                        player in ipairs(
                            detected
                        ) do

                        local quote_count =
                            tonumber(
                                player.quote_count
                            ) or 0

                        detected_rows[
                            #detected_rows + 1
                        ] = {
                            label =
                                "ID " ..
                                tostring(
                                    player.userid
                                ) ..
                                ": " ..
                                truncate_preview(
                                    tostring(
                                        player.name or
                                        "Unknown"
                                    ),
                                    22
                                ),
                            value =
                                tostring(
                                    quote_count
                                ) ..
                                " " ..
                                (
                                    quote_count == 1
                                    and "quote"
                                    or "quotes"
                                )
                        }
                    end
                end

                draw_overlay_table(
                    "QuotesStandaloneDetectedTable",
                    detected_rows,
                    176,
                    144
