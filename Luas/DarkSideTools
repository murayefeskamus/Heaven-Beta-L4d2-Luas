        or {}
    model.global_transitions =
        type(model.global_transitions) == "table"
        and model.global_transitions
        or {}
    model.observation_count = math.max(
        0,
        math.floor(tonumber(model.observation_count) or 0)
    )
    model.revision = math.max(
        0,
        math.floor(tonumber(model.revision) or 0)
    )


    return model
end

function ui.lobby.get_infected_prediction_player_state(player_record)
    local model = ui.lobby.ensure_infected_prediction_model()
    local identity = ui.lobby.get_infected_prediction_player_identity(player_record)
    local state = model.players[identity]

    if type(state) ~= "table" then
        state = {
            identity = identity,
            class_counts = {},
            transitions = {},
            active = false,
            active_class_id = nil,
            last_class_id = nil,
            last_assignment_at = 0.0,
            waiting_since = nil,
            observations = 0,
            predicted_class_id = nil,
            predicted_at = 0.0,
            predicted_wave = 0,
            last_prediction_result = "none",
            last_prediction_class_id = nil,
            last_prediction_actual_class_id = nil,
            last_prediction_checked_at = 0.0
        }

        model.players[identity] = state
    end

    state.class_counts =
        type(state.class_counts) == "table"
        and state.class_counts
        or {}
    state.transitions =
        type(state.transitions) == "table"
        and state.transitions
        or {}

    return state, model, identity
end

function ui.lobby.mark_infected_prediction_waiting(
    player_record,
    waiting_at
)
    if type(player_record) ~= "table"
        or tonumber(player_record.team) ~= 3
        or player_record.is_bot == true then

        return false
    end

    local state, model =
        ui.lobby.get_infected_prediction_player_state(player_record)

    waiting_at = tonumber(waiting_at) or get_time()

    state.active = false
    state.active_class_id = nil
    state.waiting_since = waiting_at
    model.revision = math.max(0, tonumber(model.revision) or 0) + 1
    ui.lobby.infected_prediction_cache = nil
    ui.lobby.infected_player_prediction_cache = nil

    return true
end

function ui.lobby.observe_infected_prediction_state(player_record, assignment)
    if type(player_record) ~= "table" then
        return
    end

    local state, model =
        ui.lobby.get_infected_prediction_player_state(player_record)
    local now = get_time()

    if type(assignment) ~= "table" or tonumber(assignment.id) == nil then
        if state.active == true then
            state.active = false
            state.active_class_id = nil
            state.waiting_since = now
            model.revision = model.revision + 1
            ui.lobby.infected_prediction_cache = nil
            ui.lobby.infected_player_prediction_cache = nil
        elseif state.waiting_since == nil then
            state.waiting_since = now
        end

        return
    end

    local class_id = math.floor(tonumber(assignment.id) or 0)
    if class_id <= 0 then
        return
    end

    local is_new_assignment =
        state.active ~= true
        or tonumber(state.active_class_id) ~= class_id

    if is_new_assignment then
        local predicted_class_id = math.floor(
            tonumber(state.predicted_class_id) or 0
        )

        if predicted_class_id > 0 then
            state.last_prediction_class_id = predicted_class_id
            state.last_prediction_actual_class_id = class_id
            state.last_prediction_result =
                predicted_class_id == class_id
                and "correct"
                or "wrong"
            state.last_prediction_checked_at = now
        else
            state.last_prediction_class_id = nil
            state.last_prediction_actual_class_id = class_id
            state.last_prediction_result = "none"
            state.last_prediction_checked_at = now
        end

        state.predicted_class_id = nil
        state.predicted_at = 0.0
        state.predicted_wave = 0
    end

    state.active = true
    state.active_class_id = class_id
    state.waiting_since = nil

    if not is_new_assignment then
        return
    end

    local previous_player_class = tonumber(state.last_class_id)
    local previous_global_class = tonumber(model.last_observed_class)

    state.class_counts[class_id] =
        math.max(0, tonumber(state.class_counts[class_id]) or 0) + 1
    state.observations =
        math.max(0, tonumber(state.observations) or 0) + 1

    if previous_player_class and previous_player_class > 0 then
        state.transitions[previous_player_class] =
            type(state.transitions[previous_player_class]) == "table"
            and state.transitions[previous_player_class]
            or {}

        state.transitions[previous_player_class][class_id] =
            math.max(
                0,
                tonumber(
                    state.transitions[previous_player_class][class_id]
                ) or 0
            ) + 1
    end

    if previous_global_class and previous_global_class > 0 then
        model.global_transitions[previous_global_class] =
            type(model.global_transitions[previous_global_class]) == "table"
            and model.global_transitions[previous_global_class]
            or {}

        model.global_transitions[previous_global_class][class_id] =
            math.max(
                0,
                tonumber(
                    model.global_transitions[previous_global_class][class_id]
                ) or 0
            ) + 1
    end

    state.last_class_id = class_id
    state.last_assignment_at = now
    model.last_observed_class = class_id
    model.global_class_counts[class_id] =
        math.max(0, tonumber(model.global_class_counts[class_id]) or 0) + 1
    model.global_class_last_seen[class_id] = now
    model.observation_count = model.observation_count + 1
    model.revision = model.revision + 1

    ui.lobby.infected_prediction_cache = nil
    ui.lobby.infected_player_prediction_cache = nil
end

function ui.lobby.get_infected_prediction_transition_factor(
    transition_table,
    previous_class_id,
    candidate_class_id,
    strength
)
    previous_class_id = math.floor(tonumber(previous_class_id) or 0)
    candidate_class_id = math.floor(tonumber(candidate_class_id) or 0)
    strength = math.max(0.0, math.min(1.0, tonumber(strength) or 0.0))

    if previous_class_id <= 0 or candidate_class_id <= 0 then
        return 1.0
    end

    local transitions =
        type(transition_table) == "table"
        and type(transition_table[previous_class_id]) == "table"
        and transition_table[previous_class_id]
        or nil

    if not transitions then
        return 1.0
    end

    local total = 0
    local candidate_count = 0
    local class_total = math.max(1, #ui.lobby.infected_prediction_class_order)

    for _, class_id in ipairs(ui.lobby.infected_prediction_class_order) do
        local count = math.max(0, tonumber(transitions[class_id]) or 0)
        total = total + count

        if class_id == candidate_class_id then
            candidate_count = count
        end
    end

    if total <= 0 then
        return 1.0
    end

    local smoothed_probability =
        (candidate_count + 1) / (total + class_total)
    local neutral_probability = 1 / class_total
    local relative = smoothed_probability / neutral_probability

    return 1.0 + (relative - 1.0) * strength
end


function ui.lobby.format_prediction_percentage(
    value
)
    local number = tonumber(value) or 0.0

    if number ~= number then
        number = 0.0
    end

    number = math.max(
        0.0,
        math.min(
            100.0,
            number
        )
    )

    local rounded_tenth =
        math.floor(number * 10.0 + 0.5) / 10.0
    local rounded_whole =
        math.floor(rounded_tenth + 0.5)

    if math.abs(rounded_tenth - rounded_whole) < 0.05 then
        return tostring(rounded_whole) .. "%"
    end

    return string.format(
        "%.1f%%",
        rounded_tenth
    )
end



function ui.lobby.normalize_prediction_result_state(
    value
)
    value = tostring(value or ""):lower()

    if value == "correct" or value == "yes" then
        return "correct"
    end

    if value == "wrong" or value == "incorrect" or value == "no" then
        return "wrong"
    end

    if value == "pending" then
        return "pending"
    end

    return "none"
end

function ui.lobby.get_prediction_result_indicator_color(
    prediction_row,
    persist_until_reset
)
    local state = ui.lobby.normalize_prediction_result_state(
        type(prediction_row) == "table"
        and prediction_row.prediction_result
        or nil
    )

    if state ~= "correct" and state ~= "wrong" then
        return "", 0.44, 0.44, 0.46
    end

    local checked_at = tonumber(
        type(prediction_row) == "table"
        and prediction_row.prediction_checked_at
        or 0.0
    ) or 0.0

    if persist_until_reset ~= true then
        if checked_at <= 0.0
            or get_time() - checked_at > 5.0 then

            return "", 0.44, 0.44, 0.46
        end
    elseif checked_at <= 0.0 then
        return "", 0.44, 0.44, 0.46
    end

    if state == "correct" then
        return "●", 0.20, 1.0, 0.34
    end

    return "●", 1.0, 0.22, 0.22
end

function ui.lobby.hash_infected_prediction_seed(
    seed_value
)
    local text = tostring(seed_value or "")
    local hash = 5381

    for index = 1, #text do
        hash = (
            hash * 33 +
            string.byte(text, index)
        ) % 2147483647
    end

    return math.max(
        0,
        math.floor(hash)
    )
end

function ui.lobby.score_infected_prediction_class(
    player_row,
    class_id,
    remaining_slots,
    configured_limits,
    simulated_assignments,
    prediction_wave
)
    local slots = math.max(0, tonumber(remaining_slots[class_id]) or 0)
    local class_limit = math.max(0, tonumber(configured_limits[class_id]) or 0)

    if slots <= 0 then
        return 0.0
    end

    local state, model =
        ui.lobby.get_infected_prediction_player_state(player_row.player)
    local now = get_time()
    local slot_ratio = class_limit > 0 and slots / class_limit or 1.0

    local score = slots * (0.80 + slot_ratio * 0.55)

    local player_class_count =
        math.max(0, tonumber(state.class_counts[class_id]) or 0)
    score = score / (1.0 + player_class_count * 0.28)

    if tonumber(state.last_class_id) == class_id then
        local age = now - math.max(
            0.0,
            tonumber(state.last_assignment_at) or 0.0
        )

        if age < 30.0 then
            score = score * 0.20
        elseif age < 90.0 then
            score = score * 0.38
        else
            score = score * 0.62
        end
    end

    local global_count =
        math.max(0, tonumber(model.global_class_counts[class_id]) or 0)
    score = score / (1.0 + global_count * 0.055)

    local last_seen = tonumber(model.global_class_last_seen[class_id]) or 0.0
    local global_age = now - last_seen

    if last_seen > 0 then
        if global_age < 5.0 then
            score = score * 0.58
        elseif global_age < 15.0 then
            score = score * 0.74
        elseif global_age < 35.0 then
            score = score * 0.88
        end
    end

    score = score * ui.lobby.get_infected_prediction_transition_factor(
        state.transitions,
        state.last_class_id,
        class_id,
        0.34
    )

    score = score * ui.lobby.get_infected_prediction_transition_factor(
        model.global_transitions,
        model.last_observed_class,
        class_id,
        0.18
    )

    local simulated_count =
        math.max(0, tonumber(simulated_assignments[class_id]) or 0)
    score = score / (1.0 + simulated_count * 0.42)

    if tonumber(prediction_wave) and tonumber(prediction_wave) > 1 then
        score = math.sqrt(math.max(0.0, score))
    end

    local identity = tostring(player_row.identity or "")
    local map_code = tostring(
        ui.lobby.overview
        and ui.lobby.overview.map_code
        or ""
    )
    local tie_seed = map_code ..
        "|" .. identity ..
        "|class:" .. tostring(class_id) ..
        "|wave:" .. tostring(prediction_wave or 1) ..
        "|revision:" .. tostring(model.revision or 0)
    local tie_hash = ui.lobby.hash_infected_prediction_seed(tie_seed)
    local tie_factor = 0.985 + ((tie_hash % 31) / 1000.0)

    return math.max(0.0, score * tie_factor)
end

function ui.lobby.get_next_infected_class_prediction(force_refresh)
    local now = get_time()
    local cached_prediction = ui.lobby.infected_prediction_cache

    if force_refresh ~= true
        and type(cached_prediction) == "table"
        and now - (tonumber(ui.lobby.infected_prediction_cache_at) or 0.0) <
            math.max(0.05, tonumber(ui.lobby.infected_prediction_cache_interval) or 0.20) then

        return cached_prediction
    end

    local model = ui.lobby.ensure_infected_prediction_model()
    local occupied = {}

    for _, class_id in ipairs(ui.lobby.infected_prediction_class_order) do
        occupied[class_id] = 0
    end

    local infected_players =
        ui.lobby.collect_unique_infected_players(ui.lobby.players or {})

    for _, player_record in ipairs(infected_players) do
        local assignment = nil

        if tonumber(player_record.entity_index)
            and tonumber(player_record.entity_index) > 0 then

            assignment = ui.lobby.get_verified_infected_assignment_by_index(
                player_record.entity_index,
                false
            )
        end

        if not assignment
            and tonumber(player_record.userid)
            and tonumber(player_record.userid) > 0 then

            assignment = ui.lobby.get_verified_infected_assignment(
                player_record.userid,
                false
            )
        end

        ui.lobby.observe_infected_prediction_state(player_record, assignment)

        if assignment and occupied[assignment.id] ~= nil then
            occupied[assignment.id] = occupied[assignment.id] + 1
        end
    end

    local rows = {}
    local total_weight = 0.0

    for _, class_id in ipairs(ui.lobby.infected_prediction_class_order) do
        local class_limit =
            ui.lobby.get_infected_prediction_class_limit(class_id)
        local occupied_count =
            math.max(0, tonumber(occupied[class_id]) or 0)
        local available_slots =
            math.max(0, class_limit - occupied_count)
        local weight = available_slots

        if weight > 0 then
            local global_count =
                math.max(
                    0,
                    tonumber(model.global_class_counts[class_id]) or 0
                )
            weight = weight / (1.0 + global_count * 0.04)

            local last_seen =
                tonumber(model.global_class_last_seen[class_id]) or 0.0
            local age = now - last_seen

            if last_seen > 0 and age < 10.0 then
                weight = weight * 0.78
            elseif last_seen > 0 and age < 30.0 then
                weight = weight * 0.91
            end
        end

        total_weight = total_weight + weight

        rows[#rows + 1] = {
            id = class_id,
            name = tostring(
                ui.lobby.verified_infected_class_names[class_id]
                or ("Class " .. tostring(class_id))
            ),
            occupied = occupied_count,
            limit = class_limit,
            slots = available_slots,
            weight = weight,
            chance = 0.0
        }
    end

    local fallback = false

    if total_weight <= 0 then
        fallback = true
        total_weight = 0.0

        for _, row in ipairs(rows) do
            row.weight = row.limit > 0 and row.limit or 0
            total_weight = total_weight + row.weight
        end
    end

    if total_weight <= 0 then
        for _, row in ipairs(rows) do
            row.weight = 1
        end

        total_weight = #rows
        fallback = true
    end

    local accumulated = 0.0
    local last_positive_row = nil

    for _, row in ipairs(rows) do
        if row.weight > 0 then
            row.chance =
                math.floor((row.weight / total_weight * 1000) + 0.5) / 10
            accumulated = accumulated + row.chance
            last_positive_row = row
        end
    end

    if last_positive_row then
        last_positive_row.chance = math.max(
            0.0,
            last_positive_row.chance + (100.0 - accumulated)
        )
    end

    local prediction = {
        rows = rows,
        occupied = occupied,
        fallback = fallback,
        total_weight = total_weight,
        model_revision = model.revision,
        observation_count = model.observation_count
    }

    ui.lobby.infected_prediction_cache = prediction
    ui.lobby.infected_prediction_cache_at = now

    return prediction
end

function ui.lobby.get_known_real_infected_prediction_players(
    source_records
)
    source_records =
        type(source_records) == "table"
        and source_records
        or {}

    local model =
        ui.lobby.ensure_infected_prediction_model()

    local session_key =
        tostring(model.session_key or "")

    local cache =
        type(ui.lobby.infected_prediction_known_players) == "table"
        and ui.lobby.infected_prediction_known_players
        or nil

    if not cache
        or tostring(cache.session_key or "") ~= session_key then

        cache = {
            session_key = session_key,
            records = {},
            order = {},
            stable_order = {},
            next_order = 1
        }

        ui.lobby.infected_prediction_known_players = cache
    end

    cache.records =
        type(cache.records) == "table"
        and cache.records
        or {}

    cache.order =
        type(cache.order) == "table"
        and cache.order
        or {}

    cache.stable_order =
        type(cache.stable_order) == "table"
        and cache.stable_order
        or {}

    cache.next_order =
        math.max(
            1,
            math.floor(
                tonumber(cache.next_order) or 1
            )
        )

    local now =
        get_time()

    local touched = {}

    for _, player_record in ipairs(source_records) do
        if type(player_record) == "table"
            and player_record.is_bot ~= true then

            local identity =
                ui.lobby.get_infected_prediction_player_identity(
                    player_record
                )

            if identity ~= "" then
                if player_record.connected ~= false
                    and tonumber(player_record.team) == 3 then

                    local copy = {}

                    for key, value in pairs(player_record) do
                        copy[key] = value
                    end

                    copy._dst_prediction_last_seen = now

                    if cache.records[identity] == nil then
                        cache.order[#cache.order + 1] = identity
                    end

                    if tonumber(cache.stable_order[identity]) == nil then
                        cache.stable_order[identity] = cache.next_order
                        cache.next_order = cache.next_order + 1
                    end

                    copy._dst_prediction_order =
                        tonumber(cache.stable_order[identity])
                        or #cache.order
                    copy._dst_prediction_identity = identity

                    cache.records[identity] = copy
                    touched[identity] = true
                else
                    cache.records[identity] = nil
                end
            end
        end
    end

    local refreshed_order = {}
    local output_source = {}

    for _, identity in ipairs(cache.order) do
        local record =
            cache.records[identity]

        if type(record) == "table"
            and touched[identity] == true then

            refreshed_order[#refreshed_order + 1] = identity

            record._dst_prediction_order =
                tonumber(cache.stable_order[identity])
                or tonumber(record._dst_prediction_order)
                or #refreshed_order
            record._dst_prediction_identity = identity

            output_source[#output_source + 1] = record
        else
            cache.records[identity] = nil
            cache.stable_order[identity] = nil
        end
    end

    cache.order = refreshed_order

    return ui.lobby.collect_unique_infected_players(
        output_source,
        true
    )
end

function ui.lobby.get_infected_player_predictions(force_refresh)
    local now = get_time()
    local cached = ui.lobby.infected_player_prediction_cache

    if force_refresh ~= true
        and type(cached) == "table"
        and now - (tonumber(ui.lobby.infected_player_prediction_cache_at) or 0.0) <
            math.max(0.05, tonumber(ui.lobby.infected_prediction_cache_interval) or 0.20) then

        return cached
    end

    local class_prediction =
        ui.lobby.get_next_infected_class_prediction(force_refresh)
    local model = ui.lobby.ensure_infected_prediction_model()
    local remaining_slots = {}
    local configured_limits = {}
    local simulated_assignments = {}

    for _, class_row in ipairs(class_prediction.rows or {}) do
        remaining_slots[class_row.id] = math.max(
            0,
            math.floor(tonumber(class_row.slots) or 0)
        )
        configured_limits[class_row.id] = math.max(
            0,
            math.floor(tonumber(class_row.limit) or 0)
        )
        simulated_assignments[class_row.id] = 0
    end

    local infected_players =
        ui.lobby.get_known_real_infected_prediction_players(
            ui.lobby.players or {}
        )
    local rows = {}
    local waiting_rows = {}

    for _, player_record in ipairs(infected_players) do
        local assignment = nil

        if tonumber(player_record.entity_index)
            and tonumber(player_record.entity_index) > 0 then

            assignment = ui.lobby.get_verified_infected_assignment_by_index(
                player_record.entity_index,
                false
            )
        end

        if not assignment
            and tonumber(player_record.userid)
            and tonumber(player_record.userid) > 0 then

            assignment = ui.lobby.get_verified_infected_assignment(
                player_record.userid,
                false
            )
        end

        ui.lobby.observe_infected_prediction_state(player_record, assignment)

        local state =
            ui.lobby.get_infected_prediction_player_state(player_record)
        local identity =
            ui.lobby.get_infected_prediction_player_identity(player_record)
        local row = {
            player = player_record,
            identity = identity,
            name = tostring(
                player_record._dst_display_name
                or player_record.name
                or "Player"
            ),
            is_bot = player_record.is_bot == true,
            exact = assignment ~= nil,
            class_id = assignment and assignment.id or nil,
            class_name = assignment and assignment.name or nil,
            chance = assignment and 100.0 or 0.0,
            state = assignment
                and (assignment.is_ghost and "Ghost" or "Spawned")
                or (player_record.alive == false and "Waiting" or "Pending"),
            wave = 0,
            waiting_since = tonumber(state.waiting_since) or now,
            model_observations = tonumber(state.observations) or 0,
            stable_order = tonumber(player_record._dst_prediction_order) or 9999,
            prediction_result = ui.lobby.normalize_prediction_result_state(
                state.last_prediction_result
            ),
            prediction_checked_at = tonumber(state.last_prediction_checked_at) or 0.0
        }

        rows[#rows + 1] = row

        if not assignment then
            waiting_rows[#waiting_rows + 1] = row
        end
    end

    table.sort(
        waiting_rows,
        function(first, second)
            local first_wait = tonumber(first.waiting_since) or now
            local second_wait = tonumber(second.waiting_since) or now

            if first_wait ~= second_wait then
                return first_wait < second_wait
            end

            local first_userid =
                math.floor(tonumber(first.player and first.player.userid) or 0)
            local second_userid =
                math.floor(tonumber(second.player and second.player.userid) or 0)

            if first_userid ~= second_userid then
                return first_userid < second_userid
            end

            return math.floor(
                tonumber(first.player and first.player.entity_index) or 0
            ) < math.floor(
                tonumber(second.player and second.player.entity_index) or 0
            )
        end
    )

    local prediction_wave = 1
    local used_future_wave = false

    for _, row in ipairs(waiting_rows) do
        local total_slots = 0

        for _, class_id in ipairs(ui.lobby.infected_prediction_class_order) do
            total_slots = total_slots + math.max(
                0,
                tonumber(remaining_slots[class_id]) or 0
            )
        end

        if total_slots <= 0 then
            prediction_wave = prediction_wave + 1
            used_future_wave = true

            for _, class_id in ipairs(ui.lobby.infected_prediction_class_order) do
                remaining_slots[class_id] = math.max(
                    0,
                    tonumber(configured_limits[class_id]) or 0
                )
                simulated_assignments[class_id] = 0
            end
        end

        local score_rows = {}
        local score_total = 0.0

        for _, class_id in ipairs(ui.lobby.infected_prediction_class_order) do
            local score = ui.lobby.score_infected_prediction_class(
                row,
                class_id,
                remaining_slots,
                configured_limits,
                simulated_assignments,
                prediction_wave
            )

            if score > 0 then
                score_rows[#score_rows + 1] = {
                    class_id = class_id,
                    score = score
                }
                score_total = score_total + score
            end
        end

        if #score_rows == 0 then
            for _, class_id in ipairs(ui.lobby.infected_prediction_class_order) do
                score_rows[#score_rows + 1] = {
                    class_id = class_id,
                    score = 1.0
                }
                score_total = score_total + 1.0
            end

            used_future_wave = true
        end

        table.sort(
            score_rows,
            function(first, second)
                if first.score ~= second.score then
                    return first.score > second.score
                end

                return first.class_id < second.class_id
            end
        )

        local best = score_rows[1]
        local second = score_rows[2]
        local selected_class_id = best and best.class_id or nil
        local best_score = best and best.score or 0.0
        local second_score = second and second.score or 0.0
        local raw_share = score_total > 0
            and best_score / score_total
            or 0.0
        local margin = best_score > 0
            and math.max(0.0, (best_score - second_score) / best_score)
            or 0.0
        local evidence = math.min(
            1.0,
            (tonumber(model.observation_count) or 0) / 16.0
        )

        local confidence =
            22.0 + raw_share * 48.0 + margin * 24.0 + evidence * 6.0

        if #score_rows == 1 then
            confidence = 96.0
        end

        if prediction_wave > 1 then
            confidence = math.min(78.0, confidence * 0.78)
        end

        confidence = math.max(18.0, math.min(96.0, confidence))

        row.class_id = selected_class_id
        row.class_name = tostring(
            ui.lobby.verified_infected_class_names[selected_class_id]
            or "Unavailable"
        )
        row.chance = confidence
        row.wave = prediction_wave
        row.candidate_share = raw_share * 100.0
        row.confidence_margin = margin * 100.0

        local row_state =
            ui.lobby.get_infected_prediction_player_state(
                row.player
            )

        if selected_class_id then
            row_state.predicted_class_id = selected_class_id
            row_state.predicted_at = now
            row_state.predicted_wave = prediction_wave
            row_state.last_prediction_result = "pending"
            row.prediction_result = "pending"
        end

        if selected_class_id then
            remaining_slots[selected_class_id] = math.max(
                0,
                (tonumber(remaining_slots[selected_class_id]) or 0) - 1
            )
            simulated_assignments[selected_class_id] =
                math.max(
                    0,
                    tonumber(simulated_assignments[selected_class_id]) or 0
                ) + 1
        end
    end


    table.sort(
        rows,
        function(left, right)
            local left_order = tonumber(left.stable_order) or 9999
            local right_order = tonumber(right.stable_order) or 9999

            if left_order ~= right_order then
                return left_order < right_order
            end

            local left_userid = math.floor(
                tonumber(left.player and left.player.userid) or 0
            )
            local right_userid = math.floor(
                tonumber(right.player and right.player.userid) or 0
            )

            if left_userid ~= right_userid then
                return left_userid < right_userid
            end

            return tostring(left.name or ""):lower() <
                tostring(right.name or ""):lower()
        end
    )

    local result = {
        rows = rows,
        used_future_wave = used_future_wave,
        class_prediction = class_prediction,
        model_revision = model.revision,
        observation_count = model.observation_count,
        local_only = true
    }

    ui.lobby.infected_player_prediction_cache = result
    ui.lobby.infected_player_prediction_cache_at = now

    return result
end

function ui.lobby.get_infected_player_prediction(player_record, force_refresh)
    if type(player_record) ~= "table" then
        return nil
    end

    local wanted_entity = math.floor(tonumber(player_record.entity_index) or 0)
    local wanted_userid = math.floor(tonumber(player_record.userid) or 0)
    local wanted_identity = tostring(
        player_record.prediction_identity
        or ui.lobby.get_infected_prediction_player_identity(player_record)
        or ""
    )
    local wanted_name = tostring(player_record.name or ""):lower()
    local predictions = ui.lobby.get_infected_player_predictions(force_refresh)

    for _, row in ipairs(predictions.rows or {}) do
        local candidate = row.player or {}

        if wanted_entity > 0
            and wanted_entity == math.floor(tonumber(candidate.entity_index) or 0) then
            return row
        end

        if wanted_userid > 0
            and wanted_userid == math.floor(tonumber(candidate.userid) or 0) then
            return row
        end

        if wanted_identity ~= "" and wanted_identity == tostring(row.identity or "") then
            return row
        end
    end

    local name_match = nil
    local name_match_count = 0

    if wanted_name ~= "" then
        for _, row in ipairs(predictions.rows or {}) do
            local candidate = row.player or {}
            if wanted_name == tostring(candidate.name or ""):lower() then
                name_match = row
                name_match_count = name_match_count + 1
            end
        end
    end

    return name_match_count == 1 and name_match or nil
end

function ui.lobby.infected_query_target_label(target)
    target = type(target) == "table" and target or {}

    return tostring(
        target.display_name
        or target.name
        or "Player"
    )
end

function ui.lobby.process_infected_class_queries()
    local pending_queries = ui.lobby.pending_infected_class_queries

    if type(pending_queries) ~= "table" then
        ui.lobby.pending_infected_class_queries = {}
        return
    end

    local now = get_time()
    local local_record = nil

    for _, player_record in ipairs(ui.lobby.players or {}) do
        if player_record.is_local then
            local_record = player_record
            break
        end
    end

    local prediction_snapshot_ready = false

    for query_key, query in pairs(pending_queries) do
        if now >= (tonumber(query.next_poll) or 0) then
            query.next_poll = now + ui.lobby.infected_detection_poll_interval

            local requester = ui.lobby.find_player_by_userid(query.requester_userid)
            local owner_request = query.owner_request == true
                and is_local_player_userid(query.requester_userid)
            local request_still_allowed = owner_request
                or (
                    requester
                    and tonumber(requester.team) == 3
                    and local_record
                    and tonumber(local_record.team) == 3
                )

            if not request_still_allowed then
                pending_queries[query_key] = nil
            else
                local all_resolved = true

                for _, target in ipairs(query.targets or {}) do
                    if target.resolved ~= true then
                        all_resolved = false
                        local current_record = nil

                        if tonumber(target.entity_index)
                            and tonumber(target.entity_index) > 0 then

                            current_record = ui.lobby.find_player_by_entity_index(
                                target.entity_index
                            )
                        end

                        if not current_record
                            and tonumber(target.userid)
                            and tonumber(target.userid) > 0 then

                            current_record = ui.lobby.find_player_by_userid(
                                target.userid
                            )
                        end

                        if current_record then
                            target.name = tostring(current_record.name or target.name or "Player")
                            target.entity_index = math.floor(
                                tonumber(current_record.entity_index)
                                or tonumber(target.entity_index)
                                or 0
                            )
                            target.is_bot = current_record.is_bot == true

                            local refreshed_userid = math.floor(
                                tonumber(current_record.userid) or 0
                            )

                            if refreshed_userid > 0 then
                                target.userid = refreshed_userid
                            end
                        end

                        local target_label = ui.lobby.infected_query_target_label(target)

                        if current_record and tonumber(current_record.team) ~= 3 then
                            target.result = target_label .. " is no longer on the Infected team."
                            target.resolved = true
                        else
                            local assignment = nil
                            local assignment_error = "entity unavailable"

                            if tonumber(target.entity_index)
                                and tonumber(target.entity_index) > 0 then

                                assignment, assignment_error =
                                    ui.lobby.get_verified_infected_assignment_by_index(
                                        target.entity_index,
                                        false
                                    )
                            end

                            if not assignment
                                and tonumber(target.userid)
                                and tonumber(target.userid) > 0 then

                                local userid_assignment, userid_error =
                                    ui.lobby.get_verified_infected_assignment(
                                        target.userid,
                                        false
                                    )

                                if userid_assignment then
                                    assignment = userid_assignment
                                    assignment_error = nil
                                elseif assignment_error == "entity unavailable" then
                                    assignment_error = userid_error
                                end
                            end

                            target.last_error = tostring(assignment_error or "")

                            if assignment then
                                if target.last_class_id == assignment.id then
                                    target.stable_reads =
                                        (tonumber(target.stable_reads) or 0) + 1
                                else
                                    target.last_class_id = assignment.id
                                    target.stable_reads = 1
                                end

                                if target.stable_reads >= 3 then
                                    local state_label = assignment.is_ghost
                                        and "assigned ghost class"
                                        or "current class"

                                    target.result = target_label ..
                                        " - " .. state_label ..
                                        ": " .. tostring(assignment.name)
                                    target.resolved = true
                                end
                            elseif now - (tonumber(query.started_at) or now) >=
                                ui.lobby.infected_detection_max_wait then

                                if target.last_error == "not infected" then
                                    target.result = target_label ..
                                        " - no longer on the Infected team."
                                else
                                    if not prediction_snapshot_ready then
                                        ui.lobby.get_infected_player_predictions(true)
                                        prediction_snapshot_ready = true
                                    end

                                    local prediction_row =
                                        ui.lobby.get_infected_player_prediction(
                                            current_record or target,
                                            false
                                        )

                                    if prediction_row then
                                        target.result =
                                            ui.lobby.format_infected_player_prediction_line(
                                                prediction_row
                                            )
                                        target.predicted = true
                                    else
                                        target.result = target_label ..
                                            " - class prediction unavailable."
                                    end
                                end

                                target.resolved = true
                            end
                        end

                        if target.resolved == true then
                            all_resolved = true

                            for _, other_target in ipairs(query.targets or {}) do
                                if other_target.resolved ~= true then
                                    all_resolved = false
                                    break
                                end
                            end
                        end
                    end
                end

                if all_resolved then
                    local messages = {}

                    if tostring(query.mode) == "all" then
                        messages[#messages + 1] = "Infected classes and predictions:"
                    end

                    local has_prediction = false
                    local message_order = {}
                    local message_counts = {}

                    for _, target in ipairs(query.targets or {}) do
                        local line = tostring(
                            target.result
                            or ui.lobby.format_infected_player_prediction_line(
                                ui.lobby.get_infected_player_prediction(target, false)
                            )
                        )

                        if message_counts[line] == nil then
                            message_order[#message_order + 1] = line
                            message_counts[line] = 1
                        else
                            message_counts[line] = message_counts[line] + 1
                        end

                        if target.predicted == true then
                            has_prediction = true
                        end
                    end

                    for _, line in ipairs(message_order) do
                        local count = message_counts[line] or 1
                        messages[#messages + 1] = count > 1
                            and (line .. " (x" .. tostring(count) .. ")")
                            or line
                    end

                    if has_prediction then
                        messages[#messages + 1] =
                            "Predictions use open class slots; the Director may differ."
                    end

                    ui.lobby.queue_zombieclass_messages(
                        messages,
                        query.response_team_only == true
                    )

                    pending_queries[query_key] = nil
                end
            end
        end
    end
end

function ui.enhancements.preview_infected_class_line(player_record)
    if not player_record then
        return "No Infected player selected."
    end

    local display_name = tostring(
        player_record._dst_display_name
        or player_record.name
        or "Player"
    )
    local assignment = nil

    if tonumber(player_record.entity_index)
        and tonumber(player_record.entity_index) > 0 then

        assignment = ui.lobby.get_verified_infected_assignment_by_index(
            player_record.entity_index,
            false
        )
    end

    if not assignment
        and tonumber(player_record.userid)
        and tonumber(player_record.userid) > 0 then

        assignment = ui.lobby.get_verified_infected_assignment(
            player_record.userid,
            false
        )
    end

    if assignment then
        return display_name ..
            " - " ..
            (assignment.is_ghost and "assigned ghost class" or "current class") ..
            ": " .. tostring(assignment.name)
    end

    local prediction_row = ui.lobby.get_infected_player_prediction(
        player_record,
        true
    )

    if prediction_row then
        return ui.lobby.format_infected_player_prediction_line(prediction_row)
    end

    return display_name .. " - class prediction unavailable."
end

function ui.enhancements.build_zombieclass_preview(include_all)
    local infected_players = ui.lobby.collect_unique_infected_players(
        ui.lobby.players or {}
    )

    if #infected_players == 0 then
        return { "No Infected players are currently available." }
    end

    if include_all ~= true then
        local selected = ui.lobby.get_selected_player()

        if selected and tonumber(selected.team) == 3 then
            local selected_prediction = ui.lobby.get_infected_player_prediction(
                selected,
                false
            )

            if selected_prediction and selected_prediction.player then
                selected = selected_prediction.player
            end
        else
            selected = nil
        end

        if not selected then
            for _, player_record in ipairs(infected_players) do
                if player_record.is_local then
                    selected = player_record
                    break
                end
            end
        end

        selected = selected or infected_players[1]

        return { ui.enhancements.preview_infected_class_line(selected) }
    end

    local messages = { "Infected classes and predictions:" }

    for _, player_record in ipairs(infected_players) do
        messages[#messages + 1] =
            ui.enhancements.preview_infected_class_line(player_record)
    end

    return messages
end

