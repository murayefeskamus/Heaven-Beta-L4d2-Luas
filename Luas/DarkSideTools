function ui.control.mix_color(
    first,
    second,
    amount
)
    first = type(first) == "table" and first or { 0.5, 0.5, 0.5, 1.0 }
    second = type(second) == "table" and second or first
    amount = ui.control.clamp(amount, 0.0, 1.0)

    return {
        (tonumber(first[1]) or 0.0) + ((tonumber(second[1]) or 0.0) - (tonumber(first[1]) or 0.0)) * amount,
        (tonumber(first[2]) or 0.0) + ((tonumber(second[2]) or 0.0) - (tonumber(first[2]) or 0.0)) * amount,
        (tonumber(first[3]) or 0.0) + ((tonumber(second[3]) or 0.0) - (tonumber(first[3]) or 0.0)) * amount,
        1.0
    }
end

function ui.control.normalize_rgba_color(
    color,
    fallback
)
    fallback =
        (type(fallback) == "table" or type(fallback) == "userdata")
        and fallback
        or { 1.0, 1.0, 1.0, 1.0 }

    color =
        (type(color) == "table" or type(color) == "userdata")
        and color
        or fallback

    local function safe_read(source, key)
        if source == nil then
            return nil
        end

        local read_ok, value = pcall(
            function()
                return source[key]
            end
        )

        return read_ok and value or nil
    end

    local function read_channel(source, index, keys_to_try)
        local value = tonumber(safe_read(source, index))

        if value == nil then
            for _, key in ipairs(keys_to_try or {}) do
                value = tonumber(safe_read(source, key))

                if value ~= nil then
                    break
                end
            end
        end

        return value
    end

    local function channel(index, keys_to_try)
        local value = read_channel(color, index, keys_to_try)
            or read_channel(fallback, index, keys_to_try)
            or 1.0

        if value > 1.0 then
            value = value / 255.0
        end

        return ui.control.clamp(value, 0.0, 1.0)
    end

    return {
        channel(1, { "r", "red", "x" }),
        channel(2, { "g", "green", "y" }),
        channel(3, { "b", "blue", "z" }),
        channel(4, { "a", "alpha", "w" })
    }
end

function ui.control.color_to_abgr(color)
    color = ui.control.normalize_rgba_color(
        color,
        { 1.0, 1.0, 1.0, 1.0 }
    )

    local red = math.floor(color[1] * 255.0 + 0.5)
    local green = math.floor(color[2] * 255.0 + 0.5)
    local blue = math.floor(color[3] * 255.0 + 0.5)
    local alpha = math.floor(color[4] * 255.0 + 0.5)

    return alpha * 0x1000000 +
        blue * 0x10000 +
        green * 0x100 +
        red
end

function ui.control.abgr_to_color(value, fallback)
    value = math.floor(tonumber(value) or 0)

    if value < 0 then
        value = value + 0x100000000
    end

    if value == 0 and fallback then
        return ui.control.normalize_rgba_color(fallback, fallback)
    end

    local red = value % 0x100
    local green = math.floor(value / 0x100) % 0x100
    local blue = math.floor(value / 0x10000) % 0x100
    local alpha = math.floor(value / 0x1000000) % 0x100

    return {
        red / 255.0,
        green / 255.0,
        blue / 255.0,
        alpha / 255.0
    }
end

function ui.control.has_aim_v2_session_target()
    local runtime = ui.control.runtime

    return (
        runtime.lock_session_active == true
        and tonumber(runtime.lock_session_target_index) > 0
    ) or tonumber(runtime.locked_target_index) > 0
end

function ui.control.resolve_fov_circle_color(settings, locked)
    settings = settings or ui.control.aim.v2

    local mode = math.max(
        0,
        math.min(
            2,
            math.floor(tonumber(settings.fov_circle_color_mode) or 2)
        )
    )

    if mode == 1 then
        return ui.control.normalize_rgba_color(
            settings.fov_circle_unlocked_color,
            { 0.96, 0.74, 0.16, 1.0 }
        )
    end

    if mode == 2 then
        if locked == true then
            return ui.control.normalize_rgba_color(
                settings.fov_circle_locked_color,
                { 0.18, 0.92, 0.42, 1.0 }
            )
        end

        return ui.control.normalize_rgba_color(
            settings.fov_circle_unlocked_color,
            { 0.96, 0.74, 0.16, 1.0 }
        )
    end

    return nil
end

function ui.control.get_local_team_number()
    if type(client) ~= "table"
        or type(client.get_local_player) ~= "function" then

        return 0
    end

    local player_ok, local_player = pcall(
        client.get_local_player
    )

    if not player_ok or not local_player then
        return 0
    end

    local team_ok, team = pcall(
        function()
            if type(local_player.get_team) == "function" then
                return local_player:get_team()
            end

            if type(local_player.get_prop) == "function" then
                return local_player:get_prop("m_iTeamNum")
            end

            return 0
        end
    )

    return team_ok and math.floor(tonumber(team) or 0) or 0
end

