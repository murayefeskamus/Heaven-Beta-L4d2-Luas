function ui.lobby.build_player_record(
    player_index,
    player,
    now
)
    local player_info =
        ui.lobby.get_player_info(
            player_index
        )

    local player_name =
        ui.lobby.get_info_field(
            player_info,
            {
                "name"
            }
        )

    if not player_name
        or tostring(player_name) == "" then

        player_name =
            ui.lobby.call_method(
                player,
                "get_name"
            )
    end

    player_name = tostring(
        player_name or ""
    )

    if player_name == "" then
        return nil
    end

    local team_number = tonumber(
        ui.lobby.call_method(
            player,
            "get_team"
        )
    ) or 0

    local userid =
        ui.lobby.get_player_userid(
            player_info
        )


    local health =
        ui.lobby.get_player_health(
            player
        )

    if health == nil then
        health =
            tonumber(
                ui.lobby.get_info_field(
                    player_info,
                    {
                        "health",
                        "m_iHealth"
                    }
                )
            )

        if health ~= nil then
            health =
                math.floor(
                    health
                )
        end
    end

    local alive =
        ui.lobby.get_player_alive(
            player,
            health
        )

    if alive == false then
        health = 0
    elseif health ~= nil then
        health =
            math.max(
                0,
                math.floor(health)
            )
    end

    local is_ghost =
        team_number == 3
        and ui.lobby.get_player_is_ghost(
            player
        )
        or false

    local spawned =
        alive == true
        and not is_ghost

    local local_player =
        client.get_local_player()

    local local_index =
        local_player
        and local_player:get_index()
        or -1

    local is_bot =
        name_stealer.is_player_bot(
            player_index,
            player
        )

    local key =
        ui.lobby.make_player_key(
            player_index,
            userid
        )

    return {
        key = key,
        entity_index = player_index,
        userid = userid,
        name = player_name,
        name_characters =
            ui.lobby.count_real_name_characters(
                player_name
            ),
        is_bot = is_bot,
        is_local =
            player_index == local_index,
        team = team_number,
        team_name =
            ui.lobby.team_name(
                team_number
            ),
        class_name =
            ui.lobby.get_player_class(
                player,
                team_number
            ),
        health = health,
        alive = alive,
        is_ghost = is_ghost,
        spawned = spawned,
        connected = true,
        first_seen = now,
        chat_messages = 0,
        kills = 0,
        deaths = 0,
        common_kills = 0,
        special_kills = 0,
        tank_kills = 0,
        witch_kills = 0,
        weapon_kills = {},
        si_damage_by_class = {},
        si_damage_total = 0,
        reconnects = 0,
        name_changes = 0,
        name_history = {}
    }
end

function ui.lobby.format_duration(
    seconds
)
    seconds =
        math.max(
            0,
            math.floor(
                tonumber(seconds) or 0
            )
        )

    local hours =
        math.floor(
            seconds / 3600
        )

    local minutes =
        math.floor(
            (
                seconds % 3600
            ) / 60
        )

    local remaining_seconds =
        seconds % 60

    if hours > 0 then
        return string.format(
            "%02d:%02d:%02d",
            hours,
            minutes,
            remaining_seconds
        )
    end

    return string.format(
        "%02d:%02d",
        minutes,
        remaining_seconds
    )
end

