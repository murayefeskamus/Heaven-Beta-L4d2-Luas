            if colored_button(
                "Add Field",
                0.15, 1.0, 1.0,
                0.05, 0.28, 0.30
            ) then
                local restored_message = ""
                local restored_enabled = false

                if #settings.removed_messages > 0 then
                    restored_message =
                        tostring(
                            table.remove(
                                settings.removed_messages
                            ) or ""
                        )

                    restored_enabled =
                        table.remove(
                            settings.removed_message_enabled
                        ) == true
                end

                table.insert(
                    settings.messages,
                    restored_message
