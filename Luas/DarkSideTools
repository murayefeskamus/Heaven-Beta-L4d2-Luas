function ui.lobby.infected_record_quality(player_record)
    player_record = type(player_record) == "table" and player_record or {}

    local score = 0
    local entity_index = math.floor(tonumber(player_record.entity_index) or 0)
    local userid = math.floor(tonumber(player_record.userid) or 0)

    if entity_index > 0 then
        score = score + 12

        local ok, player_entity = pcall(entity.get_by_index, entity_index)
        if ok and player_entity then
            score = score + 20

            local team_number = tonumber(
                ui.lobby.call_method(player_entity, "get_team")
                or ui.lobby.call_method(player_entity, "get_prop", "m_iTeamNum")
                or 0
            ) or 0

            if team_number == 3 then
                score = score + 8
            end
        end
    end

    if userid > 0 then
        score = score + 8
    end

    if player_record.connected ~= false then
        score = score + 2
    end

    if player_record.is_local == true then
        score = score + 1
    end

    return score
end

function ui.lobby.collect_unique_infected_players(source_records, real_players_only)
    source_records = type(source_records) == "table" and source_records or {}

    local unique = {}
    local key_to_index = {}

    for _, player_record in ipairs(source_records) do
        if type(player_record) == "table"
            and tonumber(player_record.team) == 3
            and player_record.connected ~= false
            and (
                real_players_only ~= true
                or player_record.is_bot ~= true
            ) then

            local identity_keys = ui.lobby.infected_identity_keys(player_record)
            local duplicate_index = nil

            for _, identity_key in ipairs(identity_keys) do
                if key_to_index[identity_key] then
                    duplicate_index = key_to_index[identity_key]
                    break
                end
            end

            if duplicate_index then
                local existing = unique[duplicate_index]

                if ui.lobby.infected_record_quality(player_record) >
                    ui.lobby.infected_record_quality(existing) then

                    unique[duplicate_index] = player_record
                end

                for _, identity_key in ipairs(identity_keys) do
                    key_to_index[identity_key] = duplicate_index
                end
            else
                unique[#unique + 1] = player_record
                local new_index = #unique

                for _, identity_key in ipairs(identity_keys) do
                    key_to_index[identity_key] = new_index
                end
            end
        end
    end

    table.sort(unique, function(left, right)
        if left.is_local ~= right.is_local then
            return left.is_local == true
        end

        if left.is_bot ~= right.is_bot then
            return left.is_bot ~= true
        end

        local left_name = tostring(left.name or ""):lower()
        local right_name = tostring(right.name or ""):lower()

        if left_name ~= right_name then
            return left_name < right_name
        end

        local left_entity = math.floor(tonumber(left.entity_index) or 0)
        local right_entity = math.floor(tonumber(right.entity_index) or 0)

        if left_entity ~= right_entity then
            return left_entity < right_entity
        end

        return (tonumber(left.userid) or 0) < (tonumber(right.userid) or 0)
    end)

    local name_counts = {}
    for _, player_record in ipairs(unique) do
        local normalized_name = tostring(player_record.name or "Player"):lower()
        name_counts[normalized_name] = (name_counts[normalized_name] or 0) + 1
    end

    local name_occurrences = {}
    local output = {}

    for _, player_record in ipairs(unique) do
        local copy = {}
        for key, value in pairs(player_record) do
            copy[key] = value
        end

        local base_name = tostring(player_record.name or "Player")
        local normalized_name = base_name:lower()
        local duplicate_count = name_counts[normalized_name] or 1

        name_occurrences[normalized_name] =
            (name_occurrences[normalized_name] or 0) + 1

        local display_name = base_name

        if duplicate_count > 1 then
            local entity_index = math.floor(tonumber(player_record.entity_index) or 0)
            local userid = math.floor(tonumber(player_record.userid) or 0)
            local fallback_number = name_occurrences[normalized_name]
            local identity_number = entity_index > 0 and entity_index
                or (userid > 0 and userid or fallback_number)

            if player_record.is_bot == true then
                display_name = base_name .. " [BOT #" .. tostring(identity_number) .. "]"
            elseif userid > 0 then
                display_name = base_name .. " [UID " .. tostring(userid) .. "]"
            else
                display_name = base_name .. " [#" .. tostring(identity_number) .. "]"
            end
        end

        copy._dst_display_name = display_name
        output[#output + 1] = copy
    end

    return output
end

function ui.lobby.get_infected_prediction_player_identity(player_record)
    player_record = type(player_record) == "table" and player_record or {}

    local is_bot = player_record.is_bot == true
    local entity_index = math.floor(tonumber(player_record.entity_index) or 0)
    local userid = math.floor(tonumber(player_record.userid) or 0)

    if is_bot then
        if entity_index > 0 then
            return "bot-entity:" .. tostring(entity_index)
        end

        if userid > 0 then
            return "bot-userid:" .. tostring(userid)
        end
    else
        if userid > 0 then
            return "uid:" .. tostring(userid)
        end

        if entity_index > 0 then
            return "entity:" .. tostring(entity_index)
        end
    end

    return "name:" .. tostring(player_record.name or "Player"):lower()
end

function ui.lobby.queue_infected_class_query(
    requester_userid,
    target_records,
    query_mode,
    response_team_only
)
    if type(target_records) ~= "table" then
        return false
    end

    local targets = {}
    local unique_records = ui.lobby.collect_unique_infected_players(target_records)

    for _, player_record in ipairs(unique_records) do
        local userid = math.floor(tonumber(player_record.userid) or 0)
        local entity_index = math.floor(tonumber(player_record.entity_index) or 0)

        if userid > 0 or entity_index > 0 then
            targets[#targets + 1] = {
                userid = userid,
                entity_index = entity_index,
                name = tostring(player_record.name or "Player"),
                display_name = tostring(
                    player_record._dst_display_name
                    or player_record.name
                    or "Player"
                ),
                is_bot = player_record.is_bot == true,
                prediction_identity = ui.lobby.get_infected_prediction_player_identity(player_record),
                last_class_id = nil,
                stable_reads = 0,
                resolved = false,
                result = nil
            }
        end
    end

    if #targets == 0 then
        return false
    end

    local requester_key = tostring(math.floor(tonumber(requester_userid) or 0))

    ui.lobby.pending_infected_class_queries[requester_key] = {
        requester_userid = math.floor(tonumber(requester_userid) or 0),
        owner_request = is_local_player_userid(requester_userid),
        response_team_only = response_team_only == true,
        mode = tostring(query_mode or "single"),
        targets = targets,
        started_at = get_time(),
        next_poll = get_time()
    }

    return true
end

