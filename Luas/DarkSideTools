            userid
        )
    )
end

function chat_spammer.get_parrot_route_for_source(
    userid,
    source_is_team_chat
)
    if source_is_team_chat ~= true then
        return 1,
            "all_chat"
    end

    local source_class =
        chat_spammer.get_team_chat_source_class(
            userid
        )

    if source_class == "my_team" then
        return chat_spammer.normalize_route_mode(
            chat_spammer.parrot_my_team_route
        ),
            source_class
    elseif source_class == "enemy_team" then
        return chat_spammer.normalize_route_mode(
            chat_spammer.parrot_enemy_team_route
        ),
            source_class
    end

    return chat_spammer.normalize_route_mode(
        chat_spammer.parrot_unknown_team_route
    ),
        source_class
end

