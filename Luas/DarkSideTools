        ui.favourites.get_ordered_entries()

    if get_time() <
        ui.favourites.last_status_until
        and ui.favourites.last_status_error == true
        and ui.favourites.last_status ~= "" then

        theme_text_colored(
            1.0, 0.25, 0.25, 1.0,
            ui.favourites.last_status
        )

        draw_compact_gap()
    end

    if #entries == 0 then
        theme_text_colored(
            1.0, 0.25, 0.25, 1.0,
            "No favourites pinned."
        )

        theme_text_colored(
            0.62, 0.62, 0.65, 1.0,
            "Pin a section or search result."
        )

        return
    end

    ui.favourites.pending_unpin_key = ""
    ui.favourites.pending_jump_entry = nil

    for entry_index,
        entry in ipairs(
            entries
        ) do

        if entry_index > 1 then
            ui.favourites.draw_entry_separator()
        end

        local renderer =
            ui.favourites.ensure_renderer(
                entry.tab_key,
                entry.section_key
            )

        if type(renderer) ~= "function" then
            theme_text_colored(
                1.0, 0.25, 0.25, 1.0,
                "Favourite is unavailable."
            )
        else
            local previous_rendering_tab =
                ui.favourites.rendering_tab

            local previous_pin_consumed =
                ui.favourites.section_pin_consumed

            local previous_active_entry =
                ui.favourites.active_entry

            local previous_active_entry_index =
                ui.favourites.active_entry_index

            local previous_controls_drawn =
                ui.favourites.active_controls_drawn

            local previous_selected_tool =
                ui.selected_tool

            local previous_capture_tab =
                type(ui.setting_search) == "table"
                and ui.setting_search.runtime_capture_tab
                or ""

            local previous_capture_section =
                type(ui.setting_search) == "table"
                and ui.setting_search.runtime_capture_section
                or ""

            ui.favourites.rendering_tab = true
            ui.favourites.section_pin_consumed = false
            ui.favourites.active_entry = entry
            ui.favourites.active_entry_index = entry_index
            ui.favourites.active_controls_drawn = false

            ui.selected_tool =
                ui.favourites.tool_indices[
                    entry.tab_key
                ]

            if type(ui.setting_search) == "table" then
                ui.setting_search.runtime_capture_tab =
                    tostring(entry.tab_key)

                ui.setting_search.runtime_capture_section =
                    tostring(entry.section_key)
            end

            local render_ok,
                render_error =
                    pcall(
                        renderer
                    )

            local controls_drawn =
                ui.favourites.active_controls_drawn

            if type(ui.setting_search) == "table" then
                ui.setting_search.runtime_capture_tab =
                    previous_capture_tab

                ui.setting_search.runtime_capture_section =
                    previous_capture_section
            end

            ui.selected_tool =
                previous_selected_tool

            ui.favourites.rendering_tab =
                previous_rendering_tab

            ui.favourites.section_pin_consumed =
                previous_pin_consumed

            ui.favourites.active_entry =
                previous_active_entry

            ui.favourites.active_entry_index =
                previous_active_entry_index

            ui.favourites.active_controls_drawn =
                previous_controls_drawn

            if not render_ok then
                theme_text_colored(
                    1.0, 0.25, 0.25, 1.0,
                    "Favourite could not be rendered: " ..
                    tostring(render_error)
                )
            elseif not controls_drawn then
                theme_text_colored(
                    1.0, 0.25, 0.25, 1.0,
                    "Favourite section header is unavailable."
                )
            end
        end
    end

    local pending_unpin =
        tostring(
            ui.favourites.pending_unpin_key
            or ""
        )

    local pending_jump =
        ui.favourites.pending_jump_entry

    ui.favourites.pending_unpin_key = ""
    ui.favourites.pending_jump_entry = nil

    if pending_unpin ~= "" then
        ui.favourites.unpin_key(
            pending_unpin
        )
    end

    if type(pending_jump) == "table" then
        ui.favourites.jump_to_entry(
            pending_jump
        )
    end
end

ui.favourites.previous_draw_sections_for_capture =
    ui.section_layout.draw_sections

function ui.section_layout.draw_sections(
    tab_key,
    renderers
)
    renderers =
        type(renderers) == "table"
        and renderers
        or {}

    ui.favourites.capture_renderers(
        tab_key,
        renderers
    )

    if ui.favourites.capture_only == true then
        return
    end

    local rendered_count = 0
    local spaced_renderers = {}

    for section_key,
        renderer in pairs(
            renderers
        ) do

        if type(renderer) == "function" then
            spaced_renderers[section_key] =
                function(...)
                    if ui.favourites.rendering_tab ~= true
                        and rendered_count > 0 then

                        local current_y =
                            ui.lobby.get_cursor_y()

                        if not ui.lobby.set_cursor_y(
                            current_y + 32
                        ) then
                            imgui.spacing()
                            imgui.spacing()
                            imgui.spacing()
                            imgui.spacing()
                            imgui.spacing()
                            imgui.spacing()
                            imgui.spacing()
                        end
                    end

                    local results = {
                        renderer(...)
                    }

                    rendered_count =
                        rendered_count + 1

                    return
                        (table.unpack or unpack)(
                            results
                        )
                end
        end
    end

    return
        ui.favourites.previous_draw_sections_for_capture(
            tab_key,
            spaced_renderers
        )
end


ui.favourites.section_order_original_get_default_order =
    ui.section_layout.get_default_order

ui.favourites.section_order_original_normalize_order =
    ui.section_layout.normalize_order

ui.favourites.section_order_original_get_section_label =
    ui.section_layout.get_section_label

function ui.favourites.get_default_entry_order()
    local order = {}

    for _, entry in ipairs(
        ui.favourites.normalize_entries()
    ) do
        order[#order + 1] =
            ui.favourites.entry_key(
                entry
            )
    end

    return order
end

function ui.favourites.get_ordered_entries()
    local entries =
        ui.favourites.normalize_entries()

    local entry_lookup = {}

    for _, entry in ipairs(entries) do
        entry_lookup[
            ui.favourites.entry_key(
                entry
            )
        ] = entry
    end

    local ordered_entries = {}

    for _, entry_key in ipairs(
        ui.section_layout.normalize_order(
            "favourites"
        )
    ) do
        local entry =
            entry_lookup[
                tostring(entry_key or "")
            ]

        if type(entry) == "table" then
            ordered_entries[
                #ordered_entries + 1
            ] = entry
        end
    end

    return ordered_entries
end

function ui.section_layout.get_default_order(
    tab_key
)
    tab_key =
        tostring(tab_key or "")

    if tab_key == "favourites" then
        return
            ui.favourites.get_default_entry_order()
    end

    return
        ui.favourites.section_order_original_get_default_order(
            tab_key
        )
end

function ui.section_layout.normalize_order(
    tab_key
)
    tab_key =
        tostring(tab_key or "")

    if tab_key ~= "favourites" then
        return
            ui.favourites.section_order_original_normalize_order(
                tab_key
            )
    end

    local default_order =
        ui.favourites.get_default_entry_order()

    local saved_order =
        type(
            ui.section_layout.orders[
                tab_key
            ]
        ) == "table"
        and ui.section_layout.orders[
            tab_key
        ]
        or {}

    local valid = {}

    for _, entry_key in ipairs(
        default_order
    ) do
        valid[
            tostring(entry_key or "")
        ] = true
    end

    local normalized = {}
    local seen = {}

    for _, entry_key in ipairs(
        saved_order
    ) do
        entry_key =
            tostring(entry_key or "")

        if valid[entry_key] == true
            and seen[entry_key] ~= true then

            normalized[
                #normalized + 1
            ] = entry_key

            seen[entry_key] = true
        end
    end

    for _, entry_key in ipairs(
        default_order
    ) do
        entry_key =
            tostring(entry_key or "")

        if seen[entry_key] ~= true then
            normalized[
                #normalized + 1
            ] = entry_key

            seen[entry_key] = true
        end
    end

    ui.section_layout.orders[
        tab_key
    ] = normalized

    return normalized
end

function ui.section_layout.get_section_label(
    tab_key,
    section_key
)
    tab_key =
        tostring(tab_key or "")

    section_key =
        tostring(section_key or "")

    if tab_key ~= "favourites" then
        return
            ui.favourites.section_order_original_get_section_label(
                tab_key,
                section_key
            )
    end

    for _, entry in ipairs(
        ui.favourites.normalize_entries()
    ) do
        if ui.favourites.entry_key(
            entry
        ) == section_key then

            local source_tab =
                ui.section_layout.get_tab(
                    entry.tab_key
                )

            local source_tab_label =
                tostring(
                    source_tab
                    and source_tab.label
                    or entry.tab_key
                )

            local source_section_label =
                ui.favourites.section_order_original_get_section_label(
                    entry.tab_key,
                    entry.section_key
                )

            if tostring(entry.kind) ==
                "setting" then

                return
                    source_tab_label ..
                    " → " ..
                    source_section_label ..
                    " → " ..
                    tostring(entry.term)
            end

            return
                source_tab_label ..
                " → " ..
                source_section_label
        end
    end

    return "Unavailable favourite"
end

ui.section_layout.normalize_order(
    "favourites"
)
