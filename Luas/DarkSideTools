function set_spammer_enabled(enabled)
    capture_initial_in_game_name()

    local requested_enabled =
        enabled == true

    local warning_message = nil
    local warning_status = nil

    if requested_enabled then
        spammer_cfg.normalize_cycle_limit_settings()

        warning_message,
            warning_status =
                spammer_cfg.get_automation_validation_warning()
    end

    spammer_cfg.enabled =
        requested_enabled
        and warning_message == nil

    spammer_runtime.elapsed = 0.0
    spammer_runtime.pending_message = nil
    spammer_runtime.pending_label = "None"
    spammer_runtime.pending_attempts = 0
    spammer_runtime.rate_limited = false
    spammer_runtime.reset_automation_cycle()

    if requested_enabled
        and warning_message == nil then

        spammer_runtime.reset_cycle_limit_progress()
    end

    if warning_message then
        spammer_runtime.status =
            warning_status

        ui.console.print(
            "[Name Spammer] " ..
            warning_message ..
            "."
        )

        return false
    end

    if spammer_cfg.enabled then
        stop_name_stealer()
        stop_chat_spammer()

        spammer_runtime.elapsed =
            spammer_cfg.delay

        spammer_runtime.status =
            is_game_ready()
            and "RUNNING"
            or "WAITING FOR GAME"
    else
        spammer_runtime.status = "IDLE"
    end

    return true
end

