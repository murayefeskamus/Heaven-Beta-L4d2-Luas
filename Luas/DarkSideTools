function theme_text_colored(
    r,
    g,
    b,
    a,
    text_value
)
    r = tonumber(r) or 1.0
    g = tonumber(g) or 1.0
    b = tonumber(b) or 1.0
    a = tonumber(a) or 1.0

    local palette = nil

    if ui
        and ui.enhancements
        and type(
            ui.enhancements.theme_palette
        ) == "function" then

        palette =
            ui.enhancements.theme_palette()
    end

    if palette
        and palette.light == true then

        local maximum =
            math.max(
                r,
                g,
                b
            )

        local minimum =
            math.min(
                r,
                g,
                b
            )

        local luminance =
            r * 0.2126 +
            g * 0.7152 +
            b * 0.0722

        if maximum - minimum < 0.08 then
            if luminance >= 0.78
                and type(palette.text) == "table" then

                r = palette.text[1]
                g = palette.text[2]
                b = palette.text[3]
            elseif luminance >= 0.46
                and type(
                    palette.text_disabled
                ) == "table" then

                r = palette.text_disabled[1]
                g = palette.text_disabled[2]
                b = palette.text_disabled[3]
            end
        elseif luminance > 0.56 then
            local scale =
                0.42 /
                math.max(
                    0.01,
                    luminance
                )

            r =
                math.max(
                    0.0,
                    math.min(
                        1.0,
                        r * scale
                    )
                )

            g =
                math.max(
                    0.0,
                    math.min(
                        1.0,
                        g * scale
                    )
                )

            b =
                math.max(
                    0.0,
                    math.min(
                        1.0,
                        b * scale
                    )
                )
        end
    end

    imgui.text_colored(
        r,
        g,
        b,
        a,
        tostring(
            text_value or ""
        )
    )
end

