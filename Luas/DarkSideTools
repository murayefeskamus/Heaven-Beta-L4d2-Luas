function ui.setting_search.setting_search_match_make_temporary_wrapper(
    raw_method,
    label_index
)
    return function(...)
        local label = select(label_index, ...)

        if not ui.setting_search.setting_search_match_is_exact_rendered_label(label) then
            return raw_method(...)
        end

        ui.setting_search.setting_search_match_capture_target_before_item()

        local packed_results =
            ui.setting_search.exact_pack(raw_method(...))

        ui.setting_search.setting_search_match_draw_exact_item_overlay()

        return ui.setting_search.exact_unpack(
            packed_results,
            1,
            packed_results.n
        )
    end
end

