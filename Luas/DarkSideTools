        left_rows[#left_rows + 1] = {
            label = "Packet choke",
            value = string.format(
                "%.2f%%",
                tonumber(stats.choke_percent) or 0.0
            ),
            color = { choke_r, choke_g, choke_b }
        }

        left_rows[#left_rows + 1] = {
