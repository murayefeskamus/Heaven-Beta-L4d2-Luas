function prune_pending_chat_confirmations()
    local now =
        get_time()

    local expire_before =
        now - 5.0

    while #chat_spammer.pending_confirmations > 0 do
        local first =
            chat_spammer.pending_confirmations[1]

        if first
            and first.time
            and first.time >= expire_before then

            break
        end

        table.remove(
            chat_spammer.pending_confirmations,
            1
        )
    end

    while #chat_spammer.pending_confirmations > 128 do
        table.remove(
            chat_spammer.pending_confirmations,
            1
        )
    end
end

function queue_chat_confirmation(
    message,
    source
)
    local normalized =
        normalize_chat_for_compare(
            message
        )

    if normalized == "" then
        return
    end

    prune_pending_chat_confirmations()

    table.insert(
        chat_spammer.pending_confirmations,
        {
            text = normalized,
            time = get_time(),
            source = tostring(
                source or "chat_spammer"
            )
        }
    )
end

function confirm_chat_message(message)
    local normalized =
        normalize_chat_for_compare(
            message
        )

    if normalized == "" then
        return false
    end

    prune_pending_chat_confirmations()

    for index, pending
        in ipairs(
            chat_spammer.pending_confirmations
        ) do

        if pending.text == normalized then
            table.remove(
                chat_spammer.pending_confirmations,
                index
            )

            local confirmation_source =
                tostring(
                    pending.source or "chat_spammer"
                )

            if confirmation_source == "newline_spam" then
                chat_spammer.newline_spam_sent =
                    math.max(
                        0,
                        math.floor(
                            tonumber(
                                chat_spammer.newline_spam_sent
                            ) or 0
                        )
                    ) + 1
            else
                chat_spammer.messages_sent =
                    chat_spammer.messages_sent + 1

                chat_spammer.last_confirmed_message =
                    normalized
            end

            return true
        end
    end

    return false
end

function get_next_valid_chat_index(start_index)
    local count =
        get_chat_cycle_message_count()

    if count <= 0 then
        return nil,
            nil
    end

    for offset = 0,
        count - 1 do

        local index =
            (
                (
                    start_index - 1 + offset
                ) % count
            ) + 1

        local cycle_message =
            get_chat_cycle_message(
                index
            )

        local message =
            sanitize_chat_message(
                cycle_message
                and cycle_message.text
                or ""
            )

        if message ~= "" then
            return index,
                cycle_message
        end
    end

    return nil,
        nil
end

function send_chat_message_to_channel(
    message,
    team_only,
    silent
)
    if not engine.is_in_game()
        or not engine.is_connected() then

        chat_spammer.status =
            "WAITING FOR GAME"

        return false
    end

    local expanded_message =
        expand_custom_newline_placeholders(
            message
        )

    local preserve_message_newlines =
        tostring(expanded_message or ""):find("[\r\n]") ~= nil

    local safe_message =
        sanitize_chat_message(
            expanded_message,
            preserve_message_newlines
        )

    if safe_message == "" then
        chat_spammer.status =
            "EMPTY MESSAGE"

        if not silent then
            ui.console.print(
                "[Chat Spammer] Selected message is empty."
            )
        end

        return false
    end

    local command =
        team_only == true
        and "say_team"
        or "say"

    client.execnormal(
        command ..
        ' "' ..
        safe_message ..
        '"'
    )

    chat_spammer.last_message =
        safe_message

    chat_spammer.send_attempts =
        chat_spammer.send_attempts + 1

    queue_chat_confirmation(
        safe_message
    )

    chat_spammer.status =
        chat_spammer.enabled
        and "RUNNING"
        or "READY"

    if not silent then
        ui.console.print(
            "[Chat Spammer] Sent: " ..
            safe_message
        )
    end

    return true
end


function chat_spammer.get_newline_spam_message_limit(
    use_vertical_text
)
    if use_vertical_text == nil then
        use_vertical_text =
            chat_spammer.newline_spam_vertical_text == true
    end

    return use_vertical_text == true
        and DARKSIDE_CONFIG.NEWLINE_SPAM_VERTICAL_MAX_CHARACTERS
        or DARKSIDE_CONFIG.NEWLINE_SPAM_MESSAGE_MAX_CHARACTERS
end

function chat_spammer.sanitize_heaven_newline_message(
    message,
    maximum_characters
)
    message = tostring(message or "")
    message = message:gsub("[\r\n]", " ")
    message = message:gsub('"', "'")

    maximum_characters =
        math.max(
            0,
            math.floor(
                tonumber(maximum_characters)
                or chat_spammer.get_newline_spam_message_limit()
            )
        )

    local characters =
        split_utf8_characters(
            message
        )

    if #characters > maximum_characters then
        local limited_characters = {}

        for index = 1,
            maximum_characters do

            limited_characters[index] =
                characters[index]
        end

        message =
            table.concat(
                limited_characters
            )
    end

    return message
end

function chat_spammer.get_newline_spam_message_character_count(
    message,
    maximum_characters
)
    maximum_characters =
        tonumber(maximum_characters)
        or chat_spammer.get_newline_spam_message_limit()

    return #split_utf8_characters(
        chat_spammer.sanitize_heaven_newline_message(
            message,
            maximum_characters
        )
    )
end


function chat_spammer.get_newline_spam_input_byte_limit(
    message,
    maximum_characters
)
    maximum_characters =
        math.max(
            0,
            math.floor(
                tonumber(maximum_characters)
                or chat_spammer.get_newline_spam_message_limit()
            )
        )

    local sanitized =
        chat_spammer.sanitize_heaven_newline_message(
            message,
            maximum_characters
        )

    local character_count =
        #split_utf8_characters(
            sanitized
        )

    if character_count >= maximum_characters then
        return #sanitized
    end

    return #sanitized +
        math.max(
            0,
            maximum_characters - character_count
        ) * 4
end

