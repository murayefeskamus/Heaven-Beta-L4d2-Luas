        #DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX
    ) == DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX do

        normalized =
            normalized:sub(
                #DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX + 1
            )
