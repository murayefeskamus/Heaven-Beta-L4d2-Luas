function ui.heaven_configs.config_hotkey_read_key_state(
    key_value,
    was_down
)
    key_value =
        math.floor(
            tonumber(key_value) or 0
        )

    if key_value <= 0
        or type(input) ~= "table" then

        return false,
            false
    end

    local is_down = false
    local pressed = false

    if type(input.is_key_down) == "function" then
        local down_ok,
            down_result =
                pcall(
                    input.is_key_down,
                    key_value
                )

        if down_ok
            and down_result == true then

            is_down = true
        end
    end

    if type(input.is_key_pressed) == "function" then
        local pressed_ok,
            pressed_result =
                pcall(
                    input.is_key_pressed,
                    key_value
                )

        if pressed_ok
            and pressed_result == true then

            pressed = true
            is_down = true
        end
    end

    if is_down == true
        and was_down ~= true then

        pressed = true
    end

    return is_down,
        pressed
end

function ui.heaven_configs.config_hotkey_queue_slot_load(
    slot_index,
    source
)
    local service =
        ui.heaven_configs.config_hotkey_hotkey_service

    service.pending_kind = "slot"
    service.pending_slot =
        math.max(
            1,
            math.min(
                math.floor(
                    tonumber(ui.heaven_configs.max_slots) or 10
                ),
                math.floor(
                    tonumber(slot_index) or 1
                )
            )
        )
    service.pending_source =
        tostring(source or "hotkey")
    service.pending_at =
        get_time() + 0.015

    return true
end

function ui.heaven_configs.config_hotkey_queue_cycle_load(
    source
)
    local service =
        ui.heaven_configs.config_hotkey_hotkey_service

    service.pending_kind = "cycle"
    service.pending_slot = 0
    service.pending_source =
        tostring(source or "cycle key")
    service.pending_at =
