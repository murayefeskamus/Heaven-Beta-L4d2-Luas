    local metadata =
        type(
            spammer_runtime.current_name_metadata
        ) == "table"
        and spammer_runtime.current_name_metadata
        or {}

    local metadata_name =
        clean_name_for_reverse(
            metadata.visible_name or ""
        )

    local metadata_matches =
        spammer_runtime.names_match_for_tracking(
            clean_current_name,
            metadata_name
        )

    local style_label =
        tostring(
            current_layout or "Horizontal"
        )

    local case_label =
        name_reverser.infer_name_case_label(
            clean_current_name
        )

    local shape_label = "Original"

    local decoration_label =
        name_reverser.get_known_name_decoration_label(
            clean_current_name
        )

    if metadata_matches then
        if metadata.style ~= nil
            and tostring(metadata.style) ~= "" then

            style_label =
                tostring(metadata.style)
        end

        if metadata.case_label ~= nil
            and tostring(metadata.case_label) ~= "" then

            case_label =
                tostring(metadata.case_label)
        end

        if metadata.shape_label ~= nil
            and tostring(metadata.shape_label) ~= "" then

            shape_label =
                tostring(metadata.shape_label)
        end

        if metadata.decoration_label ~= nil
            and tostring(metadata.decoration_label) ~= "" then

            decoration_label =
                tostring(metadata.decoration_label)
        end
    end

    if clean_current_name ==
        DARKSIDE_CONFIG.INVISIBLE_NAME
        or style_label == "Invisible" then

        style_label = "Invisible"
        case_label = "N/A"
        shape_label = "N/A"
        decoration_label = "None"
    end

    return {
        style = style_label,
        case_label = case_label,
        shape_label = shape_label,
        decoration_label = decoration_label
    }
end

