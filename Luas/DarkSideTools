    if type(name_stealer.invalidate_saved_names_gui_cache) == "function" then
        name_stealer.invalidate_saved_names_gui_cache()
    end

    if type(io) ~= "table"
        or type(io.open) ~= "function" then

        name_stealer.saved_names_loaded = true
        name_stealer.save_status =
            "File access is unavailable."

        return false
    end

    local file_path =
        get_saved_names_file_path()

    local open_ok,
        file_handle =
            pcall(
                io.open,
                file_path,
                "r"
            )

    if not open_ok
        or not file_handle then

        name_stealer.saved_names_loaded = true
        name_stealer.saved_names_file_exists =
            false

        name_stealer.save_status =
            "ERROR: L4D2SavedNames.txt is missing or was renamed."

        return false
    end

    name_stealer.saved_names_file_exists =
        true

    local seen_names = {}
    local removed_entry_count = 0

    local read_ok,
        read_error =
            pcall(
                function()
                    for file_line in file_handle:lines() do
                        local line =
                            tostring(file_line):gsub(
                                "\r$",
                                ""
                            )

                        local clean_name =
                            sanitize_name(
                                line
                            )

                        local normalized_key =
                            normalize_candidate_name_for_filter(
                                clean_name
                            )

                        if is_valid_candidate_name(
                            clean_name
                        )
                            and not is_excluded_bot_name(
                                clean_name
                            )
                            and not name_stealer.is_protected_saved_name(
                                clean_name
                            )
                            and not name_stealer.is_lua_decorated_name(
                                clean_name
                            )
                            and not seen_names[
                                normalized_key
                            ] then

                            seen_names[
                                normalized_key
                            ] = true

                            table.insert(
                                name_stealer.saved_names,
                                clean_name
                            )
                        elseif clean_name ~= "" then
                            removed_entry_count =
                                removed_entry_count + 1
                        end
                    end

                    file_handle:close()
                end
            )

    if not read_ok then
        pcall(
            function()
                file_handle:close()
            end
        )

        name_stealer.saved_names_loaded = true
        name_stealer.save_status =
            "Could not read saved names: " ..
            tostring(read_error)

        return false
    end

    local cleanup_succeeded = true

    if removed_entry_count > 0 then
        cleanup_succeeded =
            name_stealer.rewrite_saved_names_file(
                name_stealer.saved_names
            )
    end

    load_saved_name_metadata()
    ensure_saved_name_metadata_entries()
    save_saved_name_metadata()

    name_stealer.saved_names_loaded = true
    name_stealer.saved_names_file_exists =
        true

    name_stealer.saved_names_count =
        #name_stealer.saved_names

    if removed_entry_count > 0 then
        name_stealer.save_status =
            string.format(
                cleanup_succeeded
                and "Loaded %d saved names; removed %d blocked/duplicate entr%s."
                or "Loaded %d saved names; %d blocked/duplicate entr%s could not be removed from disk.",
                #name_stealer.saved_names,
                removed_entry_count,
                removed_entry_count == 1
                and "y"
                or "ies"
            )
    else
        name_stealer.save_status =
            string.format(
                "Loaded %d saved names.",
                #name_stealer.saved_names
            )
    end

    if not silent then
        ui.console.print(
            "[Name Stealer] " ..
            name_stealer.save_status
        )
    end

    return true
end

function save_stealer_names_to_file(
    names,
    source_label
)
    if type(io) ~= "table"
        or type(io.open) ~= "function" then

        name_stealer.save_status =
            "File access is unavailable."

        return false
    end

    if not name_stealer.saved_names_loaded then
        load_saved_names_from_file(
            true
        )
    end

    source_label =
        normalize_saved_name_source(
            source_label or "Manual"
        )

    local existing_names = {}

    for _, saved_name in ipairs(
        name_stealer.saved_names
    ) do
        existing_names[
            normalize_candidate_name_for_filter(
                saved_name
            )
        ] = true
    end

    local names_to_save = {}

    for _, name in ipairs(
        names or {}
    ) do
        local clean_name =
            sanitize_name(name)

        local normalized_key =
            normalize_candidate_name_for_filter(
                clean_name
            )

        if is_valid_candidate_name(
            clean_name
        )
            and not is_excluded_bot_name(
                clean_name
            )
            and not name_stealer.is_protected_saved_name(
                clean_name
            )
            and not name_stealer.is_lua_decorated_name(
                clean_name
            )
            and not existing_names[
                normalized_key
            ] then

            existing_names[
                normalized_key
            ] = true

            table.insert(
                names_to_save,
                clean_name
            )
        end
    end

    if #names_to_save == 0 then
        name_stealer.save_status =
            "No new names to save."

        return false
    end

    local file_path =
        get_saved_names_file_path()

    if not check_saved_names_file_exists() then
        name_stealer.save_status =
            "ERROR: L4D2SavedNames.txt is missing or was renamed."

        return false
    end

    local open_ok,
        file_handle,
        open_error =
            pcall(
                io.open,
                file_path,
                "a"
            )

    if not open_ok
        or not file_handle then

        name_stealer.save_status =
            "Could not open file: " ..
            tostring(
                open_error or file_path
            )

        return false
    end

    local write_ok,
        write_error =
            pcall(
                function()
                    for _, name in ipairs(
                        names_to_save
                    ) do
                        file_handle:write(
                            name,
                            "\n"
                        )
                    end

                    file_handle:flush()
                    file_handle:close()
                end
            )

    if not write_ok then
        pcall(
            function()
                file_handle:close()
            end
        )

        name_stealer.save_status =
            "Could not write file: " ..
            tostring(write_error)

        return false
    end

    local saved_timestamp =
        type(os) == "table"
        and type(os.time) == "function"
        and os.time()
        or 0

    name_stealer.session_saved_name_keys =
        type(name_stealer.session_saved_name_keys) == "table"
        and name_stealer.session_saved_name_keys
        or {}

    name_stealer.session_saved_count =
        math.max(
            0,
            math.floor(
                tonumber(
                    name_stealer.session_saved_count
                ) or 0
            )
        )

    for _, name in ipairs(
        names_to_save
    ) do
        table.insert(
            name_stealer.saved_names,
            name
        )

        set_saved_name_metadata(
            name,
            source_label,
            saved_timestamp
        )

        local session_name_key =
            normalize_candidate_name_for_filter(
                name
            )

        if session_name_key ~= ""
            and not name_stealer.session_saved_name_keys[
                session_name_key
            ] then

            name_stealer.session_saved_name_keys[
                session_name_key
            ] = true

            name_stealer.session_saved_count =
                name_stealer.session_saved_count + 1
        end
    end

    local metadata_saved =
        save_saved_name_metadata()

    name_stealer.saved_names_count =
        name_stealer.saved_names_count +
        #names_to_save

    if type(name_stealer.invalidate_saved_names_gui_cache) == "function" then
        name_stealer.invalidate_saved_names_gui_cache()
    end

    name_stealer.saved_names_loaded = true
    name_stealer.save_status =
        metadata_saved
        and string.format(
            "Saved %d new name(s) with date/source metadata.",
            #names_to_save
        )
        or string.format(
            "Saved %d new name(s), but date/source metadata could not be written.",
            #names_to_save
        )

    ui.console.print(
        "[Name Stealer] " ..
        name_stealer.save_status
    )

    return true
end

function collect_current_lobby_names(
    allow_bot_names
)
    local lobby_names = {}
    local seen_names = {}

    if not engine.is_in_game()
        or not engine.is_connected() then

        return lobby_names
    end

    local local_player =
        client.get_local_player()

    local local_index =
        local_player
        and local_player:get_index()
        or nil

    local max_clients =
        engine.get_max_clients()

    for player_index = 1, max_clients do
        if player_index ~= local_index then
            local player =
                entity.get_by_index(
                    player_index
                )

            if player then
                local player_name =
                    player:get_name()

                local player_is_bot =
                    name_stealer.is_player_bot(
                        player_index,
                        player
                    )


                local bot_allowed =
                    not player_is_bot
                    and not is_excluded_bot_name(
                        player_name
                    )

                if bot_allowed
                    and is_valid_candidate_name(
                        player_name,
                        false
                    ) then

                    local clean_name =
                        sanitize_name(
                            player_name
                        )

                    if clean_name ~= "" then
                        if player_is_bot then
                            name_stealer.bot_name_flags[
                                clean_name
                            ] = true
                        elseif name_stealer.bot_name_flags[
                            clean_name
                        ] == nil then

                            name_stealer.bot_name_flags[
                                clean_name
                            ] = false
                        end

                        if not seen_names[
                            clean_name
                        ] then

                            seen_names[
                                clean_name
                            ] = true

                            table.insert(
                                lobby_names,
                                clean_name
                            )
                        end
                    end
                end
            end
        end
    end

    table.sort(
        lobby_names,
        function(a, b)
            return a:lower()
                < b:lower()
        end
    )

    return lobby_names
end

function build_saved_name_announcement(
    player_name
)
    local clean_name =
        sanitize_name(
            player_name
        )

    if clean_name == "" then
        return ""
    end

    local announcement_text =
        sanitize_name(
            name_stealer.announce_saved_name_template
            or ""
        )


    announcement_text =
        announcement_text:gsub(
            "{name}",
            ""
        )

    if announcement_text == "" then
        return ""
    end

    local separator =
        announcement_text:match("%s$")
        and ""
        or " "

    local announcement =
        announcement_text ..
        separator ..
        clean_name

    announcement =
        select(
            1,
            truncate_name_utf8(
                announcement,
                DARKSIDE_CONFIG.MAX_CHAT_MESSAGE_LENGTH
            )
        )

    return announcement
end

function announce_auto_saved_name(
    player_name
)
    if not name_stealer.announce_saved_name_in_chat then
        return
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        return
    end

    local announcement =
        build_saved_name_announcement(
            player_name
        )

    if announcement == "" then
        return
    end

    client.execnormal(
        'say "' ..
        announcement ..
        '"'
    )
end

function save_auto_stolen_name_to_file(
    player_name
)
    if not name_stealer.auto_name_steal_enabled then
        return false
    end

    local clean_name =
        sanitize_name(
            player_name
        )

    if is_excluded_bot_name(
        clean_name
    ) then
        return false
    end

    if name_stealer.is_protected_saved_name(
        clean_name
    ) then
        name_stealer.save_status =
            "Skipped a protected name."

        return false
    end

    if name_stealer.is_lua_decorated_name(
        clean_name
    ) then
        name_stealer.save_status =
            "Skipped a Lua-decorated name."

        return false
    end

    if not is_valid_candidate_name(
        clean_name
    ) then
        return false
    end

    if not name_stealer.saved_names_loaded then
        load_saved_names_from_file(
            true
        )
    end

    local clean_key =
        normalize_candidate_name_for_filter(
            clean_name
        )

    for _, saved_name in ipairs(
        name_stealer.saved_names
    ) do
        if normalize_candidate_name_for_filter(
            saved_name
        ) == clean_key then

            return false
        end
    end

    if not ensure_saved_names_file_exists() then
        return false
    end

    local saved =
        save_stealer_names_to_file(
            {
                clean_name
            },
            "Automatic"
        )

    if saved then
        announce_auto_saved_name(
            clean_name
        )
    end

    return saved
end

function reset_auto_name_detection()
    name_stealer.auto_name_steal_seen_names = {}


    name_stealer.auto_name_steal_last_scan_time =
        -math.huge
end

function detect_and_save_new_lobby_names(
    force_scan
)
    if not name_stealer.auto_name_steal_enabled
        or not is_game_ready() then

        return
    end

    force_scan =
        force_scan == true

    local now =
        get_time()

    if not force_scan
        and now -
            name_stealer.auto_name_steal_last_scan_time
            < DARKSIDE_CONFIG.AUTO_NAME_SCAN_INTERVAL then

        return
    end

    name_stealer.auto_name_steal_last_scan_time =
        now

    local local_player =
        client.get_local_player()

    if not local_player then
        return
    end

    local local_index =
        local_player:get_index()

    local max_clients =
        engine.get_max_clients()

    for player_index = 1,
        max_clients do


        if player_index ~= local_index then
            local player =
                entity.get_by_index(
                    player_index
                )

            if player then
                local player_name =
                    player:get_name()

                local player_is_bot =
                    name_stealer.is_player_bot(
                        player_index,
                        player
                    )

                if not player_is_bot
                    and is_valid_candidate_name(
                        player_name
                    ) then

                    local clean_name =
                        sanitize_name(
                            player_name
                        )

                    if clean_name ~= ""
                        and not name_stealer.auto_name_steal_seen_names[
                            clean_name
                        ] then


                        local blocked_lua_decoration =
                            name_stealer.is_lua_decorated_name(
                                clean_name
                            )

                        local blocked_protected_name =
                            name_stealer.is_protected_saved_name(
                                clean_name
                            )

                        local saved_now =
                            (
                                blocked_lua_decoration
                                or blocked_protected_name
                            )
                            and false
                            or save_auto_stolen_name_to_file(
                                clean_name
                            )

                        local already_saved =
                            false

                        if not saved_now then
                            for _, saved_name in ipairs(
                                name_stealer.saved_names
                            ) do
                                if saved_name == clean_name then
                                    already_saved = true
                                    break
                                end
                            end
                        end

                        if saved_now
                            or already_saved
                            or blocked_lua_decoration
                            or blocked_protected_name then

                            name_stealer.auto_name_steal_seen_names[
                                clean_name
                            ] = true
                        end
                    end
                end
            end
        end
    end
end

function apply_stolen_name(
    player_name,
    silent,
    force_zero_width_prefix
)
    capture_initial_in_game_name()

    if not is_valid_candidate_name(
        player_name,
        true
    ) then
        name_stealer.status =
            "INVALID NAME"

        return false
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        name_stealer.status =
            "WAITING FOR GAME"

        return false
    end

    local clean_player_name =
        clean_name_for_reverse(
            player_name
        )

    clear_active_decoration_state()

    local spoofed_name =
        build_spoofed_name(
            clean_player_name,
            force_zero_width_prefix
        )

    if not spoofed_name then
        name_stealer.status =
            "INVALID NAME"

        return false
    end

    spammer_runtime.remember_requested_name(
        clean_player_name,
        spoofed_name
    )

    client.execnormal(
        'setinfo name "' ..
        spoofed_name ..
        '"'
    )

    name_stealer.last_stolen_name =
        clean_player_name

    name_stealer.total_changes =
        name_stealer.total_changes + 1

    name_stealer.status =
        name_stealer.enabled
        and "RUNNING"
        or "READY"

    name_reverser.last_source =
        clean_player_name

    name_reverser.last_result =
        clean_player_name

    add_name_to_history(
        clean_player_name
    )


    if name_stealer.bot_name_flags[
        clean_player_name
    ] ~= true
        and not is_excluded_bot_name(
            clean_player_name
        ) then

        save_auto_stolen_name_to_file(
            clean_player_name
        )
    end

    if silent then
        set_name_workshop_status(
            "Automatic lobby name applied: " ..
            clean_player_name
        )
    else
        set_name_workshop_status(
            "Lobby name applied: " ..
            clean_player_name
        )

        ui.console.print(
            "[Name Stealer] Stole name: " ..
            clean_player_name
        )
    end

    return true
end

function name_stealer.stop_target_lock(
    reason,
    silent
)
    local was_enabled =
        name_stealer.target_lock_enabled == true

    local previous_name =
        tostring(
            name_stealer.target_lock_name or "None"
        )

    name_stealer.target_lock_enabled = false
    name_stealer.target_lock_key = ""
    name_stealer.target_lock_name = "None"
    name_stealer.target_lock_userid = 0
    name_stealer.target_lock_player_index = 0
    name_stealer.target_lock_last_seen_name = ""
    name_stealer.target_lock_pending_name = ""
    name_stealer.target_lock_last_applied_name = ""
    name_stealer.target_lock_last_check = 0.0
    name_stealer.target_lock_status =
        tostring(
            reason or "OFF"
        )

    name_stealer.status =
        #name_stealer.names > 0
        and "READY"
        or "IDLE"

    if was_enabled
        and silent ~= true then

        ui.console.print(
            "[Name Stealer] Target Lock stopped" ..
            (
                previous_name ~= "None"
                and (
                    " for " ..
                    previous_name
                )
                or ""
            ) ..
            (
                reason
                and tostring(reason) ~= ""
                and (
                    ": " ..
                    tostring(reason)
                )
                or "."
            )
        )
    end

    return was_enabled
end

function name_stealer.find_locked_player_record()
    if not name_stealer.target_lock_enabled then
        return nil
    end

    local player_index = 0

    if tonumber(
        name_stealer.target_lock_userid
    ) and tonumber(
        name_stealer.target_lock_userid
    ) > 0 then

        pcall(
            function()
                player_index =
                    tonumber(
                        engine.get_player_for_userid(
                            name_stealer.target_lock_userid
                        )
                    ) or 0
            end
        )
    end

    if player_index <= 0 then
        player_index =
            tonumber(
                name_stealer.target_lock_player_index
            ) or 0
    end

    if player_index <= 0 then
        return nil
    end

    local player =
        entity.get_by_index(
            player_index
        )

    if not player then
        return nil
    end

    local record =
        name_stealer.build_lobby_player_record(
            player_index,
            player
        )

    if record then
        local locked_key =
            tostring(
                name_stealer.target_lock_key or ""
            )

        if locked_key ~= ""
            and tostring(record.key) ~= locked_key then

            return nil
        end

        return record
    end


    if tonumber(
        name_stealer.target_lock_userid
    ) and tonumber(
        name_stealer.target_lock_userid
    ) > 0 then

        local mapped_index = 0

        pcall(
            function()
                mapped_index =
                    tonumber(
                        engine.get_player_for_userid(
                            name_stealer.target_lock_userid
                        )
                    ) or 0
            end
        )

        if mapped_index == player_index then
            local raw_name = ""
            local team_number = 0

            pcall(
                function()
                    raw_name =
                        sanitize_name(
                            player:get_name()
                        )
                end
            )

            pcall(
                function()
                    team_number =
                        tonumber(
                            player:get_team()
                        ) or 0
                end
            )

            return {
                key = name_stealer.target_lock_key,
                name = raw_name,
                player_index = player_index,
                userid = name_stealer.target_lock_userid,
                team = team_number,
                blocked_name = true
            }
        end
    end

    return nil
end

function name_stealer.set_target_lock(
    player_record
)
    if type(player_record) ~= "table"
        or player_record.is_bot == true
        or tostring(
            player_record.key or ""
        ) == ""
        or tostring(
            player_record.name or ""
        ) == "" then

        return false
    end

    stop_name_spammer()
    stop_name_stealer()
    stop_chat_spammer()

    name_stealer.target_lock_enabled = true
    name_stealer.target_lock_key =
        tostring(player_record.key)
    name_stealer.target_lock_name =
        sanitize_name(player_record.name)
    name_stealer.target_lock_userid =
        tonumber(player_record.userid) or 0
    name_stealer.target_lock_player_index =
        tonumber(player_record.player_index) or 0

    local baseline_name =
        clean_name_for_reverse(
            player_record.name
        )


    name_stealer.target_lock_last_seen_name =
        baseline_name
    name_stealer.target_lock_pending_name = ""
    name_stealer.target_lock_last_applied_name = ""
    name_stealer.target_lock_last_check = 0.0
    name_stealer.target_lock_status =
        "WAITING FOR CHANGE"
    name_stealer.manual_selected_key =
        tostring(player_record.key)

    name_stealer.status =
        "TARGET LOCKED"

    ui.console.print(
        "[Name Stealer] Target Lock started: " ..
        tostring(player_record.name)
    )

    return true
end

function name_stealer.update_target_lock(
    force_update
)
    if not name_stealer.target_lock_enabled then
        return false
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        name_stealer.stop_target_lock(
            "game disconnected",
            false
        )

        return false
    end

    local now =
        get_time()

    if force_update ~= true
        and now -
            (
                tonumber(
                    name_stealer.target_lock_last_check
                ) or 0.0
            ) <
            (
                tonumber(
                    name_stealer.target_lock_poll_interval
                ) or 0.15
            ) then

        return true
    end

    name_stealer.target_lock_last_check =
        now

    local player_record =
        name_stealer.find_locked_player_record()

    if not player_record then
        name_stealer.stop_target_lock(
            "target left the game",
            false
        )

        return false
    end

    name_stealer.target_lock_player_index =
        tonumber(player_record.player_index) or 0

    if tonumber(player_record.userid)
        and tonumber(player_record.userid) > 0 then

        name_stealer.target_lock_userid =
            tonumber(player_record.userid)
    end

    local target_name =
        clean_name_for_reverse(
            player_record.name
        )

    name_stealer.target_lock_name =
        target_name ~= ""
        and target_name
        or name_stealer.target_lock_name

    local last_seen_name =
        tostring(
            name_stealer.target_lock_last_seen_name
            or ""
        )


    if target_name ~= ""
        and target_name ~= last_seen_name then

        name_stealer.target_lock_last_seen_name =
            target_name

        if player_record.blocked_name == true
            or not is_valid_candidate_name(
                target_name,
                true
            ) then

            name_stealer.target_lock_pending_name = ""
            name_stealer.target_lock_status =
                "NAME BLOCKED"
        else
            name_stealer.target_lock_pending_name =
                target_name
        end
    end

    local pending_name =
        tostring(
            name_stealer.target_lock_pending_name
            or ""
        )

    if pending_name ~= "" then
        if apply_stolen_name(
            pending_name,
            true
        ) then
            name_stealer.target_lock_last_applied_name =
                pending_name
            name_stealer.target_lock_pending_name = ""
            name_stealer.target_lock_status =
                "LOCKED"
        else
            name_stealer.target_lock_status =
                "RETRYING"
        end
    elseif name_stealer.target_lock_status
        ~= "NAME BLOCKED" then

        name_stealer.target_lock_status =
            "WAITING FOR CHANGE"
    end

    name_stealer.status =
        "TARGET LOCKED"

    return true
end

function name_stealer.handle_target_name_change(
    userid,
    new_name
)
    if not name_stealer.target_lock_enabled then
        return false
    end

    userid =
        tonumber(userid) or 0

    if userid <= 0
        or userid ~=
            (
                tonumber(
                    name_stealer.target_lock_userid
                ) or 0
            ) then

        return false
    end

    local clean_name =
        clean_name_for_reverse(
            new_name
        )

    name_stealer.target_lock_name =
        clean_name ~= ""
        and clean_name
        or name_stealer.target_lock_name

    name_stealer.refresh_requested = true

    if clean_name == ""
        or clean_name ==
            tostring(
                name_stealer.target_lock_last_seen_name
                or ""
            ) then

        return true
    end

    name_stealer.target_lock_last_seen_name =
        clean_name

    if not is_valid_candidate_name(
        clean_name,
        true
    ) then
        name_stealer.target_lock_pending_name = ""
        name_stealer.target_lock_status =
            "NAME BLOCKED"

        return true
    end


    name_stealer.target_lock_pending_name =
        clean_name

    if apply_stolen_name(
        clean_name,
        true
    ) then
        name_stealer.target_lock_last_applied_name =
            clean_name
        name_stealer.target_lock_pending_name = ""
        name_stealer.target_lock_status =
            "LOCKED"
    else
        name_stealer.target_lock_status =
            "RETRYING"
    end

    name_stealer.status =
        "TARGET LOCKED"

    return true
end

function name_stealer.handle_target_disconnect(
    event
)
    if not name_stealer.target_lock_enabled
        or not event then

        return false
    end

    local userid = 0

    pcall(
        function()
            userid =
                tonumber(
                    event:get_int(
                        "userid"
                    )
                ) or 0
        end
    )

    if userid > 0
        and userid ==
            (
                tonumber(
                    name_stealer.target_lock_userid
                ) or 0
            ) then

        name_stealer.stop_target_lock(
            "target left the game",
            false
        )

        return true
    end

    return false
end

function apply_random_saved_name_once(silent)
    if not name_stealer.saved_names_loaded then
        load_saved_names_from_file(
            true
        )
    end

    local saved_count =
        #name_stealer.saved_names

    if saved_count <= 0 then
        name_stealer.save_status =
            "No saved names are available."

        if not silent then
            ui.console.print(
                "[Name Stealer] No saved names are available."
            )
        end

        return false
    end

    local random_saved_index =
        math.random(
            1,
            saved_count
        )

    if saved_count > 1
        and random_saved_index ==
            name_stealer.saved_randomizer_last_index then

        random_saved_index =
            random_saved_index % saved_count + 1
    end

    local random_saved_name =
        name_stealer.saved_names[
            random_saved_index
        ]

    if not random_saved_name then
        return false
    end

    name_stealer.saved_randomizer_last_index =
        random_saved_index

    clear_active_decoration_state()

    local applied =
        apply_name_workshop_result(
            random_saved_name,
            "Random saved name",
            random_saved_name,
            true
        )

    if applied then
        name_stealer.last_stolen_name =
            random_saved_name
    end

    return applied
end

function set_saved_name_randomizer_enabled(enabled)
    enabled =
        enabled == true

    if not enabled then
        name_stealer.saved_randomizer_enabled = false
        name_stealer.saved_randomizer_next_time = 0.0

        ui.console.print(
            "[Name Stealer] Saved-name randomizer stopped."
        )

        return true
    end

    if not name_stealer.saved_names_loaded then
        load_saved_names_from_file(
            true
        )
    end

    if #name_stealer.saved_names == 0 then
        name_stealer.save_status =
            "No saved names are available."

        ui.console.print(
            "[Name Stealer] Cannot start randomizer: no saved names are available."
        )

        return false
    end

    stop_name_spammer()
    stop_name_stealer()
    stop_chat_spammer()

    name_stealer.saved_randomizer_enabled = true
    name_stealer.saved_randomizer_next_time =
        get_time()

    ui.console.print(
        "[Name Stealer] Saved-name randomizer started."
    )

    return true
end

function update_saved_name_randomizer()
    if not name_stealer.saved_randomizer_enabled then
        return
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        return
    end

    local now =
        get_time()

    if now
        < name_stealer.saved_randomizer_next_time then

        return
    end

    apply_random_saved_name_once(
        true
    )

    name_stealer.saved_randomizer_next_time =
        now +
        name_stealer.change_delay
end

function steal_next_name(silent)
    if not engine.is_in_game()
        or not engine.is_connected() then

        name_stealer.status =
            "WAITING FOR GAME"

        if not silent then
            ui.console.print(
                "[Name Stealer] Not connected to a game."
            )
        end

        return false
    end

    local local_player =
        client.get_local_player()

    if not local_player then
        name_stealer.status =
            "WAITING FOR PLAYER"

        return false
    end

    ensure_stealer_names_are_fresh(
        local_player,
        false
    )

    if #name_stealer.names == 0 then
        name_stealer.status =
            "NO MATCHING PLAYERS"

        if not silent then
            ui.console.print(
                "[Name Stealer] No matching player names found."
            )
        end

        return false
    end

    if name_stealer.current_index
        > #name_stealer.names then

        name_stealer.current_index = 1
    end

    local selected_name =
        name_stealer.names[
            name_stealer.current_index
        ]

    local applied =
        apply_stolen_name(
            selected_name,
            silent
        )

    if applied then
        name_stealer.current_index =
            name_stealer.current_index + 1

        if name_stealer.current_index
            > #name_stealer.names then

            name_stealer.current_index = 1
        end
    end

    return applied
end

function set_stealer_enabled(enabled)
    capture_initial_in_game_name()

    name_stealer.enabled =
        enabled == true

    if name_stealer.enabled then
        if name_stealer.target_lock_enabled then
            name_stealer.stop_target_lock(
                "replaced by Name Stealer cycle",
                true
            )
        end


        stop_name_spammer()
        stop_chat_spammer()

        name_reverser.roulette_enabled = false
        name_reverser.roulette_next_time = 0.0

        name_stealer.saved_randomizer_enabled = false
        name_stealer.saved_randomizer_next_time = 0.0

        name_stealer.next_change_time =
            get_time()

        name_stealer.status =
            "STARTING"

        name_stealer.refresh_requested =
            true
    else
        name_stealer.next_change_time =
            0.0

        name_stealer.status =
            #name_stealer.names > 0
            and "READY"
            or "IDLE"
    end
end

function set_auto_name_steal_enabled(
    enabled
)
    enabled =
        enabled == true


    name_stealer.auto_name_steal_enabled =
        enabled

    name_stealer.auto_name_steal_last_server = ""
    name_stealer.auto_name_steal_was_connected =
        false

    reset_auto_name_detection()

    if enabled then
        ensure_saved_names_file_exists()

        if not name_stealer.saved_names_loaded then
            load_saved_names_from_file(
                true
            )
        end


        detect_and_save_new_lobby_names(
            true
        )

        ui.console.print(
            "[Name Stealer] Auto Name Steal enabled. All current player names are scanned immediately, then rescanned automatically."
        )
    else
        ui.console.print(
            "[Name Stealer] Auto Name Steal disabled."
        )
    end
end

function update_auto_name_steal()
    if not name_stealer.auto_name_steal_enabled then
        return
    end

    if not is_game_ready() then
        name_stealer.auto_name_steal_last_server = ""
        name_stealer.auto_name_steal_was_connected =
            false

        reset_auto_name_detection()

        return
    end

    local server_address =
        get_server_address()

    if server_address == "" then
        server_address =
            "CONNECTED SERVER"
    end

    local joined_new_server =
        not name_stealer.auto_name_steal_was_connected
        or server_address ~=
            name_stealer.auto_name_steal_last_server

    if joined_new_server then
        name_stealer.auto_name_steal_was_connected =
            true

        name_stealer.auto_name_steal_last_server =
            server_address

        clear_stealer_runtime_names()
        reset_auto_name_detection()


        if name_stealer.enabled then
            name_stealer.next_change_time =
                get_time()

            name_stealer.status =
                "STARTING"
        end
    end


    if joined_new_server then
        detect_and_save_new_lobby_names(
            true
        )
    else
        detect_and_save_new_lobby_names()
    end
end

function update_name_stealer()
    local now =
        get_time()

    if name_stealer.target_lock_enabled then
        name_stealer.update_target_lock(
            false
        )
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        if name_stealer.target_lock_enabled then
            name_stealer.stop_target_lock(
                "game disconnected",
                false
            )
        end

        name_stealer.names = {}
        name_stealer.bot_name_flags = {}
        name_stealer.lobby_players = {}
        name_stealer.manual_players = {}
        name_stealer.automatic_players = {}
        name_stealer.player_overrides = {}
        name_stealer.manual_selected_key = ""
        name_stealer.current_index = 1
        name_stealer.last_refresh_time = 0.0
        name_stealer.last_lobby_server = ""
        name_stealer.refresh_requested = false
        name_stealer.status =
            "NOT CONNECTED"

        return
    end

    local stealer_tab_recently_visible =
        ui.selected_tool == 1
        and now -
            (tonumber(ui.last_menu_render_time) or -math.huge)
            < 0.25


    if not name_stealer.enabled
        and not name_stealer.target_lock_enabled
        and not name_stealer.refresh_requested
        and not stealer_tab_recently_visible then

        return
    end

    local local_player =
        client.get_local_player()

    if not local_player then
        if name_stealer.enabled
            or name_stealer.target_lock_enabled then

            name_stealer.status =
                "WAITING FOR PLAYER"
        end

        return
    end

    if name_stealer.enabled
        or name_stealer.target_lock_enabled
        or name_stealer.refresh_requested
        or stealer_tab_recently_visible then

        local visible_refresh_due =
            stealer_tab_recently_visible
            and now -
                (
                    tonumber(
                        name_stealer.last_refresh_time
                    ) or 0.0
                ) >=
                DARKSIDE_CONFIG.NAME_REFRESH_INTERVAL

        ensure_stealer_names_are_fresh(
            local_player,
            visible_refresh_due
        )
    end

    if not name_stealer.enabled then
        return
    end

    if #name_stealer.names == 0 then
        return
    end

    if now
        < name_stealer.next_change_time then

        return
    end

    steal_next_name(true)

    name_stealer.next_change_time =
        now +
        name_stealer.change_delay
end


local normalize_custom_newline_editor_text
local expand_custom_newline_placeholders

function get_chat_message_count()
    return #chat_spammer.messages
end

function get_chat_message(index)
    return chat_spammer.messages[index]
end

function is_chat_message_enabled(index)
    return chat_spammer.message_enabled[
        tonumber(index) or 0
    ] == true
end

function set_chat_message_enabled(
    index,
    enabled
)
    index =
        tonumber(index) or 0

    if not chat_spammer.messages[index] then
        return false
    end

    chat_spammer.message_enabled[index] =
        enabled == true

    save_chat_spammer_preferences()

    return true
end

function get_enabled_chat_message_count()
    local enabled_count = 0

    for index = 1,
        get_chat_message_count() do

        if is_chat_message_enabled(
            index
        ) then
            enabled_count =
                enabled_count + 1
        end
    end

    return enabled_count
end

function set_chat_message(index, value)
    if not chat_spammer.messages[index] then
        return
    end

    chat_spammer.messages[index] =
        normalize_custom_newline_editor_text(
            value
        )

    save_chat_spammer_preferences()
end

normalize_custom_newline_editor_text = function(message)
    message = tostring(message or "")

    message = message:gsub("\r\n", "\n"):gsub("\r", "\n")

    message = message:gsub("\n", "{newline}")

    message = message:gsub("\\n", "{newline}")

    message = message:gsub(
        "{%s*[Nn][Ee][Ww][Ll][Ii][Nn][Ee]%s*}",
        "{newline}"
    )

    while message:find("{newline}{newline}", 1, true) do
        message = message:gsub(
            "{newline}{newline}",
            "{newline}"
        )
    end

    return message
end

expand_custom_newline_placeholders = function(message)
    message = tostring(message or "")

    message = message:gsub("\r\n", "\n"):gsub("\r", "\n")

    message = message:gsub(
        "{%s*[Nn][Ee][Ww][Ll][Ii][Nn][Ee]%s*}",
        "\n"
    )

    message = message:gsub(
        "%(%s*[Nn][Ee][Ww][Ll][Ii][Nn][Ee]%s*%)",
        "\n"
    )

    message = message:gsub("\n+", "\n")

    return message
end

function is_imgui_text_input_active_or_focused()
    for _, method_name in ipairs({
        "is_item_active",
        "is_item_focused",
        "is_item_deactivated_after_edit"
    }) do
        local method =
            type(imgui) == "table"
            and imgui[method_name]
            or nil

        if type(method) == "function" then
            local ok,
                value = pcall(method)

            if ok and value == true then
                return true
            end
        end
    end

    return false
end

function draw_custom_message_input(
    label,
    message,
    maximum_length
)
    maximum_length = math.max(
        1,
        math.floor(
            tonumber(maximum_length)
            or DARKSIDE_CONFIG.MAX_CHAT_MESSAGE_LENGTH
        )
    )

    local editor_message =
        normalize_custom_newline_editor_text(
            message
        )

    if #editor_message > maximum_length then
        editor_message = editor_message:sub(
            1,
            maximum_length
        )
    end

    local changed,
        value = imgui.input_text(
            tostring(label),
            editor_message,
            maximum_length + 1
        )

    local input_active =
        is_imgui_text_input_active_or_focused()

    local raw_value = editor_message

    if value ~= nil then
        raw_value = tostring(value)
    elseif changed then
        raw_value = ""
    end

    local normalized_value =
        normalize_custom_newline_editor_text(
            raw_value
        )

    if #normalized_value > maximum_length then
        normalized_value = normalized_value:sub(
            1,
            maximum_length
        )
    end

    if changed
        or (
            input_active
            and normalized_value ~= editor_message
        ) then

        return true,
            normalized_value
    end

    return false,
        normalized_value
end

function add_chat_message_field()
    if get_chat_message_count()
        >= DARKSIDE_CONFIG.MAX_CHAT_MESSAGES then

        return false
    end

    local restored_message = ""
    local restored_enabled = false

    if #chat_spammer.removed_messages > 0 then
        restored_message =
            table.remove(
                chat_spammer.removed_messages
            ) or ""
    end

    if #chat_spammer.removed_message_enabled > 0 then
        restored_enabled =
            table.remove(
                chat_spammer.removed_message_enabled
            ) == true
    end

    table.insert(
        chat_spammer.messages,
        restored_message
    )

    table.insert(
        chat_spammer.message_enabled,
        restored_enabled
    )

    save_chat_spammer_preferences()

    return true
end

function remove_last_chat_message_field()
    if get_chat_message_count() <= 1 then
        return false
    end

    local removed_message =
        table.remove(
            chat_spammer.messages
        )

    local removed_enabled =
        table.remove(
            chat_spammer.message_enabled
        ) == true

    table.insert(
        chat_spammer.removed_messages,
        tostring(
            removed_message or ""
        )
    )

    table.insert(
        chat_spammer.removed_message_enabled,
        removed_enabled
    )

    chat_spammer.current_index = 1

    save_chat_spammer_preferences()

    return true
end

