local function start_person_followup_search(
    userid,
    source_quote
)
    if not source_quote then
        return nil, nil
    end

    local person =
        extract_quoted_person(
            source_quote.text
        )

    if not person then
        return nil, nil
    end

    local matches =
        find_quotes_by_person(
            person,
            source_quote.line_number
        )

    if #matches == 0 then
        return person, nil
    end

    local state =
        get_search_state(userid)

    state.query_key =
        "person:" ..
        normalize_player_name_for_detection(
            person
        )

    state.display_query =
        person

    state.mode =
        "Quoted person"

    state.matches = {}

    for index, quote_index
        in ipairs(matches) do

        state.matches[index] =
            quote_index
    end

    state.position = 1
    state.shown_position = 0
    state.last_quote_index = nil
    state.shown_quote_ids = {}
    state.shown_unique_count = 0
    state.last_used = os.time()

    shuffle_search_matches(state)

    return person, state
end

local function find_next_from_chat(userid, message, is_local)
    local matched, extra_text =
        extract_command_argument(
            message,
            settings.findnext_command
        )

    if not matched then
        return false
    end

    if trim(extra_text) ~= "" then
        status.message =
            "Invalid findnext input"

        ui.quotes.queue_reliable_messages(
            { "Invalid input, use !findnext" },
            is_local == true
                and 0.05
                or settings.command_response_delay
        )

        return true
    end

    if #quotes == 0 then
        if not load_quotes()
            or #quotes == 0 then

            ui.quotes.queue_reliable_messages(
                { "No quotes are available." },
                is_local == true
                    and 0.05
                    or settings.command_response_delay
            )

            return true
        end
    end

    local state =
        search_states[userid]

    if not state
        or state.query_key == ""
        or type(state.matches) ~= "table"
        or #state.matches == 0 then

        state =
            restore_quote_search_state(
                userid
            )
    end

    if not state
        or state.query_key == ""
        or type(state.matches) ~= "table"
        or #state.matches == 0 then

        local saved_state =
            last_quote_search_state_by_userid[
                userid
            ]

        local non_continuable_message =
            type(saved_state) == "table"
            and tostring(
                saved_state.non_continuable_message or ""
            )
            or ""

        status.message =
            non_continuable_message ~= ""
            and "Find next unavailable"
            or "Ready"

        status.last_requester =
            userid

        status.last_requester_name =
            get_player_name_from_userid(userid)

        if non_continuable_message ~= "" then
            local response_delay =
                is_local == true
                and 0.05
                or settings.command_response_delay

            ui.quotes.queue_reliable_messages(
                { non_continuable_message },
                response_delay
            )
        end

        return true
    end

    if not quote_search_state_has_unshown_result(state) then
        status.message =
            "No further results"

        status.last_requester =
            userid

        status.last_requester_name =
            get_player_name_from_userid(userid)

        local no_more_message =
            build_no_further_quote_results_message(
                state
            )

        ui.console.print(
            "[L4D2 Quotes] " ..
            no_more_message
        )

        remember_quote_search_state(
            userid,
            state
        )

        local response_delay =
            is_local == true
            and 0.05
            or settings.command_response_delay

        ui.quotes.queue_reliable_messages(
            { no_more_message },
            response_delay
        )

        return true
    end

    local selected_quote,
        result_position,
        result_total =
            select_next_from_state(state)

    if not selected_quote then
        status.message =
            "No further results"

        local no_more_message =
            build_no_further_quote_results_message(
                state
            )

        ui.console.print(
            "[L4D2 Quotes] " ..
            no_more_message
        )

        local response_delay =
            is_local == true
            and 0.05
            or settings.command_response_delay

        ui.quotes.queue_reliable_messages(
            { no_more_message },
            response_delay
        )

        return true
    end

    local result_message =
        format_quote_message(
            selected_quote
        )

    update_search_status(
        userid,
        state,
        result_total,
        selected_quote
    )

    if state.mode == "Quoted person" then
        status.last_search_mode =
            "Quoted person"
    else
        status.last_search_mode =
            "Find next - " ..
            state.mode
    end

    status.message =
        string.format(
            "Search continued %d/%d",
            result_position,
            result_total
        )

    ui.console.print(
        string.format(
            "[L4D2 Quotes] Next result %d/%d for \"%s\": %s",
            result_position,
            result_total,
            tostring(state.display_query or ""),
            result_message
        )
    )

    mark_quote_displayed(
        selected_quote
    )

    remember_posted_quote(
        userid,
        selected_quote
    )

    remember_quote_search_state(
        userid,
        state
    )

    local response_delay =
        is_local == true
        and 0.05
        or settings.command_response_delay

    ui.quotes.queue_reliable_messages(
        { result_message },
        response_delay
    )

    return true
end


