function spammer_cfg.get_required_name_warning()
    local mode =
        spammer_cfg.normalize_automation_order_mode()

    local selected_indices =
        spammer_cfg.get_automation_candidate_indices(
            false
        )

    local selected_nonempty_indices =
        spammer_cfg.get_automation_candidate_indices(
            true
        )

    local selected_count =
        #selected_indices

    local selected_nonempty_count =
        #selected_nonempty_indices

    local layout_name = nil

    if mode == 0 then
        layout_name = "horizontal"
    elseif mode == 1 then
        layout_name = "vertical"
    end

    if selected_count <= 0 then
        if layout_name then
            return (
                "No " ..
                layout_name ..
                " names selected"
            ),
            (
                "NO " ..
                layout_name:upper() ..
                " NAMES SELECTED"
            )
        end

        return "No names are selected",
            "NO NAMES SELECTED"
    elseif selected_nonempty_count <= 0 then
        if layout_name then
            return (
                "No " ..
                layout_name ..
                " names are set"
            ),
            (
                "NO " ..
                layout_name:upper() ..
                " NAMES ARE SET"
            )
        end

        return "No names are set",
            "NO NAMES ARE SET"
    elseif selected_nonempty_count < 2 then
        if layout_name then
            return (
                "Select at least 2 " ..
                layout_name ..
                " names"
            ),
            (
                "AT LEAST 2 " ..
                layout_name:upper() ..
                " NAMES REQUIRED"
            )
        end

        return "Select at least 2 non-empty names",
            "AT LEAST 2 NAMES REQUIRED"
    end

    return nil,
        nil
end

function spammer_cfg.get_automation_validation_warning()
    local required_warning,
        required_status =
            spammer_cfg.get_required_name_warning()

    if required_warning then
        return required_warning,
            required_status
    end

    local seen_names = {}

    for _, index in ipairs(
        spammer_cfg.get_automation_candidate_indices(
            true
        )
    ) do
        local normalized_name =
            spammer_cfg.get_normalized_name_field_text(
                index
            )

        if seen_names[normalized_name] ~= nil then
            return "Duplicate names detected",
                "Duplicate names detected"
        end

        seen_names[normalized_name] = index
    end

    for _, index in ipairs(
        spammer_cfg.get_automation_candidate_indices(
            true
        )
    ) do
        local configured_name =
            get_spammer_name(
                index
            )

        local character_count =
            spammer_cfg.get_name_character_count(
                configured_name
            )

        local vertical =
            spammer_cfg.is_name_vertical(
                index
            )

        local limit =
            vertical
            and DARKSIDE_CONFIG.MAX_VERTICAL_NAME_CHARACTERS
            or DARKSIDE_CONFIG.MAX_NAME_CHARACTERS

        if character_count > limit then
            local layout_name =
                vertical
                and "vertical"
                or "horizontal"

            local layout_position =
                spammer_cfg.get_layout_position_for_name_index(
                    index,
                    vertical
                )

            return (
                "Name " ..
                tostring(layout_position) ..
                " exceeds the " ..
                layout_name ..
                " limit"
            ),
            (
                "Name " ..
                tostring(layout_position) ..
                " exceeds the " ..
                layout_name ..
                " limit"
            )
        end
    end

    return nil,
        nil
end

