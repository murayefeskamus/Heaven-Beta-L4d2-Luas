function ui.network.draw_label_value(
    label,
    value,
    r,
    g,
    b
)
    if ui.network.rendering_overlay then
        ui.network.begin_overlay_value_cell(
            label
        )
    else
        imgui.text(
            tostring(label) .. ":"
        )

        imgui.same_line()
    end

    r = tonumber(r) or 1.0
    g = tonumber(g) or 1.0
    b = tonumber(b) or 1.0

    if ui.network.rendering_overlay then
        local is_status_color =
            (
                math.abs(r - 0.25) < 0.03
                and math.abs(g - 1.00) < 0.03
                and math.abs(b - 0.35) < 0.03
            )
            or (
                math.abs(r - 1.00) < 0.03
                and math.abs(g - 0.86) < 0.03
                and math.abs(b - 0.25) < 0.03
            )
            or (
                math.abs(r - 1.00) < 0.03
                and math.abs(g - 0.56) < 0.03
                and math.abs(b - 0.18) < 0.03
            )
            or (
                math.abs(r - 1.00) < 0.03
                and math.abs(g - 0.25) < 0.03
                and math.abs(b - 0.25) < 0.03
            )

        if not is_status_color then
            local palette =
                ui.enhancements.theme_palette()

            local requested_brightness =
                math.max(
                    r,
                    g,
                    b
                )

            local themed_color = nil

            if palette.light == true then
                themed_color =
                    palette.accent
                    or palette.section_text
                    or palette.text
            else
                themed_color =
                    requested_brightness < 0.80
                    and palette.text_disabled
                    or palette.text
            end

            r = themed_color[1]
            g = themed_color[2]
            b = themed_color[3]
        end
    end

    local display_value =
        tostring(value or "")

    if ui.network.rendering_overlay then
        display_value =
            ui.network.fit_overlay_text(
                display_value,
                ui.network.overlay_value_column_width
            )
    end

    theme_text_colored(
        r,
        g,
        b,
        1.0,
        display_value
    )

    if ui.network.rendering_overlay then
        imgui.separator()
    end
end

