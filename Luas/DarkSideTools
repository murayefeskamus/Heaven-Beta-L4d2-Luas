function ui.settings_io.copy_value(
    value
)
    if type(value) ~= "table" then
        return value
    end

    local copied = {}

    for key, child_value in pairs(
        value
    ) do
        copied[
            ui.settings_io.copy_value(
                key
            )
        ] =
            ui.settings_io.copy_value(
                child_value
            )
    end

    return copied
end

function ui.settings_io.pick(
    source,
    keys
)
    local picked = {}

    for _, key in ipairs(
        keys
    ) do
        picked[key] =
            ui.settings_io.copy_value(
                source[key]
            )
    end

    return picked
end

function ui.settings_io.merge(
    target,
    source
)
    if type(target) ~= "table"
        or type(source) ~= "table" then

        return
    end

    for key, value in pairs(
        source
    ) do
        if type(value) == "table" then
            local only_numeric_keys = true
            local highest_index = 0
            local item_count = 0

            for child_key in pairs(
                value
            ) do
                if type(child_key) ~= "number"
                    or child_key < 1
                    or child_key % 1 ~= 0 then

                    only_numeric_keys = false
                    break
                end

                highest_index =
                    math.max(
                        highest_index,
                        child_key
                    )

                item_count =
                    item_count + 1
            end

            local is_array =
                only_numeric_keys
                and (
                    item_count == 0
                    or highest_index == item_count
                )

            if is_array then
                target[key] =
                    ui.settings_io.copy_value(
                        value
                    )
            else
                if type(target[key]) ~= "table" then
                    target[key] = {}
                end

                ui.settings_io.merge(
                    target[key],
                    value
                )
            end
        elseif type(value) == "string"
            or type(value) == "number"
            or type(value) == "boolean" then

            target[key] = value
        end
    end
end

function ui.settings_io.serialize(
    value,
    depth
)
    depth =
        tonumber(depth) or 0

    local value_type =
        type(value)

    if value_type == "nil" then
        return "nil"
    elseif value_type == "boolean"
        or value_type == "number" then

        return tostring(value)
    elseif value_type == "string" then
        return string.format(
            "%q",
            value
        )
    elseif value_type ~= "table" then
        return "nil"
    end

    local keys = {}

    for key in pairs(
        value
    ) do
        table.insert(
            keys,
            key
        )
    end

    table.sort(
        keys,
        function(left, right)
            local left_type =
                type(left)

            local right_type =
                type(right)

            if left_type == right_type then
                if left_type == "number" then
                    return left < right
                end

                return tostring(left) <
                    tostring(right)
            end

            return left_type <
                right_type
        end
    )

    local indent =
        string.rep(
            "    ",
            depth
        )

    local child_indent =
        string.rep(
            "    ",
            depth + 1
        )

    local output = {
        "{\n"
    }

    for _, key in ipairs(
        keys
    ) do
        table.insert(
            output,
            child_indent ..
            "[" ..
            ui.settings_io.serialize(
                key,
                depth + 1
            ) ..
            "] = " ..
            ui.settings_io.serialize(
                value[key],
                depth + 1
            ) ..
            ",\n"
        )
    end

    table.insert(
        output,
        indent ..
        "}"
    )

    return table.concat(
        output
    )
end

