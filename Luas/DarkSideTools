function get_chat_cycle_message(slot_index)
    slot_index =
        tonumber(slot_index) or 0

    if slot_index <= 0 then
        return nil
    end

    local enabled_position = 0

    for index = 1,
        get_chat_message_count() do

        if is_chat_message_enabled(
            index
        ) then
            enabled_position =
                enabled_position + 1

            if enabled_position ==
                slot_index then

                return {
                    text =
                        get_chat_message(
                            index
                        ),
                    label =
                        "Message " ..
                        tostring(index),
                    source = "editable",
                    source_index = index
                }
            end
        end
    end

    for index = 1,
        get_hardcoded_chat_message_count() do

        if is_hardcoded_chat_message_enabled(
            index
        ) then
            enabled_position =
                enabled_position + 1

            if enabled_position ==
                slot_index then

                local entry =
                    get_hardcoded_chat_message_entry(
                        index
                    )

                return {
                    text =
                        tostring(
                            entry.text or ""
                        ),
                    label =
                        tostring(
                            entry.label or
                            (
                                "Preset symbol " ..
                                tostring(index)
                            )
                        ),
                    source = "hardcoded",
                    source_index = index
                }
            end
        end
    end

    return nil
end

