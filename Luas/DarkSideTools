    )
end

function ui.control.rgb_to_hsv(color)
    color = type(color) == "table" and color or { 1.0, 1.0, 1.0 }

    local red = ui.control.clamp(color[1], 0.0, 1.0)
    local green = ui.control.clamp(color[2], 0.0, 1.0)
    local blue = ui.control.clamp(color[3], 0.0, 1.0)
    local maximum = math.max(red, green, blue)
    local minimum = math.min(red, green, blue)
    local delta = maximum - minimum
    local hue = 0.0

    if delta > 0.00001 then
        if maximum == red then
            hue = ((green - blue) / delta) % 6.0
        elseif maximum == green then
            hue = ((blue - red) / delta) + 2.0
        else
            hue = ((red - green) / delta) + 4.0
        end

        hue = hue / 6.0
    end

    local saturation = maximum <= 0.00001 and 0.0 or delta / maximum

    return hue,
        saturation,
        maximum
end

function ui.control.hsv_to_rgb(
    hue,
    saturation,
    value
)
    hue = (tonumber(hue) or 0.0) % 1.0
    saturation = ui.control.clamp(saturation, 0.0, 1.0)
    value = ui.control.clamp(value, 0.0, 1.0)

    local sector = hue * 6.0
    local index = math.floor(sector)
    local fraction = sector - index
    local p = value * (1.0 - saturation)
    local q = value * (1.0 - fraction * saturation)
    local t = value * (1.0 - (1.0 - fraction) * saturation)
    local modulo = index % 6

    if modulo == 0 then
        return { value, t, p, 1.0 }
    elseif modulo == 1 then
        return { q, value, p, 1.0 }
    elseif modulo == 2 then
        return { p, value, t, 1.0 }
    elseif modulo == 3 then
        return { p, q, value, 1.0 }
    elseif modulo == 4 then
        return { t, p, value, 1.0 }
    end

    return { value, p, q, 1.0 }
end

function ui.control.color_luminance(color)
    color = type(color) == "table" and color or { 0.0, 0.0, 0.0 }

    return (tonumber(color[1]) or 0.0) * 0.2126 +
        (tonumber(color[2]) or 0.0) * 0.7152 +
        (tonumber(color[3]) or 0.0) * 0.0722
end

function ui.control.contrast_text_color(color)
    return ui.control.color_luminance(color) >= 0.58
        and { 0.025, 0.030, 0.040, 1.0 }
        or { 1.0, 1.0, 1.0, 1.0 }
end

function ui.control.get_aim_v2_visual_palette()
    local theme = ui.enhancements.theme_palette()
    local accent = theme.accent or theme.active_tab or theme.section_text or { 0.30, 0.60, 0.95, 1.0 }
    local background = theme.background or { 0.08, 0.08, 0.10, 1.0 }
    local frame = theme.frame or theme.child or theme.button or background
    local text = theme.text or { 1.0, 1.0, 1.0, 1.0 }
    local disabled = theme.text_disabled or ui.control.mix_color(text, background, 0.55)

    local hue,
        saturation,
        value =
            ui.control.rgb_to_hsv(accent)

    local refined_accent =
        ui.control.hsv_to_rgb(
            hue,
            ui.control.clamp(math.max(0.42, saturation), 0.38, 0.86),
            theme.light == true
                and ui.control.clamp(value * 0.82, 0.42, 0.72)
                or ui.control.clamp(math.max(0.78, value), 0.78, 1.0)
        )

    local idle =
        ui.control.mix_color(
            refined_accent,
            disabled,
            0.55
        )

    local selected = refined_accent

    local active =
        ui.control.mix_color(
            refined_accent,
            theme.light == true
                and { 0.0, 0.0, 0.0, 1.0 }
                or { 1.0, 1.0, 1.0, 1.0 },
            theme.light == true and 0.12 or 0.22
        )

    local locked =
        ui.control.hsv_to_rgb(
            hue,
            ui.control.clamp(math.max(0.64, saturation), 0.58, 0.92),
            theme.light == true and 0.56 or 1.0
        )

    local control_frame =
        ui.control.mix_color(
            frame,
            refined_accent,
            theme.light == true and 0.05 or 0.09
        )

    local control_hovered =
        ui.control.mix_color(
            control_frame,
            refined_accent,
            0.18
        )

    local control_active =
        ui.control.mix_color(
            control_frame,
            refined_accent,
            0.32
        )

    local secondary_button =
        ui.control.mix_color(
            theme.button or frame,
            refined_accent,
            theme.light == true and 0.22 or 0.30
        )

    return {
        setting = refined_accent,
        heading = refined_accent,
        hint = disabled,
        scenario = ui.control.mix_color(disabled, refined_accent, 0.16),
        frame = control_frame,
        frame_hovered = control_hovered,
        frame_active = control_active,
        border = ui.control.mix_color(theme.border or frame, refined_accent, 0.14),
        check = refined_accent,
        grab = refined_accent,
        grab_active = active,
        header = control_frame,
        header_hovered = control_hovered,
        header_active = control_active,
        action_primary = refined_accent,
        action_secondary = secondary_button,
        idle = idle,
        selected = selected,
        active = active,
        locked = locked,
        warning = ui.control.mix_color(refined_accent, { 1.0, 0.72, 0.20, 1.0 }, 0.46),
        disabled = disabled,
        text = text,
        background = background
    }
end

function ui.control.push_aim_v2_style_colors()
    if type(imgui.push_style_color) ~= "function" then
        return 0
    end

    local palette = ui.control.get_aim_v2_visual_palette()
    local count = 0

    local function push(index, color, alpha)
        local ok =
            pcall(
                imgui.push_style_color,
                index,
                color[1],
                color[2],
                color[3],
                tonumber(alpha) or color[4] or 1.0
            )

        if ok then
            count = count + 1
        end
    end

    push(5, palette.border)
    push(7, palette.frame)
    push(8, palette.frame_hovered)
    push(9, palette.frame_active)
    push(18, palette.check)
    push(19, palette.grab)
    push(20, palette.grab_active)
    push(24, palette.header)
    push(25, palette.header_hovered)
    push(26, palette.header_active)

    return count
end

