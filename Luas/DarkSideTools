function ui.heaven_configs.canonical_detected_name(
    config_name
)
    config_name =
        ui.heaven_configs.clean_config_name(
            config_name
        )

    if config_name == "" then
        return ""
    end

    local detected_index =
        type(ui.heaven_configs.detected_lookup) == "table"
        and ui.heaven_configs.detected_lookup[
            config_name:lower()
        ]
        or nil

    local detected_entry =
        detected_index
        and type(ui.heaven_configs.detected_configs) == "table"
        and ui.heaven_configs.detected_configs[
            detected_index
        ]
        or nil

    return detected_entry
        and ui.heaven_configs.clean_config_name(
            detected_entry.name
        )
        or ""
end

function ui.heaven_configs.reconcile_slot_assignments()
    local detected_configs =
        type(ui.heaven_configs.detected_configs) == "table"
        and ui.heaven_configs.detected_configs
        or {}

    local maximum_slots =
        math.max(
            1,
            math.floor(
                tonumber(
                    ui.heaven_configs.max_slots
                ) or 10
            )
        )

    local canonical_by_key = {}
    local detected_order = {}

    for _, detected_entry in ipairs(detected_configs) do
        local canonical_name =
            ui.heaven_configs.clean_config_name(
                detected_entry.name
            )

        local lookup_key = canonical_name:lower()

        if canonical_name ~= ""
            and canonical_by_key[lookup_key] == nil
            and #detected_order < maximum_slots then

            canonical_by_key[lookup_key] = canonical_name
            detected_order[#detected_order + 1] = canonical_name
        end
    end

    local ordered_slots = {}
    local used = {}

    for index = 1, maximum_slots do
        local slot =
            type(ui.heaven_configs.slots) == "table"
            and ui.heaven_configs.slots[index]
            or nil

        local current_name =
            slot
            and ui.heaven_configs.clean_config_name(
                slot.config_name
            )
            or ""

        local lookup_key = current_name:lower()
        local canonical_name = canonical_by_key[lookup_key]

        if slot
            and canonical_name
            and used[lookup_key] ~= true then

            ordered_slots[#ordered_slots + 1] = {
                enabled = slot.enabled == true,
                key = math.max(
                    0,
                    math.min(
                        255,
                        math.floor(
                            tonumber(slot.key) or 0
                        )
                    )
                ),
                config_name = canonical_name
            }

            used[lookup_key] = true
        end
    end

    for _, canonical_name in ipairs(detected_order) do
        local lookup_key = canonical_name:lower()

        if used[lookup_key] ~= true
            and #ordered_slots < maximum_slots then

            ordered_slots[#ordered_slots + 1] = {
                enabled = true,
                key = 0,
                config_name = canonical_name
            }

            used[lookup_key] = true
        end
    end

    local changed = false

    for index = 1, maximum_slots do
        local next_slot =
            ordered_slots[index]
            or ui.heaven_configs.default_slot(index)

        local current_slot =
            type(ui.heaven_configs.slots[index]) == "table"
            and ui.heaven_configs.slots[index]
            or ui.heaven_configs.default_slot(index)

        local current_name =
            ui.heaven_configs.clean_config_name(
                current_slot.config_name
            )

        if current_name ~= next_slot.config_name
            or current_slot.enabled ~= next_slot.enabled
            or math.floor(
                tonumber(current_slot.key) or 0
            ) ~= next_slot.key then

            changed = true
        end

        ui.heaven_configs.slots[index] = next_slot
    end

    ui.heaven_configs.last_applied_slot = 0

    local loaded_name =
        ui.heaven_configs.clean_config_name(
            ui.heaven_configs.last_loaded_config
        )

    if loaded_name ~= "" then
        for index = 1, #ordered_slots do
            local slot_name =
                ui.heaven_configs.clean_config_name(
                    ui.heaven_configs.slots[index].config_name
                )

            if slot_name:lower() == loaded_name:lower() then
                ui.heaven_configs.last_applied_slot = index
                break
            end
        end
    end

    return changed
end

function ui.heaven_configs.assign_config_to_slot(
    slot_index,
    config_name
)
    ui.heaven_configs.normalize_settings()

    slot_index =
        math.max(
            1,
            math.min(
                ui.heaven_configs.max_slots,
                math.floor(
                    tonumber(slot_index) or 1
                )
            )
        )

    local target_slot =
        ui.heaven_configs.slots[slot_index]

    if not target_slot then
        return false
    end

    local requested_name =
        ui.heaven_configs.clean_config_name(
            config_name
        )

    if requested_name ~= "" then
        requested_name =
            ui.heaven_configs.canonical_detected_name(
                requested_name
            )

        if requested_name == "" then
            ui.heaven_configs.last_status =
                "That config is no longer available. Press Refresh."

            ui.heaven_configs.last_status_error = true
            return false
        end
    end

    local previous_name =
        ui.heaven_configs.clean_config_name(
            target_slot.config_name
        )

    if requested_name ~= "" then
        for index = 1, ui.heaven_configs.max_slots do
            if index ~= slot_index then
                local other_slot =
                    ui.heaven_configs.slots[index]

                local other_name =
                    other_slot
                    and ui.heaven_configs.clean_config_name(
                        other_slot.config_name
                    )
                    or ""

                if other_slot
                    and other_name ~= ""
                    and other_name:lower() == requested_name:lower() then

                    local canonical_previous =
                        ui.heaven_configs.canonical_detected_name(
                            previous_name
                        )

                    other_slot.config_name =
                        canonical_previous ~= ""
                        and canonical_previous
                        or ""

                    if other_slot.config_name == "" then
                        other_slot.enabled = false
                    end

                    break
                end
            end
        end
    end

    target_slot.config_name = requested_name
    target_slot.enabled = requested_name ~= ""
    ui.heaven_configs.last_applied_slot = 0

    local loaded_name =
        ui.heaven_configs.clean_config_name(
            ui.heaven_configs.last_loaded_config
        )

    if loaded_name ~= "" then
        for index = 1, ui.heaven_configs.max_slots do
            local slot_name =
                ui.heaven_configs.clean_config_name(
                    ui.heaven_configs.slots[index].config_name
                )

            if slot_name:lower() == loaded_name:lower() then
                ui.heaven_configs.last_applied_slot = index
                break
            end
        end
    end

    ui.heaven_configs.last_status =
        requested_name ~= ""
        and (
            "Hotkey " ..
            tostring(slot_index) ..
            " uses " ..
            requested_name ..
            ".cfg"
        )
        or (
            "Hotkey " ..
            tostring(slot_index) ..
            " cleared."
        )

    ui.heaven_configs.last_status_error = false
    ui.heaven_configs.save_settings_now()

    return true
end

