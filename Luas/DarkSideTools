function ui.kill_tools.shuffle_table(
    target
)
    for index = #target,
        2,
        -1 do

        local random_index =
            math.random(index)

        target[index],
            target[random_index] =
                target[random_index],
                target[index]
    end
end

function ui.kill_tools.refill_message_pool()
    local settings =
        ui.kill_tools.message_on_kill

    local pool =
        ui.kill_tools.get_enabled_message_indices()

    ui.kill_tools.shuffle_table(
        pool
    )

    if #pool > 1
        and pool[#pool] ==
            settings.last_template_index then

        pool[1],
            pool[#pool] =
                pool[#pool],
                pool[1]
    end

    settings.pool =
        pool

    return #pool > 0
end

function ui.kill_tools.next_message_template()
    local settings =
        ui.kill_tools.message_on_kill

    if #settings.pool == 0
        and not ui.kill_tools.refill_message_pool() then

        return nil,
            0
    end

    local template_index =
        tonumber(
            table.remove(
                settings.pool
            )
        ) or 0

    local catalog =
        ui.kill_tools.get_message_catalog(
            true
        )

    local entry =
        catalog[template_index]

    if not entry
        or tostring(entry.text or "") == "" then

        ui.kill_tools.clear_message_pool()
        return nil,
            0
    end

    settings.last_template_index =
        template_index

    return tostring(entry.text),
        template_index
end

function ui.kill_tools.peek_message_template()
    local settings =
