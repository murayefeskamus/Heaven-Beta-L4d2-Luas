                if row_index < #rows then
                    imgui.separator()
                end
            end
        end
    end

    imgui.end_child()

    theme_text_colored(
        0.65, 0.65, 0.65, 1.0,
        prediction.used_future_wave
            and "Estimates use open slots, then the next available class wave. Result appears for 5 seconds after a verified guess."
            or "Estimates use verified open class slots. Result appears for 5 seconds after a verified guess."
    )
end

