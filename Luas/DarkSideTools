function ui.setting_search.setting_search_match_rgb_to_hsv(red, green, blue)
    red = math.max(0.0, math.min(1.0, tonumber(red) or 0.0))
    green = math.max(0.0, math.min(1.0, tonumber(green) or 0.0))
    blue = math.max(0.0, math.min(1.0, tonumber(blue) or 0.0))

    local maximum = math.max(red, green, blue)
    local minimum = math.min(red, green, blue)
    local delta = maximum - minimum
    local hue = 0.0
    local saturation = maximum <= 0.0001 and 0.0 or delta / maximum

    if delta > 0.0001 then
        if maximum == red then
            hue = ((green - blue) / delta) % 6
        elseif maximum == green then
            hue = ((blue - red) / delta) + 2
        else
            hue = ((red - green) / delta) + 4
        end

        hue = (hue / 6) % 1.0
    end

    return hue, saturation, maximum
end

function ui.setting_search.setting_search_match_hsv_to_rgb(hue, saturation, value)
    hue = (tonumber(hue) or 0.0) % 1.0
    saturation = math.max(0.0, math.min(1.0, tonumber(saturation) or 0.0))
    value = math.max(0.0, math.min(1.0, tonumber(value) or 0.0))

    local chroma = value * saturation
    local sector = (hue * 6.0) % 6.0
    local secondary = chroma * (1.0 - math.abs((sector % 2.0) - 1.0))
    local match = value - chroma
    local red, green, blue = 0.0, 0.0, 0.0

    if sector < 1.0 then
        red, green, blue = chroma, secondary, 0.0
    elseif sector < 2.0 then
        red, green, blue = secondary, chroma, 0.0
    elseif sector < 3.0 then
        red, green, blue = 0.0, chroma, secondary
    elseif sector < 4.0 then
        red, green, blue = 0.0, secondary, chroma
    elseif sector < 5.0 then
        red, green, blue = secondary, 0.0, chroma
    else
        red, green, blue = chroma, 0.0, secondary
    end

    return red + match, green + match, blue + match
end

function ui.setting_search.get_attention_color(palette)
    palette = type(palette) == "table" and palette or {}

    local source =
        type(palette.accent) == "table" and palette.accent
        or type(palette.section_text) == "table" and palette.section_text
        or type(palette.active_tab_text) == "table" and palette.active_tab_text
        or { 0.20, 0.78, 1.00 }

    local source_red = tonumber(source[1]) or 0.20
    local source_green = tonumber(source[2]) or 0.78
    local source_blue = tonumber(source[3]) or 1.00
    local signature = string.format(
        "%.3f|%.3f|%.3f|%s",
        source_red,
        source_green,
        source_blue,
        palette.light == true and "1" or "0"
    )

    if ui.setting_search.setting_search_match_attention_signature == signature
        and type(ui.setting_search.setting_search_match_attention_color) == "table" then
        return ui.setting_search.setting_search_match_attention_color
    end

    local hue, saturation =
        ui.setting_search.setting_search_match_rgb_to_hsv(
            source_red,
            source_green,
            source_blue
        )

    hue = (hue + 0.43) % 1.0
    saturation = math.max(0.90, saturation)

    local value = palette.light == true and 0.82 or 1.00
    local red, green, blue =
        ui.setting_search.setting_search_match_hsv_to_rgb(
            hue,
            saturation,
            value
        )

    ui.setting_search.setting_search_match_attention_signature = signature
    ui.setting_search.setting_search_match_attention_color = { red, green, blue }
    return ui.setting_search.setting_search_match_attention_color
end

function ui.setting_search.setting_search_match_read_vec2(first, second)
