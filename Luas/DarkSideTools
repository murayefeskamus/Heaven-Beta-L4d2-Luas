    function ui.quotes.get_hard_wrapped_lines(
        text_value,
        wrap_width
    )
        text_value =
            tostring(
                text_value or ""
            )

        wrap_width =
            math.max(
                40,
                tonumber(
                    wrap_width
                ) or 260
            )

        local lines = {}
        local current = ""
        local current_width = 0

        local function flush_line(
            force_empty
        )
            if current ~= ""
                or force_empty
                or #lines == 0 then

                lines[
                    #lines + 1
                ] = current
            end

            current = ""
            current_width = 0
        end

        local function append_character(
            character
        )
            local character_width =
                ui.lobby.measure_text_width(
                    character
                )

            if current ~= ""
                and current_width +
                    character_width >
                    wrap_width then

                flush_line(false)
            end

            if current == ""
                and character:match(
                    "^%s$"
                ) then

                return
            end

            current =
                current ..
                character

            current_width =
                current_width +
                character_width
        end

        local function append_token(
            token
        )
            if token == "" then
                return
            end

            local token_width =
                ui.lobby.measure_text_width(
                    token
                )

            if token_width <=
                wrap_width then

                if current ~= ""
                    and current_width +
                        token_width >
                        wrap_width then

                    flush_line(false)
                end

                if not (
                    current == ""
                    and token:match(
                        "^%s+$"
                    )
                ) then

                    current =
                        current ..
                        token

                    current_width =
                        current_width +
                        token_width
                end

                return
            end


            for _,
                character in ipairs(
                    split_utf8_characters(
                        token
                    )
                ) do

                append_character(
                    character
                )
            end
        end

        local index = 1

        while index <=
            #text_value do

            local character =
                text_value:sub(
                    index,
                    index
                )

            if character == "\r"
                or character == "\n" then

                if character == "\r"
                    and text_value:sub(
                        index + 1,
                        index + 1
                    ) == "\n" then

                    index =
                        index + 1
                end

                flush_line(true)
                index =
                    index + 1
            else
                local remaining =
                    text_value:sub(
                        index
                    )

                local token =
                    remaining:match(
                        "^(%s+)"
                    )
                    or remaining:match(
                        "^(%S+)"
                    )
                    or character

                append_token(
                    token
                )

                index =
                    index +
                    #token
            end
        end

        if current ~= ""
            or #lines == 0 then

            flush_line(false)
        end

        return lines
    end

    function ui.quotes.draw_highlighted_quote(
        text_value,
        terms,
        wrap_width
    )
        text_value =
            tostring(
                text_value or ""
            )

        terms =
            terms or {}

        wrap_width =
            math.max(
                120,
                tonumber(
                    wrap_width
                ) or 520
            )

        local clean_terms = {}

        for _,
            term in ipairs(
                terms
            ) do

            term =
                trim(
                    term
                )

            if term ~= "" then
                clean_terms[
                    #clean_terms + 1
                ] = term
            end
        end

        local palette =
            ui.enhancements.theme_palette()

        local highlight_color =
            palette.accent

        if tostring(
            palette.name or ""
        ) == "OLED Black" then
            highlight_color = {
                1.0,
                0.20,
                0.20
            }
        end

        local segments = {}
        local lower_text =
            text_value:lower()

        local position = 1

        while position <=
            #text_value do

            local match_start = nil
            local match_end = nil

            for _,
                term in ipairs(
                    clean_terms
                ) do

                local term_start,
                    term_end =
                        lower_text:find(
                            term:lower(),
                            position,
                            true
                        )

                if term_start
                    and (
                        not match_start
                        or term_start <
                            match_start
                        or (
                            term_start ==
                            match_start
                            and term_end >
                                match_end
                        )
                    ) then

                    match_start =
                        term_start

                    match_end =
                        term_end
                end
            end

            if not match_start then
                segments[
                    #segments + 1
                ] = {
                    text =
                        text_value:sub(
                            position
                        ),
                    highlighted = false
                }

                break
            end

            if match_start >
                position then

                segments[
                    #segments + 1
                ] = {
                    text =
                        text_value:sub(
                            position,
                            match_start - 1
                        ),
                    highlighted = false
                }
            end

            segments[
                #segments + 1
            ] = {
                text =
                    text_value:sub(
                        match_start,
                        match_end
                    ),
                highlighted = true
            }

            position =
                match_end + 1
        end

        if #segments == 0 then
            segments[1] = {
                text = text_value,
                highlighted = false
            }
        end


        local tokens = {}

        for _,
            segment in ipairs(
                segments
            ) do

            for _,
                character in ipairs(
                    split_utf8_characters(
                        tostring(
                            segment.text or ""
                        )
                    )
                ) do

                if character == "\r"
                    or character == "\n" then

                    tokens[
                        #tokens + 1
                    ] = {
                        newline = true
                    }
                else
                    local whitespace =
                        character:match(
                            "^%s$"
                        ) ~= nil

                    local token =
                        tokens[
                            #tokens
                        ]

                    if not token
                        or token.newline
                        or token.whitespace ~=
                            whitespace then

                        token = {
                            whitespace = whitespace,
                            characters = {},
                            width = 0
                        }

                        tokens[
                            #tokens + 1
                        ] = token
                    end

                    local character_width =
                        ui.lobby.measure_text_width(
                            character
                        )

                    token.characters[
                        #token.characters + 1
                    ] = {
                        text = character,
                        highlighted =
                            segment.highlighted == true,
                        width = character_width
                    }

                    token.width =
                        token.width +
                        character_width
                end
            end
        end

        local line_start_x =
            ui.lobby.get_cursor_x()

        local line_width = 0
        local line_has_item = false
        local pending_text = ""
        local pending_highlight = false
        local pending_width = 0

        local function occupied_width()
            return line_width +
                pending_width
        end

        local function flush_pending()
            if pending_text == "" then
                return
            end

            if line_has_item then
                imgui.same_line()

                ui.lobby.set_cursor_x(
                    line_start_x +
                    line_width
                )
            else
                ui.lobby.set_cursor_x(
                    line_start_x
                )
            end

            if pending_highlight then


                theme_text_colored(
                    highlight_color[1],
                    highlight_color[2],
                    highlight_color[3],
                    1.0,
                    pending_text
                )
            else
                theme_text_colored(
                    palette.text[1],
                    palette.text[2],
                    palette.text[3],
                    1.0,
                    pending_text
                )
            end

            line_width =
                line_width +
                pending_width

            line_has_item = true
            pending_text = ""
            pending_width = 0
        end

        local function start_new_line()
            flush_pending()

            line_width = 0
            line_has_item = false
        end

        local function append_character(
            character_entry
        )
            local character =
                tostring(
                    character_entry.text or ""
                )

            if character == "" then
                return
            end

            local character_width =
                tonumber(
                    character_entry.width
                ) or ui.lobby.measure_text_width(
                    character
                )

            if occupied_width() > 0
                and occupied_width() +
                    character_width >
                    wrap_width then

                start_new_line()

                if character_entry.whitespace
                    or character:match(
                        "^%s$"
                    ) then

                    return
                end
            end

            local highlighted =
                character_entry.highlighted == true

            if pending_text ~= ""
                and pending_highlight ~=
                    highlighted then

                flush_pending()
            end

            pending_highlight =
                highlighted

            pending_text =
                pending_text ..
                character

            pending_width =
                pending_width +
                character_width
        end

        for _,
            token in ipairs(
                tokens
            ) do

            if token.newline then
                start_new_line()
            elseif token.whitespace then
                if occupied_width() > 0 then
                    if occupied_width() +
                        token.width >
                        wrap_width then

                        start_new_line()
                    else
                        for _,
                            character_entry in ipairs(
                                token.characters
                            ) do

                            append_character(
                                character_entry
                            )
                        end
                    end
                end
            else
                if token.width <=
                    wrap_width
                    and occupied_width() > 0
                    and occupied_width() +
                        token.width >
                        wrap_width then

                    start_new_line()
                end

                for _,
                    character_entry in ipairs(
                        token.characters
                    ) do

                    append_character(
                        character_entry
                    )
                end
            end
        end

        flush_pending()

        if text_value == "" then
            imgui.text("")
        end
    end

