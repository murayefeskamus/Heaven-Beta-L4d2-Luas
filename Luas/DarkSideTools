                    player_record.chat_messages
                    or 0
                ) + 1

            if ui.lobby.activity_cache[
                player_record.key
            ] then

                ui.lobby.activity_cache[
                    player_record.key
                ].chat_messages =
                    player_record.chat_messages
            end

            return
        end
