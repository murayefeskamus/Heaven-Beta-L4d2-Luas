        local ping_r,
            ping_g,
            ping_b =
                ui.network.get_latency_color(
                    math.max(
                        tonumber(stats.ping_out_ms) or 0.0,
                        tonumber(stats.ping_in_ms) or 0.0
                    )
                )

        local jitter_r,
            jitter_g,
            jitter_b =
                ui.network.get_jitter_color(
                    tonumber(stats.jitter_ms) or 0.0
                )

        local loss_r,
            loss_g,
            loss_b =
                ui.network.get_percent_color(
                    tonumber(stats.loss_percent) or 0.0
                )

        local choke_r,
            choke_g,
            choke_b =
                ui.network.get_percent_color(
                    tonumber(stats.choke_percent) or 0.0
