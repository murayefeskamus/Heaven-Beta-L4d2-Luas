function chat_spammer.capture_vote_context(session)
    if type(session) ~= "table" then
        return
    end

    local recorded_epoch =
        math.floor(
            tonumber(os.time()) or 0
        )

    session.recorded_at_epoch = recorded_epoch
    session.recorded_at_text =
        recorded_epoch > 0
        and os.date(
            "%Y-%m-%d %H:%M:%S",
            recorded_epoch
        )
        or "Unknown"

    local map_code = "Unavailable"

    if type(ui.lobby.get_map_code) == "function" then
        local map_ok,
            map_value =
                pcall(
                    ui.lobby.get_map_code
                )

        if map_ok
            and tostring(map_value or "") ~= "" then

            map_code = tostring(map_value)
        end
    elseif ui.lobby.overview then
        map_code =
            tostring(
                ui.lobby.overview.map_code
                or "Unavailable"
            )
    end

    local map_name = map_code

    if type(ui.lobby.get_map_name) == "function" then
        local name_ok,
            name_value =
                pcall(
                    ui.lobby.get_map_name,
                    map_code
                )

        if name_ok
            and tostring(name_value or "") ~= "" then

            map_name = tostring(name_value)
        end
    elseif ui.lobby.overview then
        map_name =
            tostring(
                ui.lobby.overview.map
                or map_code
            )
    end

    session.map_code = map_code
    session.map_name = map_name
    session.game_mode =
        tostring(
            ui.lobby.overview
            and ui.lobby.overview.mode
            or "Unavailable"
        )
end

function chat_spammer.remember_vote_session(session)
    if type(session) ~= "table" then
        return false
    end

    if type(chat_spammer.vote_history) ~= "table" then
        chat_spammer.vote_history = {}
    end

    chat_spammer.capture_vote_context(
        session
    )

    table.insert(
        chat_spammer.vote_history,
        1,
        session
    )

    local history_limit =
        math.max(
            1,
            math.floor(
                tonumber(chat_spammer.vote_history_max) or 10
            )
        )

    while #chat_spammer.vote_history > history_limit do
        table.remove(
            chat_spammer.vote_history
        )
    end

    chat_spammer.vote_history_selection = 0
    chat_spammer.vote_remembered_session = session

    return true
end

