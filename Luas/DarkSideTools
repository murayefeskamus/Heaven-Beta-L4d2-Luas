function add_spammer_name_field(requested_vertical)
    if requested_vertical ~= nil
        and #spammer_cfg.get_name_indices_for_layout(
            requested_vertical == true
        ) >= DARKSIDE_CONFIG.MAX_SPAMMER_NAMES_PER_LAYOUT then

        return false
    end

    if get_spammer_name_count()
        >= DARKSIDE_CONFIG.MAX_SPAMMER_NAMES then

        return false
    end

    spammer_cfg.ensure_name_vertical_modes()
    spammer_cfg.ensure_name_enabled_states()

    local restored_name = ""
    local restored_vertical = true
    local restored_enabled = true

    if #spammer_cfg.removed_names > 0 then
        restored_name =
            table.remove(
                spammer_cfg.removed_names
            ) or ""
    end

    if #spammer_cfg.removed_name_vertical_modes > 0 then
        restored_vertical =
            table.remove(
                spammer_cfg.removed_name_vertical_modes
            ) ~= false
    end

    if #spammer_cfg.removed_name_enabled > 0 then
        restored_enabled =
            table.remove(
                spammer_cfg.removed_name_enabled
            ) ~= false
    end

    if requested_vertical ~= nil then
        restored_vertical =
            requested_vertical == true
    end

    table.insert(
        spammer_cfg.extra_names,
        restored_name
    )

    spammer_cfg.ensure_name_vertical_modes()

    spammer_cfg.name_vertical_modes[
        get_spammer_name_count()
    ] = restored_vertical

    spammer_cfg.ensure_name_enabled_states()

    spammer_cfg.name_enabled[
        get_spammer_name_count()
    ] = restored_enabled

    spammer_cfg.recalculate_smart_limits(
        true
    )

    return true
end

function spammer_cfg.ensure_minimum_layout_fields()
    spammer_cfg.ensure_name_vertical_modes()
    spammer_cfg.ensure_name_enabled_states()

    local function append_blank_field(vertical)
        if #spammer_cfg.get_name_indices_for_layout(
            vertical
        ) >= DARKSIDE_CONFIG.MAX_SPAMMER_NAMES_PER_LAYOUT
            or get_spammer_name_count() >=
                DARKSIDE_CONFIG.MAX_SPAMMER_NAMES then

            return false
        end

        table.insert(
            spammer_cfg.extra_names,
            ""
        )

        spammer_cfg.ensure_name_vertical_modes()
        spammer_cfg.name_vertical_modes[
            get_spammer_name_count()
        ] = vertical == true

        spammer_cfg.ensure_name_enabled_states()
        spammer_cfg.name_enabled[
            get_spammer_name_count()
        ] = true

        return true
    end

    local function ensure_layout(vertical)
        local indices =
            spammer_cfg.get_name_indices_for_layout(
                vertical
            )

        while #indices < 2 do
            if append_blank_field(
                vertical
            ) then
                indices =
                    spammer_cfg.get_name_indices_for_layout(
                        vertical
                    )
            else
                local opposite_indices =
                    spammer_cfg.get_name_indices_for_layout(
                        not vertical
                    )

                if #opposite_indices <= 2 then
                    break
                end

                spammer_cfg.set_name_vertical(
                    opposite_indices[
                        #opposite_indices
                    ],
                    vertical
                )

                indices =
                    spammer_cfg.get_name_indices_for_layout(
                        vertical
                    )
            end
        end
    end

    ensure_layout(true)
    ensure_layout(false)
end

function remove_last_spammer_name_field()
    if get_spammer_name_count() <= 2 then
        return false
    end

    spammer_cfg.ensure_name_vertical_modes()
    spammer_cfg.ensure_name_enabled_states()

    local removed_index =
        get_spammer_name_count()

    local removed_vertical =
        spammer_cfg.is_name_vertical(
            removed_index
        )

    local removed_enabled =
        spammer_cfg.is_name_enabled(
            removed_index
        )

    local removed_name =
        table.remove(
            spammer_cfg.extra_names
        )

    table.remove(
        spammer_cfg.name_vertical_modes,
        removed_index
    )

    table.remove(
        spammer_cfg.name_enabled,
        removed_index
    )

    spammer_runtime.name_field_vertical_active[
        removed_index
    ] = nil

    table.insert(
        spammer_cfg.removed_names,
        tostring(
            removed_name or ""
        )
    )

    table.insert(
        spammer_cfg.removed_name_vertical_modes,
        removed_vertical
    )

    table.insert(
        spammer_cfg.removed_name_enabled,
        removed_enabled
    )

    local name_count =
        get_spammer_name_count()

    if spammer_runtime.next_name_index
        > name_count then

        spammer_runtime.next_name_index = 1
    end

    return true
end

function spammer_cfg.remove_name_field_at(
    remove_index
)
    spammer_cfg.ensure_name_vertical_modes()
    spammer_cfg.ensure_name_enabled_states()

    local name_count =
        get_spammer_name_count()

    remove_index =
        math.floor(
            tonumber(remove_index) or 0
        )

    if name_count <= 2
        or remove_index < 1
        or remove_index > name_count then

        return false
    end

    local removed_name =
        tostring(
            get_spammer_name(
                remove_index
            ) or ""
        )

    local removed_vertical =
        spammer_cfg.is_name_vertical(
            remove_index
        )

    local removed_enabled =
        spammer_cfg.is_name_enabled(
            remove_index
        )

    for index = remove_index,
        name_count - 1 do

        set_spammer_name(
            index,
            get_spammer_name(
                index + 1
            )
        )

        spammer_cfg.name_vertical_modes[
            index
        ] =
            spammer_cfg.name_vertical_modes[
                index + 1
            ]

        spammer_cfg.name_enabled[
            index
        ] =
            spammer_cfg.name_enabled[
                index + 1
            ]

        spammer_runtime.name_field_vertical_active[
            index
        ] =
            spammer_runtime.name_field_vertical_active[
                index + 1
            ]
    end

    table.remove(
        spammer_cfg.extra_names,
        #spammer_cfg.extra_names
    )

    table.remove(
        spammer_cfg.name_vertical_modes,
        name_count
    )

    table.remove(
        spammer_cfg.name_enabled,
        name_count
    )

    spammer_runtime.name_field_vertical_active[
        name_count
    ] = nil

    table.insert(
        spammer_cfg.removed_names,
        removed_name
    )

    table.insert(
        spammer_cfg.removed_name_vertical_modes,
        removed_vertical
    )

    table.insert(
        spammer_cfg.removed_name_enabled,
        removed_enabled
    )

    spammer_runtime.next_name_index = 1

    spammer_cfg.recalculate_smart_limits(
        true
    )

    return true
end

function spammer_cfg.remove_last_name_field_for_layout(
    vertical
)
    local indices =
        spammer_cfg.get_name_indices_for_layout(
