function chat_spammer.truncate_utf8_to_byte_limit(
    text_value,
    byte_limit
)
    text_value =
        tostring(text_value or "")

    byte_limit =
        math.max(
            0,
            tonumber(byte_limit) or 0
        )

    if #text_value <= byte_limit then
        return text_value,
            false
    end

    local index = 1
    local last_complete_byte = 0

    while index <= #text_value do
        local first_byte =
            string.byte(
                text_value,
                index
            )

        if not first_byte then
            break
        end

        local character_length = 1

        if first_byte >= 240 then
            character_length = 4
        elseif first_byte >= 224 then
            character_length = 3
        elseif first_byte >= 192 then
            character_length = 2
        end

        local character_end =
            index +
            character_length -
            1

        if character_end > byte_limit
            or character_end > #text_value then

            break
        end

        last_complete_byte =
            character_end

        index =
            character_end + 1
    end

    return text_value:sub(
        1,
        last_complete_byte
    ),
        true
end

