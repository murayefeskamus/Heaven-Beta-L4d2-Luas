function on_create_move(
    cmd,
    pLocal
)
    if ui.control.nofall.enabled ~= true
        and ui.control.speed.enabled ~= true
        and ui.control.aim.enabled ~= true then

        return
    end

    if not pLocal then
        if ui.control.nofall.enabled == true then
            ui.control.runtime.nofall_status = "Waiting for player"
        else
            ui.control.runtime.nofall_status = "Disabled"
        end
        return
    end

    if ui.input_safety.block_runtime_hotkeys() then
        return
    end

    local alive_ok, alive_value = pcall(function()
        return pLocal:is_alive()
    end)
    local player_alive = alive_ok and (
        alive_value == true
        or alive_value == 1
        or tostring(alive_value):lower() == "true"
    )

    local v2_supported = false
    if ui.control.aim.enabled == true and tonumber(ui.control.aim.mode) == 1 then
        v2_supported = ui.control.get_special_infected_identity(pLocal)
    end


    if ui.control.nofall.enabled == true and player_alive then
        local EXPLOIT_THRESHOLD = 560.0
        local SEQUENCE_SHIFT = 90000

        local pAddr =
            entity.get_by_index_raw(
                pLocal:get_index()
            )

        local eb =
            modules.get_engine_base()

        local ptr1 =
            memory.read_int(
                eb + 4352236
            )

        local netChannel =
            (ptr1 ~= 0)
            and memory.read_int(
                ptr1 + 24
            )
            or 0

        if pAddr == 0
            or netChannel == 0 then

            ui.control.runtime.nofall_status =
                pAddr == 0
                and "Waiting for player data"
                or "Waiting for network"

            return
        end

        local tickbase =
            memory.read_float(
                pAddr + 0x11FC
            )

        local cond1 =
            memory.read_int(
                pAddr + 0x1F84
            )

        ui.control.runtime.nofall_tickbase =
            tickbase

        ui.control.runtime.nofall_condition =
            cond1

        ui.control.runtime.nofall_last_error = ""

        if (tickbase > EXPLOIT_THRESHOLD)
            or (cond1 ~= 0) then

            local currentSeq =
                memory.read_int(
                    netChannel + 8
                )

            ui.control.runtime.nofall_triggers =
                (tonumber(
                    ui.control.runtime.nofall_triggers
                ) or 0) + 1

            ui.control.runtime.nofall_last_trigger_time =
                get_time()

            ui.control.runtime.nofall_status =
                "Applied"

            return memory.write_int(
                netChannel + 8,
                currentSeq + SEQUENCE_SHIFT,
                false
            )
        end

        ui.control.runtime.nofall_status =
            "Monitoring"
    elseif ui.control.nofall.enabled == true then
        ui.control.runtime.nofall_status = "Waiting for spawn"
        ui.control.runtime.nofall_last_error = ""
    else
        ui.control.runtime.nofall_status =
            "Disabled"

        ui.control.runtime.nofall_last_error = ""
    end

    if not cmd
        or ui.control.waiting_for_key
        or ui.control.waiting_for_pursuit_key
        or ui.control.waiting_for_target_cycle_key
        or ui.control.waiting_for_toggle_key then

        return
    end

    local active_mode =
        ui.control.resolve_active_mode()

    if active_mode == 0 then
        if player_alive then
            ui.control.apply_speed_limit(
                cmd,
                pLocal
            )
        end
    else
        if player_alive or v2_supported == true then
            ui.control.apply_aim_infected(
                cmd,
                pLocal
            )

            ui.control.apply_pursuit_bot(
                cmd,
                pLocal
            )
        elseif tonumber(ui.control.aim.mode) == 1 then
            ui.control.runtime.status = "Waiting for Special Infected class"
        end
    end
end


