    green = ui.control.clamp(tonumber(green) or 0.0, 0.0, 1.0)
    blue = ui.control.clamp(tonumber(blue) or 0.0, 0.0, 1.0)
    alpha = ui.control.clamp(tonumber(alpha) or 0.0, 0.0, 1.0)

    local ok, result = pcall(
