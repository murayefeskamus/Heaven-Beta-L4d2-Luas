function ui.control.get_special_infected_identity(local_player)
    if not local_player then
        return false, 0, "Unavailable", "No player", false, false
    end

    local team = tonumber(
        ui.lobby.call_method(local_player, "get_team")
        or ui.lobby.call_method(local_player, "get_prop", "m_iTeamNum")
        or 0
    ) or 0

    local class_id = ui.control.get_local_infected_class(local_player)
    local class_name = ui.control.aim_v2_engine.special_classes[class_id]

    local alive_value = ui.lobby.call_method(local_player, "is_alive")
    local alive = alive_value == true
        or alive_value == 1
        or tostring(alive_value):lower() == "true"

    local ghost = false
    if type(ui.lobby.get_player_is_ghost) == "function" then
        local ghost_ok, ghost_value = pcall(ui.lobby.get_player_is_ghost, local_player)
        ghost = ghost_ok and ghost_value == true
    else
        local ghost_value = ui.lobby.call_method(local_player, "get_prop", "m_isGhost")
        ghost = ghost_value == true
            or ghost_value == 1
            or tostring(ghost_value):lower() == "true"
    end

    local spawn_state
    if team ~= 3 then
        spawn_state = "Not infected"
    elseif ghost then
        spawn_state = "Unspawned (Ghost)"
    elseif alive then
        spawn_state = "Spawned"
    else
        spawn_state = "Unspawned"
    end

    local class_pending = team == 3 and class_id == 0
    local supported = team == 3
        and class_id ~= 7
        and (class_name ~= nil or class_pending or ghost)

    if team ~= 3 then
        class_name = "Not infected"
    elseif class_id == 7 then
        class_name = "Unsupported infected"
    elseif class_name == nil then
        class_name = "Class pending"
    end

    return supported, class_id, class_name, spawn_state, ghost, alive
end

