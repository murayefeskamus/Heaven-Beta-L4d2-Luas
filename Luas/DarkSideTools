                ui.kill_tools.clear_message_pool()
            end

            imgui.same_line()

            if colored_button(
                "Cancel##KillCustomClearFields",
                1.0, 1.0, 1.0,
                0.18, 0.18, 0.18
            ) then
                ui.kill_tools.ui_state.clear_fields_confirmation = false
            end
        elseif colored_button(
            "Clear All Fields",
            1.0, 1.0, 1.0,
            0.38, 0.12, 0.12
        ) then
            ui.kill_tools.ui_state.clear_fields_confirmation = true
        end
    end
