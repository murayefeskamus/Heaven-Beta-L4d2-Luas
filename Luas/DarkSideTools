    function ui.quotes.get_shared_current_players()
        local players = {}
        local seen_userids = {}
        local lobby_records_available = false

        local lobby_players =
            type(ui.lobby) == "table"
            and type(ui.lobby.players) == "table"
            and ui.lobby.players
            or nil

        if lobby_players then
            lobby_records_available =
                ui.lobby.connected == true
                or next(lobby_players) ~= nil


            for _,
                record in pairs(
                    lobby_players
                ) do

                if type(record) == "table" then
                    local userid =
                        tonumber(
                            record.userid
                        ) or 0

                    local name =
                        tostring(
                            record.name or ""
                        )

                    if record.connected ~= false
                        and record.is_bot ~= true
                        and userid > 0
                        and name ~= ""
                        and not seen_userids[
                            userid
                        ] then

                        seen_userids[
                            userid
                        ] = true

                        players[
                            #players + 1
                        ] = {
                            userid = userid,
                            name = name,
                            is_local =
                                record.is_local == true,
                            player_index =
                                tonumber(
                                    record.entity_index
                                ) or 0,
                        }
                    end
                end
            end
        end


        if not lobby_records_available
            and #players == 0 then

            local fallback_ok,
                fallback =
                    pcall(
                        get_current_players
                    )

            if fallback_ok
                and type(fallback) == "table" then

                for _,
                    player in pairs(
                        fallback
                    ) do

                    if type(player) == "table" then
                        local userid =
                            tonumber(
                                player.userid
                            ) or 0

                        local name =
                            tostring(
                                player.name or ""
                            )

                        if userid > 0
                            and name ~= ""
                            and not seen_userids[
                                userid
                            ] then

                            local local_ok,
                                is_local =
                                    pcall(
                                        is_local_player_message,
                                        userid
                                    )

                            seen_userids[
                                userid
                            ] = true

                            players[
                                #players + 1
                            ] = {
                                userid = userid,
                                name = name,
                                is_local =
                                    local_ok
                                    and is_local == true,
                                player_index =
                                    tonumber(
                                        player.player_index
                                    ) or 0
                            }
                        end
                    end
                end
            end
        end

        table.sort(
            players,
            function(first, second)
                return (
                    tonumber(
                        first.userid
                    ) or 0
                ) < (
                    tonumber(
                        second.userid
                    ) or 0
                )
            end
        )

        return players
    end

    function ui.quotes.get_local_userid()
        local players =
            ui.quotes.get_shared_current_players()

        for _, player in ipairs(players) do
            if player.is_local then
                return tonumber(player.userid) or 0
            end
        end

        for _, player in ipairs(players) do
            if is_local_player_message(
                player.userid
            ) then
                return tonumber(player.userid) or 0
            end
        end

        local local_player =
            client.get_local_player()

        if local_player then
            local player_index =
                local_player:get_index()

            if player_index then
                local info_ok,
                    player_info =
                        pcall(
                            engine.get_player_info,
                            player_index
                        )

                if info_ok
                    and player_info then

                    local userid =
                        read_player_info_userid(
                            player_info
                        )

                    if userid
                        and tonumber(userid) > 0 then

                        return tonumber(userid)
                    end
                end

                local userid =
                    find_userid_from_player_index(
                        player_index
                    )

                if userid
                    and tonumber(userid) > 0 then

                    return tonumber(userid)
                end
            end
        end

        return 0
    end

    function ui.quotes.get_detected_players(
        players_override
    )
        local now =
            get_time()

        if players_override == nil
            and type(ui.quotes.cached_detected_players) == "table"
            and now <
                (tonumber(
                    ui.quotes.next_detected_players_refresh
                ) or 0.0) then

            return ui.quotes.cached_detected_players
        end

        local players =
            type(players_override) == "table"
            and players_override
            or ui.quotes.get_shared_current_players()

        local detected_ok,
            detected =
                pcall(
                    get_players_with_detected_quotes,
                    players
                )

        if not detected_ok
            or type(detected) ~= "table" then

            detected = {}
        end

        if players_override == nil then
            ui.quotes.cached_detected_players =
                detected

            ui.quotes.next_detected_players_refresh =
                now + 0.50
        end

        return detected
    end

