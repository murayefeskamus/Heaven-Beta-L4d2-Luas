local function strip_quote_zero_width_markers(message)
    message = tostring(message or "")
        :gsub("\226\128\139", "")
        :gsub("\226\128\140", "")
        :gsub("\226\128\141", "")
        :gsub("\226\128\142", "")
        :gsub("\226\128\143", "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")

    message =
        message:gsub(
            "^%[[Qq][Uu][Oo][Tt][Ee][Ss]%]%s*",
            ""
        )

    return message
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function looks_like_quote_module_response(message)
    local clean_message =
        strip_quote_zero_width_markers(
            message
        )

    if clean_message == "" then
        return false
    end

    local lower_message =
        clean_message:lower()

    if clean_message:match("^%[#%d+%]") then
        return true
    end

    if lower_message:match("^found %d+ quote")
        or lower_message:match("^no quote")
        or lower_message:match("^no current player")
        or lower_message:match("^invalid input")
        or lower_message:match("^please wait %d+ second")
        or lower_message:match("^more than one player")
        or lower_message:match("^find next is not available")
        or lower_message:match("^%[quotes? commands? help%]:?")
        then

        return true
    end

    local help_commands = {
        settings.find_command,
        settings.findnext_command,
        settings.findrandom_command,
        settings.help_command
    }

    for _, command_text in ipairs(
        help_commands
    ) do
        command_text = tostring(command_text or "")

        if command_text ~= ""
            and lower_message:sub(
                1,
                #command_text
            ) == command_text:lower() then

            return true
        end
    end

    return false
end


local function looks_like_quote_help_output_line(message)
    local clean_message =
        strip_quote_zero_width_markers(
            message
        )

    clean_message =
        clean_message:gsub("^%s+", ""):gsub("%s+$", "")

    if clean_message == "" then
        return false
    end

    local lower_message =
        clean_message:lower()

    if type(ui.quotes.get_help_messages) == "function" then
        local help_ok,
            generated_help_messages =
                pcall(
                    ui.quotes.get_help_messages
                )

        if help_ok
            and type(generated_help_messages) == "table" then

            for _, generated_help_message in ipairs(
                generated_help_messages
            ) do
                local normalized_help_message =
                    strip_quote_zero_width_markers(
                        generated_help_message
                    ):lower()

                if lower_message ==
                    normalized_help_message then

                    return true
                end
            end
        end
    end

    if lower_message:match("^%[quotes? commands? help%]:?") then
        return true
    end

    local known_help_lines = {
        { command = settings.find_command, fragment = "searches by one or more keywords" },
        { command = settings.find_command, fragment = "finds a quote containing an exact match" },
        { command = settings.find_command, fragment = "finds a quote by id" },
        { command = settings.find_command, fragment = "finds quotes for a player by id" },
        { command = settings.find_command, fragment = "finds quotes for a player by name" },
        { command = settings.findnext_command, fragment = "shows the next result" },
        { command = settings.findrandom_command, fragment = "posts a random quote" },
        { command = settings.help_command, fragment = "shows this command help" }
    }

    for _,
        row in ipairs(
            known_help_lines
        ) do

        local command_text =
            tostring(row.command or ""):lower()

        local fragment =
            tostring(row.fragment or ""):lower()

        if command_text ~= ""
            and lower_message:sub(1, #command_text) == command_text
            and lower_message:find(" %- ", 1, false) ~= nil
            and lower_message:find(fragment, 1, true) ~= nil then

            return true
        end
    end

    return false
end

local function extract_quote_line_number_from_response(message)
    local clean_message =
        strip_quote_zero_width_markers(
            message
        )

    local line_number =
        clean_message:match(
            "^%[#(%d+)%]"
        )

    return tonumber(line_number)
end

local function is_quote_count_prelude_message(message)
    local clean_message =
        strip_quote_zero_width_markers(
            message
        ):lower()

    return clean_message:match(
        "^found %d+ quote"
    ) ~= nil
end

local function is_quote_cooldown_notice_message(message)
    local clean_message =
        strip_quote_zero_width_markers(
            message
        ):lower()

    return clean_message:match(
        "^please wait %d+ second"
    ) ~= nil
end

local function cancel_pending_remote_quote_commands_for_user(
    userid,
    reason,
    response_message
)
    userid = tonumber(userid) or 0

    if userid <= 0 then
        return 0
    end

    local queued_command_to_cancel = nil

    for _, queued_command in ipairs(
        remote_quote_command_queue
    ) do
        if type(queued_command) == "table"
            and queued_command.cancelled ~= true
            and tonumber(queued_command.userid) == userid then

            queued_command_to_cancel = queued_command
            break
        end
    end

    if not queued_command_to_cancel then
        return 0
    end

    queued_command_to_cancel.cancelled = true
    queued_command_to_cancel.cancel_reason =
        tostring(reason or "answered-by-sender")

    if type(sync_remote_quote_state_from_response) == "function" then
        pcall(
            sync_remote_quote_state_from_response,
            userid,
            response_message,
            queued_command_to_cancel
        )
    end

    mark_remote_quote_sender_as_dst_user(
        userid
    )

    ui.console.print(
        "[DST Quotes] Suppressed one queued duplicate response; sender's DST answered."
    )

    return 1
end

local function observe_remote_quote_response(userid, message)
    userid = tonumber(userid) or 0

    if userid <= 0 then
        return false
    end

    if not looks_like_quote_module_response(
        message
    ) then
        return false
    end

    if (is_quote_count_prelude_message(message)
            or is_quote_cooldown_notice_message(message))
        and not extract_quote_line_number_from_response(message) then

        mark_remote_quote_sender_as_dst_user(userid)
        return false
    end

    return cancel_pending_remote_quote_commands_for_user(
        userid,
        "sender-dst-response",
        message
    ) > 0
end

local function queue_remote_public_quote_command(userid, message)
    userid = tonumber(userid) or 0
    message = tostring(message or "")

    if userid <= 0
        or message == "" then

        return false
    end

    local command_key,
        command_text =
            get_public_remote_quote_command(
                message
            )

    if not command_key then
        return false
    end


    remote_quote_command_serial =
        remote_quote_command_serial + 1

    local now =
        get_time()

    remote_quote_command_queue[
        #remote_quote_command_queue + 1
    ] = {
        id = remote_quote_command_serial,
        userid = userid,
        message = message,
        command_key = command_key,
        command_text = command_text,
        queued_at = now,
        execute_at = now + get_remote_quote_arbitration_delay(),
        cancelled = false,
        cancel_reason = ""
    }

    ui.console.print(
        "[DST Quotes] Queued public " ..
        tostring(command_text) ..
        " from UserID " ..
        tostring(userid) ..
        " for DST-user arbitration."
    )

    return true
end

local function process_quote_change_queue()
    if #quote_change_queue == 0 then
        return false
    end


    if not engine.is_in_game()
        or not engine.is_connected() then

        return true
    end

    local current_time = get_time()
    local queued_message = quote_change_queue[1]

    if not queued_message then
        return false
    end

    local message =
        tostring(
            queued_message.text or ""
        )

    if message == "" then
        table.remove(
            quote_change_queue,
            1
        )

        return #quote_change_queue > 0
    end


    if current_time -
        (tonumber(queued_message.queued_at) or current_time)
        > 30.0 then

        if queued_message.deduplicated == true then
            quote_change_pending[message] = nil
        end

        table.remove(
            quote_change_queue,
            1
        )

        ui.console.print(
            "[L4D2 Quotes] Reliable message expired after 30 seconds: " ..
            message
        )

        return #quote_change_queue > 0
    end

    if queued_message.waiting_for_echo == true then
        local next_retry_at =
            tonumber(
                queued_message.next_retry_at
            ) or 0.0

        if current_time < next_retry_at then
            return false
        end

        if (tonumber(
            queued_message.attempts
        ) or 0) >= quote_change_max_attempts then

            if queued_message.deduplicated == true then
                quote_change_pending[message] = nil
            end

            table.remove(
                quote_change_queue,
                1
            )

            ui.console.print(
                "[L4D2 Quotes] Reliable message was not echoed after " ..
                tostring(quote_change_max_attempts) ..
                " attempts: " ..
                message
            )

            return #quote_change_queue > 0
        end

        queued_message.waiting_for_echo = false
        queued_message.send_after = current_time
    end

    if current_time <
        (tonumber(queued_message.send_after) or 0.0) then

        return true
    end


    local minimum_send_interval =
        tonumber(
            queued_message.minimum_send_interval
        ) or 0.55

    if current_time - last_quote_change_send_time
        < minimum_send_interval then

        return true
    end

    if not post_to_all_chat_immediately(
        message,
        queued_message.preserve_double_quotes == true
    ) then

        return true
    end

    queued_message.attempts =
        (tonumber(
            queued_message.attempts
        ) or 0) + 1

    last_quote_change_send_time = current_time

    if queued_message.fast_mode == true then
        if queued_message.deduplicated == true then
            quote_change_pending[message] = nil
        end

        table.remove(
            quote_change_queue,
            1
        )
    else
        queued_message.waiting_for_echo = true
        queued_message.next_retry_at =
            current_time +
            (
                tonumber(
                    queued_message.retry_delay
                ) or quote_change_retry_delay
            )
    end


    last_queue_send_time = os.time()

    if ui.lobby then
        ui.lobby.next_chat_send_time =
            math.max(
                tonumber(
                    ui.lobby.next_chat_send_time
                ) or 0.0,
                current_time +
                (
                    queued_message.fast_mode == true
                    and quote_help_send_interval
                    or 0.80
                )
            )
    end

    ui.console.print(
        "[L4D2 Quotes] Confirmation attempt " ..
        tostring(queued_message.attempts) ..
        "/" ..
        tostring(quote_change_max_attempts) ..
        ": " ..
        message
    )

    return true
end

local function process_chat_queue()
    if #chat_queue == 0 then
        return
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        return
    end

    local current_time =
        os.time()

    local queued_message =
        chat_queue[1]

    if current_time < queued_message.send_after then
        return
    end

    local minimum_send_interval =
        math.max(
            0.10,
            tonumber(
                queued_message.minimum_send_interval
            ) or tonumber(
                settings.queued_message_delay
            ) or 1.0
        )

    if current_time - last_queue_send_time
        < minimum_send_interval then

        return
    end

    local sent =
        post_to_all_chat_immediately(
            queued_message.text
        )

    if not sent then
        return
    end


    table.remove(chat_queue, 1)

    last_queue_send_time =
        current_time

    ui.console.print(
        "[L4D2 Quotes] Sent chat response: " ..
        queued_message.text
    )
end


local function reset_search_states()
    search_states = {}
    last_quote_search_state_by_userid = {}
end

local function write_quote_lines(lines)
    if not io
        or not io.open then

        return false,
            "File access is unavailable."
    end

    local output,
        write_error =
            io.open(
                settings.quote_file,
                "w"
            )

    if not output then
        return false,
            "Could not rewrite quote file: " ..
            tostring(write_error)
    end

    for index,
        line in ipairs(
            lines or {}
        ) do

        output:write(
            tostring(line or "")
        )

        if index < #(lines or {}) then
            output:write("\n")
        end
    end

    if #(lines or {}) > 0 then
        output:write("\n")
    end

    output:close()

    return true
end

local function shuffle_quotes()
    quote_order = {}

    for index = 1, #quotes do
        quote_order[index] = index
    end


    for index = #quote_order, 2, -1 do
        local random_index =
            math.random(1, index)

        quote_order[index],
        quote_order[random_index] =
            quote_order[random_index],
            quote_order[index]
    end

    order_position = 1
    status.remaining = #quote_order
end

local function load_quotes()
    quotes = {}
    quotes_by_line = {}
    quote_lookup = {}
    quote_order = {}
    order_position = 1
    total_file_lines = 0


    reset_search_states()

    if not io
        or not io.open then

        status.message =
            "File unavailable"

        ui.console.print(
            "[L4D2 Quotes] File access is unavailable."
        )

        return false
    end

    local file,
        error_message =
            io.open(
                settings.quote_file,
                "r"
            )

    if not file then
        status.message =
            "File unavailable"

        ui.console.print(
            "[L4D2 Quotes] Could not open file: " ..
            tostring(error_message)
        )

        return false
    end

    local stored_lines = {}
    local blank_line_count = 0

    for line in file:lines() do
        if trim(line) == "" then
            blank_line_count =
                blank_line_count + 1
        else
            stored_lines[
                #stored_lines + 1
            ] = line
        end
    end

    file:close()


    if blank_line_count > 0 then
        local compacted,
            compact_error =
                write_quote_lines(
                    stored_lines
                )

        if compacted then
            ui.console.print(
                string.format(
                    "[L4D2 Quotes] Removed %d legacy blank line(s).",
                    blank_line_count
                )
            )
        else
            ui.console.print(
                "[L4D2 Quotes] Could not compact legacy blank lines: " ..
                tostring(compact_error)
            )
        end
    end

    total_file_lines =
        #stored_lines

    for line_number,
        line in ipairs(
            stored_lines
        ) do

        local quote = {
            text = line,
            line_number = line_number
        }

        quotes[
            #quotes + 1
        ] = quote

        quotes_by_line[
            line_number
        ] = quote

        local normalized =
            normalize_quote_text(
                line
            )


        if not quote_lookup[
            normalized
        ] then

            quote_lookup[
                normalized
            ] = line_number
        end
    end

    quotes_revision =
        quotes_revision + 1

    if #quotes == 0 then
        status.message =
            "No quotes"

        status.remaining = 0

        ui.console.print(
            "[L4D2 Quotes] No quotes found."
        )


        return true
    end

    shuffle_quotes()

    status.last_number = 0
    status.message = "Ready"

    ui.console.print(
        string.format(
            "[L4D2 Quotes] Loaded %d quote(s), %d file line(s).",
            #quotes,
            total_file_lines
        )
    )

    return true
end

local function select_next_quote()
    if #quotes == 0 then
        return nil
    end

    if order_position > #quote_order then
        shuffle_quotes()

        ui.console.print(
            "[L4D2 Quotes] All quotes used. List reshuffled."
        )
    end

    local selected_index =
        quote_order[order_position]

    order_position =
        order_position + 1

    status.remaining =
        #quote_order - order_position + 1

    return quotes[selected_index]
end

