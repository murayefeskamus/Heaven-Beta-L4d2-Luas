                local result_text,
                    result_r,
                    result_g,
                    result_b =
                        ui.lobby.get_prediction_result_indicator_color(
                            row.exact == true and row or nil
                        )

                if result_text == "" then
                    result_text = "-"
                end

                local player_r,
                    player_g,
                    player_b =
                        row.is_bot == true
                        and 0.58
                        or 1.0,
                        row.is_bot == true
                        and 0.58
                        or 1.0,
                        row.is_bot == true
                        and 0.60
                        or 1.0

                ui.lobby.draw_table_text(
                    start_x,
                    columns[1].offset,
                    columns[1].width,
                    truncate_preview(
                        tostring(row.name or "Player"),
                        18
                    ),
                    player_r,
                    player_g,
                    player_b,
                    true
                )
                draw_divider(columns[2])

                ui.lobby.draw_table_text(
                    start_x,
                    columns[2].offset,
                    columns[2].width,
                    display_state,
                    neutral_r, neutral_g, neutral_b,
                    false
                )
                draw_divider(columns[3])

                ui.lobby.draw_table_text(
                    start_x,
                    columns[3].offset,
                    columns[3].width,
                    tostring(row.class_name or "Unavailable"),
                    class_r, class_g, class_b,
                    false
                )
                draw_divider(columns[4])

                ui.lobby.draw_table_text(
