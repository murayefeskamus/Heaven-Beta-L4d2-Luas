                and "Open Mic"
                or (open_mic == false and "Push to Talk" or "Unavailable"),
            open_mic == true
                and 0.35
                or (
                    open_mic == false
                    and 0.25
                    or palette.text_disabled[1]
                ),
            open_mic == true
                and 0.90
                or (
                    open_mic == false
                    and 0.78
                    or palette.text_disabled[2]
                ),
            open_mic == true
                and 0.45
                or (
                    open_mic == false
                    and 1.00
                    or palette.text_disabled[3]
                )
        )
        return true
    end

    if key == "voice_toggle" then
        local open_mic = ui.voice_control.read_open_mic(false)
        local button_text = open_mic == true
            and "Push to Talk"
            or "Open Mic"

        if ui.network.rendering_overlay then
            ui.network.begin_overlay_value_cell("Voice control")
        else
            imgui.text("Voice control:")
            imgui.same_line()
        end

        if open_mic == nil then
            disabled_button(
                "Unavailable##GameNetVoiceStyleToggle" ..
                (detailed and "Detailed" or "Compact")
            )
        elseif colored_button(
            button_text .. "##GameNetVoiceStyleToggle" ..
                (detailed and "Detailed" or "Compact"),
            1.0, 1.0, 1.0,
            0.12, 0.34, 0.42
        ) then
            ui.voice_control.set_open_mic(not open_mic)
        end

        if ui.network.rendering_overlay then
            imgui.separator()
        end
        return true
    end

    return ui.voice_control.base_draw_overlay_field(
        key,
        detailed,
        game,
        stats
    )
end

ui.voice_control.previous_on_game_event = on_game_event

function on_game_event(event_name, event)
    pcall(
        ui.voice_control.previous_on_game_event,
        event_name,
        event
    )

    if event_name ~= "player_say" or not event then
        return
    end

    local userid = 0
    local spoken_text = ""

    pcall(function()
        userid = tonumber(event:get_int("userid")) or 0
    end)

    pcall(function()
        spoken_text = tostring(event:get_string("text") or "")
    end)

    if userid <= 0 or spoken_text == "" then
        return
    end

    pcall(
        ui.voice_control.handle_chat_command,
        userid,
        spoken_text
    )
end

