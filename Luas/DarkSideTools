local function split_search_terms(search_text)
    local terms = {}

    for term in search_text:lower():gmatch("%S+") do
        table.insert(
            terms,
            term
        )
    end

    return terms
end

local function extract_exact_phrase(search_text)
    search_text =
        trim(search_text)

    if #search_text < 2 then
        return nil
    end

    local first_character =
        search_text:sub(1, 1)

    local last_character =
        search_text:sub(-1)


    if (first_character == '"'
        and last_character == '"')
        or (first_character == "'"
        and last_character == "'") then

        return trim(
            search_text:sub(2, -2)
        )
    end


    if (search_text:sub(1, 3) == "“"
        and search_text:sub(-3) == "”")
        or (search_text:sub(1, 3) == "‘"
        and search_text:sub(-3) == "’") then

        return trim(
            search_text:sub(4, -4)
        )
    end

    return nil
end

local function extract_player_id_search(search_text)
    local target =
        extract_exact_phrase(search_text)

    if target == nil then
        target =
            trim(search_text)
    end

    local player_userid =
        target:match("^@(%d+)$")

    if not player_userid then
        return nil
    end

    return tonumber(player_userid)
end


local function extract_player_name_search(search_text)
    local target =
        extract_exact_phrase(search_text)

    if target == nil then
        target =
            trim(search_text)
    end

    if target:sub(1, 1) ~= "@" then
        return nil
    end

    target =
        trim(
            target:sub(2)
        )

    if target == ""
        or target:match("^%d+$") then

        return nil
    end

    local quoted_name =
        extract_exact_phrase(target)

    if quoted_name ~= nil then
        target = quoted_name
    end

    target = trim(target)

    if target == "" then
        return nil
    end

    return target
end

local function normalize_player_name_for_match(name)
    name = trim(name or ""):lower()

    name = name:gsub(
        "^%b()%s*",
        ""
    )

    name = name:gsub(
        "%s+",
        " "
    )


    name = name:gsub(
        "(.)%1+",
        "%1"
    )

    return trim(name)
end


normalize_player_name_for_detection = function(name)
    name = trim(name or "")

    name = name:gsub("\239\187\191", "")
    name = name:gsub("\226\128\139", "")
    name = name:gsub("\226\128\140", "")
    name = name:gsub("\226\128\141", "")
    name = name:gsub("\226\128\142", "")
    name = name:gsub("\226\128\143", "")
    name = name:gsub("\003", "")
    name = name:gsub("%c", "")

    name = name:gsub(
        "^%b()%s*",
        ""
    )

    name = name:gsub(
        "%s+",
        " "
    )

    return trim(name)
end


local function normalize_player_name_for_exact_detection(name)
    name = trim(name or "")

    name = name:gsub("\239\187\191", "")
    name = name:gsub("\226\128\139", "")
    name = name:gsub("\226\128\140", "")
    name = name:gsub("\226\128\141", "")
    name = name:gsub("\226\128\142", "")
    name = name:gsub("\226\128\143", "")
    name = name:gsub("\003", "")
    name = name:gsub("%c", "")

    return trim(name)
end


local function player_names_match(quote_person, player_name)
    local function canonical(value)
        value = normalize_player_name_for_detection(value):lower()

        value = value:gsub(
            "[%(%)%[%]{}<>]",
            " "
        )

        value = value:gsub(
            "[|_=%+%*~`'\".,;!?]",
            " "
        )

        value = value:gsub(
            "%s+",
            " "
        )

        return trim(value)
    end

    local quote_name = canonical(quote_person)
    local target_name = canonical(player_name)

    if quote_name == ""
        or target_name == "" then

        return false
    end

    if quote_name == target_name then
        return true
    end

    if #quote_name >= 3
        and target_name:find(
            quote_name,
            1,
            true
        ) then

        return true
    end

    if #target_name >= 3
        and quote_name:find(
            target_name,
            1,
            true
        ) then

        return true
    end

    return false
end

local function find_quotes_by_player_name(player_name)
    local matches = {}

    for index, quote in ipairs(quotes) do
        local quote_person =
            extract_quoted_person(
                quote.text
            )

        if quote_person
            and player_names_match(
                quote_person,
                player_name
            ) then

            table.insert(
                matches,
                index
            )
        end
    end

    return matches
end

local function find_quotes_by_exact_player_name(player_name)
    local matches = {}

    local target_name =
        normalize_player_name_for_exact_detection(
            player_name
        )

    if target_name == "" then
        return matches
    end

    for index, quote in ipairs(quotes) do
        local quote_person =
            extract_quoted_person(
                quote.text
            )

        if quote_person then
            local quote_name =
                normalize_player_name_for_exact_detection(
                    quote_person
                )

            if quote_name == target_name then
                table.insert(
                    matches,
                    index
                )
            end
        end
    end

    return matches
end

local quote_count_by_person = {}
local quote_count_person_names = {}
local quote_example_by_person = {}
local quote_indices_by_person = {}
local quote_count_index_revision = -1

local cached_detected_players = {}
local last_quote_detection_time = 0
local last_quote_detection_signature = ""
local quote_detection_refresh_seconds = 2

local function rebuild_quote_count_index()
    quote_count_by_person = {}
    quote_count_person_names = {}
    quote_example_by_person = {}
    quote_indices_by_person = {}

    for quote_index,
        quote in ipairs(
            quotes
        ) do

        local quote_person =
            extract_quoted_person(
                quote.text
            )

        if quote_person then
            local normalized_person =
                normalize_player_name_for_exact_detection(
                    quote_person
                )

            if normalized_person ~= "" then
                if not quote_count_by_person[
                    normalized_person
                ] then

                    quote_count_by_person[
                        normalized_person
                    ] = 0

                    quote_count_person_names[
                        #quote_count_person_names + 1
                    ] = normalized_person

                    quote_example_by_person[
                        normalized_person
                    ] = tostring(
                        quote.text or ""
                    )

                    quote_indices_by_person[
                        normalized_person
                    ] = {}
                end

                quote_count_by_person[
                    normalized_person
                ] =
                    quote_count_by_person[
                        normalized_person
                    ] + 1

                table.insert(
                    quote_indices_by_person[
                        normalized_person
                    ],
                    quote_index
                )
            end
        end
    end

    quote_count_index_revision =
        quotes_revision
end

local function get_detected_quote_count_for_player(
    player_name
)
    if quote_count_index_revision ~=
        quotes_revision then

        rebuild_quote_count_index()
    end

    local normalized_player =
        normalize_player_name_for_exact_detection(
            player_name
        )

    if normalized_player == "" then
        return 0,
            nil
    end

    return quote_count_by_person[
        normalized_player
    ] or 0,
        quote_example_by_person[
            normalized_player
        ]
end

local function get_players_with_detected_quotes(
    current_players
)
    current_players =
        current_players or {}

    local signature_parts = {
        tostring(
            quotes_revision
        )
    }

    for _,
        player in ipairs(
            current_players
        ) do

        signature_parts[
            #signature_parts + 1
        ] =
            tostring(
                player.userid or 0
            ) ..
            ":" ..
            tostring(
                player.name or ""
            )
    end

    local signature =
        table.concat(
            signature_parts,
            "|"
        )

    local current_time =
        os.clock()

    if signature ==
        last_quote_detection_signature
        and current_time -
            last_quote_detection_time <
            quote_detection_refresh_seconds then

        return cached_detected_players
    end

    last_quote_detection_signature =
        signature

    last_quote_detection_time =
        current_time

    cached_detected_players = {}

    if quote_count_index_revision ~=
        quotes_revision then

        rebuild_quote_count_index()
    end

    for _,
        player in ipairs(
            current_players
        ) do


        local normalized_player =
            normalize_player_name_for_exact_detection(
                player.name
            )

        local matching_indices =
            quote_indices_by_person[
                normalized_player
            ] or {}

        local quote_count =
            #matching_indices

        if quote_count > 0 then
            local first_quote =
                quotes[
                    matching_indices[1]
                ]

            cached_detected_players[
                #cached_detected_players + 1
            ] = {
                userid = player.userid,
                name = player.name,
                quote_count = quote_count,
                quote_text =
                    first_quote
                    and tostring(
                        first_quote.text or ""
                    )
                    or "",
                quote_indices =
                    matching_indices
            }
        end
    end

    return cached_detected_players
end

local function build_search_request(search_text)
    local exact_phrase =
        extract_exact_phrase(
            search_text
        )

    if exact_phrase ~= nil then
        if exact_phrase == "" then
            return nil
        end

        return {
            mode = "Exact phrase",
            display = exact_phrase,
            key = "exact:" ..
                exact_phrase:lower(),
            exact_phrase =
                exact_phrase:lower()
        }
    end

    local terms =
        split_search_terms(
            search_text
        )

    if #terms == 0 then
        return nil
    end

    return {
        mode = "Keywords",
        display = trim(search_text),
        key = "keywords:" ..
            table.concat(terms, " "),
        terms = terms
    }
end

local function quote_matches_request(
    quote_text,
    request
)
    local lower_quote =
        quote_text:lower()

    if request.exact_phrase then
        return lower_quote:find(
            request.exact_phrase,
            1,
            true
        ) ~= nil
    end

    for _, term in ipairs(request.terms) do
        if not lower_quote:find(
            term,
            1,
            true
        ) then
            return false
        end
    end

    return true
end

local function find_matching_quotes(request)
    local matches = {}

    for index, quote in ipairs(quotes) do
        if quote_matches_request(
            quote.text,
            request
        ) then
            table.insert(
                matches,
                index
            )
        end
    end

    return matches
end

local function get_search_state(userid)
    local state =
        search_states[userid]

    if state then
        return state
    end

    state = {
        query_key = "",
        display_query = "",
        mode = "",
        matches = {},
        position = 1,
        shown_position = 0,
        last_quote_index = nil,
        shown_quote_ids = {},
        shown_unique_count = 0,
        last_used = 0
    }

    search_states[userid] =
        state

    return state
end

local function shuffle_search_matches(state)
    for index = #state.matches, 2, -1 do
        local random_index =
            math.random(1, index)

        state.matches[index],
        state.matches[random_index] =
            state.matches[random_index],
            state.matches[index]
    end


    if #state.matches > 1
        and state.last_quote_index
        and state.matches[1]
            == state.last_quote_index then

        state.matches[1],
        state.matches[2] =
            state.matches[2],
            state.matches[1]
    end
end

local function start_new_search(
    state,
    request,
    matches
)
    state.query_key =
        request.key

    state.display_query =
        request.display

    state.mode =
        request.mode

    state.matches = {}

    for index, quote_index in ipairs(matches) do
        state.matches[index] =
            quote_index
    end

    state.position = 1
    state.shown_position = 0
    state.last_quote_index = nil
    state.shown_quote_ids = {}
    state.shown_unique_count = 0
    state.last_used = os.time()

    shuffle_search_matches(state)
end

local function select_next_from_state(state)
    if not state
        or #state.matches == 0 then

        return nil
    end


    local attempts = 0
    local max_attempts =
        math.max(1, #state.matches * 2)

    while attempts < max_attempts do
        if state.position > #state.matches then
            state.position = 1
            state.shown_position = 0


            state.shown_quote_ids = {}
            state.shown_unique_count = 0

            shuffle_search_matches(state)
        end

        local result_position =
            state.position

        local quote_index =
            state.matches[result_position]

        state.position =
            state.position + 1

        attempts =
            attempts + 1

        local quote =
            quotes[quote_index]

        if quote
            and not state.shown_quote_ids[
                quote.line_number
            ] then

            state.shown_quote_ids[
                quote.line_number
            ] = true

            state.shown_unique_count =
                state.shown_unique_count + 1

            state.shown_position =
                result_position

            state.last_quote_index =
                quote_index

            state.last_used =
                os.time()

            return quote,
                state.shown_unique_count,
                #state.matches
        end
    end

    return nil
end

local function select_next_search_result(
    userid,
    request,
    matches
)
    local state =
        get_search_state(userid)

    if state.query_key ~= request.key
        or #state.matches ~= #matches then

        start_new_search(
            state,
            request,
            matches
        )
    end

    return select_next_from_state(state)
end

local function build_search_context_from_find_message(message)
    local matched, raw_search_text =
        extract_command_argument(
            message,
            settings.find_command
        )

    if not matched then
        return nil, nil
    end

    local search_text =
        trim(raw_search_text)

    if search_text == "" then
        return nil, nil
    end

    if #quotes == 0 then
        load_quotes()
    end

    local direct_line_number =
        search_text:match("^#(%d+)$")

    if direct_line_number then
        return nil, nil
    end

    local player_userid =
        extract_player_id_search(
            search_text
        )

    if player_userid then
        local player_name =
            get_player_name_from_userid(
                player_userid
            )

        if not player_name
            or player_name == ""
            or player_name == "Unknown" then

            return nil, nil
        end

        return {
            mode = "Player ID",
            display = player_name ..
                " [ID: " ..
                tostring(player_userid) ..
                "]",
            key = "playerid:" ..
                tostring(player_userid) ..
                ":" ..
                normalize_player_name_for_detection(
                    player_name
                )
        },
            find_quotes_by_exact_player_name(
                player_name
            )
    end

    local malformed_at_target =
        search_text:match("^@(@.+)$")

    if malformed_at_target then
        status.message =
            "No player ID matches"

        status.last_requester =
            userid

        status.last_requester_name =
            get_player_name_from_userid(userid)

        status.last_search =
            "@" .. malformed_at_target

        status.last_search_mode =
            "Player ID"

        status.last_search_matches =
            0

        clear_quote_search_state(
            userid
        )

        ui.quotes.queue_reliable_messages(
            {
                string.format(
                    "No quotes found for player with ID: “%s”.",
                    malformed_at_target
                )
            },
            settings.command_response_delay
        )

        return true
    end

    local exact_player_name =
        extract_player_name_search(
            search_text
        )

    if exact_player_name then
        return {
            mode = "Player Name",
            display = exact_player_name,
            key = "playername:" ..
                normalize_player_name_for_detection(
                    exact_player_name
                )
        },
            find_quotes_by_exact_player_name(
                exact_player_name
            )
    end

    local request =
        build_search_request(
            search_text
        )

    if not request then
        return nil, nil
    end

    return request,
        find_matching_quotes(
            request
        )
end

local function mark_state_quote_as_seen(
    state,
    selected_quote
)
    if not state
        or not selected_quote
        or not selected_quote.line_number then

        return false
    end

    local selected_quote_index = nil

    for _, quote_index in ipairs(
        state.matches or {}
    ) do
        local quote =
            quotes[quote_index]

        if quote
            and quote.line_number ==
                selected_quote.line_number then

            selected_quote_index = quote_index
            break
        end
    end

    state.shown_quote_ids =
        type(state.shown_quote_ids) == "table"
        and state.shown_quote_ids
        or {}

    if not state.shown_quote_ids[
        selected_quote.line_number
    ] then
        state.shown_unique_count =
            (tonumber(state.shown_unique_count) or 0) + 1
    end

    state.shown_quote_ids[
        selected_quote.line_number
    ] = true

    state.shown_position =
        math.max(
            1,
            tonumber(state.shown_unique_count) or 1
        )

    state.last_quote_index =
        selected_quote_index
        or state.last_quote_index

    state.last_used =
        os.time()

    return true
end


local function copy_quote_search_state(
    source_state
)
    if type(source_state) ~= "table" then
        return nil
    end

    local copied_state = {
        query_key = tostring(source_state.query_key or ""),
        display_query = tostring(source_state.display_query or ""),
        mode = tostring(source_state.mode or ""),
        matches = {},
        position =
            math.max(
                1,
                math.floor(
                    tonumber(source_state.position) or 1
                )
            ),
        shown_position =
            math.max(
                0,
                math.floor(
                    tonumber(source_state.shown_position) or 0
                )
            ),
        last_quote_index =
            tonumber(source_state.last_quote_index),
        shown_quote_ids = {},
        shown_unique_count =
            math.max(
                0,
                math.floor(
                    tonumber(source_state.shown_unique_count) or 0
                )
            ),
        last_used =
            tonumber(source_state.last_used) or os.time(),
        quotes_revision =
            tonumber(quotes_revision) or 0
    }

    for index,
        quote_index in ipairs(
            source_state.matches or {}
        ) do

        copied_state.matches[index] =
            quote_index
    end

    for line_number,
        seen in pairs(
            source_state.shown_quote_ids or {}
        ) do

        if seen then
            copied_state.shown_quote_ids[
                line_number
            ] = true
        end
    end

    return copied_state
end

local function remember_quote_search_state(
    userid,
    state
)
    userid = tonumber(userid) or 0

    if userid <= 0 then
        return false
    end

    local copied_state =
        copy_quote_search_state(
            state
        )

    if not copied_state
        or copied_state.query_key == ""
        or #copied_state.matches == 0 then

        return false
    end

    last_quote_search_state_by_userid[
        userid
    ] = copied_state

    return true
end

local function restore_quote_search_state(
    userid
)
    userid = tonumber(userid) or 0

    if userid <= 0 then
        return nil
    end

    local saved_state =
        last_quote_search_state_by_userid[
            userid
        ]

    if type(saved_state) ~= "table"
        or tostring(saved_state.query_key or "") == ""
        or type(saved_state.matches) ~= "table"
        or #saved_state.matches == 0 then

        return nil
    end

    local state =
        get_search_state(userid)

    local copied_state =
        copy_quote_search_state(
            saved_state
        )

    if not copied_state then
        return nil
    end

    state.query_key =
        copied_state.query_key

    state.display_query =
        copied_state.display_query

    state.mode =
        copied_state.mode

    state.matches =
        copied_state.matches

    state.position =
        copied_state.position

    state.shown_position =
        copied_state.shown_position

    state.last_quote_index =
        copied_state.last_quote_index

    state.shown_quote_ids =
        copied_state.shown_quote_ids

    state.shown_unique_count =
        copied_state.shown_unique_count

    state.last_used =
        os.time()

    return state
end

local function clear_quote_search_state(
    userid
)
    userid = tonumber(userid) or 0

    if userid <= 0 then
        return false
    end

    search_states[userid] = nil

    last_quote_search_state_by_userid[
        userid
    ] = nil

    return true
end

function quote_search_state_has_unshown_result(state)
    if type(state) ~= "table"
        or type(state.matches) ~= "table"
        or #state.matches == 0 then

        return false
    end

    state.shown_quote_ids =
        type(state.shown_quote_ids) == "table"
        and state.shown_quote_ids
        or {}

    for _, quote_index in ipairs(state.matches) do
        local quote =
            quotes[quote_index]

        if quote
            and quote.line_number
            and not state.shown_quote_ids[
                quote.line_number
            ] then

            return true
        end
    end

    return false
end

function build_no_further_quote_results_message(state)
    state =
        type(state) == "table"
        and state
        or {}

    local mode =
        tostring(state.mode or "")

    local display =
        trim(tostring(state.display_query or ""))

    if display == "" then
        display = "this search"
    end

    if mode == "Exact phrase" then
        return string.format(
            "No further exact matches for “%s”.",
            display
        )
    end

    if mode == "Keywords" then
        return string.format(
            "No further quotes found with keyword: “%s”.",
            display
        )
    end

    if mode == "Player ID"
        or mode == "Player Name"
        or mode == "Quoted person" then

        return string.format(
            "No further quotes for player “%s”.",
            display
        )
    end

    return string.format(
        "No further quotes for “%s”.",
        display
    )
end

sync_remote_quote_state_from_response = function(
    userid,
    response_message,
    queued_command
)
    userid = tonumber(userid) or 0

    if userid <= 0 then
        return false
    end

    local line_number =
        extract_quote_line_number_from_response(
            response_message
        )

    local selected_quote = nil

    if line_number then
        if #quotes == 0 then
            load_quotes()
        end

        selected_quote =
            quotes_by_line[
                line_number
            ]

        if selected_quote then
            remember_posted_quote(
                userid,
                selected_quote
            )
        end
    end

    if type(queued_command) ~= "table" then
        return selected_quote ~= nil
    end

    local command_key =
        tostring(queued_command.command_key or "")

    if command_key == "findrandom" then
        clear_quote_search_state(
            userid
        )
        return selected_quote ~= nil
    end

    if command_key == "findnext" then
        local state =
            search_states[userid]
            or restore_quote_search_state(
                userid
            )

        if state and selected_quote then
            mark_state_quote_as_seen(
                state,
                selected_quote
            )

            remember_quote_search_state(
                userid,
                state
            )
        end

        return selected_quote ~= nil
    end

    if command_key ~= "find" then
        return selected_quote ~= nil
    end

    local request, matches =
        build_search_context_from_find_message(
            queued_command.message
        )

    if not request
        or type(matches) ~= "table"
        or #matches == 0 then

        return selected_quote ~= nil
    end

    local state =
        get_search_state(userid)

    start_new_search(
        state,
        request,
        matches
    )

    if selected_quote then
        mark_state_quote_as_seen(
            state,
            selected_quote
        )
    end

    remember_quote_search_state(
        userid,
        state
    )

    return true
end

local function update_search_status(
    userid,
    state,
    result_total,
    selected_quote
)
    status.last_requester =
        userid

    status.last_requester_name =
        get_player_name_from_userid(userid)

    status.last_search =
        state.display_query

    status.last_search_mode =
        state.mode

    status.last_search_matches =
        result_total

    status.last_number =
        selected_quote.line_number
end

local function find_quote_from_chat(userid, message, is_local)
    local matched, raw_search_text =
        extract_command_argument(
            message,
            settings.find_command
        )

    if not matched then
        return false
    end

    local search_text =
        trim(raw_search_text)

    if search_text == "" then
        status.message =
            "Invalid find input"

        clear_quote_search_state(
            userid
        )

        ui.quotes.queue_reliable_messages(
            { "Invalid input, use: !find <keywords, #ID, @playerID or @'player name'>." },
            settings.command_response_delay
        )

        return true
    end

    if #quotes == 0 then
        if not load_quotes()
            or #quotes == 0 then

            ui.quotes.queue_reliable_messages(
                { "No quotes are available." },
                settings.command_response_delay
            )

            return true
        end
    end

    local direct_line_number =
        search_text:match("^#(%d+)$")

    if direct_line_number then
        direct_line_number =
            tonumber(direct_line_number)

        if not can_use_find_command(
            userid,
            is_local
        ) then
            return true
        end

        local selected_quote =
            quotes_by_line[
                direct_line_number
            ]

        if not selected_quote then
            local no_result_message =
                string.format(
                    "No quote found with ID: “#%d”.",
                    direct_line_number
                )

            status.message = "No matches"
            status.last_requester = userid
            status.last_requester_name =
                get_player_name_from_userid(userid)
            status.last_search =
                "#" .. tostring(direct_line_number)
            status.last_search_mode = "ID"
            status.last_search_matches = 0

            ui.console.print(
                "[L4D2 Quotes] " ..
                no_result_message
            )

            clear_quote_search_state(
                userid
            )

            ui.quotes.queue_reliable_messages(
                { no_result_message },
                settings.command_response_delay
            )

            return true
        end

        local result_message =
            format_quote_message(
                selected_quote
            )

        status.last_number =
            selected_quote.line_number

        status.last_requester =
            userid

        status.last_requester_name =
            get_player_name_from_userid(userid)

        status.last_search =
            "#" .. tostring(direct_line_number)

        status.last_search_mode =
            "ID"

        status.last_search_matches =
            1

        status.message = "Quote found by ID"

        ui.console.print(
            "[L4D2 Quotes] Direct result: " ..
            result_message
        )

        search_states[userid] = nil

        last_quote_search_state_by_userid[
            userid
        ] = {
            query_key =
                "id:" ..
                tostring(direct_line_number),
            display_query =
                "#" ..
                tostring(direct_line_number),
            mode = "ID",
            matches = {},
            position = 1,
            shown_position = 0,
            last_quote_index = nil,
            shown_quote_ids = {},
            shown_unique_count = 0,
            last_used = os.time(),
            non_continuable_message =
                "Find next is not available after searching by quote ID."
        }

        mark_quote_displayed(
            selected_quote
        )

        remember_posted_quote(
            userid,
            selected_quote
        )

        ui.quotes.queue_reliable_messages(
            { result_message },
            settings.command_response_delay
        )

        return true
    end

    local malformed_at_target = nil

    if search_text:sub(1, 2) == "@@" then
        malformed_at_target =
            trim(
                search_text:sub(2)
            )
    end

    if malformed_at_target ~= nil
        and malformed_at_target ~= "" then

        status.message =
            "No player ID matches"

        status.last_requester =
            userid

        status.last_requester_name =
            get_player_name_from_userid(userid)

        status.last_search =
            "@" .. malformed_at_target

        status.last_search_mode =
            "Player ID"

        status.last_search_matches =
            0

        clear_quote_search_state(
            userid
        )

        ui.quotes.queue_reliable_messages(
            {
                string.format(
                    "No quotes found for player with ID: “%s”.",
                    malformed_at_target
                )
            },
            settings.command_response_delay
        )

        return true
    end

    local player_userid =
        extract_player_id_search(
            search_text
        )

    if player_userid then
        local player_name =
            get_player_name_from_userid(
                player_userid
            )

        if not player_name
            or player_name == ""
            or player_name == "Unknown" then
            status.message =
                "Player not found."

            status.last_requester =
                userid

            status.last_requester_name =
                get_player_name_from_userid(userid)

            status.last_search =
                "@" .. tostring(player_userid)

            status.last_search_mode =
                "Player ID"

            status.last_search_matches =
                0

            clear_quote_search_state(
                userid
            )

            ui.quotes.queue_reliable_messages(
                {
                    string.format(
                        "No current player found with ID: “%d”.",
                        player_userid
                    )
                },
                settings.command_response_delay
            )

            return true
        end

        if not can_use_find_command(
            userid,
            is_local
        ) then
            return true
        end

        local matches =
            find_quotes_by_exact_player_name(
                player_name
            )

        if #matches == 0 then
            status.message =
                "No matches"

            status.last_requester =
                userid

            status.last_requester_name =
                get_player_name_from_userid(userid)

            status.last_search =
                player_name ..
                " [ID: " ..
                tostring(player_userid) ..
                "]"

            status.last_search_mode =
                "Player ID"

            status.last_search_matches =
                0

            clear_quote_search_state(
                userid
            )

            ui.quotes.queue_reliable_messages(
                {
                    string.format(
                        "No quotes found for player “%s” [ID: %d].",
                        player_name,
                        player_userid
                    )
                },
                settings.command_response_delay
            )

            return true
        end

        local request = {
            mode = "Player ID",
            display = player_name ..
                " [ID: " ..
                tostring(player_userid) ..
                "]",
            key = "playerid:" ..
                tostring(player_userid) ..
                ":" ..
                normalize_player_name_for_detection(
                    player_name
                )
        }

        local selected_quote,
            result_position,
            result_total =
                select_next_search_result(
                    userid,
                    request,
                    matches
                )

        if not selected_quote then
            status.message =
                "Search selection failed"

            ui.console.print(
                "[L4D2 Quotes] Could not select a player ID search result."
            )

            return true
        end

        local state =
            get_search_state(userid)

        local result_message =
            format_quote_message(
                selected_quote
            )

        local quote_word =
            result_total == 1
            and "quote"
            or "quotes"

        local count_message =
            string.format(
                "Found %d %s for player “%s” [ID: %d].",
                result_total,
                quote_word,
                player_name,
                player_userid
            )

        update_search_status(
            userid,
            state,
            result_total,
            selected_quote
        )

        status.message =
            string.format(
                "Player search %d/%d",
                result_position,
                result_total
            )

        ui.console.print(
            "[L4D2 Quotes] " ..
            count_message
        )

        ui.console.print(
            "[L4D2 Quotes] Result: " ..
            result_message
        )

        remember_quote_search_state(
            userid,
            state
        )

        if ui.quotes.queue_reliable_messages(
            {
                count_message,
                result_message
            },
            settings.command_response_delay
        ) then
            mark_quote_displayed(
                selected_quote
            )

            remember_posted_quote(
                userid,
                selected_quote
            )
        end

        return true
    end

    local exact_player_name =
        extract_player_name_search(
            search_text
        )

    if exact_player_name then
        if not can_use_find_command(
            userid,
            is_local
        ) then
            return true
        end

        local matches =
            find_quotes_by_exact_player_name(
                exact_player_name
            )

        if #matches == 0 then
            status.message =
                "No matches"

            status.last_requester =
                userid

            status.last_requester_name =
                get_player_name_from_userid(userid)

            status.last_search =
                exact_player_name

            status.last_search_mode =
                "Player Name"

            status.last_search_matches =
                0

            local no_result_message =
                string.format(
                    "No quotes found for player “%s”.",
                    exact_player_name
                )

            ui.console.print(
                "[L4D2 Quotes] " ..
                no_result_message
            )


            clear_quote_search_state(
                userid
            )

            ui.quotes.queue_reliable_messages(
                { no_result_message },
                settings.command_response_delay
            )

            return true
        end

        local request = {
            mode = "Player Name",
            display = exact_player_name,
            key = "playername:" ..
                normalize_player_name_for_detection(
                    exact_player_name
                )
        }

        local selected_quote,
            result_position,
            result_total =
