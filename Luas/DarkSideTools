function ui.favourites.unpin_key(
    target_key
)
    target_key =
        tostring(target_key or "")

    local retained = {}
    local removed = false

    for _, entry in ipairs(
        ui.favourites.normalize_entries()
    ) do
        if not removed
            and ui.favourites.entry_key(
                entry
            ) == target_key then

            removed = true
        else
            retained[
                #retained + 1
            ] = entry
        end
    end

    if removed then
        ui.favourites.entries = retained
    end

    return removed
end

function ui.favourites.capture_renderers(
    tab_key,
    renderers
)
    tab_key =
        tostring(tab_key or "")

    if ui.favourites.tool_indices[
        tab_key
    ] == nil
        or type(renderers) ~= "table" then

        return
    end

    ui.favourites.renderer_cache[
        tab_key
    ] =
        type(
            ui.favourites.renderer_cache[
                tab_key
            ]
        ) == "table"
        and ui.favourites.renderer_cache[
            tab_key
        ]
        or {}

    for section_key,
        renderer in pairs(
            renderers
        ) do

        if type(renderer) == "function" then
            ui.favourites.renderer_cache[
                tab_key
            ][
                tostring(section_key)
            ] = renderer
        end
    end
end

