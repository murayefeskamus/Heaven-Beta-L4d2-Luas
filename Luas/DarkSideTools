function ui.setting_search.is_exact_rendered_label(label)
    if ui.setting_search.exact_observer_guard == true
        or ui.setting_search.rendering_highlight_active ~= true then

        return false
    end

    local candidate = ui.setting_search.normalize(
        ui.setting_search.visible_item_label(label)
    )
    local target = ui.setting_search.normalize(
        ui.setting_search.active_highlight_term
    )

    return candidate ~= "" and target ~= "" and candidate == target
end

function ui.setting_search.capture_current_item_content_y()
    local item_screen_y = nil
    local window_screen_y = 0.0
    local scroll_y = 0.0

    if type(imgui.get_item_rect_min) == "function" then
        local ok, first, second = pcall(imgui.get_item_rect_min)
        if ok then
            if type(first) == "table" then
                item_screen_y = tonumber(first.y) or tonumber(first[2])
            else
                item_screen_y = tonumber(second)
            end
        end
    end

    if item_screen_y ~= nil then
        for _, method_name in ipairs({ "get_window_pos", "get_window_position" }) do
            local method = imgui[method_name]
            if type(method) == "function" then
                local ok, first, second = pcall(method)
                if ok then
                    if type(first) == "table" then
                        window_screen_y =
                            tonumber(first.y) or tonumber(first[2]) or window_screen_y
                    else
                        window_screen_y = tonumber(second) or window_screen_y
                    end
                    break
                end
            end
        end

        if type(imgui.get_scroll_y) == "function" then
            local ok, value = pcall(imgui.get_scroll_y)
            if ok then
                scroll_y = tonumber(value) or 0.0
            end
        end

        return math.max(0.0, item_screen_y - window_screen_y + scroll_y)
    end

    local cursor_y = ui.lobby.get_cursor_y()
    local line_height = 18.0

    if type(imgui.get_text_line_height_with_spacing) == "function" then
        local ok, value = pcall(imgui.get_text_line_height_with_spacing)
        if ok then
            line_height = tonumber(value) or line_height
        end
    elseif type(imgui.get_frame_height_with_spacing) == "function" then
        local ok, value = pcall(imgui.get_frame_height_with_spacing)
        if ok then
            line_height = tonumber(value) or line_height
        end
    end

    return math.max(0.0, cursor_y - line_height)
end

function ui.setting_search.observe_rendered_item(label)
    if ui.setting_search.exact_observer_guard == true
        or ui.setting_search.rendering_exact_target_section ~= true
        or ui.setting_search.exact_scroll_pending ~= true
        or ui.setting_search.exact_capture_consumed == true
        or not ui.setting_search.is_exact_rendered_label(label) then

        return false
    end

    ui.setting_search.exact_target_content_y =
        ui.setting_search.capture_current_item_content_y()
    ui.setting_search.exact_capture_consumed = true
    ui.setting_search.exact_scroll_found =
        ui.setting_search.exact_target_content_y ~= nil

    return ui.setting_search.exact_scroll_found
end

function ui.setting_search.apply_exact_scroll()
    local target_y = tonumber(ui.setting_search.exact_target_content_y)
    if target_y == nil then
        return false
    end

    local offset = math.max(
        24,
        tonumber(ui.setting_search.exact_scroll_top_offset) or 72
    )
    local requested_scroll = math.max(0.0, target_y - offset)
    local applied = false

    if type(imgui.set_scroll_y) == "function" then
        local ok = pcall(imgui.set_scroll_y, requested_scroll)
        applied = ok == true
    elseif type(imgui.set_scroll_from_pos_y) == "function" then
        local ok = pcall(imgui.set_scroll_from_pos_y, target_y, 0.08)
        applied = ok == true
    elseif type(imgui.set_scroll_here_y) == "function"
        or type(imgui.set_scroll_here) == "function" then

        local restore_y = ui.lobby.get_cursor_y()
        ui.lobby.set_cursor_y(target_y)

        if type(imgui.set_scroll_here_y) == "function" then
            local ok = pcall(imgui.set_scroll_here_y, 0.08)
            applied = ok == true
        else
            local ok = pcall(imgui.set_scroll_here, 0.08)
            applied = ok == true
        end

        ui.lobby.set_cursor_y(restore_y)
    end

    if applied then
        ui.setting_search.exact_scroll_success_frames =
            math.max(
                0,
                math.floor(
                    tonumber(ui.setting_search.exact_scroll_success_frames) or 0
                )
            ) + 1

        if ui.setting_search.exact_scroll_success_frames >= 2 then
            ui.setting_search.exact_scroll_pending = false
            ui.setting_search.exact_scroll_found = true
        end
    end

    return applied
end

function ui.setting_search.reinstall_exact_item_observers()
    ui.setting_search.exact_original_imgui =
        type(ui.setting_search.exact_original_imgui) == "table"
        and ui.setting_search.exact_original_imgui
        or {}

    local methods = {
        { name = "text", label_index = 1 },
        { name = "text_colored", label_index = 5 },
        { name = "button", label_index = 1 },
        { name = "small_button", label_index = 1 },
        { name = "checkbox", label_index = 1 },
        { name = "combo", label_index = 1 },
        { name = "input_text", label_index = 1 },
        { name = "input_text_multiline", label_index = 1 },
        { name = "input_int", label_index = 1 },
        { name = "input_float", label_index = 1 },
        { name = "slider_int", label_index = 1 },
        { name = "slider_float", label_index = 1 },
        { name = "drag_int", label_index = 1 },
        { name = "drag_float", label_index = 1 },
        { name = "radio_button", label_index = 1 },
        { name = "selectable", label_index = 1 },
        { name = "color_edit3", label_index = 1 },
        { name = "color_edit4", label_index = 1 },
        { name = "color_picker3", label_index = 1 },
        { name = "color_picker4", label_index = 1 }
    }

    for _, definition in ipairs(methods) do
        local method_name = definition.name
        local label_index = definition.label_index
        local raw_method = ui.setting_search.exact_original_imgui[method_name]

        if type(raw_method) ~= "function" and type(imgui[method_name]) == "function" then
            raw_method = imgui[method_name]
            ui.setting_search.exact_original_imgui[method_name] = raw_method
        end

        if type(raw_method) == "function" then
            imgui[method_name] = function(...)
                local arguments = { ... }
                local label = arguments[label_index]
                local exact_match =
                    ui.setting_search.exact_label_highlight_consumed ~= true
                    and ui.setting_search.is_exact_rendered_label(label)
                local pushed_text_color = false

                if exact_match then
                    ui.setting_search.exact_label_highlight_consumed = true

                    if ui.setting_search.exact_inline_marker_consumed ~= true
                        and not ui.setting_search.is_inside_table() then

                        ui.setting_search.exact_inline_marker_consumed = true
                        ui.setting_search.exact_observer_guard = true
                        ui.setting_search.draw_exact_inline_marker()
                        ui.setting_search.exact_observer_guard = false
                    end

                    if type(imgui.push_style_color) == "function" then
                        local palette = ui.enhancements.theme_palette()
                        local attention = ui.setting_search.get_attention_color(palette)
                        local ok = pcall(
                            imgui.push_style_color,
                            0,
                            attention[1] or 1.0,
                            attention[2] or 0.82,
                            attention[3] or 0.18,
                            1.0
                        )
                        pushed_text_color = ok == true
                    end
                end

                local packed_results =
                    ui.setting_search.exact_pack(raw_method(...))

                if pushed_text_color
                    and type(imgui.pop_style_color) == "function" then
                    pcall(imgui.pop_style_color, 1)
                end

                if exact_match then
                    ui.setting_search.observe_rendered_item(label)
                end

                return ui.setting_search.exact_unpack(
                    packed_results,
                    1,
                    packed_results.n
                )
            end
        end
    end
end

ui.setting_search.reinstall_exact_item_observers()

