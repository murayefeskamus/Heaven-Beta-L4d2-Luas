        player_record.alive == true
        and "Alive"
        or (
            player_record.alive == false
            and "Dead"
            or "?"
        )

    local full_player_name =
        tostring(
            player_record.name or "Unknown"
        )

    local player_name =
        truncate_preview(
            full_player_name,
            13
        )

    if player_record.is_local then
        local name_column =
            ui.lobby.player_table_columns[3]

        local badge_width =
            ui.lobby.measure_text_width(
                "YOU"
            ) + 14

        local available_name_width =
            math.max(
                16,
                name_column.width -
                badge_width -
                5
            )

        local character_limit =
            math.min(
                13,
                #full_player_name
            )

        player_name =
            truncate_preview(
                full_player_name,
                character_limit
            )

        while character_limit > 1
            and ui.lobby.measure_text_width(
                player_name
            ) > available_name_width do

            character_limit =
                character_limit - 1

            player_name =
                truncate_preview(
                    full_player_name,
                    character_limit
                )
        end
    end

    local uid_r, uid_g, uid_b =
        1.0, 1.0, 1.0

    local team_r, team_g, team_b =
        1.0, 1.0, 1.0

    if player_record.team == 2 then
        team_r, team_g, team_b =
            0.45, 0.90, 1.0
    elseif player_record.team == 3 then
        team_r, team_g, team_b =
            1.0, 0.35, 0.35
    end

    local state_r, state_g, state_b =
        1.0, 1.0, 1.0

    if player_record.alive == true then
        state_r, state_g, state_b =
            0.20, 1.00, 0.20
    elseif player_record.alive == false then
        state_r, state_g, state_b =
            1.00, 0.30, 0.30
    end

    local hp_r, hp_g, hp_b =
        1.0, 1.0, 1.0

    local displayed_health =
        tonumber(
            player_record.health
        )

    if player_record.alive == false then
        displayed_health = 0
    end

    if displayed_health ~= nil
        and displayed_health <= 0 then

        hp_r, hp_g, hp_b =
            0.55, 0.55, 0.55
    elseif player_record.team == 2 then
        hp_r, hp_g, hp_b =
            ui.lobby.get_health_color(
                displayed_health
            )
    end

    local background_r,
        background_g,
        background_b =
            0.16, 0.16, 0.16

    if ui.lobby.selected_key ==
        player_record.key then

        if player_record.is_bot then
            background_r,
            background_g,
            background_b =
                0.34, 0.34, 0.34
        elseif player_record.team == 2 then
            background_r,
            background_g,
            background_b =
                0.08, 0.32, 0.62
        elseif player_record.team == 3 then
            background_r,
            background_g,
            background_b =
                0.58, 0.08, 0.08
        else
            background_r,
            background_g,
            background_b =
                0.30, 0.30, 0.30
        end
    end

    local start_x =
        ui.lobby.get_cursor_x()

    local start_y =
        ui.lobby.get_cursor_y()

    local selected_row =
        ui.lobby.selected_key ==
        player_record.key

    local row_background = {
        0.0, 0.0, 0.0, 0.0
    }

    local row_hover = {
        0.18, 0.18, 0.20, 0.72
    }

    if player_record.is_bot then
        row_background = selected_row
            and { 0.46, 0.46, 0.46, 0.72 }
            or row_background

        row_hover = {
            0.38, 0.38, 0.38, 0.30
        }
    elseif player_record.team == 2 then
        row_background = selected_row
            and { 0.45, 0.90, 1.00, 0.36 }
            or row_background

        row_hover = {
            0.45, 0.90, 1.00, 0.18
        }
    elseif player_record.team == 3 then
        row_background = selected_row
            and { 1.00, 0.35, 0.35, 0.36 }
            or row_background

        row_hover = {
            1.00, 0.35, 0.35, 0.18
        }
    elseif selected_row then
        row_background = {
            0.38, 0.38, 0.38, 0.70
        }
    end

    local last_column =
        ui.lobby.player_table_columns[
            #ui.lobby.player_table_columns
        ]

    local row_width =
        last_column.offset +
        last_column.width -
        2

    local pushed_row_colors = 0

    local function push_row_color(
        color_index,
        color
    )
        local ok =
            type(imgui.push_style_color) == "function"
            and pcall(
                imgui.push_style_color,
                color_index,
                color[1],
                color[2],
                color[3],
                color[4]
            )

        if ok then
            pushed_row_colors =
                pushed_row_colors + 1
        end
    end

    push_row_color(
        0,
        { 1.0, 1.0, 1.0, 0.0 }
    )

    push_row_color(
        21,
        row_background
    )

    push_row_color(
        22,
        row_hover
    )

    push_row_color(
        23,
        row_hover
    )

    local row_clicked =
        ui.heaven_configs.draw_sized_button(
            "##LobbyRow_" ..
                tostring(section_name) ..
                "_" ..
                tostring(player_record.entity_index) ..
                "_" ..
                tostring(row_index),
            row_width
        )

    if pushed_row_colors > 0
        and type(imgui.pop_style_color) == "function" then

        for _ = 1, pushed_row_colors do
            pcall(imgui.pop_style_color)
        end
    end

    if row_clicked then
        ui.lobby.selected_key =
            player_record.key

        selected_row = true
    end

    ui.lobby.set_cursor_x(start_x)
    ui.lobby.set_cursor_y(start_y)

    if selected_row then
        team_r, team_g, team_b =
            1.0, 1.0, 1.0
    end

    local userid_label =
        player_record.userid > 0
        and tostring(player_record.userid)
        or "-"

    ui.lobby.draw_player_table_cell(
        start_x,
        1,
        userid_label,
        uid_r, uid_g, uid_b,
        true
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        2,
        tostring(
            player_record.entity_index
        ),
        1.0, 1.0, 1.0,
        false
    )

    if player_record.is_local then
        local name_column =
            ui.lobby.player_table_columns[3]

        local name_width =
            ui.lobby.measure_text_width(
                player_name
            )

        local badge_width =
            ui.lobby.measure_text_width(
                "YOU"
            ) + 14

        local badge_gap = 3

        local group_width =
            name_width +
            badge_gap +
            badge_width

        local group_start_x =
            start_x +
            name_column.offset +
            math.max(
                0,
                (
                    name_column.width -
                    group_width
                ) * 0.5
            )

        imgui.same_line()

        ui.lobby.set_cursor_x(
            group_start_x
        )

        theme_text_colored(
            1.0, 1.0, 1.0, 1.0,
            player_name
        )

        imgui.same_line()

        ui.lobby.set_cursor_x(
            group_start_x +
            name_width +
            badge_gap
        )

        if colored_button(
            "YOU##LobbyYouBadge_" ..
                tostring(section_name) ..
                "_" ..
                tostring(player_record.entity_index) ..
                "_" ..
                tostring(row_index),
            0.0, 0.0, 0.0,
            1.0, 1.0, 1.0
        ) then
            ui.lobby.selected_key =
                player_record.key
        end
    else
        ui.lobby.draw_table_text(
            start_x,
            ui.lobby.player_table_columns[3].offset,
            ui.lobby.player_table_columns[3].width,
            player_name,
            1.0, 1.0, 1.0,
            false
        )
    end

    ui.lobby.draw_player_table_divider(
        start_x,
        ui.lobby.player_table_columns[4].offset
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        4,
        truncate_preview(
            player_record.class_name,
            11
        ),
        1.0, 1.0, 1.0,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        5,
        tostring(
            player_record.team_name
        ),
        team_r, team_g, team_b,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        6,
        state_text,
        state_r, state_g, state_b,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        7,
        displayed_health ~= nil
            and tostring(
                math.max(
                    0,
                    math.floor(
                        displayed_health
                    )
                )
            )
            or "N/A",
        hp_r, hp_g, hp_b,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        8,
        tostring(
            player_record.kills or 0
        ),
        1.0, 1.0, 1.0,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        9,
        tostring(
            player_record.deaths or 0
        ),
        1.0, 1.0, 1.0,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        10,
        ui.lobby.format_kd_ratio(
            player_record.kills,
            player_record.deaths
        ),
        1.0, 1.0, 1.0,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        11,
        player_record.team == 2
            and tostring(
                player_record.special_kills or 0
            )
            or "-",
        1.0, 1.0, 1.0,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        12,
        player_record.team == 2
            and tostring(
                player_record.common_kills or 0
            )
            or "-",
        1.0, 1.0, 1.0,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        13,
        player_record.team == 3
            and tostring(
                player_record.si_damage_total or 0
            )
            or "-",
        1.0, 1.0, 1.0,
        false
    )

    ui.lobby.draw_player_table_cell(
        start_x,
        14,
        ui.lobby.format_session_hms(
            get_time() -
                (
                    player_record.first_seen
                    or get_time()
                )
        ),
        1.0, 1.0, 1.0,
        false
    )

    ui.lobby.set_cursor_x(start_x)
    ui.lobby.set_cursor_y(start_y + 18)

    imgui.separator()
end


function ui.lobby.draw_inline_counter(
    label,
    value,
    unique_id,
    first_item,
    label_r,
    label_g,
    label_b
)
    value = tonumber(value) or 0

    if not first_item then
        imgui.same_line()

        theme_text_colored(
            0.45, 0.45, 0.45, 1.0,
            "|"
        )

        imgui.same_line()
    end

    theme_text_colored(
        label_r or 1.0,
        label_g or 1.0,
        label_b or 1.0,
        1.0,
        tostring(label) .. ":"
    )

    imgui.same_line()

    theme_text_colored(
        value > 0 and 0.20 or 0.65,
        value > 0 and 1.00 or 0.65,
        value > 0 and 0.20 or 0.65,
        1.0,
        tostring(value)
    )
end

function ui.lobby.draw_team_card(
    team_name,
    label,
    unique_id,
    text_r,
    text_g,
    text_b,
    background_r,
    background_g,
    background_b
)
    local summary =
        ui.lobby.overview.team_breakdown[
            team_name
        ] or {
            humans = 0,
            bots = 0,
            alive = 0,
            dead = 0,
            kills = 0,
            special_kills = 0,
            common_kills = 0,
            tank_kills = 0,
            witch_kills = 0,
            deaths = 0
        }

    local total =
        (summary.humans or 0) +
        (summary.bots or 0)

    local function draw_counter_pair(
        first_label,
        first_value,
        second_label,
        second_value,
        first_r,
        first_g,
        first_b
    )
        ui.lobby.draw_inline_counter(
            first_label,
            first_value,
            unique_id .. first_label,
            true,
            first_r,
            first_g,
            first_b
        )

        if second_label ~= nil then
            ui.lobby.draw_inline_counter(
                second_label,
                second_value,
                unique_id .. second_label,
                false
            )
        end
    end


    draw_counter_pair(
        label,
        total,
        "Players",
        summary.humans or 0,
        text_r,
        text_g,
        text_b
    )

    draw_counter_pair(
        "Bots",
        summary.bots or 0,
        "Alive",
        summary.alive or 0
    )

    draw_counter_pair(
        "Dead",
        summary.dead or 0,
        "Special kills",
        summary.kills or 0
    )

    if team_name == "Survivors" then
        draw_counter_pair(
            "Common kills",
            summary.common_kills or 0,
            "Tank kills",
            summary.tank_kills or 0
        )

        draw_counter_pair(
            "Witch kills",
            summary.witch_kills or 0,
            "Deaths",
            summary.deaths or 0
        )
    else
        draw_counter_pair(
            "Deaths",
            summary.deaths or 0,
            nil,
            nil
        )
    end

    if colored_button(
        "Send " .. team_name ..
            " Summary to All Chat##LobbyTeamSend" .. unique_id,
        1.0, 1.0, 1.0,
        background_r,
        background_g,
        background_b
    ) then
        ui.lobby.print_team_summary(
            team_name,
            label
        )
    end
end

function ui.lobby.draw_player_details_table(
    selected_player
)
    if not selected_player then
        return
    end

    local rows = {}

    local function add_row(
        label,
        value,
        r,
        g,
        b
    )
        table.insert(
            rows,
            {
                label = tostring(label),
                value = tostring(value),
                r = r or 1.0,
                g = g or 1.0,
                b = b or 1.0
            }
        )
    end

    local function add_stat_row(
        label,
        value
    )
        local numeric_value =
            tonumber(value) or 0

        if numeric_value > 0 then
            add_row(
                label,
                value,
                0.20, 1.0, 0.20
            )
        else
            add_row(
                label,
                value,
                1.0, 1.0, 1.0
            )
        end
    end

    add_row(
        "User ID",
        selected_player.userid > 0
            and selected_player.userid
            or "Unavailable"
    )

    add_row(
        "Entity ID",
        selected_player.entity_index
    )

    add_row(
        "Type",
        selected_player.is_bot
            and "Bot"
            or "Real player"
    )

    add_row(
        "Character",
        selected_player.class_name
    )

    local team_r,
        team_g,
        team_b =
            1.0, 1.0, 1.0

    if selected_player.team == 2 then
        team_r, team_g, team_b =
            0.45, 0.90, 1.0
    elseif selected_player.team == 3 then
        team_r, team_g, team_b =
            1.0, 0.35, 0.35
    end

    add_row(
        "Team",
        selected_player.team_name,
        team_r,
        team_g,
        team_b
    )

    add_row(
        "State",
        selected_player.alive == true
            and "Alive"
            or (
                selected_player.alive == false
                and "Dead"
                or "Unknown"
            )
    )

    local health_value =
        selected_player.health ~= nil
        and selected_player.health
        or "Unavailable"

    local health_r,
        health_g,
        health_b =
            ui.lobby.get_health_color(
                health_value
            )

    add_row(
        "Health",
        health_value,
        health_r,
        health_g,
        health_b
    )

    add_stat_row(
        "Kills",
        selected_player.kills or 0
    )

    add_stat_row(
        "Deaths",
        selected_player.deaths or 0
    )

    add_row(
        "K/D",
        ui.lobby.format_kd_ratio(
            selected_player.kills,
            selected_player.deaths
        )
    )

    add_stat_row(
        "Common infected kills",
        selected_player.common_kills or 0
    )

    add_stat_row(
        "Special infected kills",
        selected_player.special_kills or 0
    )

    add_stat_row(
        "Tank kills",
        selected_player.tank_kills or 0
    )

    add_stat_row(
        "Witch kills",
        selected_player.witch_kills or 0
    )

    add_row(
        "Connection",
        selected_player.connected
            and "Connected"
            or "Disconnected"
    )

    add_row(
        "Joined",
        ui.lobby.format_age(
            get_time() -
                (
                    selected_player.first_seen
                    or get_time()
                )
        )
    )

    add_stat_row(
        "Chat messages",
        selected_player.chat_messages or 0
    )

    add_stat_row(
        "Reconnects",
        selected_player.reconnects or 0
    )

    add_stat_row(
        "Name changes",
        selected_player.name_changes or 0
    )

    add_row(
        "Name length",
        string.format(
            "%d characters",
            selected_player.name_characters or 0
        )
    )

    local label_width = 150
    local value_width = 130

    for _, row in ipairs(
        rows
    ) do
        label_width =
            math.max(
                label_width,
                ui.lobby.measure_text_width(
                    row.label
                ) + 24
            )

        value_width =
            math.max(
                value_width,
                ui.lobby.measure_text_width(
                    row.value
                ) + 24
            )
    end

    local table_width =
        math.max(
            330,
            math.min(
                560,
                label_width +
                value_width +
                24
            )
        )

    local table_height =
        2 +
        #rows * 20

    local tables_start_x =
        ui.lobby.get_cursor_x()

    local tables_start_y =
        ui.lobby.get_cursor_y()

    local table_open =
        imgui.begin_child(
            "LobbySelectedPlayerDetailsTable",
            table_width,
            table_height,
            false,
            0
        )

    if table_open then
        local start_x =
            ui.lobby.get_cursor_x()

        local function draw_column_divider()
            imgui.same_line()

            ui.lobby.set_cursor_x(
                start_x +
                label_width
            )

            theme_text_colored(
                0.42, 0.42, 0.44, 1.0,
                "|"
            )
        end

        for _, row in ipairs(
            rows
        ) do
            ui.lobby.draw_table_text(
                start_x,
                0,
                label_width,
                row.label,
                0.75, 0.75, 0.78,
                true
            )

            draw_column_divider()

            ui.lobby.draw_table_text(
                start_x,
                label_width + 8,
                value_width,
                row.value,
                row.r,
                row.g,
                row.b,
                false
            )

            imgui.separator()
        end
    end

    imgui.end_child()

    local details_end_y =
        ui.lobby.get_cursor_y()

    local history_width = 430
    local history_height = table_height
    local history_rows =
        type(selected_player.name_history) == "table"
        and selected_player.name_history
        or {}

    ui.lobby.set_cursor_x(
        tables_start_x +
        table_width +
        12
    )

    ui.lobby.set_cursor_y(
        tables_start_y
    )

    local history_open =
        imgui.begin_child(
            "LobbyTrackedNameChangesTable",
            history_width,
            history_height,
            false,
            0
        )

    if history_open then
        local palette =
            ui.enhancements.theme_palette()

        local start_x =
            ui.lobby.get_cursor_x()

        local time_width = 76
        local old_width = 166
        local new_width =
            history_width -
            time_width -
            old_width -
            22

        local time_divider_x =
            start_x + time_width

        local old_x =
            time_divider_x + 8

        local old_divider_x =
            time_divider_x + old_width

        local new_x =
            old_divider_x + 8

        local function draw_history_pipe(
            x
        )
            imgui.same_line()

            ui.lobby.set_cursor_x(
                x
            )

            theme_text_colored(
                palette.text_disabled[1],
                palette.text_disabled[2],
                palette.text_disabled[3],
                1.0,
                "|"
            )
        end

        local function draw_history_arrow(
            x
        )
            imgui.same_line()

            ui.lobby.set_cursor_x(
                x
            )

            theme_text_colored(
                palette.text_disabled[1],
                palette.text_disabled[2],
                palette.text_disabled[3],
                1.0,
                "->"
            )
        end

        local function fit_name(
            value,
            maximum_width
        )
            value = tostring(value or "")

            if ui.lobby.measure_text_width(
                value
            ) <= maximum_width then

                return value
            end

            local characters =
                split_utf8_characters(
                    value
                )

            while #characters > 0 do
                table.remove(
                    characters
                )

                local candidate =
                    table.concat(
                        characters
                    ) ..
                    "..."

                if ui.lobby.measure_text_width(
                    candidate
                ) <= maximum_width then

                    return candidate
                end
            end

            return "..."
        end

        local title_r,
            title_g,
            title_b =
                ui.get_theme_table_title_color(
                    "TRACKED NAME CHANGES",
                    3
                )

        local title_color = {
            title_r,
            title_g,
            title_b
        }

        theme_text_colored(
            title_color[1],
            title_color[2],
            title_color[3],
            1.0,
            "TRACKED NAME CHANGES"
        )

        imgui.separator()

        ui.lobby.draw_table_text(
            start_x,
            0,
            time_width,
            "TIME",
            title_color[1],
            title_color[2],
            title_color[3],
            true
        )

        draw_history_pipe(
            time_divider_x
        )

        ui.lobby.draw_table_text(
            start_x,
            old_x - start_x,
            old_width - 8,
            "PREVIOUS NAME",
            title_color[1],
            title_color[2],
            title_color[3],
            false
        )

        draw_history_arrow(
            old_divider_x
        )

        ui.lobby.draw_table_text(
            start_x,
            new_x - start_x,
            new_width,
            "NEW NAME",
            title_color[1],
            title_color[2],
            title_color[3],
            false
        )

        imgui.separator()

        if #history_rows == 0 then
            theme_text_colored(
                palette.text_disabled[1],
                palette.text_disabled[2],
                palette.text_disabled[3],
                1.0,
                "No name changes detected."
            )

            imgui.separator()
        else
            for _, history_entry in ipairs(
                history_rows
            ) do
                ui.lobby.draw_table_text(
                    start_x,
                    0,
                    time_width,
                    tostring(
                        history_entry.timestamp
                        or "--:--:--"
                    ),
                    palette.text_disabled[1],
                    palette.text_disabled[2],
                    palette.text_disabled[3],
                    true
                )

                draw_history_pipe(
                    time_divider_x
                )

                ui.lobby.draw_table_text(
                    start_x,
                    old_x - start_x,
                    old_width - 8,
                    fit_name(
                        history_entry.old_name,
                        old_width - 20
                    ),
                    palette.text_disabled[1],
                    palette.text_disabled[2],
                    palette.text_disabled[3],
                    false
                )

                draw_history_arrow(
                    old_divider_x
                )

                ui.lobby.draw_table_text(
                    start_x,
                    new_x - start_x,
                    new_width,
                    fit_name(
                        history_entry.new_name,
                        new_width - 12
                    ),
                    palette.text[1],
                    palette.text[2],
                    palette.text[3],
                    false
                )

                imgui.separator()
            end
        end
    end

    imgui.end_child()

    local history_end_y =
        ui.lobby.get_cursor_y()

    ui.lobby.set_cursor_x(
        tables_start_x
    )

    ui.lobby.set_cursor_y(
        math.max(
            details_end_y,
            history_end_y
        )
    )

    ui.lobby.compact_after_child(4)
end

function ui.lobby.draw_detection_and_announcements_section()
    ui.lobby.detection_expanded =
        draw_collapsible_section(
            "DETECTION & ANNOUNCEMENTS",
            ui.lobby.detection_expanded,
            "LobbyDetectionAnnouncements"
        )

    if not ui.lobby.detection_expanded then
        return
    end

    ui.lobby.normalize_special_infected_announcement_templates()

    ui.draw_theme_table_header_text(
        "SPAWN MESSAGE SETTINGS"
    )

    imgui.separator()

    local changed_spawn_messages,
        spawn_messages_value =
            imgui.checkbox(
                "Enable spawn messages",
                ui.lobby.special_infected_announcements_enabled == true
            )

    if changed_spawn_messages then
        ui.lobby.special_infected_announcements_enabled =
            spawn_messages_value == true

        if ui.lobby.special_infected_announcements_enabled == true
            and tonumber(
                ui.lobby.special_infected_announce_route
            ) == 0 then

            ui.lobby.special_infected_announce_route = 1
        end
    end

    imgui.same_line()
    theme_text_colored(
        0.65, 0.65, 0.65, 1.0,
        "Verified player and bot Special Infected spawns."
    )

    imgui.text("Send messages to:")
    imgui.same_line()
    imgui.push_item_width(90)

    local neutral_detection_colors =
        push_neutral_combo_colors()

    local changed_route,
        route_value =
            imgui.combo(
                "##LobbySpecialInfectedAnnounceRoute",
                ui.lobby.special_infected_announce_route,
                ui.lobby.special_infected_announce_routes
            )

    pop_neutral_combo_colors(
        neutral_detection_colors
    )

    imgui.pop_item_width()

    if changed_route then
        ui.lobby.special_infected_announce_route =
            math.max(
                0,
                math.min(
                    2,
                    math.floor(
                        tonumber(route_value) or 0
                    )
                )
            )

        ui.lobby.special_infected_announcements_enabled =
            ui.lobby.special_infected_announce_route > 0
    end

    local changed_block_infected,
        block_infected_value =
            imgui.checkbox(
                "Do not announce while I am Infected",
                ui.lobby.special_infected_suppress_while_infected == true
            )

    if changed_block_infected then
        ui.lobby.special_infected_suppress_while_infected =
            block_infected_value == true
    end

    imgui.same_line()
    theme_text_colored(
        0.65, 0.65, 0.65, 1.0,
        "Stops automatic spawn chat when your local player is on the Infected team."
    )

    draw_compact_gap()

    ui.draw_theme_table_header_text(
        "MESSAGE TEMPLATES"
    )

    imgui.separator()

    local maximum_templates =
        math.max(
            1,
            math.floor(
                tonumber(
                    DARKSIDE_CONFIG.MAX_SPECIAL_INFECTED_ANNOUNCEMENT_TEMPLATES
                ) or 10
            )
        )

    local maximum_characters =
        math.max(
            1,
            math.floor(
                tonumber(
                    DARKSIDE_CONFIG.SPECIAL_INFECTED_ANNOUNCEMENT_MAX_CHARACTERS
                ) or 120
            )
        )

    local row_start_x =
        ui.lobby.get_cursor_x()
    local label_x = row_start_x + 24
    local input_x = row_start_x + 102
    local input_width = 300
    local clear_x = input_x + input_width + 8

    for index = 1,
        #ui.lobby.special_infected_announce_templates do

        local template_text =
            tostring(
                ui.lobby.special_infected_announce_templates[index]
                or ""
            )

        ui.lobby.set_cursor_x(
            row_start_x
        )

        local changed_preferred,
            preferred_value =
                imgui.checkbox(
                    "##PreferredSpecialInfectedAnnouncement" ..
                        tostring(index),
                    ui.lobby.special_infected_announce_preferred[index] == true
                )

        if changed_preferred then
            for preferred_index = 1,
                #ui.lobby.special_infected_announce_preferred do

                ui.lobby.special_infected_announce_preferred[
                    preferred_index
                ] = false
            end

            if preferred_value == true
                and template_text ~= "" then

                ui.lobby.special_infected_announce_preferred[index] = true
            end

            ui.lobby.reset_special_infected_announcement_cycle()
        end

        imgui.same_line()
        ui.lobby.set_cursor_x(
            label_x
        )
        imgui.text(
            "Message " ..
            tostring(index) ..
            ":"
        )

        imgui.same_line()
        ui.lobby.set_cursor_x(
            input_x
        )
        imgui.push_item_width(
            input_width
        )

        local changed_template,
            template_value =
                imgui.input_text(
                    "##LobbySpecialInfectedAnnouncementTemplate" ..
                        tostring(index),
                    template_text,
                    maximum_characters + 1
                )

        imgui.pop_item_width()

        if changed_template then
            local proposed_text =
                tostring(template_value or "")
                :gsub("[\r\n]", " ")
                :gsub('"', "'")

            local proposed_length =
                #split_utf8_characters(
                    proposed_text
                )

            if proposed_length <= maximum_characters then
                ui.lobby.special_infected_announce_templates[index] =
                    ui.lobby.sanitize_special_infected_announcement_template(
                        proposed_text
                    )

                template_text =
                    tostring(
                        ui.lobby.special_infected_announce_templates[index]
                        or ""
                    )

                if template_text == "" then
                    ui.lobby.special_infected_announce_preferred[index] = false
                end

                ui.lobby.special_infected_announce_template =
                    tostring(
                        ui.lobby.special_infected_announce_templates[1]
                        or ""
                    )

                ui.lobby.reset_special_infected_announcement_cycle()
            end
        end

        imgui.same_line()
        ui.lobby.set_cursor_x(
            clear_x
        )

        if template_text ~= "" then
            if colored_button(
                "Clear##SpecialInfectedAnnouncement" ..
                    tostring(index),
                1.0, 1.0, 1.0,
                0.34, 0.12, 0.12
            ) then
                ui.lobby.special_infected_announce_templates[index] = ""
                ui.lobby.special_infected_announce_preferred[index] = false
                ui.lobby.reset_special_infected_announcement_cycle()
                template_text = ""
            end
        else
            disabled_button(
                "Clear##SpecialInfectedAnnouncement" ..
                    tostring(index)
            )
        end

        imgui.same_line()

        local character_count =
            #split_utf8_characters(
                template_text
            )

        local length_text =
            string.format(
                "Length: %d/%d",
                character_count,
                maximum_characters
            )

        if character_count >= maximum_characters then
            theme_text_colored(
                1.0, 0.20, 0.20, 1.0,
                length_text
            )
        else
            imgui.text(
                length_text
            )
        end
    end

    if #ui.lobby.special_infected_announce_templates <
        maximum_templates then

        if colored_button(
            "Add Field##SpecialInfectedAnnouncement",
            0.15, 1.0, 1.0,
            0.05, 0.28, 0.30
        ) then
            local restored_template = ""
            local restored_preferred = false

            if #ui.lobby.special_infected_removed_templates > 0 then
                restored_template =
                    tostring(
                        table.remove(
                            ui.lobby.special_infected_removed_templates
                        ) or ""
                    )

                restored_preferred =
                    table.remove(
                        ui.lobby.special_infected_removed_preferred
                    ) == true
            end

            if ui.lobby.get_preferred_special_infected_announcement_index() then
                restored_preferred = false
            end

            table.insert(
                ui.lobby.special_infected_announce_templates,
                restored_template
            )

            table.insert(
                ui.lobby.special_infected_announce_preferred,
                restored_preferred and restored_template ~= ""
            )

            ui.lobby.reset_special_infected_announcement_cycle()
        end
    else
        disabled_button(
            "Add Field##SpecialInfectedAnnouncement"
        )
    end

    imgui.same_line()

    if #ui.lobby.special_infected_announce_templates > 1 then
        if colored_button(
            "Remove Last Field##SpecialInfectedAnnouncement",
            1.0, 0.75, 0.20,
            0.32, 0.20, 0.04
        ) then
            table.insert(
                ui.lobby.special_infected_removed_templates,
                tostring(
                    table.remove(
                        ui.lobby.special_infected_announce_templates
                    ) or ""
                )
            )

            table.insert(
                ui.lobby.special_infected_removed_preferred,
                table.remove(
                    ui.lobby.special_infected_announce_preferred
                ) == true
            )

            ui.lobby.special_infected_announce_template =
                tostring(
                    ui.lobby.special_infected_announce_templates[1]
                    or ""
                )

            ui.lobby.normalize_special_infected_announcement_templates()
            ui.lobby.reset_special_infected_announcement_cycle()
        end
    else
        disabled_button(
            "Remove Last Field##SpecialInfectedAnnouncement"
        )
    end

    theme_text_colored(
        0.65, 0.65, 0.65, 1.0,
        "Use {player} and {class}. Select one message to keep it fixed; select none to shuffle."
    )

    draw_compact_gap()

    ui.draw_theme_table_header_text(
        "PREVIEWS & CLASS COMMANDS"
    )

    imgui.separator()

    local changed_bot_alerts,
        bot_alerts_value =
            imgui.checkbox(
                "Bot class alerts",
                ui.lobby.special_infected_bot_announcements == true
            )

    if changed_bot_alerts then
        ui.lobby.special_infected_bot_announcements =
            bot_alerts_value == true
    end

    imgui.text("Player preview:")
    imgui.same_line()
    ui.draw_theme_accent_text(
        ui.lobby.build_special_infected_announcement(
            "Ghost",
            "Smoker",
            ui.lobby.get_special_infected_preview_template()
        )
    )

    imgui.text("Bot preview:")
    imgui.same_line()

    if ui.lobby.special_infected_bot_announcements == true then
        ui.draw_theme_accent_text(
            ui.lobby.build_bot_special_infected_announcement(
                "Smoker"
            )
        )
    else
        theme_text_colored(
            0.60, 0.60, 0.62, 1.0,
            "Disabled"
        )
    end

    draw_compact_gap()

    imgui.text("Owner class-command replies:")
    imgui.same_line()
    imgui.push_item_width(90)

    local neutral_owner_route_colors =
        push_neutral_combo_colors()

    local changed_owner_route,
        owner_route_value =
            imgui.combo(
                "##LobbyZombieClassOwnerRoute",
                ui.lobby.zombieclass_owner_route,
                ui.lobby.zombieclass_owner_routes
            )

    pop_neutral_combo_colors(
        neutral_owner_route_colors
    )

    imgui.pop_item_width()

    if changed_owner_route then
        ui.lobby.zombieclass_owner_route =
            math.max(
                0,
                math.min(
                    1,
                    math.floor(
                        tonumber(owner_route_value) or 1
                    )
                )
            )
    end

    theme_text_colored(
        0.65, 0.65, 0.65, 1.0,
        "Your replies use this chat; other users stay in Infected team chat."
    )

    theme_text_colored(
        0.65, 0.65, 0.65, 1.0,
        "Exact classes require a verified spawn or ghost assignment."
    )

    draw_compact_gap()

    if not ui.lobby.is_connected_to_server() then
        ui.draw_theme_accent_text(
            "NEXT CLASS PREDICTION"
        )

        theme_text_colored(
            0.70, 0.70, 0.72, 1.0,
            "Waiting for a server connection."
        )
    else
        ui.lobby.draw_next_infected_class_prediction_table()
    end

end

function ui.lobby.draw()
