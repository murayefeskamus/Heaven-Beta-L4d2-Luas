    return true
end

function ui.heaven_configs.config_hotkey_process_queued_load()
    local service =
        ui.heaven_configs.config_hotkey_hotkey_service

    if type(service) ~= "table"
        or tostring(service.pending_kind or "") == "" then

        return false
    end

    local now = get_time()

    if now <
        (tonumber(service.pending_at) or 0.0) then

        return false
    end

    local kind =
        tostring(service.pending_kind or "")
    local slot_index =
        math.floor(
            tonumber(service.pending_slot) or 0
        )
    local source =
        tostring(service.pending_source or "hotkey")

    service.pending_kind = ""
    service.pending_slot = 0
    service.pending_source = ""
    service.pending_at = 0.0
    service.last_load_at = now

    if kind == "cycle" then
        return ui.heaven_configs.cycle_next_enabled_config()
    end

    if kind == "slot"
        and slot_index > 0 then

        return ui.heaven_configs.apply_slot(
            slot_index,
            source
        )
    end

    return false
end

ui.heaven_configs.config_hotkey_previous_update_hotkeys =
    ui.heaven_configs.update_hotkeys

function ui.heaven_configs.update_hotkeys()
    if ui.input_safety.block_runtime_hotkeys() then
        for index = 1,
            math.max(
                1,
                math.floor(
                    tonumber(ui.heaven_configs.max_slots) or 10
                )
            ) do

            ui.heaven_configs.hotkey_was_down[index] = false
        end

        ui.heaven_configs.cycle_key_was_down = false
        return
    end

    if type(input) ~= "table" then
        return
    end

    if type(input.is_key_down) ~= "function"
        and type(input.is_key_pressed) ~= "function" then

        return
    end

    ui.heaven_configs.normalize_settings()

    local blocked =
        ui.heaven_configs.enabled ~= true
        or ui.heaven_configs.waiting_for_key_slot > 0
        or ui.heaven_configs.waiting_for_cycle_key == true
        or (
            type(ui.window_hotkeys) == "table"
            and tostring(
                ui.window_hotkeys.waiting_target
                or ""
            ) ~= ""
        )
        or ui.control.waiting_for_key == true
        or ui.control.waiting_for_pursuit_key == true
        or ui.control.waiting_for_toggle_key == true

    local now = get_time()

    if ui.heaven_configs.use_cycle_key == true then
        local key_value =
            math.floor(
                tonumber(
                    ui.heaven_configs.cycle_key
                ) or 0
            )

        local is_down,
            pressed =
                ui.heaven_configs.config_hotkey_read_key_state(
                    key_value,
                    ui.heaven_configs.cycle_key_was_down
                )

        if blocked then
            ui.heaven_configs.cycle_key_was_down = is_down
            return
        end

        if key_value > 0
            and pressed == true
            and now >=
                (tonumber(ui.heaven_configs.next_switch_time) or 0.0)
            and not ui.heaven_configs.reserved_key_reason(
                key_value
            ) then

            ui.heaven_configs.cycle_key_was_down = true
            ui.heaven_configs.next_switch_time =
                now +
                math.max(
                    0.10,
                    tonumber(ui.heaven_configs.switch_cooldown) or 0.35
                )

            ui.heaven_configs.config_hotkey_queue_cycle_load(
                "cycle key"
            )
        else
            ui.heaven_configs.cycle_key_was_down = is_down
        end

        return
    end

    for index = 1,
        ui.heaven_configs.max_slots do

        local slot =
            ui.heaven_configs.slots[index]

        local key_value =
            slot
            and math.floor(
                tonumber(slot.key) or 0
            )
            or 0

        local is_down,
            pressed =
                ui.heaven_configs.config_hotkey_read_key_state(
                    key_value,
                    ui.heaven_configs.hotkey_was_down[index]
                )

        if blocked then
            ui.heaven_configs.hotkey_was_down[index] = is_down
        elseif slot
            and slot.enabled == true
            and key_value > 0
            and pressed == true
            and now >=
                (tonumber(ui.heaven_configs.next_switch_time) or 0.0)
            and ui.heaven_configs.clean_config_name(
                slot.config_name
            ) ~= ""
            and not ui.heaven_configs.reserved_key_reason(
                key_value
            ) then

            ui.heaven_configs.hotkey_was_down[index] = true
            ui.heaven_configs.next_switch_time =
                now +
                math.max(
                    0.10,
                    tonumber(ui.heaven_configs.switch_cooldown) or 0.35
                )

            ui.heaven_configs.config_hotkey_queue_slot_load(
                index,
                "hotkey"
            )

            return
        else
            ui.heaven_configs.hotkey_was_down[index] = is_down
        end
    end
end

function ui.heaven_configs.config_hotkey_pump_hotkey_service()
    if type(ui.heaven_configs) ~= "table" then
        return
    end

    local service =
        ui.heaven_configs.config_hotkey_hotkey_service

    if type(service) ~= "table" then
