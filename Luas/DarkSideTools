ui.setting_search.exact_stop_words = {
    ["a"] = true,
    ["an"] = true,
    ["and"] = true,
    ["the"] = true,
    ["to"] = true,
    ["for"] = true,
    ["of"] = true,
    ["in"] = true,
    ["on"] = true,
    ["off"] = true,
    ["with"] = true,
    ["setting"] = true,
    ["settings"] = true,
    ["control"] = true,
    ["controls"] = true,
    ["button"] = true,
    ["field"] = true,
    ["fields"] = true
}

function ui.setting_search.meaningful_tokens(value)
    local result = {}
    local seen = {}

    for token in ui.setting_search.normalize(value):gmatch("%S+") do
        if #token >= 2
            and ui.setting_search.exact_stop_words[token] ~= true
            and seen[token] ~= true then

            result[#result + 1] = token
            seen[token] = true
        end
    end

    return result
end

function ui.setting_search.item_match_score(label)
    local visible = ui.setting_search.visible_item_label(label)
    local candidate = ui.setting_search.normalize(visible)
    local target = ui.setting_search.normalize(
        ui.setting_search.exact_scroll_term
    )

    if candidate == "" or target == "" then
        return 0
    end

    if candidate == target then
        return 100
    end

    if #candidate >= 4 then
        if target:find(candidate, 1, true) == 1
            or candidate:find(target, 1, true) == 1 then

            return 94
        end

        if target:find(candidate, 1, true)
            or candidate:find(target, 1, true) then

            return 88
        end
    end

    local target_tokens =
        ui.setting_search.meaningful_tokens(target)
    local candidate_tokens =
        ui.setting_search.meaningful_tokens(candidate)

    if #target_tokens == 0 or #candidate_tokens == 0 then
        return 0
    end

    local candidate_lookup = {}
    for _, token in ipairs(candidate_tokens) do
        candidate_lookup[token] = true
    end

    local matches = 0
    for _, token in ipairs(target_tokens) do
        if candidate_lookup[token] then
            matches = matches + 1
        end
    end

    if matches == 0 then
        return 0
    end

    local target_coverage = matches / #target_tokens
    local candidate_coverage = matches / #candidate_tokens

    if target_coverage >= 0.75 and candidate_coverage >= 0.60 then
        return 84
    end

    if matches >= 2
        and target_coverage >= 0.60
        and candidate_coverage >= 0.50 then

        return 80
    end

    return 0
end

function ui.setting_search.scroll_current_item_to_view()
    local scrolled = false

    if type(imgui.set_scroll_here_y) == "function" then
        local ok = pcall(imgui.set_scroll_here_y, 0.12)
        scrolled = ok == true
    elseif type(imgui.set_scroll_here) == "function" then
        local ok = pcall(imgui.set_scroll_here, 0.12)
        scrolled = ok == true
    end

    return scrolled
end

function ui.setting_search.observe_rendered_item(label)
    if ui.setting_search.exact_observer_guard == true
        or ui.setting_search.exact_scroll_pending ~= true
        or ui.setting_search.rendering_exact_target_section ~= true then

        return false
    end

    local score = ui.setting_search.item_match_score(label)
    if score < 80 then
        return false
    end

    ui.setting_search.exact_observer_guard = true
    local scrolled = ui.setting_search.scroll_current_item_to_view()
    ui.setting_search.exact_observer_guard = false

    if scrolled then
        ui.setting_search.exact_scroll_pending = false
        ui.setting_search.exact_scroll_found = true
        ui.setting_search.exact_scroll_attempts = 0
        return true
    end

    return false
end

function ui.setting_search.install_exact_item_observers()
    if ui.setting_search.exact_observers_installed == true then
        return
    end

    ui.setting_search.exact_observers_installed = true
    ui.setting_search.exact_original_imgui =
        type(ui.setting_search.exact_original_imgui) == "table"
        and ui.setting_search.exact_original_imgui
        or {}

    local observed_methods = {
        "text",
        "button",
        "checkbox",
        "combo",
        "input_text",
        "input_text_multiline",
        "slider_int",
        "slider_float",
        "drag_int",
        "drag_float",
        "radio_button",
        "selectable",
        "color_edit3",
        "color_edit4"
    }

    for _, method_name in ipairs(observed_methods) do
        local original_method = imgui[method_name]

        if type(original_method) == "function"
            and ui.setting_search.exact_original_imgui[method_name] == nil then

            ui.setting_search.exact_original_imgui[method_name] =
                original_method

            local wrapped_method = function(...)
                local arguments = { ... }
                local packed_results =
                    ui.setting_search.exact_pack(
                        original_method(...)
                    )

                ui.setting_search.observe_rendered_item(
                    arguments[1]
                )

                return ui.setting_search.exact_unpack(
                    packed_results,
                    1,
                    packed_results.n
                )
            end

            pcall(function()
                imgui[method_name] = wrapped_method
            end)
        end
    end
end

