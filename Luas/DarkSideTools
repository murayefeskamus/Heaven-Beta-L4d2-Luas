function ui.lobby.rebuild_overview()
    local map_code =
        ui.lobby.get_map_code()

    local overview = {
        server =
            ui.network.get_server_display_address(
                ui.lobby.last_server_address ~= ""
                and ui.lobby.last_server_address
                or "Connected server"
            ),
        map =
            ui.lobby.get_map_name(
                map_code
            ),
        map_code = map_code,
        mode =
            ui.lobby.get_game_mode(),
        difficulty =
            ui.lobby.get_difficulty(),
        show_difficulty = true,
        show_teams = false,
        total = 0,
        humans = 0,
        bots = 0,
        spectators = 0,
        survivors = 0,
        infected = 0,
        human_spectators = 0,
        human_survivors = 0,
        human_infected = 0,
        bot_spectators = 0,
        bot_survivors = 0,
        bot_infected = 0,
        alive = 0,
        dead = 0,
        bot_alive = 0,
        bot_dead = 0,
        team_counts = {},
        team_breakdown = {},
        infected_classes = {}
    }

    for _, player_record in ipairs(
        ui.lobby.players
    ) do
        overview.total =
            overview.total + 1

        if player_record.is_bot then
            overview.bots =
                overview.bots + 1
        else
            overview.humans =
                overview.humans + 1
        end

        if player_record.team == 1 then
            overview.spectators =
                overview.spectators + 1

            if player_record.is_bot then
                overview.bot_spectators =
                    overview.bot_spectators + 1
            else
                overview.human_spectators =
                    overview.human_spectators + 1
            end
        elseif player_record.team == 2 then
            overview.survivors =
                overview.survivors + 1

            if player_record.is_bot then
                overview.bot_survivors =
                    overview.bot_survivors + 1
            else
                overview.human_survivors =
                    overview.human_survivors + 1
            end
        elseif player_record.team == 3 then
            overview.infected =
                overview.infected + 1

            if player_record.is_bot then
                overview.bot_infected =
                    overview.bot_infected + 1
            else
                overview.human_infected =
                    overview.human_infected + 1
            end
        end

        overview.team_counts[
            player_record.team_name
        ] =
            (
                overview.team_counts[
                    player_record.team_name
                ] or 0
            ) + 1

        if not overview.team_breakdown[
            player_record.team_name
        ] then
            overview.team_breakdown[
                player_record.team_name
            ] = {
                humans = 0,
                bots = 0,
                alive = 0,
                dead = 0,
                kills = 0,
                special_kills = 0,
                common_kills = 0,
                tank_kills = 0,
                witch_kills = 0,
                deaths = 0
            }
        end

        local team_summary =
            overview.team_breakdown[
                player_record.team_name
            ]

        if player_record.is_bot then
            team_summary.bots =
                team_summary.bots + 1
        else
            team_summary.humans =
                team_summary.humans + 1
        end

        team_summary.kills =
            team_summary.kills +
            (player_record.kills or 0)

        team_summary.special_kills =
            (team_summary.special_kills or 0) +
            (player_record.special_kills or 0)

        team_summary.common_kills =
            (team_summary.common_kills or 0) +
            (player_record.common_kills or 0)

        team_summary.tank_kills =
            (team_summary.tank_kills or 0) +
            (player_record.tank_kills or 0)

        team_summary.witch_kills =
            (team_summary.witch_kills or 0) +
            (player_record.witch_kills or 0)

        team_summary.deaths =
            team_summary.deaths +
            (player_record.deaths or 0)

        if player_record.alive == true then
            team_summary.alive =
                team_summary.alive + 1

            if player_record.is_bot then
                overview.bot_alive =
                    overview.bot_alive + 1
            else
                overview.alive =
                    overview.alive + 1
            end
        elseif player_record.alive == false then
            team_summary.dead =
                team_summary.dead + 1

            if player_record.is_bot then
                overview.bot_dead =
                    overview.bot_dead + 1
            else
                overview.dead =
                    overview.dead + 1
            end
        end

        if player_record.team == 3 then
            overview.infected_classes[
                player_record.class_name
            ] =
                (
                    overview.infected_classes[
                        player_record.class_name
                    ] or 0
                ) + 1
        end
    end

    overview.show_teams =
        ui.lobby.mode_allows_infected(
            overview.mode
        )
        or overview.human_infected > 0

    overview.show_difficulty =
        not overview.show_teams

    ui.lobby.overview =
        overview
end

function ui.lobby.refresh(
    force
)
    force =
        force == true

    if not is_game_ready() then
        ui.lobby.history = {}
        ui.lobby.clear_logs_confirmation = false

        ui.lobby.connected = false
        ui.lobby.last_server_address = ""
        ui.lobby.players = {}
        ui.lobby.players_by_key = {}
        ui.lobby.recent_damage_events = {}
        ui.lobby.last_weapon_by_player = {}
        ui.lobby.infected_spawn_scan_states = {}
        ui.lobby.infected_spawn_scan_next = 0.0
        ui.lobby.selected_key = ""
        ui.lobby.last_refresh_time = 0.0
        ui.lobby.force_refresh = true

        ui.lobby.overview = {
            server = "Not connected",
            map = "Unavailable",
            map_code = "Unavailable",
            mode = "Unavailable",
            difficulty = "Unavailable",
            show_difficulty = true,
            show_teams = false,
            total = 0,
            humans = 0,
            bots = 0,
            spectators = 0,
            survivors = 0,
            infected = 0,
            human_spectators = 0,
            human_survivors = 0,
            human_infected = 0,
            bot_spectators = 0,
            bot_survivors = 0,
            bot_infected = 0,
            alive = 0,
            dead = 0,
            bot_alive = 0,
            bot_dead = 0,
            team_counts = {},
            team_breakdown = {},
            infected_classes = {}
        }

        return false
    end

    local now =
        get_time()

    if not force
        and not ui.lobby.force_refresh
        and now -
            ui.lobby.last_refresh_time
            < ui.lobby.refresh_interval then

        return false
    end

    local server_address =
        get_server_address()

    if server_address == "" then
        server_address =
            "CONNECTED SERVER"
    end

    local entered_new_server =
        not ui.lobby.connected
        or ui.lobby.last_server_address
            ~= server_address

    if entered_new_server then
        ui.lobby.connected = true
        ui.lobby.last_server_address =
            server_address

        ui.lobby.session_started_at =
            now

        ui.lobby.players = {}
        ui.lobby.players_by_key = {}
        ui.lobby.activity_cache = {}
        ui.lobby.recent_deaths = {}
        ui.lobby.recent_boss_kills = {}
        ui.lobby.recent_damage_events = {}
        ui.lobby.last_weapon_by_player = {}
        ui.lobby.pending_chat_messages = {}
        ui.lobby.next_chat_send_time = 0.0
        ui.lobby.infected_spawn_scan_states = {}
        ui.lobby.infected_spawn_scan_next = 0.0
        ui.lobby.selected_key = ""
        ui.lobby.history = {}
        ui.lobby.clear_logs_confirmation = false

        ui.lobby.add_history(
            "SERVER",
            "Joined server: " ..
                tostring(server_address)
        )
    end

    local old_players_by_key =
        ui.lobby.players_by_key

    local refreshed_players = {}
    local refreshed_by_key = {}

    local max_clients =
        tonumber(
            engine.get_max_clients()
        ) or 0

    for player_index = 1,
        max_clients do

        local player =
            entity.get_by_index(
                player_index
            )

        if player then
            local player_record =
                ui.lobby.build_player_record(
                    player_index,
                    player,
                    now
                )

            if player_record then
                local old_record =
                    old_players_by_key[
                        player_record.key
                    ]

                local cached_activity =
                    ui.lobby.find_cached_activity_for_record(
                        player_record
                    )

                if old_record then
                    player_record.first_seen =
                        old_record.first_seen
                        or now

                    player_record.chat_messages =
                        old_record.chat_messages
                        or 0

                    player_record.kills =
                        old_record.kills
                        or 0

                    player_record.deaths =
                        old_record.deaths
                        or 0

                    player_record.common_kills =
                        old_record.common_kills
                        or 0

                    player_record.special_kills =
                        old_record.special_kills
                        or 0

                    player_record.tank_kills =
                        old_record.tank_kills
                        or 0

                    player_record.witch_kills =
                        old_record.witch_kills
                        or 0

                    player_record.weapon_kills =
                        ui.lobby.merge_counter_totals(
                            player_record.weapon_kills,
                            old_record.weapon_kills
                        )

                    if cached_activity then
                        player_record.weapon_kills =
                            ui.lobby.merge_counter_totals(
                                player_record.weapon_kills,
                                cached_activity.weapon_kills
                            )
                    end

                    player_record.si_damage_by_class =
                        old_record.si_damage_by_class
                        or {}

                    player_record.si_damage_total =
                        old_record.si_damage_total
                        or 0

                    player_record.reconnects =
                        old_record.reconnects
                        or 0

                    player_record.name_changes =
                        old_record.name_changes
                        or 0

                    player_record.name_history =
                        old_record.name_history
                        or {}

                    if player_record.health == nil
                        and old_record.health ~= nil then

                        player_record.health =
                            old_record.health
                    end

                    if old_record.name
                        ~= player_record.name then

                        ui.lobby.record_name_change(
                            player_record,
                            old_record.name,
                            player_record.name,
                            now
                        )
                    end

                    if old_record.team
                        ~= player_record.team then

                        ui.lobby.add_history(
                            "TEAM",
                            tostring(
                                player_record.name
                            ) ..
                                " moved from " ..
                                tostring(
                                    old_record.team_name
                                ) ..
                                " to " ..
                                tostring(
                                    player_record.team_name
                                )
                        )
                    end
                elseif cached_activity then
                    local recent_death_time =
                        player_record.userid > 0
                        and ui.lobby.recent_deaths[
                            player_record.userid
                        ]
                        or nil

                    local returned_after_death =
                        cached_activity.temporary_death == true

                    player_record.first_seen =
                        cached_activity.first_seen
                        or now

                    player_record.chat_messages =
                        cached_activity.chat_messages
                        or 0

                    player_record.kills =
                        cached_activity.kills
                        or 0

                    player_record.deaths =
                        cached_activity.deaths
                        or 0

                    player_record.common_kills =
                        cached_activity.common_kills
                        or 0

                    player_record.special_kills =
                        cached_activity.special_kills
                        or 0

                    player_record.tank_kills =
                        cached_activity.tank_kills
                        or 0

                    player_record.witch_kills =
                        cached_activity.witch_kills
                        or 0

                    player_record.weapon_kills =
                        ui.lobby.merge_counter_totals(
                            player_record.weapon_kills,
                            cached_activity.weapon_kills
                        )

                    player_record.si_damage_by_class =
                        cached_activity.si_damage_by_class
                        or {}

                    player_record.si_damage_total =
                        cached_activity.si_damage_total
                        or 0

                    player_record.name_changes =
                        cached_activity.name_changes
                        or 0

                    player_record.name_history =
                        cached_activity.name_history
                        or {}

                    if cached_activity.last_name
                        and tostring(cached_activity.last_name) ~= ""
                        and tostring(cached_activity.last_name) ~=
                            tostring(player_record.name) then

                        ui.lobby.record_name_change(
                            player_record,
                            cached_activity.last_name,
                            player_record.name,
                            now
                        )
                    end

                    if player_record.health == nil
                        and cached_activity.health ~= nil then

                        player_record.health =
                            cached_activity.health
                    end

                    if returned_after_death then
                        player_record.reconnects =
                            cached_activity.reconnects
                            or 0
                    elseif player_record.is_bot then
                        player_record.first_seen = now
                        player_record.reconnects = 0

                        ui.lobby.add_history(
                            "SPAWN",
                            tostring(
                                player_record.name
                            ) ..
                                " [BOT] spawned"
                        )
                    else
                        player_record.first_seen = now

                        player_record.reconnects =
                            (
                                cached_activity.reconnects
                                or 0
                            ) + 1

                        ui.lobby.add_history(
                            "RECONNECT",
                            tostring(
                                player_record.name
                            ) ..
                                " reconnected"
                        )
                    end
                else
                    local new_event_type =
                        entered_new_server
                        and "DETECTED"
                        or (
                            player_record.is_bot
                            and "SPAWN"
                            or "JOIN"
                        )

                    local new_event_suffix =
                        entered_new_server
                        and " detected"
                        or (
                            player_record.is_bot
                            and " [BOT] spawned"
                            or " joined"
                        )

                    ui.lobby.add_history(
                        new_event_type,
                        tostring(
                            player_record.name
                        ) ..
                            new_event_suffix
                    )
                end

                local active_weapon_identifier =
                    ui.lobby.get_active_weapon_identifier(
                        player_record
                    )

                if active_weapon_identifier then
                    ui.lobby.remember_player_weapon(
                        player_record,
                        active_weapon_identifier
                    )
                end

                refreshed_by_key[
                    player_record.key
                ] =
                    player_record

                table.insert(
                    refreshed_players,
                    player_record
                )

                ui.lobby.activity_cache[
                    player_record.key
                ] = {
                    userid =
                        player_record.userid,
                    is_bot =
                        player_record.is_bot == true,
                    first_seen =
                        player_record.first_seen,
                    chat_messages =
                        player_record.chat_messages,
                    kills =
                        player_record.kills,
                    deaths =
                        player_record.deaths,
                    common_kills =
                        player_record.common_kills,
                    special_kills =
                        player_record.special_kills,
                    tank_kills =
                        player_record.tank_kills,
                    witch_kills =
                        player_record.witch_kills,
                    weapon_kills =
                        player_record.weapon_kills,
                    si_damage_by_class =
                        player_record.si_damage_by_class,
                    si_damage_total =
                        player_record.si_damage_total,
                    reconnects =
                        player_record.reconnects,
                    name_changes =
                        player_record.name_changes,
                    name_history =
                        player_record.name_history,
                    health =
                        player_record.health,
                    last_name =
                        player_record.name,
                    last_left = nil,
                    temporary_death = false
                }
            end
        end
    end

    for old_key, old_record in pairs(
        old_players_by_key
    ) do
        if not refreshed_by_key[
            old_key
        ] then

            local recent_death_time =
                old_record.userid > 0
                and ui.lobby.recent_deaths[
                    old_record.userid
                ]
                or nil

            local temporary_death =
                recent_death_time ~= nil
                and now - recent_death_time
                    <= ui.lobby.recent_death_window

            if not temporary_death then
                if old_record.is_bot then
                    ui.lobby.add_history(
                        "DESPAWN",
                        tostring(
                            old_record.name
                        ) ..
                            " [BOT] despawned"
                    )
                else
                    ui.lobby.add_history(
                        "LEAVE",
                        tostring(
                            old_record.name
                        ) ..
                            " left"
                    )
                end
            end

            ui.lobby.activity_cache[
                old_key
            ] = {
                userid =
                    old_record.userid,
                is_bot =
                    old_record.is_bot == true,
                first_seen =
                    old_record.first_seen
                    or now,
                chat_messages =
                    old_record.chat_messages
                    or 0,
                kills =
                    old_record.kills
                    or 0,
                deaths =
                    old_record.deaths
                    or 0,
                common_kills =
                    old_record.common_kills
                    or 0,
                special_kills =
                    old_record.special_kills
                    or 0,
                tank_kills =
                    old_record.tank_kills
                    or 0,
                witch_kills =
                    old_record.witch_kills
                    or 0,
                weapon_kills =
                    old_record.weapon_kills
                    or {},
                si_damage_by_class =
                    old_record.si_damage_by_class
                    or {},
                si_damage_total =
                    old_record.si_damage_total
                    or 0,
                reconnects =
                    old_record.reconnects
                    or 0,
                name_changes =
                    old_record.name_changes
                    or 0,
                name_history =
                    old_record.name_history
                    or {},
                health =
                    old_record.health,
                last_name =
                    old_record.name,
                last_left =
                    temporary_death
                    and nil
                    or now,
                temporary_death =
                    temporary_death
            }
        end
    end

    for userid, death_time in pairs(
        ui.lobby.recent_deaths
    ) do
        if now - death_time
            > ui.lobby.recent_death_window * 2 then

            ui.lobby.recent_deaths[
                userid
            ] = nil
        end
    end

    table.sort(
        refreshed_players,
        function(a, b)
            return a.entity_index
                < b.entity_index
        end
    )

    ui.lobby.players =
        refreshed_players

    ui.lobby.players_by_key =
        refreshed_by_key

    if ui.lobby.selected_key ~= ""
        and not refreshed_by_key[
            ui.lobby.selected_key
        ] then

        ui.lobby.selected_key = ""
    end

    if ui.lobby.selected_key == ""
        and refreshed_players[1] then

        ui.lobby.selected_key =
            refreshed_players[1].key
    end

    ui.lobby.rebuild_overview()

    ui.lobby.last_refresh_time =
        now

    ui.lobby.force_refresh = false

    return true
end

