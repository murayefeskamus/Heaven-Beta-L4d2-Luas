        tostring(case_index) ..
        "|" ..
        tostring(shape_index)

    if force_refresh ~= true
        and preview_key ==
            name_reverser.case_shape_preview_key
        and name_reverser.case_shape_preview ~= "" then

        return name_reverser.case_shape_preview,
            nil
    end

    local case_result =
        source_name

    if case_index == 1 then
        case_result =
            source_name:upper()
    elseif case_index == 2 then
        case_result =
            source_name:lower()
    elseif case_index == 3 then
        case_result =
            alternating_case_text(
                source_name,
                true
            )
    elseif case_index == 4 then
        case_result =
            alternating_case_text(
                source_name,
                false
            )
    end

    local shape_result =
        case_result

    if shape_index == 1 then
        shape_result =
            reverse_utf8_text(
                case_result
            )
    elseif shape_index == 2 then
        shape_result =
            shuffle_name_text(
                case_result
            )
    elseif shape_index == 3 then
        shape_result =
            build_palindrome_name(
                case_result
            )

        if not shape_result then
            name_reverser.case_shape_preview_key =
                preview_key

            name_reverser.case_shape_preview = ""
            name_reverser.case_shape_preview_error =
                "Palindrome is too long."

            return nil,
                name_reverser.case_shape_preview_error
        end
    end

    local fitted_result =
        select(
            1,
            fit_name_for_application(
                shape_result
            )
        )

    if fitted_result == "" then
        name_reverser.case_shape_preview_key =
            preview_key

        name_reverser.case_shape_preview = ""
        name_reverser.case_shape_preview_error =
            "The result is empty."

        return nil,
            name_reverser.case_shape_preview_error
    end

    name_reverser.case_shape_preview_key =
        preview_key

    name_reverser.case_shape_preview =
        fitted_result

    name_reverser.case_shape_preview_error = ""

    return fitted_result,
        nil
end

function name_reverser.build_name_workshop_metadata(
    action_label,
    fitted_name,
    generated_by_decoration
)
    local label =
        tostring(
            action_label or "Name applied"
        )

    local metadata = {
        style = "Horizontal",
        case_label = "Original",
        shape_label = "Original",
        decoration_label = nil,
        source = "Name Workshop"
    }

    if fitted_name ==
        DARKSIDE_CONFIG.INVISIBLE_NAME then

        metadata.style = "Invisible"
        metadata.case_label = "N/A"
        metadata.shape_label = "N/A"
        metadata.decoration_label = "None"

        return metadata
    end

    if label == "Case and shape" then
        metadata.case_label =
            tostring(
                name_reverser.case_modes[
                    name_reverser.case_selection + 1
                ] or "Original"
            )

        metadata.shape_label =
            tostring(
                name_reverser.shape_modes[
                    name_reverser.shape_selection + 1
                ] or "Original"
            )
    elseif label:find(
        "Revers",
        1,
        true
    ) then
        metadata.shape_label = "Reverse"
    elseif label:find(
        "Palindrome",
        1,
        true
    ) then
        metadata.shape_label = "Palindrome"
    elseif label:find(
        "Shuff",
        1,
        true
    ) then
        metadata.shape_label = "Shuffle"
    elseif label:find(
        "Alternating case",
        1,
        true
    ) then
        metadata.case_label =
            name_reverser.infer_name_case_label(
                fitted_name
            )
    end

    local decoration_prefix = "Decoration "

    if label == "Decoration removed" then
        metadata.decoration_label = "None"
    elseif label:sub(
        1,
        #decoration_prefix
    ) == decoration_prefix then

        metadata.decoration_label =
            label:sub(
                #decoration_prefix + 1
            )
    end

    local roulette_prefix = "Roulette "

    if label:sub(
        1,
        #roulette_prefix
    ) == roulette_prefix then

        local roulette_label =
            label:sub(
                #roulette_prefix + 1
            )

        if roulette_label == "Reverse" then
            metadata.shape_label = "Reverse"
        elseif roulette_label == "Alternating case" then
            metadata.case_label =
                name_reverser.infer_name_case_label(
                    fitted_name
                )
        elseif roulette_label == "Palindrome" then
            metadata.shape_label = "Palindrome"
        elseif roulette_label == "Shuffle" then
            metadata.shape_label = "Shuffle"
        else
            metadata.decoration_label =
                roulette_label
        end
    end

    if generated_by_decoration == true
        or metadata.decoration_label == nil then

        local detected_decoration =
            name_reverser.get_known_name_decoration_label(
                fitted_name
            )

        if detected_decoration ~= "None" then
            metadata.decoration_label =
                detected_decoration
        end
    end

    return metadata
end

function apply_name_workshop_result(
    result_name,
    action_label,
    source_name,
    skip_history,
    generated_by_decoration
)
    capture_initial_in_game_name()

    if not engine.is_in_game()
        or not engine.is_connected() then

        set_name_workshop_status(
            "Waiting for game"
        )

        ui.console.print(
            "[Name Workshop] Not connected to a game."
        )

        return false,
            nil
    end

    local fitted_name,
        was_truncated =
            fit_name_for_application(
                result_name
            )

    if fitted_name == "" then
        set_name_workshop_status(
            "Invalid empty result"
        )

        ui.console.print(
            "[Name Workshop] The transformed name is empty."
        )

        return false,
            nil
    end

    if generated_by_decoration == true then
        name_stealer.remember_lua_decorated_name(
            fitted_name
        )
    end

    local final_name =
        build_spoofed_name(
            fitted_name
        )

    if not final_name then
        set_name_workshop_status(
            "Could not build name"
        )

        return false,
            nil
    end

    stop_name_spammer()

    spammer_runtime.remember_requested_name(
        fitted_name,
        final_name
    )

    spammer_runtime.set_current_name_metadata(
        fitted_name,
        name_reverser.build_name_workshop_metadata(
            action_label,
            fitted_name,
            generated_by_decoration
        )
    )

    client.execnormal(
        'setinfo name "' ..
        final_name ..
        '"'
    )

    name_reverser.last_source =
        tostring(
            source_name or fitted_name
        )

    name_reverser.last_result =
        fitted_name

    local status_message =
        tostring(
            action_label or "Name applied"
        ) ..
        ": " ..
        fitted_name

    if was_truncated then
        status_message =
            status_message ..
            " (trimmed)"
    end

    set_name_workshop_status(
        status_message
    )

    if skip_history ~= true then
        add_name_to_history(
            fitted_name
        )
    end

    name_stealer.total_changes =
        name_stealer.total_changes + 1

    name_stealer.status =
        name_stealer.enabled
        and "RUNNING"
        or "READY"

    if name_stealer.enabled then
        name_stealer.next_change_time =
            get_time() +
            name_stealer.change_delay
    end

    ui.console.print(
        "[Name Workshop] " ..
        status_message
    )

    return true,
        fitted_name
end

