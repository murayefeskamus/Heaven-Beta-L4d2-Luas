function ui.lobby.handle_zombieclass_command(
    userid,
    spoken_text
)
    spoken_text = tostring(spoken_text or "")

    local command,
        argument =
            spoken_text:match(
                "^%s*(![%w_]+)%s*(.-)%s*$"
            )

    if not command
        or command:lower() ~= "!class" then

        return false
    end

    local requester,
        local_record,
        owner_request,
        response_team_only =
            ui.lobby.get_zombieclass_command_context(
                userid
            )

    if not ui.lobby.zombieclass_command_access_allowed(
        userid,
        requester,
        local_record,
        owner_request,
        response_team_only
    ) then
        if owner_request then
            ui.console.print(
                "[Lobby & Network] Infected class information is still loading."
            )
        end

        return true
    end

    if ui.enhancements
        and type(
            ui.enhancements.command_allowed
        ) == "function"
        and not ui.enhancements.command_allowed(
            "zombieclass",
            userid,
            response_team_only
        ) then

        return true
    end

    argument = tostring(argument or ""):gsub(
        "^%s+",
        ""
    ):gsub(
        "%s+$",
        ""
    )

    local target = requester

    if argument ~= "" then
        if argument:sub(1, 1) ~= "@" then
            ui.lobby.queue_zombieclass_messages({
                "Usage: !class or !class @name/@UserID"
            }, response_team_only)

            return true
        end

        local target_query =
            argument:sub(2):gsub(
                "^%s+",
                ""
            ):gsub(
                "%s+$",
                ""
            )

        if target_query == "" then
            ui.lobby.queue_zombieclass_messages({
                "Usage: !class or !class @name/@UserID"
            }, response_team_only)

            return true
        end

        target =
            ui.lobby.find_player_for_command(
                target_query,
                requester or local_record
            )
    end

    if not target then
        ui.lobby.queue_zombieclass_messages({
            "Infected player not found."
        }, response_team_only)

        return true
    end

    if tonumber(target.team) ~= 3 then
        ui.lobby.queue_zombieclass_messages({
            tostring(target.name) ..
                " is not on the Infected team."
        }, response_team_only)

        return true
    end

    if not ui.lobby.queue_infected_class_query(
        userid,
        { target },
        "single",
        response_team_only
    ) then
        ui.lobby.queue_zombieclass_messages({
            "Infected class information is unavailable."
        }, response_team_only)
    end

    return true
end

