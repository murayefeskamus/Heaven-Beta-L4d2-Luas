function ui.heaven_configs.default_slot(
    index
)
    return {
        enabled = false,
        key = 0,
        config_name = ""
    }
end

function ui.heaven_configs.clean_config_name(
    value
)
    value =
        tostring(value or "")
        :gsub("[\r\n]", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
        :gsub("[\\/]", "")

    local lower_value =
        value:lower()

    if lower_value:sub(-4) == ".cfg" then
        value =
            value:sub(
                1,
                math.max(
                    0,
                    #value - 4
                )
            )
    end

    return value:sub(1, 128)
end

function ui.heaven_configs.visible_slot_count()
    local maximum_slots =
        math.max(
            1,
            math.floor(
                tonumber(
                    ui.heaven_configs.max_slots
                ) or 10
            )
        )

    local detected_count =
        type(ui.heaven_configs.detected_configs) == "table"
        and #ui.heaven_configs.detected_configs
        or 0

    return math.min(
        maximum_slots,
        math.max(
            0,
            detected_count
        )
    )
end

function ui.heaven_configs.configured_slot_count()
    local count = 0

    for index = 1,
        math.max(
            1,
            math.floor(
                tonumber(
                    ui.heaven_configs.max_slots
                ) or 10
            )
        ) do

        local slot =
            type(ui.heaven_configs.slots) == "table"
            and ui.heaven_configs.slots[index]
            or nil

        if slot
            and ui.heaven_configs.clean_config_name(
                slot.config_name
            ) ~= "" then

            count = count + 1
        end
    end

    return count
end

function ui.heaven_configs.active_config_count()
    local count = 0

    for index = 1,
        math.max(
            1,
            math.floor(
                tonumber(
                    ui.heaven_configs.max_slots
                ) or 10
            )
        ) do

        local slot =
            type(ui.heaven_configs.slots) == "table"
            and ui.heaven_configs.slots[index]
            or nil

        if slot
            and slot.enabled == true
            and ui.heaven_configs.clean_config_name(
                slot.config_name
            ) ~= "" then

            count = count + 1
        end
    end

    return count
end

function ui.heaven_configs.set_visible_slots_enabled(
    enabled
)
    local changed = false
    local visible_count =
        ui.heaven_configs.visible_slot_count()

    for index = 1, visible_count do
        local slot = ui.heaven_configs.slots[index]

        if slot then
            local has_config =
                ui.heaven_configs.clean_config_name(
                    slot.config_name
                ) ~= ""

            local next_enabled =
                enabled == true
                and has_config
                or false

            if slot.enabled ~= next_enabled then
                slot.enabled = next_enabled
                changed = true
            end
        end
    end

    if changed then
        ui.heaven_configs.save_settings_now()
    end

    return changed
end

function ui.heaven_configs.all_visible_slots_enabled()
    local visible_count =
        ui.heaven_configs.visible_slot_count()

    if visible_count <= 0 then
        return false
    end

    for index = 1, visible_count do
        local slot = ui.heaven_configs.slots[index]

        if not slot
            or slot.enabled ~= true
            or ui.heaven_configs.clean_config_name(
                slot.config_name
            ) == "" then

            return false
        end
    end

    return true
end

