function ui.network.get_field_definition(definitions, key)
    for _, definition in ipairs(
        type(definitions) == "table" and definitions or {}
    ) do
        if tostring(definition.key or "") ==
            tostring(key or "") then

            return definition
        end
    end

    return nil
end

function ui.network.draw_player_id_rows(
    detailed
)
    detailed = detailed == true

    ui.network.draw_section_title(
        "PLAYER IDs"
    )

    local function resolved_player_team(
        player_record
    )
        player_record =
            type(player_record) == "table"
            and player_record
            or {}

        local team_number =
            math.floor(
                tonumber(player_record.team) or 0
            )

        if team_number == 2
            or team_number == 3
            or team_number == 1 then

            return team_number
        end

        local team_name =
            tostring(
                player_record.team_name or ""
            ):lower()

        if team_name:find(
            "surviv",
            1,
            true
        ) then
            return 2
        elseif team_name:find(
            "infect",
            1,
            true
        ) then
            return 3
        elseif team_name:find(
            "spect",
            1,
            true
        ) then
            return 1
        end

        return 0
    end

    local function should_show_player_id(
        player_record
    )
        if type(player_record) ~= "table" then
            return false
        end

        if player_record.is_bot ~= true then
            return true
        end

        if player_record.alive == false then
            return false
        end

        local player_health =
            tonumber(player_record.health)

        if player_health ~= nil
            and player_health <= 0 then

            return false
        end

        return true
    end

    local player_signature_parts = {
        tostring(ui.lobby.last_refresh_time or 0),
        tostring(#(ui.lobby.players or {}))
    }

    for _, player_record in ipairs(
        ui.lobby.players or {}
    ) do
        player_signature_parts[#player_signature_parts + 1] =
            table.concat(
                {
                    tostring(player_record.userid or 0),
                    tostring(player_record.entity_index or 0),
                    tostring(resolved_player_team(player_record)),
                    player_record.is_bot == true and "1" or "0",
                    player_record.alive == false and "0" or "1",
                    tostring(player_record.health or ""),
                    tostring(player_record.name or "")
                },
                "|"
            )
    end

    local player_cache_key =
        table.concat(
            player_signature_parts,
            ";"
        )

    if ui.network.cached_player_rows_key ~= player_cache_key
        or type(ui.network.cached_player_rows) ~= "table" then

        local refreshed_rows = {}

        for _, player_record in ipairs(
            ui.lobby.players or {}
        ) do
            if should_show_player_id(
                player_record
            ) then

                refreshed_rows[#refreshed_rows + 1] =
                    player_record
            end
        end

        local function team_group_order(
            player_record
        )
            local team_number =
                resolved_player_team(
                    player_record
                )

            if team_number == 2 then
                return 1
            elseif team_number == 3 then
                return 2
            elseif team_number == 1 then
                return 3
            end

            return 4
        end

        table.sort(
            refreshed_rows,
            function(left, right)
                local left_group =
                    team_group_order(left)

                local right_group =
                    team_group_order(right)

                if left_group ~= right_group then
                    return left_group < right_group
                end

                local left_userid =
                    tonumber(left.userid) or 0

                local right_userid =
                    tonumber(right.userid) or 0

                if left_userid > 0
                    and right_userid > 0
                    and left_userid ~= right_userid then

                    return left_userid < right_userid
                end

                if (left_userid > 0) ~=
                    (right_userid > 0) then

                    return left_userid > 0
                end

                return (tonumber(left.entity_index) or 0) <
                    (tonumber(right.entity_index) or 0)
            end
        )

        ui.network.cached_player_rows =
            refreshed_rows

        ui.network.cached_player_rows_key =
            player_cache_key
    end

    local player_rows =
        ui.network.cached_player_rows

    local players_palette =
        ui.enhancements.theme_palette()

    if #player_rows == 0 then
        ui.network.draw_label_value(
            "Players",
            "None",
            players_palette.text_disabled[1],
            players_palette.text_disabled[2],
            players_palette.text_disabled[3]
        )

        return true
    end

    local default_player_color =
        players_palette.light == true
        and (
            players_palette.accent
            or players_palette.section_text
            or players_palette.text
        )
        or players_palette.text

    local survivor_color =
        { 0.35, 0.90, 1.00 }

    local infected_color =
        { 1.00, 0.30, 0.30 }

    local bot_color =
        players_palette.text_disabled
        or { 0.58, 0.58, 0.60 }

    local you_tag_color =
        players_palette.accent
        or players_palette.section_text
        or players_palette.text
        or { 1.00, 0.82, 0.20 }

    local current_display =
        detailed
        and ui.network.display.detailed
        or ui.network.display.compact

    local show_infected_status =
        type(current_display) == "table"
        and current_display.infected_predictions == true

    local prediction_by_userid = {}
    local prediction_by_entity = {}
    local prediction_by_identity = {}
    local used_future_wave = false

    if show_infected_status
        and type(ui.lobby.get_infected_player_predictions) == "function" then

        local prediction_snapshot =
            ui.lobby.get_infected_player_predictions()

        used_future_wave =
            type(prediction_snapshot) == "table"
            and prediction_snapshot.used_future_wave == true

        for _, prediction_row in ipairs(
            type(prediction_snapshot) == "table"
            and type(prediction_snapshot.rows) == "table"
            and prediction_snapshot.rows
            or {}
        ) do
            if type(prediction_row) == "table"
                and prediction_row.is_bot ~= true then

                local prediction_player =
                    type(prediction_row.player) == "table"
                    and prediction_row.player
                    or {}

                local prediction_userid =
                    math.floor(
                        tonumber(prediction_player.userid) or 0
                    )

                local prediction_entity =
                    math.floor(
                        tonumber(prediction_player.entity_index) or 0
                    )

                local prediction_identity =
                    tostring(prediction_row.identity or "")

                if prediction_userid > 0 then
                    prediction_by_userid[prediction_userid] =
                        prediction_row
                end

                if prediction_entity > 0 then
                    prediction_by_entity[prediction_entity] =
                        prediction_row
                end

                if prediction_identity ~= "" then
                    prediction_by_identity[prediction_identity] =
                        prediction_row
                end
            end
        end
    end

    local function find_player_prediction(
        player_record
    )
        if not show_infected_status
            or type(player_record) ~= "table"
            or player_record.is_bot == true
            or resolved_player_team(player_record) ~= 3 then

            return nil
        end

        local player_userid =
            math.floor(
                tonumber(player_record.userid) or 0
            )

        if player_userid > 0
            and prediction_by_userid[player_userid] then

            return prediction_by_userid[player_userid]
        end

        local player_entity =
            math.floor(
                tonumber(player_record.entity_index) or 0
            )

        if player_entity > 0
            and prediction_by_entity[player_entity] then

            return prediction_by_entity[player_entity]
        end

        if type(
            ui.lobby.get_infected_prediction_player_identity
        ) == "function" then

            local player_identity =
                tostring(
                    ui.lobby.get_infected_prediction_player_identity(
                        player_record
                    ) or ""
                )

            if player_identity ~= ""
                and prediction_by_identity[player_identity] then

                return prediction_by_identity[player_identity]
            end
        end

        return nil
    end

    local function build_prediction_parts(
        prediction_row
    )
        if type(prediction_row) ~= "table" then
            return nil
        end

        local class_name =
            tostring(
                prediction_row.class_name or "Unavailable"
            )

        local prefix_text = "Guess:"
        local main_text = class_name
        local suffix_text =
            " (" ..
            ui.lobby.format_prediction_percentage(
                prediction_row.chance
            ) ..
            ")"
        local main_color =
            { 0.78, 0.44, 1.00 }

        if prediction_row.exact == true then
            suffix_text = ""

            if prediction_row.state == "Ghost" then
                prefix_text = "Unspawned:"
                main_color =
                    { 0.82, 0.86, 0.90 }
            else
                prefix_text = "Spawned:"
                main_color =
                    { 1.00, 0.25, 0.25 }
            end
        elseif used_future_wave == true
            and tonumber(prediction_row.wave) ~= nil
            and tonumber(prediction_row.wave) > 1 then

            suffix_text =
                suffix_text ..
                " W" ..
                tostring(
                    math.floor(
                        tonumber(prediction_row.wave) or 1
                    )
                )
        end

        local indicator_state =
            prediction_row.exact == true
            and prediction_row.prediction_result
            or "none"

        local indicator_checked_at =
            prediction_row.exact == true
            and prediction_row.prediction_checked_at
            or 0.0

        local indicator_text,
            indicator_r,
            indicator_g,
            indicator_b =
                ui.lobby.get_prediction_result_indicator_color(
                    {
                        prediction_result = indicator_state,
                        prediction_checked_at = indicator_checked_at
                    },
                    true
                )

        return {
            indicator_text = indicator_text,
            indicator_color = {
                indicator_r,
                indicator_g,
                indicator_b
            },
            prefix_text = prefix_text,
            main_text = main_text,
            suffix_text = suffix_text,
            main_color = main_color
        }
    end

    local function prediction_parts_width(
        prediction_parts
    )
        if type(prediction_parts) ~= "table" then
            return 0
        end

        local total_width = 0
        local part_count = 0

        local function include_part(
            value
        )
            value = tostring(value or "")

            if value ~= "" then
                total_width =
                    total_width +
                    ui.lobby.measure_text_width(value)
                part_count = part_count + 1
            end
        end

        include_part(prediction_parts.indicator_text)
        include_part(prediction_parts.prefix_text)
        include_part(prediction_parts.main_text)
        include_part(prediction_parts.suffix_text)

        if part_count > 1 then
            total_width =
                total_width +
                (part_count - 1) * 4
        end

        return total_width
    end

    local function draw_prediction_parts(
        prediction_parts,
        status_origin_x
    )
        if type(prediction_parts) ~= "table" then
            return
        end

        local disabled_color =
            players_palette.text_disabled
            or { 0.62, 0.62, 0.62 }

        local indicator_text =
            tostring(
                prediction_parts.indicator_text or ""
            )

        local prefix_text =
            tostring(
                prediction_parts.prefix_text or ""
            )

        local main_text =
            tostring(
                prediction_parts.main_text or ""
            )

        local suffix_text =
            tostring(
                prediction_parts.suffix_text or ""
            )

        if ui.network.rendering_overlay
            and tonumber(status_origin_x) ~= nil then

            local origin_x =
                tonumber(status_origin_x) or 0

            local indicator_x =
                origin_x + (detailed and 16 or 14)

            local prefix_x =
                origin_x + (detailed and 32 or 26)

            local suffix_x =
                origin_x + (detailed and 126 or 104)

            if indicator_text ~= "" then
                imgui.same_line()
                ui.lobby.set_cursor_x(
                    indicator_x
                )

                local indicator_color =
                    prediction_parts.indicator_color
                    or { 0.44, 0.44, 0.46 }

                theme_text_colored(
                    indicator_color[1],
                    indicator_color[2],
                    indicator_color[3],
                    1.0,
                    indicator_text
                )
            end

            if prefix_text ~= "" then
                imgui.same_line()
                ui.lobby.set_cursor_x(
                    prefix_x
                )

                theme_text_colored(
                    disabled_color[1],
                    disabled_color[2],
                    disabled_color[3],
                    1.0,
                    prefix_text
                )
            end

            if main_text ~= "" then
                imgui.same_line()

                local main_color =
                    prediction_parts.main_color
                    or { 1.0, 1.0, 1.0 }

                theme_text_colored(
                    main_color[1],
                    main_color[2],
                    main_color[3],
                    1.0,
                    main_text
                )
            end

            if suffix_text ~= "" then
                imgui.same_line()
                ui.lobby.set_cursor_x(
                    suffix_x
                )

                theme_text_colored(
                    disabled_color[1],
                    disabled_color[2],
                    disabled_color[3],
                    1.0,
                    suffix_text
                )
            end

            return
        end

        local drew_part = false

        if indicator_text ~= "" then
            local indicator_color =
                prediction_parts.indicator_color
                or { 0.44, 0.44, 0.46 }

            theme_text_colored(
                indicator_color[1],
                indicator_color[2],
                indicator_color[3],
                1.0,
                indicator_text
            )

            drew_part = true
        end

        if prefix_text ~= "" then
            if drew_part then
                imgui.same_line()
            end

            theme_text_colored(
                disabled_color[1],
                disabled_color[2],
                disabled_color[3],
                1.0,
                prefix_text
            )

            drew_part = true
        end

        if main_text ~= "" then
            if drew_part then
                imgui.same_line()
            end

            local main_color =
                prediction_parts.main_color
                or { 1.0, 1.0, 1.0 }

            theme_text_colored(
                main_color[1],
                main_color[2],
                main_color[3],
                1.0,
                main_text
            )

            drew_part = true
        end

        if suffix_text ~= "" then
            if drew_part then
                imgui.same_line()
            end

            theme_text_colored(
                disabled_color[1],
                disabled_color[2],
                disabled_color[3],
                1.0,
                suffix_text
            )
        end
    end

    local function draw_player_id_row(
