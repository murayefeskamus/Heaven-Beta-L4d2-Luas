function ui.network.load_geoip_online_cache()
    if ui.network.server_region_online_lookup_cache_loaded == true then
        return
    end

    ui.network.server_region_online_lookup_cache_loaded = true

    if type(ui.network.server_region_online_lookup_cache) ~= "table" then
        ui.network.server_region_online_lookup_cache = {}
    end

    if type(io) ~= "table" or type(io.open) ~= "function" then
        return
    end

    local path = ui.network.get_geoip_online_cache_path()
    local file_ok, file = pcall(io.open, path, "rb")

    if not file_ok or not file then
        return
    end

    for line in file:lines() do
        line = tostring(line or "")
            :gsub("^\239\187\191", "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

        local ip_address, country =
            line:match("^(%d+%.%d+%.%d+%.%d+)%s*,%s*([^,]+)")

        if ip_address ~= nil and country ~= nil then
            country = ui.network.normalize_geoip_country_label(country)

            if country ~= "" then
                ui.network.server_region_online_lookup_cache[ip_address] =
                    country
            end
        end
    end

    pcall(function() file:close() end)
end

function ui.network.save_geoip_online_cache()
    if type(io) ~= "table" or type(io.open) ~= "function" then
        return false
    end

    local cache =
        type(ui.network.server_region_online_lookup_cache) == "table"
        and ui.network.server_region_online_lookup_cache
        or {}

    local path = ui.network.get_geoip_online_cache_path()
    local file_ok, file = pcall(io.open, path, "wb")

    if not file_ok or not file then
        return false
    end

    local keys = {}

    for ip_address, country in pairs(cache) do
        if tostring(ip_address or "") ~= ""
            and tostring(country or "") ~= "" then

            keys[#keys + 1] = tostring(ip_address)
        end
    end

    table.sort(keys)

    pcall(
        function()
            file:write("# DarkSideTools online GeoIP country cache\n")

            for _, ip_address in ipairs(keys) do
                local country =
                    tostring(cache[ip_address] or "")
                        :gsub("[\r\n,]", " ")
                        :gsub("%s+", " ")
                        :gsub("^%s+", "")
                        :gsub("%s+$", "")

                if country ~= "" then
                    file:write(
                        ip_address ..
                        "," ..
                        country ..
                        "," ..
                        tostring(os.time and os.time() or 0) ..
                        "\n"
                    )
                end
            end
        end
    )

    pcall(function() file:close() end)

    return true
end

function ui.network.cache_geoip_online_country(ip_address, country)
    ip_address = tostring(ip_address or "")
    country = ui.network.normalize_geoip_country_label(country)

    if ip_address == "" or country == "" then
        return false
    end

    ui.network.load_geoip_online_cache()

    if type(ui.network.server_region_online_lookup_cache) ~= "table" then
        ui.network.server_region_online_lookup_cache = {}
    end

    ui.network.server_region_online_lookup_cache[ip_address] = country
    ui.network.server_region_online_lookup_status =
        "Resolved " .. ip_address .. " as " .. country .. "."

    ui.network.save_geoip_online_cache()

    return true
end

function ui.network.get_geoip_country_from_online_cache(ip_address)
    ip_address =
        ui.network.extract_ipv4_address(
            ip_address
        )

    if ip_address == "" then
        return ""
    end

    ui.network.load_geoip_online_cache()

    local cache =
        type(ui.network.server_region_online_lookup_cache) == "table"
        and ui.network.server_region_online_lookup_cache
        or {}

    return tostring(cache[ip_address] or "")
end

function ui.network.escape_powershell_single_quoted(value)
    value = tostring(value or "")
    return value:gsub("'", "''")
end

function ui.network.build_geoip_online_lookup_powershell(ip_address, output_path)
    local ip = ui.network.escape_powershell_single_quoted(
        ui.network.extract_ipv4_address(ip_address)
    )

    local out = ui.network.escape_powershell_single_quoted(output_path)

    return table.concat(
        {
            "$ErrorActionPreference='SilentlyContinue'",
            "$ProgressPreference='SilentlyContinue'",
            "try{[Net.ServicePointManager]::SecurityProtocol=[Net.SecurityProtocolType]::Tls12}catch{}",
            "$ip='" .. ip .. "'",
            "$out='" .. out .. "'",
            "New-Item -ItemType Directory -Force -Path (Split-Path $out) | Out-Null",
            "$urls=@(",
            "@{n='ipapi';u=('https://ipapi.co/'+$ip+'/json/')},",
            "@{n='ipwhois';u=('https://ipwho.is/'+$ip)},",
            "@{n='ip-api';u=('http://ip-api.com/json/'+$ip+'?fields=status,country,countryCode,query')},",
            "@{n='wpstats1';u=('https://geo.wp-statistics.com/'+$ip+'?format=json')},",
            "@{n='wpstats2';u=('https://geo.wp-statistics.com/api/lookup?ip='+$ip+'&format=json')}",
            ")",
            "$country=$null",
            "$source=$null",
            "foreach($e in $urls){",
            "try{",
            "$r=Invoke-RestMethod -Uri $e.u -TimeoutSec 8 -Headers @{ 'User-Agent'='DarkSideTools GeoIP' }",
            "if($r){",
            "if($r.success -eq $false){throw 'provider returned failure'}",
            "if($r.status -and ([string]$r.status).ToLower() -eq 'fail'){throw 'provider returned failure'}",
            "if($r.country_name){$country=$r.country_name}",
            "if((-not $country) -and $r.country){$country=$r.country}",
            "if((-not $country) -and $r.countryName){$country=$r.countryName}",
            "if((-not $country) -and $r.countryCode){$country=$r.countryCode}",
            "if((-not $country) -and $r.country_code){$country=$r.country_code}",
            "if((-not $country) -and $r.country_code2){$country=$r.country_code2}",
            "if((-not $country) -and $r.location -and $r.location.country){$country=$r.location.country}",
            "if((-not $country) -and $r.geo -and $r.geo.country){$country=$r.geo.country}",
            "if((-not $country) -and $r.maxmind -and $r.maxmind.country){$country=$r.maxmind.country}",
            "if((-not $country) -and $r.dbip -and $r.dbip.country){$country=$r.dbip.country}",
            "}",
            "if($country){$source=$e.n;break}",
            "}catch{}",
            "}",
            "if($country){Set-Content -Path $out -Value ('OK|' + [string]$country + '|' + [string]$source) -Encoding UTF8}else{Set-Content -Path $out -Value 'ERR|No country from online providers' -Encoding UTF8}"
        },
        "; "
    )
end

function ui.network.start_geoip_online_lookup(ip_address)
    ip_address =
        ui.network.extract_ipv4_address(
            ip_address
        )

    if ui.network.server_region_online_lookup_enabled ~= true
        or ip_address == ""
        or ui.network.ipv4_to_number(ip_address) == nil
        or ui.network.is_private_ipv4_address(ip_address) then

        return false
    end

    local now = os.clock()

    local next_retry =
        type(ui.network.server_region_online_lookup_next_retry) == "table"
        and tonumber(ui.network.server_region_online_lookup_next_retry[ip_address])
        or 0.0

    if next_retry ~= nil and now < next_retry then
        return false
    end

    local active_ip =
        tostring(
            ui.network.server_region_online_lookup_active_ip or ""
        )

    if active_ip ~= "" then
        local active_age =
            now -
            (
                tonumber(
                    ui.network.server_region_online_lookup_started_at
                ) or 0.0
            )

        local timeout =
            math.max(
                3.0,
                tonumber(
                    ui.network.server_region_online_lookup_timeout
                ) or 8.0
            )

        if active_ip == ip_address and active_age < timeout then
            return true
        end

        if active_age < timeout then
            return false
        end

        ui.network.server_region_online_lookup_active_ip = ""
        ui.network.server_region_online_lookup_active_path = ""
    end

    if type(os) ~= "table" or type(os.execute) ~= "function" then
        ui.network.server_region_online_lookup_status =
            "OS execute unavailable."
        return false
    end

    local output_path =
        ui.network.get_geoip_online_result_path(ip_address)

    if type(os.remove) == "function" then
        pcall(os.remove, output_path)
    end

    local ps_command =
        ui.network.build_geoip_online_lookup_powershell(
            ip_address,
            output_path
        )

    local script_path =
        output_path:gsub(
            "%.txt$",
            ".ps1"
        )

    local script_written = false

    if type(io) == "table"
        and type(io.open) == "function" then

        local script_ok,
            script_file =
                pcall(
                    io.open,
                    script_path,
                    "wb"
                )

        if script_ok and script_file then
            local write_ok =
                pcall(
                    function()
                        script_file:write(ps_command)
                    end
                )

            pcall(
                function()
                    script_file:close()
                end
            )

            script_written = write_ok == true
        end
    end

    local shell_command

    if script_written == true then
        shell_command =
            'cmd.exe /C start "" /min powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "' ..
            script_path:gsub('"', '') ..
            '"'
    else
        shell_command =
            'cmd.exe /C start "" /min powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -Command "' ..
            ps_command:gsub('"', '\\"') ..
            '"'
    end

    local ok = pcall(os.execute, shell_command)

    if ok then
        ui.network.server_region_online_lookup_active_ip = ip_address
        ui.network.server_region_online_lookup_active_path = output_path
        ui.network.server_region_online_lookup_started_at = now
        ui.network.server_region_online_lookup_status =
            "Online lookup started for " .. ip_address .. "."
        return true
    end

    ui.network.server_region_online_lookup_status =
        "Online lookup start failed."

    return false
end

function ui.network.read_geoip_online_lookup_result(ip_address)
    ip_address =
        ui.network.extract_ipv4_address(
            ip_address
        )

    if ip_address == ""
        or type(io) ~= "table"
        or type(io.open) ~= "function" then

        return ""
    end

    local active_ip =
        tostring(
            ui.network.server_region_online_lookup_active_ip or ""
        )

    if active_ip ~= ip_address then
        return ""
    end

    local path =
        tostring(
            ui.network.server_region_online_lookup_active_path or ""
        )

    if path == "" then
        path = ui.network.get_geoip_online_result_path(ip_address)
    end

    local file_ok, file = pcall(io.open, path, "rb")

    if not file_ok or not file then
        local age =
            os.clock() -
            (
                tonumber(
                    ui.network.server_region_online_lookup_started_at
                ) or 0.0
            )

        local timeout =
            math.max(
                3.0,
                tonumber(
                    ui.network.server_region_online_lookup_timeout
                ) or 8.0
            )

        if age >= timeout then
            ui.network.server_region_online_lookup_active_ip = ""
            ui.network.server_region_online_lookup_active_path = ""
            ui.network.server_region_online_lookup_status =
                "Online lookup timed out."

            if type(ui.network.server_region_online_lookup_next_retry) ~= "table" then
                ui.network.server_region_online_lookup_next_retry = {}
            end

            ui.network.server_region_online_lookup_next_retry[ip_address] =
                os.clock() +
                math.max(
                    30.0,
                    tonumber(
                        ui.network.server_region_online_lookup_retry_interval
                    ) or 300.0
                )
        end

        return ""
    end

    local read_ok, content = pcall(function() return file:read("*a") end)
    pcall(function() file:close() end)

    if not read_ok then
        return ""
    end

    content = tostring(content or "")
        :gsub("^\239\187\191", "")
        :gsub("[\r\n]+", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")

    if content == "" then
        return ""
    end

    ui.network.server_region_online_lookup_active_ip = ""
    ui.network.server_region_online_lookup_active_path = ""

    local status, value = content:match("^([^|]+)|(.+)$")

    status = tostring(status or "")
    value = tostring(value or "")

    if status == "OK" then
        local country = ui.network.normalize_geoip_country_label(value)

        if country ~= "" then
            ui.network.cache_geoip_online_country(
                ip_address,
                country
            )

            return country
        end
    end

    ui.network.server_region_online_lookup_status =
        "Online lookup failed: " ..
        tostring(value ~= "" and value or "Unknown error")

    if type(ui.network.server_region_online_lookup_next_retry) ~= "table" then
        ui.network.server_region_online_lookup_next_retry = {}
    end

    ui.network.server_region_online_lookup_next_retry[ip_address] =
        os.clock() +
        math.max(
            30.0,
            tonumber(
                ui.network.server_region_online_lookup_retry_interval
            ) or 300.0
        )

    return ""
end

function ui.network.get_geoip_country_from_online_lookup(ip_address)
    ip_address =
        ui.network.extract_ipv4_address(
            ip_address
        )

    if ip_address == "" then
        return ""
    end

    local cached = ui.network.get_geoip_country_from_online_cache(ip_address)

    if cached ~= "" then
        return cached
    end

    local active_result =
        ui.network.read_geoip_online_lookup_result(
            ip_address
        )

    if active_result ~= "" then
        return active_result
    end

    ui.network.start_geoip_online_lookup(ip_address)

    return ""
end

function ui.network.is_geoip_online_lookup_pending(ip_address)
    ip_address =
        ui.network.extract_ipv4_address(
            ip_address
        )

    if ip_address == "" then
        return false
    end

    if tostring(ui.network.server_region_online_lookup_active_ip or "") ~= ip_address then
        return false
    end

    local age =
        os.clock() -
        (
            tonumber(
                ui.network.server_region_online_lookup_started_at
            ) or 0.0
        )

    return age <
        math.max(
            3.0,
            tonumber(
                ui.network.server_region_online_lookup_timeout
            ) or 8.0
        )
end

