function extract_command_argument(message, command)
    if not message or not command then
        return false, nil
    end

    local lower_message =
        message:lower()

    local lower_command =
        command:lower()

    if lower_message == lower_command then
        return true, ""
    end

    if lower_message:sub(1, #lower_command)
        ~= lower_command then

        return false, nil
    end

    local remainder =
        message:sub(#command + 1)


    if remainder:match("^%s") then
        return true,
            remainder:gsub("^%s+", "")
    end

    return false, nil
end


function prepare_for_chat(message)


    return message:gsub('"', "'")
