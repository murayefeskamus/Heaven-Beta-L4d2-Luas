function ui.lobby.player_matches_filter(
    player_record
)
    local filter_index =
        tonumber(
            ui.lobby.filter_index
        ) or 0

    if filter_index == 0 then
        return true
    elseif filter_index == 1 then
        return not player_record.is_bot
    elseif filter_index == 2 then
        return player_record.is_bot
    elseif filter_index == 3 then
        return player_record.team == 2
    elseif filter_index == 4 then
        return player_record.team == 3
    elseif filter_index == 5 then
        return player_record.team == 1
    elseif filter_index == 6 then
        return player_record.alive == true
    elseif filter_index == 7 then
        return player_record.alive == false
    elseif filter_index == 8 then
        return true
    end

    return true
end


