function ui.heaven_configs.draw_sized_button(
    full_label,
    width
)
    width = math.max(
        1,
        math.floor(
            tonumber(width) or 1
        )
    )


    if ui.heaven_configs.sized_button_supported ~= false then
        local sized_ok,
            sized_clicked =
                pcall(
                    imgui.button,
                    tostring(full_label),
                    width,
                    0
                )

        if sized_ok then
            ui.heaven_configs.sized_button_supported = true
            return sized_clicked == true
        end

        ui.heaven_configs.sized_button_supported = false
    end


    local full_text = tostring(full_label or "Action")
    local visible_text,
        hidden_id =
            full_text:match("^(.-)(##.*)$")

    visible_text = visible_text or full_text
    hidden_id = hidden_id or ""

    local visible_width =
        ui.lobby.measure_text_width(
            visible_text
        )

    local space_width =
        math.max(
            1,
            ui.lobby.measure_text_width(" ")
        )

    local target_text_width =
        math.max(
            visible_width,
            width - 16
        )

    local total_spaces =
        math.max(
            0,
            math.floor(
                (
                    target_text_width -
                    visible_width
                ) /
                space_width +
                0.5
            )
        )

    local left_spaces =
        math.floor(
            total_spaces / 2
        )

    local right_spaces =
        total_spaces -
        left_spaces

    return imgui.button(
        string.rep(" ", left_spaces) ..
        visible_text ..
        string.rep(" ", right_spaces) ..
        hidden_id
    ) == true
end

