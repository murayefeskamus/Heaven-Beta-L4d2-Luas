function ui.control.aim_v2_clamp_level(value, fallback, maximum)
    return math.max(
        1,
        math.min(
            maximum or 10,
            math.floor((tonumber(value) or fallback or 1) + 0.5)
        )
    )
end

function ui.control.aim_v2_nearest_level(value, values, fallback)
    value = tonumber(value)
    if not value or type(values) ~= "table" or #values == 0 then
        return ui.control.aim_v2_clamp_level(fallback or 1, 1, #values > 0 and #values or 10)
    end

    local best_index = 1
    local best_distance = math.huge

    for index, candidate in ipairs(values) do
        local distance = math.abs(value - (tonumber(candidate) or value))
        if distance < best_distance then
            best_distance = distance
            best_index = index
        end
    end

    return best_index
end

function ui.control.aim_v2_copy_color(color)
    color = ui.control.normalize_rgba_color(color, { 1.0, 1.0, 1.0, 1.0 })
    return { color[1], color[2], color[3], color[4] or 1.0 }
end

function ui.control.aim_v2_nearest_palette_index(color)
    color = ui.control.normalize_rgba_color(color, { 1.0, 1.0, 1.0, 1.0 })

    local best_index = 1
    local best_error = math.huge

    for index, entry in ipairs(ui.control.aim_v2_color_palette) do
        local candidate = entry.rgb
        local red = color[1] - candidate[1]
        local green = color[2] - candidate[2]
        local blue = color[3] - candidate[3]
        local error = red * red + green * green + blue * blue

        if error < best_error then
            best_error = error
            best_index = index
        end
    end

    return best_index
end

function ui.control.normalize_aim_v2_rebuilt_settings()
    local settings = ui.control.aim.v2
    local should_migrate_fov_circle_visibility = settings.fov_circle_visibility_migrated ~= true

    settings.simple_core_profile_ready = true
    settings.silent_aim = false
    settings.sticky_lock = true
    settings.hold_lock_until_release = true
    settings.hold_lock_release_debounce = 0.0

    if settings.fov_level == nil then
        settings.fov_level = ui.control.aim_v2_nearest_level(
            tonumber(settings.fov) or 120.0,
            ui.control.aim_v2_fov_values,
            4
        )
    end
    settings.fov_level = ui.control.aim_v2_clamp_level(settings.fov_level, 4, 10)
    settings.fov = ui.control.aim_v2_fov_values[settings.fov_level]

    if settings.response_level == nil then
        settings.response_level = ui.control.aim_v2_nearest_level(
            tonumber(settings.smooth) or 1.32,
            ui.control.aim_v2_smooth_values,
            8
        )
    end
    settings.response_level = ui.control.aim_v2_clamp_level(settings.response_level, 8, 10)
    settings.smooth = ui.control.aim_v2_smooth_values[settings.response_level]

    if settings.range_level == nil then
        settings.range_level = ui.control.aim_v2_nearest_level(
            tonumber(settings.max_distance) or 5000.0,
            ui.control.aim_v2_range_values,
            6
        )
    end
    settings.range_level = ui.control.aim_v2_clamp_level(settings.range_level, 6, 10)
    settings.max_distance = ui.control.aim_v2_range_values[settings.range_level]

    settings.target_point = math.max(
        0,
        math.min(2, math.floor(tonumber(settings.target_point) or 2))
    )
    settings.target_head = settings.target_point == 0
    settings.target_incapacitated = settings.target_incapacitated ~= false
    settings.target_hanging = settings.target_hanging == true
    settings.incapacitated_center_mass = true
    settings.visible_only = settings.visible_only == true

    settings.prediction = settings.prediction ~= false
    if settings.prediction_strength_level == nil then
        local old_time = tonumber(settings.prediction_time) or 0.045
        settings.prediction_strength_level = ui.control.aim_v2_clamp_level(
            1 + old_time / 0.012,
            5,
            10
        )
    end
    settings.prediction_strength_level = ui.control.aim_v2_clamp_level(
        settings.prediction_strength_level,
        5,
        10
    )
    settings.adaptive_prediction = true
    settings.relative_prediction = true
    settings.vertical_prediction = false
    settings.prediction_time = 0.012 + (settings.prediction_strength_level - 1) * 0.0105
    settings.prediction_max_time = settings.prediction_time

    settings.pursuit_enabled = settings.pursuit_enabled == true
    settings.pursuit_use_shared_key = true
    if settings.pursuit_strength_level == nil then
        settings.pursuit_strength_level = ui.control.aim_v2_clamp_level(
            1 + ((tonumber(settings.pursuit_move_speed) or 450.0) - 80.0) / (370.0 / 9.0),
            10,
            10
        )
    end
    settings.pursuit_strength_level = ui.control.aim_v2_clamp_level(
        settings.pursuit_strength_level,
        10,
        10
    )
    settings.pursuit_move_speed = 80.0 + (settings.pursuit_strength_level - 1) * (370.0 / 9.0)
    settings.pursuit_manual_override = settings.pursuit_manual_override ~= false
    settings.pursuit_glue_mode = true
    settings.pursuit_contact_pressure = 1.0

    if settings.pursuit_obstacle_avoidance == nil then
        settings.pursuit_obstacle_avoidance = true
    else
        settings.pursuit_obstacle_avoidance = settings.pursuit_obstacle_avoidance == true
    end

    settings.pursuit_avoidance_level = ui.control.aim_v2_clamp_level(
        settings.pursuit_avoidance_level,
        7,
        10
    )

    local avoidance = settings.pursuit_avoidance_level
    settings.pursuit_target_lead = true
    settings.pursuit_target_lead_time = 0.08 + avoidance * 0.014
