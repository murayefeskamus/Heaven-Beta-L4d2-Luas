function spammer_cfg.find_next_nonempty_name_index(
    start_index
)
    local nonempty_indices =
        spammer_cfg.get_nonempty_name_indices()

    if #nonempty_indices <= 0 then
        return nil
    end

    start_index =
        math.max(
            1,
            math.floor(
                tonumber(start_index) or 1
            )
        )

    for _, configured_index in ipairs(
        nonempty_indices
    ) do
        if configured_index >= start_index then
            return configured_index
        end
    end

    return nonempty_indices[1]
end

