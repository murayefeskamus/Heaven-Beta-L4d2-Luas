                "KILL",
                tostring(attacker.name) ..
                    " killed " ..
                    victim_name ..
                    weapon_suffix
            )
        end
    end
end

function ui.lobby.record_special_infected_damage(
    event,
    event_name
)
    event_name =
        tostring(
            event_name or "player_hurt"
        )

    local function resolve_attacker()
        return ui.lobby.resolve_event_player(
            event,
            {
                "attacker",
                "attacker_userid",
                "attackeruserid"
            },
            {
                "attackerentid",
                "attackerentindex",
                "attacker_entindex",
                "attacker_entity",
                "attacker_index"
            }
        )
    end

    local function resolve_victim()
        return ui.lobby.resolve_event_player(
            event,
            {
                "userid",
                "victim",
                "victim_userid",
                "victimuserid"
            },
            {
                "victimentid",
                "victimentindex",
                "victim_entindex",
                "victim_entity",
                "victim_index"
            }
        )
    end

    local attacker =
        resolve_attacker()

    local victim =
        resolve_victim()

    if not attacker
        or not victim then

        ui.lobby.refresh(true)

        attacker =
            resolve_attacker()

        victim =
            resolve_victim()
    end

    if not attacker
        or not victim
        or attacker == victim
        or attacker.team ~= 3
        or victim.team ~= 2 then

        return false
    end

    local damage = 0

    local damage_fields = {
        "dmg_health",
        "damageamount",
        "damage",
        "amount"
    }

    for _, field_name in ipairs(
        damage_fields
    ) do
        damage =
            ui.lobby.get_event_int(
                event,
                field_name
            )

        if damage > 0 then
            break
        end
    end

    damage =
        math.max(
            0,
            math.floor(
                tonumber(damage) or 0
            )
        )

    if damage <= 0 then
        return false
    end

    local now =
        get_time()

    local source_name =
        event_name == "player_hurt_concise"
        and "concise"
        or "full"

    local opposite_name =
        source_name == "concise"
        and "full"
        or "concise"

    local damage_type =
        ui.lobby.get_event_int(
            event,
            "type"
        )

    local signature =
        tostring(attacker.key) ..
        ":" ..
        tostring(victim.key) ..
        ":" ..
        tostring(damage) ..
        ":" ..
        tostring(damage_type)

    local pair_state =
        ui.lobby.recent_damage_events[
            signature
        ] or {
            full = {},
            concise = {}
        }

    local function prune_queue(
        queue
    )
        while #queue > 0
            and now - (queue[1] or 0)
                > ui.lobby.damage_event_dedup_window do

            table.remove(
                queue,
                1
            )
        end
    end

    prune_queue(
        pair_state.full
    )

    prune_queue(
        pair_state.concise
    )

    if #pair_state[
        opposite_name
    ] > 0 then

        table.remove(
            pair_state[
                opposite_name
            ],
            1
        )

        ui.lobby.recent_damage_events[
            signature
        ] = pair_state

        return false
    end

    table.insert(
        pair_state[
            source_name
        ],
        now
    )

    ui.lobby.recent_damage_events[
        signature
    ] = pair_state

    for old_signature,
        old_state in pairs(
            ui.lobby.recent_damage_events
        ) do

        prune_queue(
            old_state.full or {}
        )

        prune_queue(
            old_state.concise or {}
        )

        if #(old_state.full or {}) == 0
            and #(old_state.concise or {}) == 0 then

            ui.lobby.recent_damage_events[
                old_signature
            ] = nil
        end
    end

    local class_name =
        tostring(
            attacker.class_name
            or "Special Infected"
        )

    local attacker_entity =
        entity.get_by_index(
            attacker.entity_index
        )

    if attacker_entity then
        local current_class =
            ui.lobby.get_player_class(
                attacker_entity,
                3
            )

        if current_class
            and tostring(current_class) ~= ""
            and tostring(current_class) ~= "Unknown" then

            class_name =
                tostring(current_class)
        end
    end

    if class_name == ""
        or class_name == "Unknown"
        or class_name == "Infected" then

        class_name =
            "Special Infected"
    end

    attacker.si_damage_by_class =
        attacker.si_damage_by_class
        or {}

    attacker.si_damage_by_class[
        class_name
    ] =
        (
            attacker.si_damage_by_class[
                class_name
            ] or 0
        ) + damage

    attacker.si_damage_total =
        (
            attacker.si_damage_total
            or 0
        ) + damage

    ui.lobby.update_activity_cache(
        attacker
    )

    return true
end

function ui.lobby.pack_chat_fields(
    fields,
    max_length
)
    max_length =
        math.max(
            48,
            tonumber(max_length) or 92
        )

    local messages = {}
    local current_message = ""

    local function flush_current()
        if current_message ~= "" then
            table.insert(
                messages,
                current_message
            )

            current_message = ""
        end
    end

    local function append_long_field(
        field_text
    )
        local remaining =
            tostring(field_text or "")

        while #remaining > max_length do
            local split_at = nil

            for index = max_length,
                1,
                -1 do

                local character =
                    remaining:sub(
                        index,
                        index
                    )

                if character == ","
                    or character == " " then

                    split_at = index
                    break
                end
            end

            split_at =
                split_at
                or max_length

            local chunk =
                remaining:sub(
                    1,
                    split_at
                ):gsub(
                    "%s+$",
                    ""
                )

            if chunk ~= "" then
                table.insert(
                    messages,
                    chunk
                )
            end

            remaining =
                remaining:sub(
                    split_at + 1
                ):gsub(
                    "^%s+",
                    ""
                )
        end

        current_message = remaining
    end

    for _, field_value in ipairs(
        fields or {}
    ) do
        local field_text =
            tostring(
                field_value or ""
            )

        field_text = field_text:gsub(
            "[\r\n]",
            " "
        )

        if field_text ~= "" then
            if #field_text > max_length then
                flush_current()
                append_long_field(
                    field_text
                )
            else
                local candidate =
                    current_message == ""
                    and field_text
                    or (
                        current_message ..
                        " | " ..
                        field_text
                    )

                if #candidate <= max_length then
                    current_message = candidate
                else
                    flush_current()
                    current_message = field_text
                end
            end
        end
    end

    flush_current()

    return messages
end

function ui.lobby.format_count(
    count,
    singular,
    plural
)
    count =
        math.max(
            0,
            math.floor(
                tonumber(count) or 0
            )
        )

    singular =
        tostring(
            singular or "item"
        )

    plural =
        tostring(
            plural
            or (singular .. "s")
        )

    return tostring(count) ..
        " " ..
        (
            count == 1
            and singular
            or plural
        )
end

function ui.lobby.join_readable_list(
    values,
    empty_text
)
    values = values or {}

    if #values == 0 then
        return tostring(
            empty_text or "None"
        )
    elseif #values == 1 then
        return tostring(values[1])
    elseif #values == 2 then
        return tostring(values[1]) ..
            " and " ..
            tostring(values[2])
    end

    local leading = {}

    for index = 1,
        #values - 1 do

        table.insert(
            leading,
            tostring(values[index])
        )
    end

    return table.concat(
        leading,
        ", "
    ) ..
        " and " ..
        tostring(values[#values])
end

function ui.lobby.get_team_member_names(
    team_number,
    alive_state
)
    local names = {}

    for _, player_record in ipairs(
        ui.lobby.players
    ) do
        if player_record.team == team_number
            and player_record.alive == alive_state then

            local display_name =
                tostring(
                    player_record.name
                    or "Unknown"
                )

            if player_record.is_bot then
                display_name =
                    display_name .. " [BOT]"
            end

            table.insert(
                names,
                display_name
            )
        end
    end

    table.sort(
        names,
        function(left, right)
            return tostring(left):lower()
                < tostring(right):lower()
        end
    )

    return names
end

function ui.lobby.get_infected_class_list(
    spawned_state
)
    local class_counts = {}
    local player_count = 0

    for _, player_record in ipairs(
        ui.lobby.players
    ) do
        if tonumber(player_record.team) == 3 then
            local player_index =
                math.floor(
                    tonumber(
                        player_record.entity_index
                    ) or 0
                )

            local assignment = nil

            if player_index > 0 then
                assignment =
                    ui.lobby.get_verified_infected_assignment_by_index(
                        player_index,
                        false
                    )
            end

            local matches_state =
                assignment ~= nil
                and (
                    spawned_state == true
                    and assignment.spawned == true
                    or spawned_state ~= true
                    and assignment.is_ghost == true
                )

            if matches_state then
                local class_name =
                    tostring(
                        assignment.name or ""
                    )

                if class_name ~= ""
                    and class_name ~= "Unknown"
                    and class_name ~= "Infected"
                    and class_name ~= "Unassigned"
                    and class_name ~= "Witch" then

                    player_count =
                        player_count + 1

                    class_counts[class_name] =
                        (class_counts[class_name] or 0) + 1

                    player_record.class_name =
                        class_name
                end
            end
        end
    end

    local class_names = {}

    for class_name, count in pairs(
        class_counts
    ) do
        table.insert(
            class_names,
            count > 1
                and (
                    class_name ..
                    " x" ..
                    tostring(count)
                )
                or class_name
        )
    end

    table.sort(
        class_names,
        function(left, right)
            return tostring(left):lower()
                < tostring(right):lower()
        end
    )

    return class_names,
        player_count
end

