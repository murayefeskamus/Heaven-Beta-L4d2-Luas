    while clean_name:sub(
        1,
        #DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX
    ) == DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX do

        clean_name =
            clean_name:sub(
                #DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX + 1
            )
    end

    if clean_name:sub(
        1,
        #DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR
    ) == DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR then

        clean_name =
            clean_name:sub(
                #DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR + 1
            )
    end

    if clean_name == "" then
        return
    end

    spammer_runtime.original_name_vertical_active = false
    spammer_runtime.custom_name_vertical_active = false
    spammer_runtime.preview_applied_key = nil


    spammer_runtime.restore_name_disabled = false
    spammer_runtime.restore_name_assumed_until = 0.0
    spammer_runtime.restore_name_check_time =
        get_time()

    spammer_runtime.last_requested_visible_name =
        clean_name

    spammer_runtime.last_requested_at =
        get_time()

    raw_name = tostring(raw_name or clean_name)

    local requested_style =
        raw_name:find(
            "[\r\n]"
        ) ~= nil
        and "Vertical"
        or "Horizontal"

    spammer_runtime.preview_applied_key =
        spammer_runtime.make_preview_applied_key(
            clean_name,
            requested_style == "Vertical"
        )

    spammer_runtime.set_current_name_metadata(
        clean_name,
        {
            style = requested_style,
            case_label = "Original",
            shape_label = "Original",
            decoration_label = nil,
            source = "Internal"
