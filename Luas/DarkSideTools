function spammer_cfg.build_horizontal_name(
    target_name_str
)
    local clean_name =
        sanitize_name(
            target_name_str
        )

    if clean_name == "" then
        return nil, false, 0
    end

    local prefix =
        spammer_cfg.use_color_char
        and DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR
        or ""

    local output_parts = {}
    local output_length = #prefix
    local character_count = 0
    local fitted_character_count = 0

    for character in clean_name:gmatch(
        "[%z\1-\127\194-\244][\128-\191]*"
    ) do
        character_count =
            character_count + 1

        if output_length + #character
            <= DARKSIDE_CONFIG.MAX_NAME_LENGTH then

            table.insert(
                output_parts,
                character
            )

            output_length =
                output_length +
                #character

            fitted_character_count =
                fitted_character_count + 1
        else
            break
        end
    end

    if fitted_character_count <= 0 then
        return nil, true, 0
    end

    local final_message =
        prefix ..
        table.concat(
            output_parts
        )

    local truncated =
        fitted_character_count <
        character_count
        or #final_message <
            #prefix + #clean_name

    return final_message,
        truncated,
        #final_message
end

function build_vertical_name(target_name_str)
    local clean_name =
        sanitize_name(
            target_name_str
        )

    if clean_name == "" then
        return nil, false, 0
    end

    local prefix =
        spammer_cfg.use_color_char
        and DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR
        or ""


    local visible_characters = {}

    for character in clean_name:gmatch(
        "[%z\1-\127\194-\244][\128-\191]*"
    ) do
        table.insert(
            visible_characters,
            character
        )
    end

    if #visible_characters <= 0 then
        return nil, false, 0
    end


    local function calculate_layout(
        character_count
    )
        local line_groups = {}

        if character_count <= 7 then
            for index = 1,
                character_count do

                table.insert(
                    line_groups,
                    visible_characters[
                        index
                    ]
                )
            end
        else
            for index = 1, 6 do
                table.insert(
                    line_groups,
                    visible_characters[
                        index
                    ]
                )
            end

            local final_line_parts = {}

            for index = 7,
                character_count do

                table.insert(
                    final_line_parts,
                    visible_characters[
                        index
                    ]
                )
            end

            table.insert(
                line_groups,
                table.concat(
                    final_line_parts
                )
            )
        end

        local leading_line_count =
            1 +
            math.abs(
                character_count - 7
            )

        local encoded_name =
            prefix ..
            string.rep(
                "\r",
                leading_line_count
            ) ..
            table.concat(
                line_groups,
                "\r"
            )

        return encoded_name,
            leading_line_count,
            line_groups
    end


    local fitted_character_count =
        math.min(
            #visible_characters,
            DARKSIDE_CONFIG.MAX_VERTICAL_NAME_CHARACTERS
        )

    local final_message = nil
    local leading_line_count = 0
    local line_groups = nil

    while fitted_character_count > 0 do
        local candidate_message,
            candidate_leading_lines,
            candidate_groups =
                calculate_layout(
                    fitted_character_count
                )

        if #candidate_message
            <= DARKSIDE_CONFIG.MAX_NAME_LENGTH then

            final_message =
                candidate_message

            leading_line_count =
                candidate_leading_lines

            line_groups =
                candidate_groups

            break
        end

        fitted_character_count =
            fitted_character_count - 1
    end

    if not final_message
        or fitted_character_count <= 0 then

        return nil, true, 0
    end

    local truncated =
        fitted_character_count <
        #visible_characters

    return final_message,
        truncated,
        #final_message
end

function build_vertical_name_preview(
    target_name_str
)
    local final_name,
        truncated,
        final_length =
            build_vertical_name(
                target_name_str
            )

    if not final_name then
        return "(empty)",
            truncated,
            final_length
    end

    local preview =
        tostring(final_name)

    preview =
        preview:gsub(
            DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR,
            ""
        )

    preview =
        preview:gsub(
            "\r\n",
            "\n"
        )

    preview =
        preview:gsub(
            "\r",
            "\n"
        )

    local leading_breaks =
        preview:match(
            "^\n*"
        ) or ""

    local leading_blank_lines =
        #leading_breaks

    if leading_blank_lines > 0 then
        preview =
            string.rep(
                "-\n",
                leading_blank_lines
            ) ..
            preview:sub(
                leading_blank_lines + 1
            )
    end

    if preview == "" then
        preview = "(empty)"
    end

    return preview,
        truncated,
        final_length
end


