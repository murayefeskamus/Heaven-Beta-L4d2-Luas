function ui.control.capture_tool_cycle_key()
    if ui.control.waiting_for_toggle_key ~= true then
        return false
    end

    if ui.input_safety.block_runtime_hotkeys() then
        return true
    end

    if type(input) ~= "table" then
        ui.control.toggle_key_capture_status =
            "Heaven input API is unavailable."

        return true
    end

    local can_read_down =
        type(input.is_key_down) == "function"

    local can_read_pressed =
        type(input.is_key_pressed) == "function"

    if not can_read_down
        and not can_read_pressed then

        ui.control.toggle_key_capture_status =
            "Heaven key input functions are unavailable."

        return true
    end

    local capture =
        ui.control.tool_cycle_capture

    local now =
        get_time()

    if now - (
        tonumber(capture.started_at) or now
    ) >= (
        tonumber(capture.timeout) or 12.0
    ) then
        ui.control.cancel_tool_cycle_key_capture(
            "Key capture timed out."
        )

        return true
    end

    local candidates =
        ui.control.get_tool_cycle_capture_keys()

    if capture.waiting_for_release then
        if can_read_down then
            for _, key_value in ipairs(candidates) do
                if ui.control.tool_cycle_key_is_down(
                    key_value
                ) then
                    ui.control.toggle_key_capture_status =
                        "Release all keys and mouse buttons."

                    return true
                end
            end
        elseif now < (
            tonumber(capture.ready_at) or 0.0
        ) then
            return true
        end

        capture.waiting_for_release = false
        capture.ready_at = now + 0.05
        capture.previous_down = {}

        ui.control.toggle_key_capture_status =
            "Press any keyboard key or mouse button. ESC cancels."

        return true
    end

    if now < (
        tonumber(capture.ready_at) or 0.0
    ) then
        return true
    end

    for _, key_value in ipairs(candidates) do
        local is_down = false
        local pressed = false

        if can_read_down then
            is_down =
                ui.control.tool_cycle_key_is_down(
                    key_value
                )

            pressed =
                is_down
                and capture.previous_down[
                    key_value
                ] ~= true

            capture.previous_down[key_value] =
                is_down
        end

        if not pressed
            and can_read_pressed then

            local pressed_ok,
                pressed_result =
                    pcall(
                        input.is_key_pressed,
                        key_value
                    )

            pressed =
                pressed_ok
                and pressed_result == true
        end

        if pressed then
            if key_value ==
                (
                    keys.ESCAPE
                    or 0x1B
                ) then

                ui.control.cancel_tool_cycle_key_capture(
                    "Cancelled."
                )

                return true
            end

            ui.control.toggle_key =
                key_value

            ui.control.toggle_key_was_down =
                is_down == true

            ui.control.waiting_for_toggle_key =
                false

            capture.waiting_for_release = false
            capture.previous_down = {}

            ui.control.toggle_key_capture_status =
                "Tool cycle key set to " ..
                ui.control.get_key_name(
                    key_value
                ) ..
                "."

            return true
        end
    end

    return true
end

