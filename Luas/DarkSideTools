function chat_spammer.build_single_line_vertical_name(
    text_value
)
    local clean_name =
        sanitize_name(
            text_value
        )

    if clean_name == "" then
        return nil,
            false,
            0
    end

    local characters = {}
    local index = 1

    while index <= #clean_name do
        local first_byte =
            string.byte(
                clean_name,
                index
            )

        if not first_byte then
            break
        end

        local character_length = 1

        if first_byte >= 240 then
            character_length = 4
        elseif first_byte >= 224 then
            character_length = 3
        elseif first_byte >= 192 then
            character_length = 2
        end

        local character_end =
            index +
            character_length -
            1

        if character_end >
            #clean_name then

            character_end = index
        end

        characters[
            #characters + 1
        ] =
            clean_name:sub(
                index,
                character_end
            )

        index =
            character_end + 1
    end

    if #characters == 0 then
        return nil,
            false,
            0
    end


    local safe_byte_limit =
        DARKSIDE_CONFIG.MAX_NAME_LENGTH

    local full_length_with_leading = 0

    for _,
        character in ipairs(
            characters
        ) do

        full_length_with_leading =
            full_length_with_leading +
            1 +
            #character
    end


    local use_leading_separator =
        full_length_with_leading <=
        safe_byte_limit

    local output_parts = {}
    local output_length = 0
    local truncated = false

    for character_index,
        character in ipairs(
            characters
        ) do

        local needs_separator =
            use_leading_separator
            or character_index > 1

        local addition =
            needs_separator
            and (
                "\r" ..
                character
            )
            or character

        if output_length +
            #addition >
            safe_byte_limit then

            truncated = true
            break
        end

        output_parts[
            #output_parts + 1
        ] = addition

        output_length =
            output_length +
            #addition
    end

    if #output_parts <
        #characters then

        truncated = true
    end

    local final_name =
        table.concat(
            output_parts
        )

    if final_name == "" then
        return nil,
            truncated,
            0
    end

    return final_name,
        truncated,
        #final_name
end

function chat_spammer.apply_chat_message_as_name(
    message,
    label,
    vertical,
    source,
    source_index
)
    capture_initial_in_game_name()

    if not is_game_ready() then
        ui.console.print(
            "[Chat Spammer] Cannot change name while disconnected."
        )

        return false
    end

    local safe_name = nil
    local truncated = false
    local final_length = 0

    if vertical == true then
        safe_name,
            truncated,
            final_length =
                chat_spammer.build_single_line_vertical_name(
                    message
                )
    else
        local clean_name =
            sanitize_name(
                message
            )

        safe_name,
            truncated =
                chat_spammer.truncate_utf8_to_byte_limit(
                    clean_name,
                    DARKSIDE_CONFIG.MAX_NAME_LENGTH
                )

        final_length =
            #safe_name
    end

    if not safe_name
        or safe_name == "" then

        ui.console.print(
            "[Chat Spammer] Selected message produced an empty name."
        )

        return false
    end


    spammer_runtime.remember_requested_name(
        message,
        safe_name
    )

    client.execnormal(
        'setinfo name "' ..
        safe_name ..
        '"'
    )

    chat_spammer.set_chat_applied_name_state(
        source,
        source_index,
        vertical
    )

    spammer_runtime.last_applied =
        tostring(
            label or
            "Chat message"
        )

    ui.console.print(
        "[Chat Spammer] Applied as " ..
        (
            vertical
            and "vertical name: "
            or "name: "
        ) ..
        tostring(
            label or
            "Chat message"
        ) ..
        (
            truncated
            and (
                " (trimmed to " ..
                tostring(final_length) ..
                "/" ..
                tostring(
                    DARKSIDE_CONFIG.MAX_NAME_LENGTH
                ) ..
                " bytes)"
            )
            or ""
        )
    )

    return true
end

