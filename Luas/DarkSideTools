            end

            if type(
                palette.combo_active
            ) == "table" then

                active =
                    palette.combo_active
            end
        end
    end

    local pushed = 0

    local function try_push(
        index,
        color
    )
        local ok =
            pcall(
                imgui.push_style_color,
                index,
                color[1],
                color[2],
                color[3],
                color[4] or 1.0
            )

        if ok then
            pushed = pushed + 1
        end
    end


    try_push(
        24,
        normal
    )

    try_push(
        25,
        hovered
    )

    try_push(
        26,
        active
    )

    return pushed
end

function pop_neutral_combo_colors(count)
