            draw_scenario("Subtle: 0.25-0.40; recommended: 0.45-0.65; dramatic/blatant: 0.70-1.00.")
        end

        local changed_opacity,
            opacity_value =
                draw_float(
                    "Circle opacity:",
                    "##ControlFovCircleOpacity",
                    aim_settings.fov_circle_opacity,
                    0.15,
                    1.0
                )

