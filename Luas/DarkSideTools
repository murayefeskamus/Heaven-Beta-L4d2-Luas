function ui.enhancements.get_log_player_filter_data()
    local filters =
        ui.enhancements.log_filters

    local player_rows = {}

    for _, player_record in ipairs(
        ui.lobby.players or {}
    ) do
        player_rows[#player_rows + 1] =
            player_record
    end

    table.sort(
        player_rows,
        function(left, right)
            local left_name =
                tostring(
                    left.name or ""
                ):lower()

            local right_name =
                tostring(
                    right.name or ""
                ):lower()

            if left_name == right_name then
                return (tonumber(left.userid) or 0) <
                    (tonumber(right.userid) or 0)
            end

            return left_name < right_name
        end
    )

    local labels = {
        "All players"
    }

    local keys = {
        ""
    }

    local selected_index = 0

    for _, player_record in ipairs(
        player_rows
    ) do
        local userid =
            tonumber(
                player_record.userid
            ) or 0

        labels[#labels + 1] =
            "[ID: " ..
            (
                userid > 0
                and tostring(userid)
                or "N/A"
            ) ..
            "] " ..
            tostring(
                player_record.name or "Unknown"
            )

        keys[#keys + 1] =
            tostring(
                player_record.key or ""
            )

        if tostring(filters.player_key or "") ==
            tostring(player_record.key or "") then

            selected_index =
                #labels - 1
        end
    end

    if tostring(filters.player_key or "") ~= ""
        and selected_index == 0 then

        filters.player_key = ""
    end

    return labels,
        keys,
        selected_index
end

function ui.enhancements.get_log_player_names(
    player_key
)
    player_key =
        tostring(player_key or "")

    if player_key == "" then
        return {}
    end

    local player_record =
        ui.lobby.players_by_key[
            player_key
        ]

    local cached_record =
        ui.lobby.activity_cache[
            player_key
        ]

    local names = {}
    local seen = {}

    local function add_name(
        value
    )
        value = tostring(value or "")

        if value == "" then
            return
        end

        local normalized =
            value:lower()

        if seen[normalized] then
            return
        end

        seen[normalized] = true
        names[#names + 1] = value
    end

    add_name(
        player_record
        and player_record.name
        or nil
    )

    add_name(
        cached_record
        and cached_record.last_name
        or nil
    )

    local history_rows =
        player_record
        and player_record.name_history
        or (
            cached_record
            and cached_record.name_history
            or {}
        )

    for _, history_entry in ipairs(
        type(history_rows) == "table"
        and history_rows
        or {}
    ) do
        add_name(
            history_entry.old_name
        )

        add_name(
            history_entry.new_name
        )
    end

    return names
end

function ui.enhancements.get_filtered_history()
    local filters =
        ui.enhancements.log_filters

    local search =
        tostring(
            filters.search or ""
        ):lower()

    search =
        search:gsub(
            "^%s+",
            ""
        ):gsub(
            "%s+$",
            ""
        )

    local selected_player_key =
        tostring(
            filters.player_key or ""
        )

    local selected_player_names =
        ui.enhancements.get_log_player_names(
            selected_player_key
        )

    local filtered = {}

    for _, entry in ipairs(
        ui.lobby.history
    ) do
        local event_type =
            tostring(
                entry.event_type or "SYSTEM"
            ):upper()

        local filter_key =
            filters.enabled[
                event_type
            ] ~= nil
            and event_type
            or "SYSTEM"

        local matches_filter =
            filters.enabled[
                filter_key
            ] ~= false

        local searchable =
            event_type ..
            " " ..
            tostring(
                entry.message or ""
            )

        local searchable_lower =
            searchable:lower()

        local matches_search =
            search == ""
            or searchable_lower:find(
                search,
                1,
                true
            ) ~= nil

        local matches_player =
            selected_player_key == ""

        if not matches_player then
            for _, player_name in ipairs(
                selected_player_names
            ) do
                if searchable_lower:find(
                    tostring(player_name):lower(),
                    1,
                    true
                ) ~= nil then

                    matches_player = true
                    break
                end
            end
        end

        if matches_filter
            and matches_search
            and matches_player then

            table.insert(
                filtered,
                entry
            )
        end
    end

    return filtered
end

