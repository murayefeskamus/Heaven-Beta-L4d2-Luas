function ui.window_hotkeys.key_conflict_reason(
    target,
    key_value
)
    target = tostring(target or "")

    key_value =
        math.floor(
            tonumber(key_value) or 0
        )

    if key_value <= 0 then
        return "Choose a valid key."
    end

    if key_value ==
        (keys.ESCAPE or 0x1B) then

        return "Escape cancels key capture."
    end

    if target ~= "network"
        and ui.network.f5_toggle_enabled == true
        and key_value ==
            math.floor(
                tonumber(
                    ui.network.toggle_key
                ) or 0x74
            ) then

        return "Used by Game & Net."
    end

    if target ~= "quotes"
        and type(ui.quotes) == "table"
        and type(ui.quotes.settings) == "table"
        and ui.quotes.settings.f7_toggle_enabled == true
        and key_value ==
            math.floor(
                tonumber(
                    ui.quotes.settings.layout_toggle_key
                ) or 0x76
            ) then

        return "Used by Quotes."
    end

    if type(ui.quotes) == "table"
        and type(ui.quotes.settings) == "table"
        and ui.quotes.settings.hotkey_enabled == true
        and key_value ==
            math.floor(
                tonumber(
                    ui.quotes.settings.key
                ) or 0xBB
            ) then

        return "Used by the random quote hotkey."
    end

    if ui.control.f8_toggle_enabled == true
        and key_value ==
            math.floor(
                tonumber(
                    ui.control.toggle_key
                ) or 0x77
            ) then

        return "Used by the Control view toggle."
    end

    if key_value ==
        math.floor(
            tonumber(
                ui.control.action_key
            ) or 0
        ) then

        return "Used by the gameplay action key."
    end

    if ui.heaven_configs.enabled == true then
        if ui.heaven_configs.use_cycle_key == true then
            if key_value ==
                math.floor(
                    tonumber(
                        ui.heaven_configs.cycle_key
                    ) or 0
                ) then

                return "Used by the config cycle key."
            end
        else
            for index = 1, ui.heaven_configs.max_slots do
                local slot =
                    ui.heaven_configs.slots[index]

                if slot
                    and slot.enabled == true
                    and key_value ==
                        math.floor(
                            tonumber(
                                slot.key
                            ) or 0
                        ) then

                    return "Used by config hotkey " ..
                        tostring(index) ..
                        "."
                end
            end
        end
    end

    return nil
end

function ui.window_hotkeys.cancel_capture()
    ui.window_hotkeys.waiting_target = ""
    ui.window_hotkeys.capture_waiting_release = false
end

function ui.window_hotkeys.begin_capture(
    target
)
    target = tostring(target or "")

    if target ~= "network"
        and target ~= "quotes" then

        return false
    end

    if type(ui.heaven_configs.cancel_key_capture) == "function" then
        ui.heaven_configs.cancel_key_capture()
    end

    ui.control.waiting_for_key = false
    ui.control.waiting_for_pursuit_key = false
    ui.control.waiting_for_toggle_key = false

    ui.window_hotkeys.waiting_target =
        target

    local now = get_time()

    ui.window_hotkeys.capture_started_at = now
    ui.window_hotkeys.capture_ready_at = now + 0.08
    ui.window_hotkeys.capture_waiting_release = true

    return true
end

function ui.window_hotkeys.set_target_key(
    target,
    key_value
)
    target = tostring(target or "")

    key_value =
        math.max(
            1,
            math.min(
                255,
                math.floor(
                    tonumber(key_value) or 0
                )
            )
        )

    if target == "network" then
        ui.network.toggle_key = key_value
        ui.network.toggle_key_was_down = true
    elseif target == "quotes"
        and type(ui.quotes) == "table"
        and type(ui.quotes.settings) == "table" then

        ui.quotes.settings.layout_toggle_key =
            key_value

        ui.quotes.settings.layout_toggle_key_name =
            ui.control.get_key_name(
                key_value
            )

        ui.quotes.suppress_layout_toggle_until_release =
            true
    else
        return false
    end

    ui.window_hotkeys.save_settings_now()

    ui.console.print(
        "[DST] " ..
        ui.window_hotkeys.get_target_name(target) ..
        " key: " ..
        ui.control.get_key_name(key_value)
    )

    return true
end

function ui.window_hotkeys.capture_keybind()
    if ui.input_safety.block_runtime_hotkeys() then
        return
    end

    local target =
        tostring(
            ui.window_hotkeys.waiting_target
            or ""
        )

    if target == "" then
        return
    end

    if type(input) ~= "table"
        or type(input.is_key_pressed) ~= "function" then

        return
    end

    local now = get_time()

    if now -
        (
            tonumber(
                ui.window_hotkeys.capture_started_at
            ) or now
        ) >=
        math.max(
            2.0,
            tonumber(
                ui.window_hotkeys.capture_timeout
            ) or 10.0
        ) then

        ui.window_hotkeys.cancel_capture()

        ui.console.print(
            "[DST] Key binding timed out. Try again."
        )

        return
    end

    if ui.window_hotkeys.capture_waiting_release == true then
        if type(input.is_key_down) == "function" then
            local mouse_ok,
                mouse_down =
                    pcall(
                        input.is_key_down,
                        keys.MOUSE1 or 0x01
                    )

            if mouse_ok
                and mouse_down == true then

                return
            end
        end

        ui.window_hotkeys.capture_waiting_release = false
        ui.window_hotkeys.capture_ready_at = now + 0.04
        return
    end

    if now <
        (
            tonumber(
                ui.window_hotkeys.capture_ready_at
            ) or 0.0
        ) then

        return
    end

    local bindable_keys =
        type(ui.heaven_configs.get_bindable_keys) == "function"
        and ui.heaven_configs.get_bindable_keys()
        or {}

    for _, key_value in ipairs(bindable_keys) do
        local pressed_ok,
            pressed =
                pcall(
                    input.is_key_pressed,
                    key_value
                )

        if pressed_ok
            and pressed == true then

            if key_value ==
                (keys.ESCAPE or 0x1B) then

                ui.window_hotkeys.cancel_capture()

                ui.console.print(
                    "[DST] Key binding cancelled."
                )

                return
            end

            local conflict_reason =
                ui.window_hotkeys.key_conflict_reason(
                    target,
                    key_value
                )

            if conflict_reason then
                ui.console.print(
                    "[DST] " ..
                    tostring(conflict_reason)
                )

                ui.window_hotkeys.cancel_capture()
                return
            end

            ui.window_hotkeys.set_target_key(
                target,
                key_value
            )

            ui.window_hotkeys.cancel_capture()
            return
        end
    end
end

function ui.window_hotkeys.draw_binding_row(
