    if ui.control.nofall.enabled ~= true then
        return "OFF"
    end

    local status =
        tostring(
            ui.control.runtime.nofall_status
            or "Monitoring"
        )

    if status == ""
        or status == "Disabled" then

        return "ON"
    end

    return status
end

function ui.control.handle_toggle_key()
    if ui.input_safety.block_runtime_hotkeys() then
        ui.control.toggle_key_was_down = false
        return
    end

    if type(input) ~= "table"
        or type(input.is_key_down) ~= "function" then

        return
    end

    local key_ok,
        key_down =
            pcall(
                input.is_key_down,
                ui.control.toggle_key
            )

    key_down =
        key_ok
        and key_down == true

    if ui.control.f8_toggle_enabled
        and not ui.control.waiting_for_key
        and not ui.control.waiting_for_pursuit_key
        and key_down
        and not ui.control.toggle_key_was_down then

        if ui.control.speed.enabled
            and ui.control.aim.enabled then

            ui.control.set_active_mode(
                ui.control.active_mode == 0
                and 1
                or 0
            )
        elseif ui.control.speed.enabled then
            ui.control.set_active_mode(0)
        elseif ui.control.aim.enabled then
            ui.control.set_active_mode(1)
        else
            ui.control.set_active_mode(
                ui.control.active_mode == 0
                and 1
                or 0
            )
        end
    end

    ui.control.toggle_key_was_down =
        key_down
end

function ui.control.capture_keybind()
    if ui.input_safety.block_runtime_hotkeys() then
        return
    end

    if (not ui.control.waiting_for_key
            and not ui.control.waiting_for_pursuit_key)
        or type(input) ~= "table"
        or type(input.is_key_pressed) ~= "function" then

        return
    end

    for key_value, key_name in pairs(
        ui.control.key_names
    ) do
        local pressed_ok,
            pressed =
                pcall(
                    input.is_key_pressed,
                    key_value
                )

        if pressed_ok
            and pressed == true then

            if key_name == "ESC" then
                ui.control.waiting_for_key = false
                ui.control.waiting_for_pursuit_key = false
            elseif key_value ~= ui.control.toggle_key then
                if ui.control.waiting_for_pursuit_key then
                    ui.control.aim.v2.pursuit_key = key_value
                    ui.control.waiting_for_pursuit_key = false
                else
                    ui.control.action_key = key_value
                    ui.control.waiting_for_key = false
                end
            end

            return
        end
    end
end

