function ui.voice_control.set_all_players_muted(muted, from_chat)
    muted = muted == true

    local players =
        ui.voice_control.get_remote_human_players()

    if not muted then
        local copied = ui.voice_control.copy_console_command(
            "voice_reset_mutelist",
            from_chat
        )

        for _, player_record in ipairs(players) do
            ui.voice_control.set_player_tracked_muted(
                player_record,
                false
            )
        end

        return copied
    end

    if #players == 0 then
        local message = "No eligible players are connected."
        ui.voice_control.set_status(message, true)
        if from_chat then
            ui.voice_control.queue_command_response({ message })
        end
        return false
    end

    local commands = {}

    for _, player_record in ipairs(players) do
        commands[#commands + 1] =
            "voice_mute " ..
            tostring(ui.voice_control.get_voice_id(player_record))
    end

    local copied = ui.voice_control.copy_console_command(
        table.concat(commands, "; "),
        from_chat
    )

    for _, player_record in ipairs(players) do
        ui.voice_control.set_player_tracked_muted(
            player_record,
            true
        )
    end

    return copied
end

function ui.voice_control.show_mute_list(from_chat)
    local players =
        ui.voice_control.get_remote_human_players()

    local rows = {}

    if #players == 0 then
        rows[1] = "No eligible players are connected."
