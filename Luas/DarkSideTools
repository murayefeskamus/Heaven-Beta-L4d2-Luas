function ui.setting_search.is_action_term(term)
    local normalized = ui.setting_search.normalize(term)
    return ui.setting_search.action_terms[normalized] == true
end

function ui.setting_search.result_term_label(term)
    local label = tostring(term or "")
    label = label:gsub("##.*$", "")
    label = label:gsub("^%s+", ""):gsub("%s+$", "")
    label = label:gsub("%s*:%s*$", "")
    return label
end

function ui.setting_search.normalize(value)
    value = tostring(value or ""):lower()
    value = value:gsub("[_%-]+", " ")
    value = value:gsub("[^%w%s]", " ")
    value = value:gsub("%s+", " ")
    value = value:gsub("^%s+", ""):gsub("%s+$", "")
    return value
end

function ui.setting_search.tokenize(value)
    local tokens = {}
    for token in ui.setting_search.normalize(value):gmatch("%S+") do
        tokens[#tokens + 1] = token
    end
    return tokens
end

function ui.setting_search.section_label(tab_key, section_key)
    return ui.section_layout.get_section_label(tab_key, section_key)
end

function ui.setting_search.tab_label(tab_key)
    local tab = ui.section_layout.get_tab(tab_key)
    return tostring(tab and tab.label or tab_key)
end

function ui.setting_search.build_matches(query)
    local normalized_query = ui.setting_search.normalize(query)
    local tokens = ui.setting_search.tokenize(normalized_query)
    local results = {}

    if normalized_query == "" or #tokens == 0 then
        return results
    end

    for tab_key, section_groups in pairs(ui.setting_search.groups) do
        for section_key, terms in pairs(section_groups) do
            local tab_label = ui.setting_search.tab_label(tab_key)
            local section_label = ui.setting_search.section_label(tab_key, section_key)

            for _, term in ipairs(terms) do
                if not ui.setting_search.is_action_term(term) then
                    local normalized_term = ui.setting_search.normalize(term)
                    local haystack = ui.setting_search.normalize(
                        tostring(term) .. " " .. tab_label .. " " .. section_label
                    )
                    local all_tokens = true
                    local score = 0

                for _, token in ipairs(tokens) do
                    local position = haystack:find(token, 1, true)
                    if not position then
                        all_tokens = false
                        break
                    end

                    score = score + 18
                    if position == 1 then
                        score = score + 7
                    end
                end

                if all_tokens then
                    if normalized_term == normalized_query then
                        score = score + 140
                    elseif normalized_term:find(normalized_query, 1, true) == 1 then
                        score = score + 80
                    elseif normalized_term:find(normalized_query, 1, true) then
                        score = score + 45
                    end

                    local normalized_section =
                        ui.setting_search.normalize(section_label)
                    if normalized_section == normalized_query then
                        score = score + 120
                    elseif normalized_section:find(normalized_query, 1, true) then
                        score = score + 55
                    end

                    local display_term =
                        ui.setting_search.result_term_label(term)

                    results[#results + 1] = {
                        tab_key = tab_key,
                        section_key = section_key,
                        term = tostring(term),
                        display_term = display_term,
                        tab_label = tab_label,
                        section_label = section_label,
                        score = score,
                        display = tab_label .. " > " ..
                            section_label .. " > " .. display_term
                    }
                end
                end
            end
        end
    end

    table.sort(results, function(a, b)
        if tonumber(a.score) ~= tonumber(b.score) then
            return tonumber(a.score) > tonumber(b.score)
        end
        return tostring(a.display) < tostring(b.display)
    end)

    local deduplicated = {}
    local seen = {}
    for _, result in ipairs(results) do
        local key = ui.setting_search.normalize(result.term) .. "|" ..
            tostring(result.tab_key) .. "|" .. tostring(result.section_key)
        if not seen[key] then
            deduplicated[#deduplicated + 1] = result
            seen[key] = true
        end
        if #deduplicated >= 40 then
            break
        end
    end

    return deduplicated
end

function ui.setting_search.refresh_matches()
    ui.setting_search.matches =
        ui.setting_search.build_matches(ui.setting_search.query)

    ui.setting_search.selected_match =
        math.max(
            1,
            math.min(
                #ui.setting_search.matches > 0 and #ui.setting_search.matches or 1,
                math.floor(tonumber(ui.setting_search.selected_match) or 1)
            )
        )
end

