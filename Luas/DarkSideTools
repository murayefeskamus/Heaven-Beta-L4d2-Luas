function ui.enhancements.special_infected_route()
    return math.max(
        0,
        math.min(
            2,
            math.floor(
                tonumber(
                    ui.lobby.special_infected_announce_route
                ) or 0
            )
        )
    )
end

function ui.enhancements.send_special_infected_announcement(
    message
)
    if ui.lobby.special_infected_announcements_enabled ~= true then
        return false
    end

    if ui.lobby.special_infected_suppress_while_infected == true then
        local local_team = 0

        if type(ui.enhancements.local_player_team) == "function" then
            local_team =
                tonumber(
                    ui.enhancements.local_player_team()
                ) or 0
        end

        if local_team == 3 then
            return false
        end
    end

    local route =
        ui.enhancements.special_infected_route()

    if route == 1 then
        return ui.lobby.append_chat_message(
            message,
            false,
            0.05
        )
    elseif route == 2 then
        return ui.lobby.append_chat_message(
            message,
            true,
            0.05
        )
    end

    return false
end

function ui.enhancements.special_spawn_was_announced(
    identity,
    class_id
)
    local alerts =
        ui.enhancements.alerts

    local now = get_time()
    local key =
        tostring(identity or "unknown") ..
        ":" ..
        tostring(tonumber(class_id) or 0)

    local previous =
        alerts.recent_infected_spawns[key]

    if previous
        and now - previous < 2.0 then

        return true
    end

    alerts.recent_infected_spawns[key] = now

    for old_key, old_time in pairs(
        alerts.recent_infected_spawns
    ) do
        if now - old_time > 8.0 then
            alerts.recent_infected_spawns[old_key] = nil
        end
    end

    return false
end

function ui.enhancements.announce_verified_infected_spawn(
    userid,
    assignment,
    supplied_record
)
    if not assignment
        or not assignment.name then

        return false
    end

    userid = math.floor(
        tonumber(userid) or 0
    )

    local record = supplied_record

    if not record
        and userid > 0 then

        record =
            ui.lobby.find_player_by_userid(
                userid
            )
    end

    if not record
        and tonumber(assignment.player_index)
        and tonumber(assignment.player_index) > 0 then

        for _, player_record in ipairs(
            ui.lobby.players or {}
        ) do
            if tonumber(player_record.entity_index) ==
                tonumber(assignment.player_index) then

                record = player_record
                break
            end
        end
    end

    local identity =
        userid > 0
        and ("uid:" .. tostring(userid))
        or (
            "idx:" ..
            tostring(
                tonumber(assignment.player_index) or 0
            )
        )

    if ui.enhancements.special_spawn_was_announced(
        identity,
        assignment.id
    ) then
        return false
    end

    if assignment.name == "Tank" then
        if ui.enhancements.alerts.tank_announced == true then
            return false
        end

        ui.enhancements.alerts.tank_announced = true
    end

    local is_bot =
        record
        and record.is_bot == true
        or false

    if not record
        and tonumber(assignment.player_index)
        and tonumber(assignment.player_index) > 0 then

        local player_entity =
            entity.get_by_index(
                assignment.player_index
            )

        if player_entity then
            is_bot =
                name_stealer.is_player_bot(
                    assignment.player_index,
                    player_entity
                ) == true
        end
    end

    if is_bot
        and ui.lobby.special_infected_bot_announcements ~= true then

        return false
    end

    local player_name =
        record
        and tostring(record.name or "")
        or ""

    if player_name == ""
        and userid > 0 then

        player_name =
            tostring(
                get_player_name_from_userid(
                    userid
                ) or ""
            )
    end

    if player_name == "" then
        player_name = "Infected player"
    end

    local message =
        is_bot
        and ui.lobby.build_bot_special_infected_announcement(
            assignment.name
        )
        or ui.lobby.build_special_infected_announcement(
            player_name,
            assignment.name
        )

    ui.lobby.add_history(
        assignment.name == "Tank"
            and "TANK"
            or "SPAWN",
        message:gsub("%.$", "")
    )

    return ui.enhancements.send_special_infected_announcement(
        message
    )
end

function ui.enhancements.queue_verified_infected_spawn(
    userid,
    expected_class_id
)
    userid = math.floor(
        tonumber(userid) or 0
    )

    if userid <= 0 then
        return false
    end

    ui.lobby.pending_infected_spawns[
        tostring(userid)
    ] = {
        userid = userid,
        expected_class_id = tonumber(expected_class_id),
        started_at = get_time(),
        next_poll = get_time() + 0.02,
        last_class_id = nil,
        stable_reads = 0
    }

    return true
end

function ui.enhancements.process_verified_infected_spawns()
    local pending_spawns =
        ui.lobby.pending_infected_spawns

    if type(pending_spawns) ~= "table" then
        ui.lobby.pending_infected_spawns = {}
        return
    end

    local now = get_time()

    for spawn_key, pending in pairs(
        pending_spawns
    ) do
        if now >= (tonumber(pending.next_poll) or 0) then
            pending.next_poll =
                now +
                ui.lobby.infected_detection_poll_interval

            local assignment =
                ui.lobby.get_verified_infected_assignment(
                    pending.userid,
                    true
                )

            if assignment
                and (
                    pending.expected_class_id == nil
                    or assignment.id ==
                        pending.expected_class_id
                ) then

                if pending.last_class_id ==
                    assignment.id then

                    pending.stable_reads =
                        (tonumber(pending.stable_reads) or 0) + 1
                else
                    pending.last_class_id =
                        assignment.id

                    pending.stable_reads = 1
                end

                if pending.stable_reads >= 3 then
                    ui.enhancements.announce_verified_infected_spawn(
                        pending.userid,
                        assignment
                    )

                    pending_spawns[spawn_key] = nil
                end
            elseif now -
                (tonumber(pending.started_at) or now) >=
                ui.lobby.infected_detection_max_wait then


                pending_spawns[spawn_key] = nil
            end
        end
    end
end

function ui.enhancements.infected_spawn_identity(
    player_record
)
    if tonumber(player_record.userid)
        and tonumber(player_record.userid) > 0 then

        return "uid:" ..
            tostring(
                math.floor(
                    tonumber(player_record.userid)
                )
            )
    end

    return "idx:" ..
        tostring(
            math.floor(
                tonumber(player_record.entity_index) or 0
            )
        )
end

function ui.enhancements.scan_verified_infected_spawns()
    if not is_game_ready() then
        ui.lobby.infected_spawn_scan_states = {}
        ui.lobby.infected_spawn_scan_next = 0.0
        return
    end

    local now = get_time()

    if now <
        (tonumber(ui.lobby.infected_spawn_scan_next) or 0.0) then

        return
    end

    ui.lobby.infected_spawn_scan_next =
        now +
        math.max(
            0.05,
            tonumber(
                ui.lobby.infected_spawn_scan_interval
            ) or 0.12
        )

    local states =
        type(ui.lobby.infected_spawn_scan_states) == "table"
        and ui.lobby.infected_spawn_scan_states
        or {}

    ui.lobby.infected_spawn_scan_states = states

    local seen = {}

    for _, player_record in ipairs(
        ui.lobby.players or {}
    ) do
        if tonumber(player_record.team) == 3
            and tonumber(player_record.entity_index)
            and tonumber(player_record.entity_index) > 0 then

            local identity =
                ui.enhancements.infected_spawn_identity(
                    player_record
                )

            seen[identity] = true

            local state =
                states[identity]
                or {
                    last_class_id = nil,
                    stable_reads = 0,
                    active = false,
                    active_class_id = nil,
                    misses = 0
                }

            local assignment =
                ui.lobby.get_verified_infected_assignment_by_index(
                    player_record.entity_index,
                    true
                )

            if assignment then
                state.misses = 0

                if state.last_class_id == assignment.id then
                    state.stable_reads =
                        (tonumber(state.stable_reads) or 0) + 1
                else
                    state.last_class_id = assignment.id
                    state.stable_reads = 1
                end

                if state.stable_reads >= 3 then
                    local new_spawn =
                        state.active ~= true
                        or state.active_class_id ~= assignment.id

                    state.active = true
                    state.active_class_id = assignment.id

                    if new_spawn then
                        ui.enhancements.announce_verified_infected_spawn(
                            player_record.userid,
                            assignment,
                            player_record
                        )
                    end
                end
            else
                state.last_class_id = nil
                state.stable_reads = 0
                state.misses =
                    (tonumber(state.misses) or 0) + 1

                if state.misses >= 3 then
                    state.active = false
                    state.active_class_id = nil
                end
            end

            states[identity] = state
        end
    end

    for identity, state in pairs(states) do
        if not seen[identity] then
            state.misses =
                (tonumber(state.misses) or 0) + 1

            if state.misses >= 3 then
                states[identity] = nil
            end
        end
    end
end


function ui.enhancements.safe_register_event(event_name)
