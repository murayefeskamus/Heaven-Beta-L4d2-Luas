function get_next_roulette_label()
    local step =
        NAME_ROULETTE_STEPS[
            name_reverser.roulette_index
        ]

    if not step then
        return "Reverse"
    end

    return tostring(
        step.label or "Unknown"
    )
end

function advance_name_roulette()
    name_reverser.roulette_index =
        name_reverser.roulette_index + 1

    if name_reverser.roulette_index
        > #NAME_ROULETTE_STEPS then

        name_reverser.roulette_index = 1
    end
end

function apply_name_roulette_step()
    local source_name =
        name_reverser.roulette_base_name

    if source_name == "" then
        source_name =
            get_name_workshop_source()
            or ""
    end

    if source_name == "" then
        return false
    end

    local attempts = 0

    while attempts
        < #NAME_ROULETTE_STEPS do

        if name_reverser.roulette_index
            > #NAME_ROULETTE_STEPS then

            name_reverser.roulette_index = 1
        end

        local step =
            NAME_ROULETTE_STEPS[
                name_reverser.roulette_index
            ]

        if not step then
            return false
        end

        attempts =
            attempts + 1

        local result_name = nil

        if step.mode == "reverse" then
            clear_active_decoration_state()

            result_name =
                reverse_utf8_text(
                    source_name
                )
        elseif step.mode == "alternating" then
            clear_active_decoration_state()

            result_name =
                alternating_case_text(
                    source_name,
                    name_reverser.alternating_upper_next
                )

            name_reverser.alternating_upper_next =
                not name_reverser.alternating_upper_next
        elseif step.mode == "palindrome" then
            clear_active_decoration_state()

            result_name =
                build_palindrome_name(
                    source_name
                )
        elseif step.mode == "shuffle" then
            clear_active_decoration_state()

            result_name =
                shuffle_name_text(
                    source_name
                )
        elseif step.mode == "decoration" then
            local decoration_index =
                tonumber(
                    step.decoration_index
                ) or 1

            local base_name =
                strip_known_name_decorations(
                    source_name
                )

            result_name =
                build_decorated_name(
                    base_name,
                    decoration_index
                )

            name_reverser.active_decoration_index =
                decoration_index

            name_reverser.decoration_base_name =
                base_name
        end

        local step_label =
            tostring(
                step.label or "Unknown"
            )

        advance_name_roulette()


        if result_name
            and result_name ~= "" then

            return apply_name_workshop_result(
                result_name,
                "Roulette " ..
                step_label,
                source_name,
                false,
                step.mode == "decoration"
            )
        end
    end

    return false
end

function set_name_roulette_enabled(enabled)
    enabled =
        enabled == true

    if not enabled then
        name_reverser.roulette_enabled = false
        name_reverser.roulette_next_time = 0.0
        name_reverser.roulette_base_name = ""

        ui.console.print(
            "[Name Workshop] Name Roulette stopped."
        )

        return true
    end

    local source_name =
        get_name_workshop_source()

    if not source_name then
        return false
    end

    stop_name_spammer()
    stop_name_stealer()
    stop_chat_spammer()

    name_reverser.roulette_base_name =
        strip_known_name_decorations(
            source_name
        )

    name_reverser.roulette_enabled = true
    name_reverser.roulette_next_time =
        get_time()

    ui.console.print(
        "[Name Workshop] Name Roulette started."
    )

    return true
end

function update_name_roulette()
    if not name_reverser.roulette_enabled then
        return
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        return
    end

    local now =
        get_time()

    if now
        < name_reverser.roulette_next_time then

        return
    end

    apply_name_roulette_step()

    name_reverser.roulette_next_time =
        now +
        name_stealer.change_delay
end

function is_valid_candidate_name(
    name,
    allow_bot_names
)
    if not name
        or name == "" then

        return false
    end

    local normalized_name =
        normalize_candidate_name_for_filter(
            name
        )

    if normalized_name == ""
        or normalized_name == "unknown" then

        return false
    end


    if is_excluded_bot_name(
        normalized_name
    ) and allow_bot_names ~= true then
        return false
    end

    return true
end

function should_include_player(
    local_team,
    other_team
)
    if name_stealer.target_mode == 0 then
        return true
    elseif name_stealer.target_mode == 1 then
        return local_team == other_team
    end

    return local_team ~= other_team
end

function name_stealer.build_lobby_player_record(
    player_index,
    player,
    allow_bots
)
    player_index =
        tonumber(player_index) or 0

    if player_index <= 0
        or not player then

        return nil
    end

    local player_is_bot =
        name_stealer.is_player_bot(
            player_index,
            player
        )

    if player_is_bot
        and allow_bots ~= true then

        return nil
    end

    local player_info = nil

    pcall(
        function()
            player_info =
                engine.get_player_info(
                    player_index
                )
        end
    )

    local player_name = nil

    if player_info
        and player_info.name then

        player_name =
            tostring(
                player_info.name
            )
    end

    if not player_name
        or player_name == "" then

        pcall(
            function()
                player_name =
                    tostring(
                        player:get_name()
                        or ""
                    )
            end
        )
    end

    local clean_name =
        sanitize_name(
            player_name
        )

    if not is_valid_candidate_name(
        clean_name,
        player_is_bot and allow_bots == true
    ) then
        return nil
    end

    local team_number = 0

    pcall(
        function()
            team_number =
                tonumber(
                    player:get_team()
                ) or 0
        end
    )

    local userid = 0

    if player_info then
        local userid_fields = {
            "userid",
            "user_id",
            "userID",
            "UserID"
        }

        for _, field_name in ipairs(
            userid_fields
        ) do
            local field_value = nil

            pcall(
                function()
                    field_value =
                        player_info[
                            field_name
                        ]
                end
            )

            field_value =
                tonumber(field_value)

            if field_value
                and field_value > 0 then

                userid =
                    math.floor(
                        field_value
                    )

                break
            end
        end
    end

    local player_key = nil

    if ui.lobby
        and type(
            ui.lobby.make_player_key
        ) == "function" then

        player_key =
            ui.lobby.make_player_key(
                player_index,
                userid
            )
    elseif userid > 0 then
        player_key =
            "USERID:" ..
            tostring(userid)
    else
        player_key =
            "INDEX:" ..
            tostring(player_index)
    end

    return {
        key = tostring(player_key),
        name = clean_name,
        player_index = player_index,
        userid = userid,
        team = team_number,
        is_bot = player_is_bot == true
    }
end

function name_stealer.collect_lobby_player_records(
    local_player,
    allow_bots
)
    local records = {}

    if not local_player
        or not engine.is_in_game()
        or not engine.is_connected() then

        return records
    end

    local current_server =
        get_server_address()

    if current_server == "" then
        current_server =
            "CONNECTED SERVER"
    end

    if name_stealer.last_lobby_server ~= ""
        and current_server ~=
            name_stealer.last_lobby_server then

        name_stealer.player_overrides = {}

        if name_stealer.target_lock_enabled
            and type(
                name_stealer.stop_target_lock
            ) == "function" then

            name_stealer.stop_target_lock(
                "SERVER CHANGED",
                true
            )
        end
    end

    name_stealer.last_lobby_server =
        current_server

    local local_index =
        local_player:get_index()

    local max_clients =
        engine.get_max_clients()

    for player_index = 1,
        max_clients do

        if player_index ~= local_index then
            local player =
                entity.get_by_index(
                    player_index
                )

            if player then
                local record =
                    name_stealer.build_lobby_player_record(
                        player_index,
                        player,
                        allow_bots == true
                    )

                if record then
                    table.insert(
                        records,
                        record
                    )
                end
            end
        end
    end

    table.sort(
        records,
        function(first_record, second_record)
            local first_name =
                tostring(
                    first_record.name or ""
                ):lower()

            local second_name =
                tostring(
                    second_record.name or ""
                ):lower()

            if first_name == second_name then
                return (
                    tonumber(
                        first_record.player_index
                    ) or 0
                ) < (
                    tonumber(
                        second_record.player_index
                    ) or 0
                )
            end

            return first_name < second_name
        end
    )

    return records
end

function name_stealer.get_player_override(
    player_key
)
    local override_value =
        tonumber(
            name_stealer.player_overrides[
                tostring(player_key or "")
            ]
        ) or 0

    if override_value > 0 then
        return 1
    elseif override_value < 0 then
        return -1
    end

    return 0
end

function name_stealer.set_player_override(
    player_key,
    override_value
)
    player_key =
        tostring(player_key or "")

    if player_key == "" then
        return false
    end

    override_value =
        tonumber(override_value) or 0

    if override_value > 0 then
        name_stealer.player_overrides[
            player_key
        ] = 1
    elseif override_value < 0 then
        name_stealer.player_overrides[
            player_key
        ] = -1
    else
        name_stealer.player_overrides[
            player_key
        ] = nil
    end

    name_stealer.refresh_requested = true

    return true
end

function name_stealer.get_player_override_counts()
    local included_count = 0
    local ignored_count = 0

    for _, player_record in ipairs(
        name_stealer.lobby_players
    ) do
        local override_value =
            name_stealer.get_player_override(
                player_record.key
            )

        if override_value == 1 then
            included_count =
                included_count + 1
        elseif override_value == -1 then
            ignored_count =
                ignored_count + 1
        end
    end

    return included_count,
        ignored_count
end

function name_stealer.set_all_player_overrides(
    override_value
)
    override_value =
        tonumber(override_value) or 0

    if override_value > 0 then
        override_value = 1
    elseif override_value < 0 then
        override_value = -1
    else
        override_value = 0
    end

    if override_value == 0 then
        name_stealer.player_overrides = {}
    else
        local refreshed_overrides = {}

        for _, player_record in ipairs(
            name_stealer.lobby_players
        ) do
            local player_key =
                tostring(
                    player_record.key or ""
                )

            if player_key ~= "" then
                refreshed_overrides[
                    player_key
                ] = override_value
            end
        end

        name_stealer.player_overrides =
            refreshed_overrides
    end

    name_stealer.refresh_requested = true

    return true
end

function name_stealer.clear_player_overrides_by_value(
    override_value
)
    override_value =
        tonumber(override_value) or 0

    if override_value > 0 then
        override_value = 1
    elseif override_value < 0 then
        override_value = -1
    else
        return false
    end

    local changed = false

    for player_key,
        current_value in pairs(
            name_stealer.player_overrides
        ) do

        local normalized_value =
            tonumber(current_value) or 0

        if (
            override_value == 1
            and normalized_value > 0
        ) or (
            override_value == -1
            and normalized_value < 0
        ) then

            name_stealer.player_overrides[
                player_key
            ] = nil

            changed = true
        end
    end

    if changed then
        name_stealer.refresh_requested = true
    end

    return changed
end

function name_stealer.should_use_player_record(
    record,
    local_team
)
    if type(record) ~= "table" then
        return false
    end

    local override_value =
        name_stealer.get_player_override(
            record.key
        )

    if override_value == 1 then
        return true
    elseif override_value == -1 then
        return false
    end

    return should_include_player(
        local_team,
        tonumber(record.team) or 0
    )
end

function name_stealer.get_player_record_label(
