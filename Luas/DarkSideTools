function ui.control.capture_keybind()
    if ui.input_safety.block_runtime_hotkeys() then
        return
    end

    if (not ui.control.waiting_for_key
            and not ui.control.waiting_for_pursuit_key
            and not ui.control.waiting_for_toggle_key)
        or type(input) ~= "table"
        or type(input.is_key_pressed) ~= "function" then
        return
    end

    for key_value, key_name in pairs(ui.control.key_names) do
        local pressed_ok, pressed = pcall(input.is_key_pressed, key_value)

        if pressed_ok and pressed == true then
            if key_name == "ESC" then
                ui.control.waiting_for_key = false
                ui.control.waiting_for_pursuit_key = false
                ui.control.waiting_for_toggle_key = false
                ui.control.toggle_key_capture_status = "Cancelled."
                return
            end

            local action_key = math.floor(tonumber(ui.control.action_key) or 0)
            local pursuit_key = math.floor(tonumber(ui.control.aim.v2.pursuit_key) or 0)
            local cycle_key = math.floor(tonumber(ui.control.toggle_key) or 0)

            if ui.control.waiting_for_toggle_key then
                if key_value == action_key or key_value == pursuit_key then
                    ui.control.toggle_key_capture_status = "That key is already used by a Gameplay hold action."
                    return
                end

                ui.control.toggle_key = key_value
                ui.control.toggle_key_was_down = false
                ui.control.waiting_for_toggle_key = false
                ui.control.toggle_key_capture_status = "Tool cycle key set to " .. ui.control.get_key_name(key_value) .. "."
                return
            end

            if key_value == cycle_key then
                ui.control.toggle_key_capture_status = "That key is reserved for cycling Gameplay tools."
                return
            end

            if ui.control.waiting_for_pursuit_key then
                ui.control.aim.v2.pursuit_key = key_value
                ui.control.waiting_for_pursuit_key = false
                return
            end

            ui.control.action_key = key_value
            ui.control.waiting_for_key = false
            return
        end
    end
end

function ui.control.handle_toggle_key()
    if ui.input_safety.block_runtime_hotkeys() then
        ui.control.toggle_key_was_down = false
        return
    end

    if type(input) ~= "table" or type(input.is_key_down) ~= "function" then
        return
    end

    local key_ok, key_down = pcall(input.is_key_down, ui.control.toggle_key)
    key_down = key_ok and key_down == true

    local capture_active = ui.control.waiting_for_key
        or ui.control.waiting_for_pursuit_key
        or ui.control.waiting_for_toggle_key

    if ui.control.f8_toggle_enabled == true
        and not capture_active
        and key_down
        and not ui.control.toggle_key_was_down then

        if ui.control.speed.enabled == true and ui.control.aim.enabled == true then
            ui.control.set_active_mode(ui.control.active_mode == 0 and 1 or 0)
        elseif ui.control.speed.enabled == true then
            ui.control.set_active_mode(0)
        elseif ui.control.aim.enabled == true then
            ui.control.set_active_mode(1)
        end
    end

    ui.control.toggle_key_was_down = key_down
end

function ui.control.aim_v2_get_paint_screen_size()
    local function parse(first, second)
        local width = tonumber(first)
        local height = tonumber(second)

        if type(first) == "table" or type(first) == "userdata" then
            local function read(key)
                local ok, value = pcall(function() return first[key] end)
                return ok and tonumber(value) or nil
            end
            width = read("x") or read("width") or read(1)
            height = read("y") or read("height") or read(2)
        end

        if width and height and width > 0 and height > 0 then
            return width, height
        end
        return nil, nil
    end

    if type(engine) == "table" and type(engine.get_screen_size) == "function" then
        local ok, first, second = pcall(engine.get_screen_size)
        if ok then
            local width, height = parse(first, second)
            if width then return width, height end
        end
    end

    if type(draw) == "table" and type(draw.get_screen_size) == "function" then
        local ok, first, second = pcall(draw.get_screen_size)
        if ok then
            local width, height = parse(first, second)
            if width then return width, height end
        end
    end

    return nil, nil
end

function ui.control.aim_v2_draw_paint_line(x1, y1, x2, y2, red, green, blue, alpha)
    if type(draw) ~= "table" or type(draw.line) ~= "function" then
        return false
    end

    local ok, result = pcall(
        draw.line,
        math.floor(x1 + 0.5),
        math.floor(y1 + 0.5),
        math.floor(x2 + 0.5),
        math.floor(y2 + 0.5),
        red, green, blue, alpha
    )

    return ok and result ~= false
end

function ui.control.draw_fov_circle()
    local settings = ui.control.aim and ui.control.aim.v2 or nil
    local runtime = ui.control.runtime

    if not settings or settings.draw_fov_circle ~= true then
        runtime.fov_circle_status = "Disabled"
        runtime.fov_circle_renderer = "Not drawn"
        return false
    end

    ui.control.normalize_aim_v2_rebuilt_settings()

    if not ui.control.aim_v2_should_show_circle() then
        runtime.fov_circle_status = "Hidden by current visibility rule"
        runtime.fov_circle_renderer = "Not drawn"
        return false
    end

    if type(draw) ~= "table" or type(draw.line) ~= "function" then
        runtime.fov_circle_status = "Heaven draw.line is unavailable"
        runtime.fov_circle_renderer = "Unavailable"
        return false
    end

    local width, height = ui.control.aim_v2_get_paint_screen_size()
    if not width or not height then
        runtime.fov_circle_status = "Screen size unavailable"
        runtime.fov_circle_renderer = "Unavailable"
        return false
    end

    local center_x = width * 0.5
    local center_y = height * 0.5
    local radius = ui.control.calculate_fov_circle_radius(width, height, settings.fov)
        * ui.control.clamp(settings.fov_circle_scale, 0.50, 1.35)

    local locked = ui.control.has_aim_v2_session_target()
    local color = ui.control.resolve_fov_circle_color(settings, locked)

    if not color then
        local palette = ui.control.get_aim_v2_visual_palette()
        color = locked and palette.locked or palette.idle
    end

    color = ui.control.normalize_rgba_color(color, { 1.0, 1.0, 1.0, 1.0 })

    local red = math.floor(color[1] * 255.0 + 0.5)
    local green = math.floor(color[2] * 255.0 + 0.5)
    local blue = math.floor(color[3] * 255.0 + 0.5)
    local alpha = math.floor(
        ui.control.clamp(settings.fov_circle_opacity, 0.15, 1.0) * 255.0 + 0.5
    )

    local quality = math.max(1, math.min(4, math.floor(tonumber(settings.fov_circle_quality) or 3)))
    local segment_map = { 48, 72, 96, 128 }
    local segments = segment_map[quality]
    local thickness = math.max(1, math.min(4, math.floor(tonumber(settings.fov_circle_thickness) or 2)))

    local all_ok = true

    if settings.fov_circle_glow == true then
        local glow_strength = ui.control.clamp(settings.fov_circle_glow_strength, 0.0, 1.0)
        for glow_ring = 3, 1, -1 do
            local glow_radius = radius + thickness * 0.75 + glow_ring * 1.6
            local glow_alpha = math.max(1, math.floor(alpha * glow_strength * (0.22 / glow_ring) + 0.5))
            local previous_x = center_x + glow_radius
            local previous_y = center_y

            for segment = 1, segments do
                local angle = segment / segments * math.pi * 2.0
                local next_x = center_x + math.cos(angle) * glow_radius
                local next_y = center_y + math.sin(angle) * glow_radius
                if not ui.control.aim_v2_draw_paint_line(
                    previous_x, previous_y, next_x, next_y,
                    red, green, blue, glow_alpha
                ) then
                    all_ok = false
                    break
                end
                previous_x, previous_y = next_x, next_y
            end

            if not all_ok then break end
        end
    end

    if all_ok then
        for layer = 1, thickness do
            local offset = (layer - (thickness + 1) * 0.5) * 1.25
            local ring_radius = math.max(2.0, radius + offset)
            local previous_x = center_x + ring_radius
            local previous_y = center_y

            for segment = 1, segments do
                local angle = segment / segments * math.pi * 2.0
                local next_x = center_x + math.cos(angle) * ring_radius
                local next_y = center_y + math.sin(angle) * ring_radius
                if not ui.control.aim_v2_draw_paint_line(
                    previous_x, previous_y, next_x, next_y,
                    red, green, blue, alpha
                ) then
                    all_ok = false
                    break
                end
                previous_x, previous_y = next_x, next_y
            end

            if not all_ok then break end
        end
    end

    if settings.fov_circle_center_dot == true and all_ok then
        local marker = 3.0 + thickness
        ui.control.aim_v2_draw_paint_line(
            center_x - marker, center_y, center_x + marker, center_y,
            red, green, blue, alpha
        )
        ui.control.aim_v2_draw_paint_line(
            center_x, center_y - marker, center_x, center_y + marker,
            red, green, blue, alpha
        )
    end

    runtime.fov_circle_radius = radius
    runtime.fov_circle_state = locked and "Locked" or "Unlocked"
    runtime.fov_circle_selected_hex = ui.control.color_to_hex(color)
    runtime.fov_circle_submitted_hex = runtime.fov_circle_selected_hex
    runtime.fov_circle_predicted_hex = runtime.fov_circle_selected_hex
    runtime.fov_circle_draw_order = "Standard RGB"
    runtime.fov_circle_color_profile = "Direct picker RGB"
    runtime.fov_circle_color_profile_status = "No channel swap or color compensation"
    runtime.fov_circle_render_stage = "Paint - reliable"
    runtime.fov_circle_renderer = all_ok and "Continuous draw.line outline" or "Failed"
    runtime.fov_circle_status = all_ok
        and string.format(
            "%s | %s | thickness %d | quality %d",
            runtime.fov_circle_state,
            runtime.fov_circle_selected_hex,
            thickness,
            quality
        )
        or "Circle draw failed"

    return all_ok
end

