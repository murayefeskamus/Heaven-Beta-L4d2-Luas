function ui.control.aim_boundary_screen_metrics(settings)
    settings = settings or ui.control.normalize_aim_v2_rebuilt_settings()

    local width, height = ui.control.aim_v2_get_paint_screen_size()
    width = tonumber(width)
    height = tonumber(height)

    if not width or not height or width <= 1.0 or height <= 1.0 then
        return nil
    end

    local radius = ui.control.calculate_fov_circle_radius(
        width,
        height,
        tonumber(settings.fov) or 120.0
    ) * (tonumber(settings.fov_circle_scale) or 1.0)

    radius = ui.control.clamp(
        radius,
        4.0,
        math.sqrt(width * width + height * height) * 0.49
    )

    local requested_fov = ui.control.clamp(
        tonumber(ui.control.get_camera_fov()) or 90.0,
        60.0,
        140.0
    )
    local aspect = width / height
    local reference_aspect = 4.0 / 3.0
    local vertical_fov = 2.0 * math.atan(
        math.tan(math.rad(requested_fov) * 0.5) / reference_aspect
    )
    local horizontal_fov = 2.0 * math.atan(
        math.tan(vertical_fov * 0.5) * aspect
    )
    local focal_x = width / (2.0 * math.tan(horizontal_fov * 0.5))
    local focal_y = height / (2.0 * math.tan(vertical_fov * 0.5))

    return {
        width = width,
        height = height,
        center_x = width * 0.5,
        center_y = height * 0.5,
        radius = radius,
        focal_x = focal_x,
        focal_y = focal_y
    }
end

function ui.control.aim_boundary_project_angle(current_angles, aim_angle, settings)
    if not current_angles or not aim_angle then return nil end

    local metrics = ui.control.aim_boundary_screen_metrics(settings)
    if not metrics then return nil end

    local pitch_delta = ui.control.normalize_angle(
        (tonumber(aim_angle.x) or 0.0) - (tonumber(current_angles.x) or 0.0)
    )
    local yaw_delta = ui.control.normalize_angle(
        (tonumber(aim_angle.y) or 0.0) - (tonumber(current_angles.y) or 0.0)
    )

    local pitch = math.rad(pitch_delta)
    local yaw = math.rad(yaw_delta)
    local cos_pitch = math.cos(pitch)
    local forward = cos_pitch * math.cos(yaw)

    if forward <= 0.0001 then
        return nil
    end

    local right = cos_pitch * math.sin(yaw)
    local up = -math.sin(pitch)
    local offset_x = metrics.focal_x * (right / forward)
    local offset_y = metrics.focal_y * (up / forward)
    local radial_distance = math.sqrt(
        offset_x * offset_x + offset_y * offset_y
    )

    return {
        x = metrics.center_x + offset_x,
        y = metrics.center_y + offset_y,
        offset_x = offset_x,
        offset_y = offset_y,
        distance = radial_distance,
        radius = metrics.radius,
        inside = radial_distance <= metrics.radius
    }
end

function ui.control.aim_boundary_target_inside(settings, current_angles, target)
    settings = settings or ui.control.normalize_aim_v2_rebuilt_settings()

    if (tonumber(settings.fov_level) or 1) >= 10
        or (tonumber(settings.fov) or 0.0) >= 359.5 then
        return true, 0.0, math.huge, "360-degree mode"
    end

    local projected = ui.control.aim_boundary_project_angle(
        current_angles,
        target and target.aim_angle,
        settings
    )

    if projected then
        return projected.inside == true,
            projected.distance,
            projected.radius,
            "screen boundary"
    end

    local angular_fov = tonumber(target and target.fov) or math.huge
    local conservative_limit = math.min(
        tonumber(settings.fov) or 30.0,
        45.0
    )
    return angular_fov <= conservative_limit,
        angular_fov,
        conservative_limit,
        "conservative angular fallback"
end

function ui.control.aim_guided_collect_targets(
    local_player,
    settings,
    current_angles,
    ignore_fov
)
    local standing = {}
    local downed = {}
    local local_index = tonumber(
        ui.lobby.call_method(local_player, "get_index")
    ) or -1
    local maximum_clients = tonumber(engine.get_max_clients()) or 0

    for player_index = 1, maximum_clients do
        local player = entity.get_by_index(player_index)

        if player then
            local valid = ui.control.is_valid_survivor(
                player,
                local_index,
                settings.target_incapacitated == true,
                settings.target_hanging == true
            )

            if valid == true then
                local target = ui.control.aim_v2_simple_build_target(
                    local_player,
                    player_index,
                    settings,
                    current_angles,
                    true
                )

                if target
                    and tonumber(target.distance) <= tonumber(settings.max_distance) then
                    local within_fov = true
                    local boundary_distance = 0.0
                    local boundary_radius = math.huge
                    local boundary_mode = "held / cycle"

                    if ignore_fov ~= true then
                        within_fov,
                        boundary_distance,
                        boundary_radius,
                        boundary_mode = ui.control.aim_boundary_target_inside(
                            settings,
                            current_angles,
                            target
                        )
                    end

                    local visible = true
                    if within_fov and settings.visible_only == true then
                        local eye_position = ui.control.aim_v2_simple_get_eye_position(
                            local_player
                        )
                        visible = eye_position ~= nil
                            and ui.control.is_target_visible(
                                local_player,
                                player,
                                eye_position,
                                target.aim_position,
                                player_index
                            ) == true
                    end

                    if within_fov and visible then
                        target.boundary_distance = boundary_distance
                        target.boundary_radius = boundary_radius
                        target.boundary_mode = boundary_mode

                        if target.incapacitated == true or target.hanging == true then
                            table.insert(downed, target)
                        else
                            table.insert(standing, target)
                        end
                    end
                end
            end
        end
    end

    local function nearest_first(left, right)
        local left_distance = tonumber(left.distance) or math.huge
        local right_distance = tonumber(right.distance) or math.huge
        if left_distance == right_distance then
            return (tonumber(left.index) or 0) < (tonumber(right.index) or 0)
        end
        return left_distance < right_distance
    end

    table.sort(standing, nearest_first)
    table.sort(downed, nearest_first)

    return standing, downed
end

