    local signature =
        tostring(tab_key or "") ..
        "/" ..
        tostring(section_key or "") ..
        ":" ..
        tostring(error_message or "")

    if signature == ui.section_layout.command_permission_last_renderer_error
        and now < ui.section_layout.command_permission_last_renderer_error_time + 2.0 then
        return
    end

    ui.section_layout.command_permission_last_renderer_error = signature
    ui.section_layout.command_permission_last_renderer_error_time = now

