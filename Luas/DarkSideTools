function ui.lobby.get_sorted_counter_rows(
    counters
)
    local rows = {}

    for counter_name, counter_value in pairs(
        counters or {}
    ) do
        counter_value =
            math.max(
                0,
                tonumber(counter_value) or 0
            )

        if counter_value > 0 then
            table.insert(
                rows,
                {
                    name =
                        tostring(counter_name),
                    value =
                        counter_value
                }
            )
        end
    end

    table.sort(
        rows,
        function(left, right)
            if left.value == right.value then
                return left.name:lower()
                    < right.name:lower()
            end

            return left.value > right.value
        end
    )

    return rows
end

function ui.lobby.claim_boss_kill(
    boss_name,
    attacker_userid
)
    boss_name = tostring(boss_name or "Boss")
    attacker_userid = tonumber(attacker_userid) or 0

    local now = get_time()
    local key =
        boss_name:lower() ..
        ":" ..
        tostring(attacker_userid)

    local previous =
        ui.lobby.recent_boss_kills[
            key
        ]

    if previous
        and now - previous <
            ui.lobby.boss_kill_dedup_window then

        return false
    end

    ui.lobby.recent_boss_kills[key] = now

    for old_key, old_time in pairs(
        ui.lobby.recent_boss_kills
    ) do
        if now - old_time > 6.0 then
            ui.lobby.recent_boss_kills[old_key] = nil
        end
    end

    return true
end

