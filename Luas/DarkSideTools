function ui.control.capture_keybind()
    if ui.input_safety.block_runtime_hotkeys() then return end

    local capture_active = ui.control.waiting_for_key
        or ui.control.waiting_for_pursuit_key
        or ui.control.waiting_for_toggle_key
        or ui.control.waiting_for_target_cycle_key

    if not capture_active
        or type(input) ~= "table"
        or type(input.is_key_pressed) ~= "function" then
        return
    end

    for key_value, key_name in pairs(ui.control.key_names) do
        local pressed_ok, pressed = pcall(input.is_key_pressed, key_value)

        if pressed_ok and pressed == true then
            if key_name == "ESC" then
                ui.control.waiting_for_key = false
                ui.control.waiting_for_pursuit_key = false
                ui.control.waiting_for_toggle_key = false
                ui.control.waiting_for_target_cycle_key = false
                ui.control.toggle_key_capture_status = "Cancelled."
                ui.control.target_cycle_key_capture_status = "Cancelled."
                return
            end

            local action_key = math.floor(tonumber(ui.control.action_key) or 0)
            local pursuit_key = math.floor(tonumber(ui.control.aim.v2.pursuit_key) or 0)
            local tool_cycle_key = math.floor(tonumber(ui.control.toggle_key) or 0)
            local target_cycle_key = math.floor(
                tonumber(ui.control.aim.v2.target_cycle_key) or 0
            )

            if ui.control.waiting_for_target_cycle_key then
                if key_value == action_key then
                    ui.control.target_cycle_key_capture_status =
                        "That key is already used by the Aim/Gameplay hold action."
                    return
                end

                if key_value == tool_cycle_key then
                    ui.control.target_cycle_key_capture_status =
                        "That key is already used to cycle gameplay tools."
                    return
                end

                if key_value == pursuit_key
                    and ui.control.aim.v2.pursuit_use_shared_key == false then
                    ui.control.target_cycle_key_capture_status =
                        "That key is already used by Auto-follow."
                    return
                end

                ui.control.aim.v2.target_cycle_key = key_value
                ui.control.waiting_for_target_cycle_key = false
                ui.control.runtime.target_cycle_key_was_down = false
                ui.control.target_cycle_key_capture_status =
                    "Target cycle key set to " .. ui.control.get_key_name(key_value) .. "."
                return
            end

            if ui.control.waiting_for_toggle_key then
                if key_value == action_key
                    or key_value == pursuit_key
                    or key_value == target_cycle_key then
                    ui.control.toggle_key_capture_status =
                        "That key is already used by a gameplay action."
                    return
                end

                ui.control.toggle_key = key_value
                ui.control.toggle_key_was_down = false
                ui.control.waiting_for_toggle_key = false
                ui.control.toggle_key_capture_status =
                    "Tool cycle key set to " .. ui.control.get_key_name(key_value) .. "."
                return
            end

            if key_value == tool_cycle_key then
                ui.control.toggle_key_capture_status =
                    "That key is reserved for cycling Gameplay tools."
                return
            end

            if key_value == target_cycle_key and target_cycle_key > 0 then
                ui.control.target_cycle_key_capture_status =
                    "That key is reserved for cycling Aim V2 targets."
                return
            end

            if ui.control.waiting_for_pursuit_key then
                ui.control.aim.v2.pursuit_key = key_value
                ui.control.waiting_for_pursuit_key = false
                return
            end

            ui.control.action_key = key_value
            ui.control.waiting_for_key = false
            return
        end
    end
end

function ui.control.handle_toggle_key()
    if ui.input_safety.block_runtime_hotkeys() then
        ui.control.toggle_key_was_down = false
        return
    end

    if type(input) ~= "table" or type(input.is_key_down) ~= "function" then
        return
    end

    local key_ok, key_down = pcall(input.is_key_down, ui.control.toggle_key)
    key_down = key_ok and key_down == true

    local capture_active = ui.control.waiting_for_key
        or ui.control.waiting_for_pursuit_key
        or ui.control.waiting_for_toggle_key
        or ui.control.waiting_for_target_cycle_key

    if ui.control.f8_toggle_enabled == true
        and not capture_active
        and key_down
        and not ui.control.toggle_key_was_down then
        if ui.control.speed.enabled == true and ui.control.aim.enabled == true then
            ui.control.set_active_mode(ui.control.active_mode == 0 and 1 or 0)
        elseif ui.control.speed.enabled == true then
            ui.control.set_active_mode(0)
        elseif ui.control.aim.enabled == true then
            ui.control.set_active_mode(1)
        end
    end

    ui.control.toggle_key_was_down = key_down
end

function ui.control.aim_guided_poll_cycle_key(settings)
    local runtime = ui.control.runtime
    local key_value = math.floor(tonumber(settings.target_cycle_key) or 0)

    if key_value <= 0
        or ui.control.waiting_for_target_cycle_key
        or ui.input_safety.block_runtime_hotkeys()
        or type(input) ~= "table"
        or type(input.is_key_down) ~= "function" then
        runtime.target_cycle_key_was_down = false
        return false
    end

    local key_ok, key_down = pcall(input.is_key_down, key_value)
    key_down = key_ok and key_down == true
    local pressed = key_down and runtime.target_cycle_key_was_down ~= true
    runtime.target_cycle_key_was_down = key_down

    return pressed
        and runtime.lock_session_active == true
        and ui.control.is_action_key_down()
end

function ui.control.aim_guided_collect_targets(
    local_player,
    settings,
    current_angles,
    ignore_fov
)
    local standing = {}
    local downed = {}
    local local_index = tonumber(
        ui.lobby.call_method(local_player, "get_index")
    ) or -1
    local maximum_clients = tonumber(engine.get_max_clients()) or 0

    for player_index = 1, maximum_clients do
        local player = entity.get_by_index(player_index)

        if player then
            local valid = ui.control.is_valid_survivor(
                player,
                local_index,
                settings.target_incapacitated == true,
                settings.target_hanging == true
            )

            if valid == true then
                local target = ui.control.aim_v2_simple_build_target(
                    local_player,
                    player_index,
                    settings,
                    current_angles,
                    true
                )

                if target
                    and tonumber(target.distance) <= tonumber(settings.max_distance) then
                    local within_fov = ignore_fov == true
                        or tonumber(target.fov) <= tonumber(settings.fov)
                    local visible = true

                    if within_fov and settings.visible_only == true then
                        local eye_position = ui.control.aim_v2_simple_get_eye_position(
                            local_player
                        )
                        visible = eye_position ~= nil
                            and ui.control.is_target_visible(
                                local_player,
                                player,
                                eye_position,
                                target.aim_position,
                                player_index
                            ) == true
                    end

                    if within_fov and visible then
                        if target.incapacitated == true or target.hanging == true then
                            table.insert(downed, target)
                        else
                            table.insert(standing, target)
                        end
                    end
                end
            end
        end
    end

    local function nearest_first(left, right)
        local left_distance = tonumber(left.distance) or math.huge
        local right_distance = tonumber(right.distance) or math.huge
        if left_distance == right_distance then
            return (tonumber(left.index) or 0) < (tonumber(right.index) or 0)
        end
        return left_distance < right_distance
    end

    table.sort(standing, nearest_first)
    table.sort(downed, nearest_first)

    return standing, downed
end

function ui.control.aim_guided_commit_target(target, reason)
    if not target then return nil end

    local runtime = ui.control.runtime
    runtime.lock_session_target_index = target.index
    runtime.lock_session_target_userid = target.userid or 0
    runtime.lock_session_target_name = ui.control.get_target_name(target.index)
    runtime.locked_target_index = target.index
    runtime.lock_session_status = reason or "Held until key release"
    runtime.simple_cached_aim_position = nil
    runtime.simple_cached_target_origin = nil
    runtime.filtered_target_angle = nil
    runtime.last_target_switch_time = get_time()
    runtime.target_cycle_notice = reason or "Target changed."
    runtime.target_cycle_notice_until = get_time() + 2.0

    return target
end

function ui.control.aim_guided_next_target(candidates, current_index)
    if type(candidates) ~= "table" or #candidates == 0 then return nil end

    current_index = math.floor(tonumber(current_index) or 0)
    for position, target in ipairs(candidates) do
        if tonumber(target.index) == current_index then
            return candidates[position % #candidates + 1]
        end
    end

    return candidates[1]
end

function ui.control.get_best_target_v2(local_player, settings, current_angles)
    local runtime = ui.control.runtime
    local held_index = math.floor(tonumber(runtime.lock_session_target_index) or 0)
    local cycle_requested = ui.control.aim_guided_poll_cycle_key(settings)

    if runtime.lock_session_active == true and held_index > 0 then
        local standing, downed = ui.control.aim_guided_collect_targets(
            local_player,
            settings,
            current_angles,
            true
        )
        local eligible = #standing > 0 and standing or downed

        if cycle_requested then
            local next_target = ui.control.aim_guided_next_target(eligible, held_index)
            if next_target and tonumber(next_target.index) ~= held_index then
                return ui.control.aim_guided_commit_target(
                    next_target,
                    "Cycled to next target"
                )
            end

            runtime.target_cycle_notice = "No other eligible target."
            runtime.target_cycle_notice_until = get_time() + 2.0
        end

        local current_target = ui.control.aim_v2_simple_build_target(
            local_player,
            held_index,
            settings,
            current_angles,
            true
        )

        if current_target then
            local expected_userid = math.floor(
                tonumber(runtime.lock_session_target_userid) or 0
            )
            local identity_matches = expected_userid <= 0
                or current_target.userid <= 0
                or expected_userid == current_target.userid

            if identity_matches then
                if (current_target.incapacitated == true
                        or current_target.hanging == true)
                    and #standing > 0 then
                    return ui.control.aim_guided_commit_target(
                        standing[1],
                        "Smart switch: nearest standing survivor"
                    )
                end

                return current_target
            end
        end

        if #eligible > 0 then
            return ui.control.aim_guided_commit_target(
                eligible[1],
                "Smart switch: previous target unavailable"
            )
        end

        local cached_position = runtime.simple_cached_aim_position
        local eye_position = ui.control.aim_v2_simple_get_eye_position(local_player)

        if cached_position and eye_position then
            local aim_angle = ui.control.calculate_angle(eye_position, cached_position)
            if aim_angle then
                return {
                    player = nil,
                    index = held_index,
                    userid = runtime.lock_session_target_userid or 0,
                    aim_position = cached_position,
                    target_origin = runtime.simple_cached_target_origin or cached_position,
                    aim_angle = aim_angle,
                    distance = vector.distance(
                        eye_position,
                        runtime.simple_cached_target_origin or cached_position
                    ),
                    fov = ui.control.get_fov(current_angles, aim_angle),
                    prediction_time = 0.0,
                    incapacitated = false,
                    hanging = false,
                    held = true,
                    cached = true,
                    score = 0.0
                }
            end
        end

        return nil
    end

    local standing, downed = ui.control.aim_guided_collect_targets(
        local_player,
        settings,
        current_angles,
        false
    )
    local eligible = #standing > 0 and standing or downed

    return eligible[1]
end

function ui.control.aim_guided_candidate_clearance(
    origin,
    candidate_yaw,
    lookahead,
    local_player,
    target_index,
    ledge_safety
)
    local radians = math.rad(candidate_yaw)
    local direction_x = math.cos(radians)
    local direction_y = math.sin(radians)
    local low_start = vector.new(origin.x, origin.y, origin.z + 18.0)
    local high_start = vector.new(origin.x, origin.y, origin.z + 50.0)
    local low_end = vector.new(
        low_start.x + direction_x * lookahead,
        low_start.y + direction_y * lookahead,
        low_start.z
    )
    local high_end = vector.new(
        high_start.x + direction_x * lookahead,
        high_start.y + direction_y * lookahead,
        high_start.z
    )
    local low_fraction = ui.control.pursuit_trace(
        low_start,
        low_end,
        local_player,
        target_index
    )
    local high_fraction = ui.control.pursuit_trace(
        high_start,
        high_end,
        local_player,
        target_index
    )
    local ground_safe = true

    if ledge_safety == true then
        local middle_point = vector.new(
            origin.x + direction_x * lookahead * 0.45,
            origin.y + direction_y * lookahead * 0.45,
            origin.z
        )
        local far_point = vector.new(
            origin.x + direction_x * lookahead * 0.78,
            origin.y + direction_y * lookahead * 0.78,
            origin.z
        )
        ground_safe = ui.control.pursuit_ground_supported(
            middle_point,
            local_player
        ) and ui.control.pursuit_ground_supported(
            far_point,
            local_player
        )
    end

    return ui.control.clamp(
        math.min(tonumber(low_fraction) or 1.0, tonumber(high_fraction) or 1.0),
        0.0,
        1.0
    ),
    ui.control.clamp(tonumber(low_fraction) or 1.0, 0.0, 1.0),
    ui.control.clamp(tonumber(high_fraction) or 1.0, 0.0, 1.0),
    ground_safe
end

function ui.control.apply_pursuit_bot(command, local_player)
    local settings = ui.control.normalize_aim_v2_rebuilt_settings()
    local runtime = ui.control.runtime

    if tonumber(ui.control.aim.mode) ~= 1
        or settings.pursuit_enabled ~= true then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Disabled"
        return false
    end

    if not ui.control.is_action_key_down()
        or runtime.lock_session_active ~= true
        or tonumber(runtime.lock_session_target_index) <= 0 then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Waiting for lock"
        runtime.pursuit_stuck_time = 0.0
        runtime.pursuit_recovery_until = 0.0
        return false
    end

    if settings.pursuit_manual_override == true
        and ui.control.aim_v2_simple_manual_movement_down() then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Manual movement override"
        runtime.pursuit_stuck_time = 0.0
        return false
    end

    local target_index = math.floor(
        tonumber(runtime.lock_session_target_index) or 0
    )
    local target_player = entity.get_by_index(target_index)
    local origin = ui.lobby.call_method(local_player, "get_origin")
    local target_origin = target_player
        and ui.lobby.call_method(target_player, "get_origin")
        or runtime.simple_cached_target_origin

    if not origin or not target_origin then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Position unavailable"
        return false
    end

    local target_velocity = target_player
        and ui.lobby.call_method(target_player, "get_velocity")
        or nil
    local raw_dx = target_origin.x - origin.x
    local raw_dy = target_origin.y - origin.y
    local raw_distance = math.sqrt(raw_dx * raw_dx + raw_dy * raw_dy)

    if target_velocity and settings.pursuit_target_lead ~= false then
        local lead_time = ui.control.clamp(
            tonumber(settings.pursuit_target_lead_time) or 0.18,
            0.0,
            0.45
        ) * ui.control.clamp((raw_distance - 64.0) / 420.0, 0.0, 1.0)
        target_origin = vector.new(
            target_origin.x + (tonumber(target_velocity.x) or 0.0) * lead_time,
            target_origin.y + (tonumber(target_velocity.y) or 0.0) * lead_time,
            target_origin.z
        )
        runtime.pursuit_target_lead_used = lead_time
    else
        runtime.pursuit_target_lead_used = 0.0
    end

    local dx = target_origin.x - origin.x
    local dy = target_origin.y - origin.y
    local horizontal_distance = math.sqrt(dx * dx + dy * dy)
    local desired_yaw = horizontal_distance > 5.0
        and math.deg(math.atan(dy, dx))
        or (tonumber(runtime.pursuit_last_target_yaw) or 0.0)

    if horizontal_distance > 5.0 then
        runtime.pursuit_last_target_yaw = desired_yaw
    end

    local velocity = ui.lobby.call_method(local_player, "get_velocity")
    local current_speed = 0.0
    if velocity then
        local velocity_x = tonumber(velocity.x) or 0.0
        local velocity_y = tonumber(velocity.y) or 0.0
        current_speed = math.sqrt(velocity_x * velocity_x + velocity_y * velocity_y)
    end

    local avoidance_level = ui.control.aim_v2_clamp_level(
        settings.pursuit_avoidance_level,
        7,
        10
    )
    local lookahead = ui.control.clamp(
        68.0 + avoidance_level * 24.0
            + current_speed * (0.08 + avoidance_level * 0.012),
        90.0,
        520.0
    )
    local now = get_time()

    if now >= (tonumber(runtime.pursuit_next_scan_time) or 0.0) then
        runtime.pursuit_next_scan_time = now + (0.075 - avoidance_level * 0.004)

        local offsets = {
            0.0,
            -18.0, 18.0,
            -36.0, 36.0,
            -58.0, 58.0,
            -82.0, 82.0,
            -108.0, 108.0,
            -132.0, 132.0,
            -156.0, 156.0,
            180.0
        }
        local direct_clearance = ui.control.aim_guided_candidate_clearance(
            origin,
            desired_yaw,
            lookahead,
            local_player,
            target_index,
            settings.pursuit_ledge_safety
        )
        local best_score = -math.huge
        local best_offset = 0.0
        local best_clearance = 0.0
        local best_low = 0.0
        local best_high = 0.0
        local best_side = 0
        local best_jump = false

        for _, offset in ipairs(offsets) do
            local clearance, low_clearance, high_clearance, ground_safe =
                ui.control.aim_guided_candidate_clearance(
                    origin,
                    desired_yaw + offset,
                    lookahead,
                    local_player,
                    target_index,
                    settings.pursuit_ledge_safety
                )
            local progress = math.cos(math.rad(offset))
            local angle_cost = math.abs(offset) / 180.0
            local side = offset < -1.0 and -1 or (offset > 1.0 and 1 or 0)
            local commitment = 0.0
            local committed_side = tonumber(runtime.pursuit_committed_side) or 0
            local commitment_active = now < (tonumber(runtime.pursuit_commit_until) or 0.0)

            if side ~= 0 and side == (tonumber(runtime.pursuit_last_side) or 0) then
                commitment = commitment + 0.18
            end

            if commitment_active and committed_side ~= 0 and side ~= 0 then
                commitment = commitment + (side == committed_side and 0.42 or -0.72)
            end

            local reverse_need = ui.control.clamp(
                (0.58 - direct_clearance) / 0.58,
                0.0,
                1.0
            )
            local progress_weight = 2.55 - reverse_need * 1.80
            local clearance_weight = 2.35 + reverse_need * 2.40
            local reverse_penalty = math.max(0.0, -progress) * (1.35 - reverse_need * 1.15)
            local score = progress * progress_weight
                + clearance * clearance_weight
                - angle_cost * 0.38
                - reverse_penalty
                + commitment

            if clearance < 0.16 then score = score - 7.0 end
            if not ground_safe then score = score - 12.0 end
            if offset == 180.0 and direct_clearance > 0.72 then score = score - 3.0 end

            local jump_candidate = math.abs(offset) <= 82.0
                and low_clearance < 0.36
                and high_clearance > low_clearance + 0.24
                and high_clearance > 0.56
                and ground_safe

            if jump_candidate then score = score + 0.72 end

            if score > best_score then
                best_score = score
                best_offset = offset
                best_clearance = clearance
                best_low = low_clearance
                best_high = high_clearance
                best_side = side
                best_jump = jump_candidate
            end
        end

        runtime.pursuit_heading_offset = best_offset
        runtime.pursuit_chosen_yaw = desired_yaw + best_offset
        runtime.pursuit_clearance = best_clearance
        runtime.pursuit_low_clearance = best_low
        runtime.pursuit_high_clearance = best_high
        runtime.pursuit_jump_planned = best_jump

        if best_side ~= 0 then
            runtime.pursuit_last_side = best_side
            runtime.pursuit_committed_side = best_side
            runtime.pursuit_commit_until = now
                + ui.control.clamp(
                    tonumber(settings.pursuit_corner_commit_time) or 0.30,
                    0.12,
                    0.90
                )
        elseif best_clearance > 0.80 then
            runtime.pursuit_committed_side = 0
            runtime.pursuit_commit_until = 0.0
        end
    end

    if horizontal_distance <= 72.0 then
        runtime.pursuit_stuck_time = 0.0
        runtime.pursuit_recovery_until = 0.0
    else
        ui.control.pursuit_update_stuck_state(origin, 1.0, settings)
    end

    local command_angles = command:get_viewangles()
    if not command_angles then
        runtime.pursuit_active = false
        runtime.pursuit_status = "View direction unavailable"
        return false
    end

    local movement_yaw = tonumber(runtime.pursuit_chosen_yaw) or desired_yaw
    local delta_yaw = ui.control.normalize_angle(
        movement_yaw - (tonumber(command_angles.y) or 0.0)
    )
    local move_speed = ui.control.clamp(
        tonumber(settings.pursuit_move_speed) or 450.0,
        80.0,
        450.0
    )
    local recovering = now < (tonumber(runtime.pursuit_recovery_until) or 0.0)
    local forward_move
    local side_move

    if recovering then
        local elapsed = now - (tonumber(runtime.pursuit_recovery_started) or now)
        local recovery_side = tonumber(runtime.pursuit_recovery_side) or 1

        if elapsed < 0.20 then
            forward_move = -move_speed * 0.82
            side_move = move_speed * recovery_side * 0.62
            runtime.pursuit_status = "Recovery: backing out"
        elseif elapsed < 0.46 then
            forward_move = -move_speed * 0.38
            side_move = move_speed * recovery_side
            runtime.pursuit_status = "Recovery: rotating escape route"
        else
            forward_move = move_speed
            side_move = move_speed * recovery_side * 0.58
            ui.control.pursuit_try_jump(command, settings)
            runtime.pursuit_status = "Recovery: forward jump escape"
        end
    else
        local radians = math.rad(delta_yaw)
        forward_move = math.cos(radians) * move_speed
        side_move = -math.sin(radians) * move_speed

        local jumped = false
        if runtime.pursuit_jump_planned == true then
            jumped = ui.control.pursuit_try_jump(command, settings) == true
            if jumped then
                forward_move = math.max(forward_move, move_speed * 0.86)
                side_move = side_move * 0.72
                runtime.pursuit_status = "Jumping over obstacle"
            end
        end

        if not jumped then
            local offset = tonumber(runtime.pursuit_heading_offset) or 0.0
            if math.abs(offset) < 2.0 then
                runtime.pursuit_status = "Direct pursuit"
            elseif math.abs(offset) > 150.0 then
                runtime.pursuit_status = "Reversing out of blocked route"
            elseif math.abs(offset) > 100.0 then
                runtime.pursuit_status = "Routing behind obstruction"
            else
                runtime.pursuit_status = string.format(
                    "Obstacle route: %+.0f deg",
                    offset
                )
            end
        end
    end

    command:set_forwardmove(forward_move)
    command:set_sidemove(side_move)

    runtime.pursuit_active = true
    runtime.pursuit_distance = horizontal_distance
    return true
end

