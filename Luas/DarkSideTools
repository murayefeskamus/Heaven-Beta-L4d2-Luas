function chat_spammer.update_vote_relay()
    local session =
        chat_spammer.vote_session

    if type(session) ~= "table" then
        chat_spammer.reset_vote_session()
        return
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        if session.active == true then
            chat_spammer.reset_vote_session()
        end

        return
    end

    local now = get_time()

    local delivery_mode =
        chat_spammer.normalize_vote_delivery_mode(
            chat_spammer.vote_delivery_mode
        )

    local automatic_enabled =
        chat_spammer.vote_relay_enabled == true
        and chat_spammer.vote_automatic_delivery_enabled == true


    if session.active == true
        and session.finalized_at <= 0.0
        and session.expires_at > 0.0
        and now >= session.expires_at then

        session.final_status = "expired"
        session.finalized_at = now
        session.final_summary_due = now
        chat_spammer.vote_manual_last_status =
            "Remembered vote expired; final result is available."
    end

    if automatic_enabled
        and delivery_mode == 1
        and session.active == true
        and session.finalized_at <= 0.0
        and session.summary_due > 0.0
        and now >= session.summary_due then

        chat_spammer.flush_vote_summary(
            "automatic summary"
        )
    elseif automatic_enabled
        and delivery_mode == 2
        and session.active == true
        and session.final_summary_sent ~= true
        and session.finalized_at > 0.0
        and session.final_summary_due > 0.0
        and now >= session.final_summary_due then

        chat_spammer.flush_vote_summary(
            session.final_status ~= ""
            and session.final_status
            or "vote end",
            true
        )
    end


    if session.finalized_at > 0.0
        and now - session.finalized_at > 4.0 then

        chat_spammer.reset_vote_session()
    elseif session.started_at > 0.0
        and now - session.started_at > 60.0 then

        if session.finalized_at <= 0.0 then
            session.final_status = "expired"
            session.finalized_at = now
            session.final_summary_due = now
        end

        if automatic_enabled
            and delivery_mode == 2
            and session.final_summary_sent ~= true then

            chat_spammer.flush_vote_summary(
                "hard timeout",
                true
            )
        end

        chat_spammer.reset_vote_session()
    end
end

function chat_spammer.relay_vote_event(
    event_name,
    event,
    status_message
)
    if chat_spammer.vote_relay_enabled ~= true then
        return false
    end

    local automatic_enabled =
        chat_spammer.vote_automatic_delivery_enabled == true

    local event_lower =
        tostring(event_name or ""):lower()

    local is_individual_vote =
        event_lower == "vote_cast"
        or event_lower == "vote_cast_yes"
        or event_lower == "vote_cast_no"

    if event_lower == "vote_started" then
        chat_spammer.begin_vote_session(
            event,
            status_message
        )
    elseif is_individual_vote then
        local vote_record,
            duplicate =
                chat_spammer.record_vote_cast(
                    event_name,
                    event
                )

        if duplicate then
            return false
        end


        if not automatic_enabled then
            return true
        end

        if chat_spammer.normalize_vote_delivery_mode(
            chat_spammer.vote_delivery_mode
        ) > 0 then

            return true
        end

        local session =
            chat_spammer.vote_session

        local route_mode =
            chat_spammer.get_immediate_vote_route(
                session,
                vote_record
            )

        if route_mode == 0 then
            return false
        end

        local relay_message =
            "[VOTE] " ..
            tostring(vote_record.name) ..
            " voted " ..
            tostring(vote_record.choice)

        if chat_spammer.send_to_route(
            relay_message,
            route_mode,
            true
        ) then
            chat_spammer.vote_relay_sent =
                chat_spammer.vote_relay_sent + 1

            chat_spammer.last_vote_relay =
                relay_message

            return true
        end

        return false
    elseif event_lower == "vote_changed" then


        chat_spammer.update_vote_counts_from_event(
            event
        )

        return false
    end

    local session =
        chat_spammer.ensure_vote_session(
            event
        )

    chat_spammer.update_vote_descriptor_from_event(
        session,
        event
    )

    chat_spammer.update_vote_counts_from_event(
        event
    )

    local is_final_event =
        event_lower == "vote_passed"
        or event_lower == "vote_failed"
        or event_lower == "callvote_failed"
        or event_lower == "vote_ended"

    local delivery_mode =
        chat_spammer.normalize_vote_delivery_mode(
            chat_spammer.vote_delivery_mode
        )

    if is_final_event then
        if event_lower ~= "vote_ended"
            or session.final_status == "" then

            session.final_status = event_lower
        end

        session.finalized_at = get_time()
        chat_spammer.vote_manual_last_status =
            "Remembered vote completed; final result is available."

        if automatic_enabled
            and delivery_mode == 1 then

            chat_spammer.flush_vote_summary(
                event_lower
            )
        elseif automatic_enabled
            and delivery_mode == 2
            and session.final_summary_sent ~= true then

            session.final_summary_due =
                session.finalized_at +
                math.max(
                    0.05,
                    tonumber(
                        chat_spammer.vote_final_grace
                    ) or 0.20
                )
        end
    end

    if not automatic_enabled then
        return false
    end

    local send_status = true


    if event_lower == "vote_ended"
        and session.final_status ~= "" then

        send_status = false
    end

    local route_mode =
        chat_spammer.normalize_route_mode(
            chat_spammer.vote_status_route
        )

    local relay_status_message =
        chat_spammer.build_vote_status_message(
            session,
            event_lower,
            status_message
        )

    local relay_message =
        "[VOTE] " ..
        tostring(
            relay_status_message
        )

    local relay_key =
        "status|" ..
        event_lower ..
        "|" ..
        relay_message:lower()

    local sent = false

    if send_status
        and route_mode > 0
        and not chat_spammer.vote_relay_is_duplicate(
            relay_key
        ) then

        if chat_spammer.send_to_route(
            relay_message,
            route_mode,
            true
        ) then
            chat_spammer.vote_relay_sent =
                chat_spammer.vote_relay_sent + 1

            chat_spammer.last_vote_relay =
                relay_message

            sent = true
        end
    end

    return sent
end


function name_stealer.get_silent_steal_blank_chat_newline_count()
    return 100
end

function name_stealer.is_silent_steal_chat_busy()
    return name_stealer.silent_steal_sequence_active == true
end

function name_stealer.cancel_silent_steal_blank_chat()
    name_stealer.silent_steal_sequence_active = false
    name_stealer.silent_steal_sequence_due_at = 0.0
    name_stealer.silent_steal_pending_target_name = ""
    name_stealer.silent_steal_confirmation_deadline = 0.0
end

function name_stealer.send_silent_steal_blank_chat_payload()
    if not engine.is_in_game()
        or not engine.is_connected() then

        return false
    end

    client.execnormal(
        'say "' ..
        string.rep(
            "\r",
            name_stealer.get_silent_steal_blank_chat_newline_count()
        ) ..
        '"'
    )

    return true
end

function name_stealer.silent_steal_target_matches(
    observed_name
)
    if name_stealer.silent_steal_sequence_active ~= true then
        return false
    end

    local pending_target =
        tostring(
            name_stealer.silent_steal_pending_target_name or ""
        )

    if pending_target == "" then
        return false
    end

    return spammer_runtime.names_match_for_tracking(
        observed_name,
        pending_target
    )
end

function name_stealer.complete_silent_steal_after_name_change(
    observed_name
)
    if not name_stealer.silent_steal_target_matches(
        observed_name
    ) then

        return false
    end


    name_stealer.silent_steal_sequence_due_at =
        get_time() + 0.01

    return true
end

function name_stealer.begin_silent_steal_sequence(
    target_name
)
    target_name =
        clean_name_for_reverse(
            target_name
        )

    if target_name == "" then
        return false
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        name_stealer.status = "WAITING FOR GAME"
        return false
    end

    name_stealer.cancel_silent_steal_blank_chat()


    name_stealer.silent_steal_sequence_active = true
    name_stealer.silent_steal_sequence_due_at = 0.0
    name_stealer.silent_steal_pending_target_name =
        target_name
    name_stealer.silent_steal_confirmation_deadline =
        get_time() + 2.5

    local applied =
        apply_stolen_name(
            target_name,
            false,
            true
        )

    if not applied then
        name_stealer.cancel_silent_steal_blank_chat()
        return false
    end

    return true
end

function name_stealer.update_silent_steal_blank_chat()
    if name_stealer.silent_steal_sequence_active ~= true then
        return
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        name_stealer.cancel_silent_steal_blank_chat()
        return
    end

    local now =
        get_time()

    local retry_due_at =
        tonumber(
            name_stealer.silent_steal_sequence_due_at
        ) or 0.0


    if retry_due_at > 0.0 then
        if now < retry_due_at then
            return
        end

        if name_stealer.send_silent_steal_blank_chat_payload() then
            name_stealer.cancel_silent_steal_blank_chat()
        else
            name_stealer.silent_steal_sequence_due_at =
                now + 0.05
        end

        return
    end


    local observed_name =
        get_current_player_name()

    if observed_name
        and name_stealer.complete_silent_steal_after_name_change(
            observed_name
        ) then

        return
    end

    local confirmation_deadline =
        tonumber(
            name_stealer.silent_steal_confirmation_deadline
        ) or 0.0

    if confirmation_deadline > 0.0
        and now >= confirmation_deadline then


        name_stealer.cancel_silent_steal_blank_chat()
    end
end

function send_chat_message(
    message,
    silent
)
    local expanded_message =
        expand_custom_newline_placeholders(
            message
        )

    local preserve_message_newlines =
        tostring(expanded_message or ""):find("[\r\n]") ~= nil

    local outgoing_message =
        sanitize_chat_message(
            expanded_message,
            preserve_message_newlines
        )

    if chat_spammer.twist_my_messages_enabled then
        outgoing_message =
            twist_chat_message(
                outgoing_message
            )
    end

    return send_chat_message_to_channel(
        outgoing_message,
        chat_spammer.mode == 1,
        silent
    )
end

function update_chat_delay_from_speed()
    name_reverser.case_selection =
        math.max(
            0,
            math.min(
                #name_reverser.case_modes - 1,
                math.floor(
                    tonumber(
                        name_reverser.case_selection
                    ) or 0
                )
            )
        )

    name_reverser.shape_selection =
        math.max(
            0,
            math.min(
                #name_reverser.shape_modes - 1,
                math.floor(
                    tonumber(
                        name_reverser.shape_selection
                    ) or 0
                )
            )
        )

    name_reverser.case_shape_preview_key = ""
    name_reverser.case_shape_preview = ""
    name_reverser.case_shape_preview_error = ""

    chat_spammer.speed =
        math.max(
            math.floor(
                DARKSIDE_CONFIG.MIN_CHAT_SPEED
            ),
            math.min(
                math.floor(
                    DARKSIDE_CONFIG.MAX_CHAT_SPEED
                ),
                math.floor(
                    (
                        tonumber(
                            chat_spammer.speed
                        ) or DARKSIDE_CONFIG.MIN_CHAT_SPEED
                    ) + 0.5
                )
            )
        )

    chat_spammer.delay =
        1.0 /
        chat_spammer.speed
end

function set_chat_spammer_enabled(enabled)
    update_chat_delay_from_speed()

    if enabled == true
        and get_chat_cycle_message_count() <= 0 then

        chat_spammer.enabled = false
        chat_spammer.elapsed = 0.0
        chat_spammer.was_ready = false
        chat_spammer.status =
            "NO ENABLED MESSAGES"

        return false
    end

    chat_spammer.enabled =
        enabled == true

    chat_spammer.elapsed = 0.0
    chat_spammer.was_ready = false

    if chat_spammer.enabled then
        stop_name_spammer()
        stop_name_stealer()


        if chat_spammer.newline_spam_enabled == true then
            chat_spammer.automatic_chat_lane_next_source = "regular"
        end

        chat_spammer.current_index = 1

        chat_spammer.elapsed =
            chat_spammer.delay

        chat_spammer.status =
            engine.is_in_game()
            and engine.is_connected()
            and "RUNNING"
            or "WAITING FOR GAME"
    else
        chat_spammer.status =
            "IDLE"
    end

    return true
end

function chat_spammer.set_newline_spam_enabled(enabled)
    update_chat_delay_from_speed()

    if enabled ~= true then
        chat_spammer.newline_spam_enabled = false
        chat_spammer.newline_spam_elapsed = 0.0
        chat_spammer.newline_spam_was_ready = false
        chat_spammer.newline_spam_status = "IDLE"
        chat_spammer.reset_newline_spam_counters()
        return true
    end

    local body =
        chat_spammer.get_heaven_newline_message_body(
            chat_spammer.newline_spam_message,
            chat_spammer.newline_spam_use_invisible_symbol,
            chat_spammer.newline_spam_vertical_text
        )

    if body == "" then
        chat_spammer.newline_spam_enabled = false
        chat_spammer.newline_spam_elapsed = 0.0
        chat_spammer.newline_spam_was_ready = false
        chat_spammer.reset_newline_spam_counters()
        chat_spammer.newline_spam_status = "EMPTY MESSAGE"
        return false
    end


    stop_name_spammer()
    stop_name_stealer()


    chat_spammer.reset_newline_spam_counters()

    if chat_spammer.enabled == true then
        chat_spammer.automatic_chat_lane_next_source = "newline"
    end
    chat_spammer.newline_spam_enabled = true
    chat_spammer.newline_spam_elapsed = chat_spammer.delay
    chat_spammer.newline_spam_was_ready = false
    chat_spammer.newline_spam_status =
        engine.is_in_game()
        and engine.is_connected()
        and "RUNNING"
        or "WAITING FOR GAME"

    return true
end

function chat_spammer.update_newline_spam()
    if chat_spammer.newline_spam_enabled ~= true then
        return
    end


    if name_stealer.is_silent_steal_chat_busy() then
        return
    end

    local ready =
        engine.is_in_game()
        and engine.is_connected()

    if not ready then
        chat_spammer.newline_spam_elapsed = 0.0
        chat_spammer.newline_spam_was_ready = false
        chat_spammer.newline_spam_status = "WAITING FOR GAME"
        return
    end

    local body =
        chat_spammer.get_heaven_newline_message_body(
            chat_spammer.newline_spam_message,
            chat_spammer.newline_spam_use_invisible_symbol,
            chat_spammer.newline_spam_vertical_text
        )

    if body == "" then
        chat_spammer.set_newline_spam_enabled(false)
        chat_spammer.newline_spam_status = "EMPTY MESSAGE"
        return
    end

    if not chat_spammer.newline_spam_was_ready then
        chat_spammer.newline_spam_elapsed = chat_spammer.delay
        chat_spammer.newline_spam_was_ready = true
        chat_spammer.newline_spam_status = "RUNNING"
    end

    local frame_time =
        tonumber(
            client.get_frame_time()
        ) or 0.0

    if frame_time < 0.0 then
        frame_time = 0.0
    end

    chat_spammer.newline_spam_elapsed =
        chat_spammer.newline_spam_elapsed + frame_time

    if chat_spammer.newline_spam_elapsed < chat_spammer.delay then
        return
    end

    if chat_spammer.automatic_chat_lane_used_this_frame == true then
        return
    end

    local sent =
        chat_spammer.send_heaven_newline_message(
            chat_spammer.newline_spam_message,
            chat_spammer.newline_spam_use_invisible_symbol,
            chat_spammer.mode == 1,
            chat_spammer.newline_spam_prefix_count,
            chat_spammer.newline_spam_vertical_text
        )

    if sent then
        chat_spammer.automatic_chat_lane_used_this_frame = true
        chat_spammer.automatic_chat_lane_next_source = "regular"

        chat_spammer.newline_spam_attempts =
            math.max(
                0,
                math.floor(
                    tonumber(
                        chat_spammer.newline_spam_attempts
                    ) or 0
                )
            ) + 1


        queue_chat_confirmation(
            body,
            "newline_spam"
        )

        chat_spammer.newline_spam_status = "RUNNING"
    end

    chat_spammer.newline_spam_elapsed =
        math.max(
            0.0,
            chat_spammer.newline_spam_elapsed - chat_spammer.delay
        )
end

function update_chat_spammer()


    if name_stealer.is_silent_steal_chat_busy() then
        return
    end

    local ready =
        engine.is_in_game()
        and engine.is_connected()

    if not ready then
        chat_spammer.elapsed = 0.0
        chat_spammer.was_ready = false

        if chat_spammer.enabled then
            chat_spammer.status =
                "WAITING FOR GAME"
        end

        return
    end

    if not chat_spammer.enabled then
        chat_spammer.elapsed = 0.0
        chat_spammer.was_ready = false
        return
    end

    if stop_chat_spammer_if_no_messages_enabled() then
        return
    end

    if not chat_spammer.was_ready then
        chat_spammer.elapsed =
            chat_spammer.delay

        chat_spammer.was_ready = true
        chat_spammer.status =
            "RUNNING"
    end

    local frame_time =
        tonumber(
            client.get_frame_time()
        ) or 0.0

    if frame_time < 0 then
        frame_time = 0.0
    end

    chat_spammer.elapsed =
        chat_spammer.elapsed +
        frame_time

    if chat_spammer.elapsed
        < chat_spammer.delay then

        return
    end

    local valid_index,
        cycle_message =
            get_next_valid_chat_index(
                chat_spammer.current_index
            )

    if not valid_index
        or not cycle_message then

        chat_spammer.status =
            "NO VALID MESSAGES"

        chat_spammer.elapsed = 0.0
        return
    end

    local message =
        cycle_message.text

    if chat_spammer.automatic_chat_lane_used_this_frame == true then
        return
    end

    if send_chat_message(
        message,
        true
    ) then
        chat_spammer.automatic_chat_lane_used_this_frame = true
        chat_spammer.automatic_chat_lane_next_source = "newline"

        chat_spammer.current_index =
            valid_index + 1

        if chat_spammer.current_index
            > get_chat_cycle_message_count() then

            chat_spammer.current_index = 1
        end
    end

    chat_spammer.elapsed =
        math.max(
            0.0,
            chat_spammer.elapsed -
            chat_spammer.delay
        )
end

function chat_spammer.update_automatic_chat_paths()
    local regular_allowed =
        chat_spammer.enabled == true

    if regular_allowed then
        local quote_confirmation_busy =
            ui.quotes
            and type(
                ui.quotes.has_pending_change_confirmation
            ) == "function"
            and ui.quotes.has_pending_change_confirmation()

        regular_allowed =
            quote_confirmation_busy ~= true
    end

    local newline_allowed =
        chat_spammer.newline_spam_enabled == true

    if not regular_allowed
        and not newline_allowed then

        return
    end

    local prefer_newline =
        regular_allowed
        and newline_allowed
        and chat_spammer.automatic_chat_lane_next_source == "newline"

    if prefer_newline then
        chat_spammer.update_newline_spam()

        if chat_spammer.automatic_chat_lane_used_this_frame ~= true
            and regular_allowed then

            update_chat_spammer()
        end
    else
        if regular_allowed then
            update_chat_spammer()
        end

        if chat_spammer.automatic_chat_lane_used_this_frame ~= true
            and newline_allowed then

            chat_spammer.update_newline_spam()
        end
    end
end


function ui.lobby.call_method(object, method_name, argument)
    if not object
        or type(method_name) ~= "string" then

        return nil
    end

    local method_ok,
        method =
            pcall(
                function()
                    return object[
                        method_name
                    ]
                end
            )

    if not method_ok
        or type(method) ~= "function" then

        return nil
    end

    local call_ok,
        value

    if argument ~= nil then
        call_ok,
        value =
            pcall(
                method,
                object,
                argument
            )
    else
        call_ok,
        value =
            pcall(
                method,
                object
            )
    end

    if not call_ok then
        return nil
    end

    return value
end

function ui.lobby.get_info_field(
    player_info,
    field_names
)
    if not player_info
        or type(field_names) ~= "table" then

        return nil
    end

    for _, field_name in ipairs(
        field_names
    ) do
        local field_ok,
            field_value =
                pcall(
                    function()
                        return player_info[
                            field_name
                        ]
                    end
                )

        if field_ok
            and field_value ~= nil
            and tostring(
                field_value
            ) ~= "" then

            return field_value
        end
    end

    return nil
end

function ui.lobby.read_cvar(
    cvar_name
)
    local read_ok,
        value =
            pcall(
                function()
                    local handle =
                        cvar.find(
                            cvar_name
                        )

                    if not handle
                        or handle == 0 then

                        return nil
                    end

                    return cvar.get_string(
                        handle
                    )
                end
            )

    if not read_ok
        or value == nil
        or tostring(value) == "" then

        return nil
    end

    return tostring(value)
end

function ui.lobby.get_map_code()
    local engine_methods = {
        "get_level_name_short",
        "get_level_name",
        "get_map_name"
    }

    for _, method_name in ipairs(
        engine_methods
    ) do
        local method = engine[method_name]

        if type(method) == "function" then
            local method_ok, value = pcall(method)

            if method_ok
                and value
                and tostring(value) ~= "" then

                local map_code = tostring(value)

                map_code = map_code:gsub("\\", "/")
                map_code = map_code:gsub("^maps/", "")
                map_code = map_code:gsub("%.bsp$", "")

                return map_code:lower()
            end
        end
    end

    local cvar_map =
        ui.lobby.read_cvar("host_map")
        or ui.lobby.read_cvar("mapname")

    if not cvar_map or cvar_map == "" then
        return "Unavailable"
    end

    cvar_map = tostring(cvar_map):gsub("\\", "/")
    cvar_map = cvar_map:gsub("^maps/", "")
    cvar_map = cvar_map:gsub("%.bsp$", "")

    return cvar_map:lower()
end

function ui.lobby.get_map_name(
    map_code
)
    map_code = tostring(
        map_code or ui.lobby.get_map_code()
    )

    if map_code == ""
        or map_code == "Unavailable" then

        return "Unavailable"
    end

    return ui.lobby.map_names[
        map_code:lower()
    ] or map_code
end

function ui.lobby.get_game_mode()
    local raw_mode =
        ui.lobby.read_cvar("mp_gamemode")
        or ui.lobby.read_cvar("game_mode")
        or "Unavailable"

    raw_mode = tostring(raw_mode)

    local display_names = {
        campaign = "Campaign",
        realism = "Realism",
        versus = "Versus",
        teamversus = "Team Versus",
        scavenge = "Scavenge",
        teamscavenge = "Team Scavenge",
        survival = "Survival"
    }

    local normalized = raw_mode:lower()

    if display_names[normalized] then
        return display_names[normalized]
    end

    return raw_mode:gsub(
        "^%l",
        string.upper
    )
end

function ui.lobby.mode_allows_infected(
