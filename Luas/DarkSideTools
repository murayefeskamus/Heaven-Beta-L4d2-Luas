                end

                draw_divider(actions_x)

                imgui.same_line()
                ui.lobby.set_cursor_x(
                    actions_x + 5
                )

                if is_active then
                    ui.heaven_configs.draw_action_button(
                        "Current",
                        "HeavenConfigLoad" .. tostring(index),
                        "current",
                        false,
                        62
                    )
                elseif ui.heaven_configs.draw_action_button(
                    "Load",
                    "HeavenConfigLoad" .. tostring(index),
                    "success",
                    ui.heaven_configs.config_is_detected(
                        config_name
                    ),
                    62
                ) then
                    ui.heaven_configs.apply_slot(index, "button")
                end

                imgui.same_line()
                ui.lobby.set_cursor_x(
                    actions_x + 69
                )

                if ui.heaven_configs.draw_action_button(
                    "Unbind",
                    "HeavenConfigUnbind" .. tostring(index),
                    "danger",
                    ui.heaven_configs.use_cycle_key ~= true
                        and slot.key > 0,
                    58
                ) then
                    slot.key = 0
                    ui.heaven_configs.hotkey_was_down[index] = false

                    if waiting_for_this_slot then
                        ui.heaven_configs.cancel_key_capture()
                    end

                    ui.heaven_configs.last_status =
                        "Hotkey " .. tostring(index) .. " unbound."

                    ui.heaven_configs.last_status_error = false
                    ui.heaven_configs.save_settings_now()
                end

                if index < visible_slot_count then
                    imgui.separator()
                end
            end
        end

        imgui.end_child()
    end


