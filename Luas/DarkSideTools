        or chat_spammer.vote_session

    status =
        tostring(status or ""):lower()

    local vote_kind =
        tostring(
            session.vote_kind or "unknown"
        )

    local subject =
        chat_spammer.get_vote_display_subject(
            session
        )

    local action =
        chat_spammer.vote_action_label(
            session
        )

    if status == "vote_passed" then
        if vote_kind == "kick" then
            return subject ~= ""
                and (
                    "Kicking " ..
                    subject
                )
                or "Kick approved"
        elseif vote_kind == "change_map" then
            return subject ~= ""
                and (
                    "Changing map to " ..
                    subject
                )
                or "Map change approved"
        elseif vote_kind == "change_campaign" then
            return subject ~= ""
                and (
                    "Changing campaign to " ..
                    subject
                )
                or "Campaign change approved"
        elseif vote_kind == "change_chapter" then
            return subject ~= ""
                and (
                    "Changing chapter to " ..
                    subject
                )
                or "Chapter change approved"
        elseif vote_kind == "change_alltalk" then
            return subject ~= ""
                and (
                    "Changing All Talk to " ..
                    subject
                )
                or "All Talk change approved"
        elseif vote_kind == "return_lobby" then
            return "Returning to lobby"
        elseif vote_kind == "restart" then
            return "Restarting the chapter"
        elseif vote_kind == "difficulty" then
            return subject ~= ""
                and (
                    "Changing difficulty to " ..
                    subject
                )
                or "Difficulty change approved"
        elseif vote_kind == "shuffle_teams" then
            return "Shuffling teams"
        end

        return action ..
            " approved"
    elseif status == "vote_failed"
        or status == "callvote_failed" then

        if vote_kind == "kick" then
            return subject ~= ""
                and (
                    subject ..
                    " will not be kicked"
                )
                or "Kick rejected"
        elseif vote_kind == "change_map" then
            return subject ~= ""
                and (
                    "Map change rejected: " ..
                    subject
                )
                or "Map change rejected"
        elseif vote_kind == "change_campaign" then
            return subject ~= ""
                and (
                    "Campaign change rejected: " ..
                    subject
                )
                or "Campaign change rejected"
        elseif vote_kind == "change_chapter" then
            return subject ~= ""
                and (
                    "Chapter change rejected: " ..
                    subject
                )
                or "Chapter change rejected"
        elseif vote_kind == "change_alltalk" then
            return "All Talk change rejected"
        elseif vote_kind == "return_lobby" then
            return "Return to lobby rejected"
        elseif vote_kind == "restart" then
            return "Restart vote rejected"
        elseif vote_kind == "difficulty" then
            return subject ~= ""
                and (
                    "Difficulty change rejected: " ..
                    subject
                )
                or "Difficulty change rejected"
        elseif vote_kind == "shuffle_teams" then
            return "Team shuffle rejected"
        end

        return action ..
            " rejected"
    elseif status == "expired" then
        return action ..
            " expired"
    elseif status == "superseded" then
        return action ..
            " was replaced"
    elseif status == "vote_ended" then
        return action ..
            " ended"
    end

    return action
end

