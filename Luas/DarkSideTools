function ui.network.extract_region_from_hostname(hostname)
    local raw_hostname =
        tostring(hostname or "")

    local clean_hostname =
        ui.network.clean_server_region_text(
            raw_hostname
        )

    if clean_hostname == "" then
        return "", false
    end

    local keyword_region,
        keyword_known =
            ui.network.match_server_region_keyword(
                clean_hostname
            )

    if keyword_known == true
        and tostring(keyword_region or "") ~= "" then

        return keyword_region, true
    end

    local code =
        ui.network.extract_valve_datacenter_code(
            raw_hostname
        )

    local datacenter =
        ui.network.get_valve_datacenter_region(
            code
        )

    if type(datacenter) == "table" then
        local dc_region =
            tostring(datacenter.region or "")

        local dc_country =
            tostring(datacenter.country or "")

        local dc_city =
            tostring(datacenter.city or "")

        if dc_region ~= "" then
            return dc_region, true
        elseif dc_country ~= ""
            and dc_city ~= "" then

            return dc_country .. " / " .. dc_city, true
        elseif dc_country ~= "" then
            return dc_country, true
        end
    end

    local valve_patterns = {
        "^[Vv]alve%s+[Ll]eft4[Dd]ead%s*2%s+(.+)%s+[Ss]erver",
        "^[Vv]alve%s+[Ll]eft%s*4%s*[Dd]ead%s*2%s+(.+)%s+[Ss]erver",
        "^[Vv]alve%s+[Ll]4[Dd]2%s+(.+)%s+[Ss]erver"
    }

    for _, pattern in ipairs(valve_patterns) do
        local label =
            clean_hostname:match(pattern)

        if label ~= nil then
            label =
                ui.network.clean_server_region_text(
                    label
                )

            label =
                label:gsub(
                    "%s+[Ss]erver$",
                    ""
                )
                :gsub(
                    "%s+[%d#]+$",
                    ""
                )
                :gsub(
                    "^%s+",
                    ""
                )
                :gsub(
                    "%s+$",
                    ""
                )

            if label ~= ""
                and #label <= 36 then

                local label_region,
                    label_known =
                        ui.network.match_server_region_keyword(
                            label
                        )

                if label_known == true
                    and tostring(label_region or "") ~= "" then

                    return label_region, true
                end

                return label, true
            end
        end
    end

    for segment in clean_hostname:gmatch("[^:|%[%]{}]+") do
        local segment_region,
            segment_known =
                ui.network.match_server_region_keyword(
                    segment
                )

        if segment_known == true
            and tostring(segment_region or "") ~= "" then

            return segment_region, true
        end
    end

    return "", false
end

function ui.network.ipv4_to_number(ip_address)
    ip_address =
        tostring(ip_address or "")

    local a, b, c, d =
        ip_address:match(
            "^(%d+)%.(%d+)%.(%d+)%.(%d+)$"
        )

    a = tonumber(a)
    b = tonumber(b)
    c = tonumber(c)
    d = tonumber(d)

    if not a or not b or not c or not d then
        return nil
    end

    if a < 0 or a > 255
        or b < 0 or b > 255
        or c < 0 or c > 255
        or d < 0 or d > 255 then

        return nil
    end

    return (((a * 256) + b) * 256 + c) * 256 + d
end

function ui.network.cidr_to_ipv4_range(cidr)
    cidr =
        tostring(cidr or "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

    local ip, bits =
        cidr:match(
            "^(%d+%.%d+%.%d+%.%d+)%s*/%s*(%d+)$"
        )

    if ip == nil then
        return nil, nil
    end

    bits =
        math.floor(
            tonumber(bits) or -1
        )

    if bits < 0 or bits > 32 then
        return nil, nil
    end

    local base =
        ui.network.ipv4_to_number(ip)

    if base == nil then
        return nil, nil
    end

    local size = 2 ^ (32 - bits)
    local start_value = math.floor(base / size) * size
    local end_value = start_value + size - 1

    return start_value, end_value
end

function ui.network.parse_geoip_country_range(range_text)
    range_text =
        tostring(range_text or "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

    if range_text == "" then
        return nil, nil
    end

    if range_text:find("/", 1, true) then
        return ui.network.cidr_to_ipv4_range(range_text)
    end

    local first_ip, last_ip =
        range_text:match(
            "^(%d+%.%d+%.%d+%.%d+)%s*%-%s*(%d+%.%d+%.%d+%.%d+)$"
        )

    if first_ip ~= nil and last_ip ~= nil then
        local first_value = ui.network.ipv4_to_number(first_ip)
        local last_value = ui.network.ipv4_to_number(last_ip)

        if first_value ~= nil and last_value ~= nil then
            if first_value > last_value then
                first_value, last_value = last_value, first_value
            end

            return first_value, last_value
        end
    end

    local prefix = range_text:match("^(%d+%.%d+%.%d+%.)$")

    if prefix ~= nil then
        return ui.network.ipv4_to_number(prefix .. "0"),
            ui.network.ipv4_to_number(prefix .. "255")
    end

    prefix = range_text:match("^(%d+%.%d+%.)$")

    if prefix ~= nil then
        return ui.network.ipv4_to_number(prefix .. "0.0"),
            ui.network.ipv4_to_number(prefix .. "255.255")
    end

    local exact_value = ui.network.ipv4_to_number(range_text)

    if exact_value ~= nil then
        return exact_value, exact_value
    end

    return nil, nil
end

function ui.network.normalize_geoip_country_label(value)
    value =
        tostring(value or "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

    if value == "" then
        return ""
    end

    local function clean_token(token)
        token = tostring(token or "")
            :gsub("^[\"']+", "")
            :gsub("[\"']+$", "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

        return token
    end

    local code_names = {
        AD = "Andorra", AE = "United Arab Emirates", AF = "Afghanistan",
        AL = "Albania", AM = "Armenia", AO = "Angola", AR = "Argentina",
        AT = "Austria", AU = "Australia", AZ = "Azerbaijan",
        BA = "Bosnia and Herzegovina", BD = "Bangladesh", BE = "Belgium",
        BG = "Bulgaria", BH = "Bahrain", BO = "Bolivia", BR = "Brazil",
