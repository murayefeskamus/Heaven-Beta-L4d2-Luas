function update_name_spammer()


    if not spammer_cfg.enabled
        and spammer_runtime.pending_message == nil then

        spammer_runtime.elapsed = 0.0
        spammer_runtime.was_ready = false
        return
    end

    if spammer_cfg.enabled then
        local warning_message,
            warning_status =
                spammer_cfg.get_automation_validation_warning()

        if warning_message then
            stop_name_spammer()

            spammer_runtime.status =
                warning_status

            ui.console.print(
                "[Name Spammer] Automation stopped: " ..
                warning_message ..
                "."
            )

            return
        end
    end

    local ready =
        is_game_ready()

    if not ready then
        spammer_runtime.elapsed = 0.0
        spammer_runtime.was_ready = false
        spammer_runtime.last_server_address = ""
        spammer_runtime.pending_message = nil
        spammer_runtime.pending_label = "None"
        spammer_runtime.pending_attempts = 0
        spammer_runtime.rate_limited = false
        spammer_runtime.last_observed_name = nil
        spammer_runtime.last_observed_at = 0.0
        spammer_runtime.restore_name_check_time = 0.0

        if spammer_cfg.enabled then
            spammer_runtime.status =
                "WAITING FOR GAME"
        end

        return
    end

    local server_address =
        get_server_address()

    if server_address
        ~= spammer_runtime.last_server_address then

        spammer_runtime.last_server_address =
            server_address

        spammer_runtime.pending_message = nil
        spammer_runtime.pending_label = "None"
        spammer_runtime.pending_attempts = 0
        spammer_runtime.rate_limited = false
        spammer_runtime.last_observed_name = nil
        spammer_runtime.last_observed_at = 0.0
        spammer_runtime.restore_name_check_time = 0.0

        if spammer_cfg.enabled then
            spammer_runtime.elapsed =
                spammer_cfg.delay

            spammer_runtime.status =
                "RUNNING"
        end
    end

    update_spammer_confirmation()

    if not spammer_cfg.enabled then
        spammer_runtime.elapsed = 0.0
        spammer_runtime.was_ready = false
        return
    end

    if not spammer_runtime.was_ready then
        spammer_runtime.elapsed =
            spammer_cfg.delay

        spammer_runtime.was_ready = true
        spammer_runtime.status =
            "RUNNING"
    end

    local frame_time =
        tonumber(
            client.get_frame_time()
        ) or 0.0

    if frame_time < 0 then
        frame_time = 0.0
    end

    spammer_runtime.elapsed =
        spammer_runtime.elapsed +
        frame_time

    spammer_runtime.run_elapsed_seconds =
        spammer_runtime.run_elapsed_seconds +
        frame_time

    local duration_limit_reason =
        spammer_runtime.get_cycle_limit_reached_reason()

    if duration_limit_reason then
        spammer_runtime.finish_cycle_limit(
            duration_limit_reason
        )

        return
    end

    if spammer_runtime.elapsed
        < spammer_cfg.delay then

        return
    end

    local target_index =
        spammer_runtime.get_next_automation_name_index()

    if not target_index then
        spammer_runtime.pending_message = nil
        spammer_runtime.pending_label = "None"
        spammer_runtime.pending_attempts = 0
        spammer_runtime.rate_limited = false
        spammer_runtime.status =
            "NO CONFIGURED NAMES"
        spammer_runtime.elapsed = 0.0
        return
    end

    spammer_runtime.next_name_index =
        target_index

    local target_name =
        get_spammer_name(
            target_index
        )

    local target_label =
        spammer_cfg.get_layout_field_label(
            target_index,
            true
        )

    local sent, final_message =
        apply_specific_spammer_name(
            target_name,
            target_label,
            true,
            spammer_cfg.is_name_vertical(
                target_index
            )
        )

    if sent then
        spammer_runtime.run_command_attempts =
            spammer_cfg.get_run_request_count() + 1

        spammer_runtime.pending_message =
            final_message

        spammer_runtime.pending_label =
            target_label

        spammer_runtime.pending_attempts =
            spammer_runtime.pending_attempts + 1

        if spammer_runtime.pending_attempts >= 2 then
            if not spammer_runtime.rate_limited then
                spammer_runtime.rate_limited = true

                spammer_runtime.rate_limit_detections =
                    spammer_runtime.rate_limit_detections + 1
            end

            spammer_runtime.status =
                "RATE LIMITED - PROBING"
        else
            spammer_runtime.status =
                "WAITING FOR SERVER ACCEPTANCE"
        end
    end

    spammer_runtime.elapsed = 0.0
end


