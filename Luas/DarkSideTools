            if queued_message.deduplicated == true then
                quote_change_pending[
                    tostring(queued_message.text or "")
                ] = nil
            end

            ui.console.print(
                "[L4D2 Quotes] Confirmation acknowledged in chat: " ..
                message
            )

            return true
        end
    end

    return false
end

local function quote_sender_is_local(
    userid,
    hinted_local
)
    userid = tonumber(userid) or 0

    if userid <= 0 then
        return false
    end

    if hinted_local == true then
        cached_local_quote_userid = userid
        return true
    end

    if cached_local_quote_userid > 0
        and userid == cached_local_quote_userid then

        return true
    end

    local local_player =
        client.get_local_player()

    if not local_player then
        return false
    end

    local local_index =
        tonumber(
            local_player:get_index()
        ) or 0

    if local_index <= 0 then
        return false
    end

    local info_ok,
        player_info =
            pcall(
                engine.get_player_info,
                local_index
            )

    if info_ok
        and player_info then

        local info_userid =
            tonumber(
                player_info.userid
                or player_info.user_id
                or player_info.userID
                or player_info.UserID
            ) or 0

        if info_userid > 0 then
            cached_local_quote_userid = info_userid

            if userid == info_userid then
                return true
            end
        end
    end

    local map_ok,
        mapped_index =
            pcall(
                engine.get_player_for_userid,
                userid
            )

    if map_ok
        and tonumber(mapped_index) == local_index then

        cached_local_quote_userid = userid
        return true
    end

    return false
end

