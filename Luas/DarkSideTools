function chat_spammer.vote_record_matches_table_filter(
    vote_record,
    filter_mode
)
    filter_mode =
        chat_spammer.normalize_manual_vote_table_filter(
            filter_mode
        )

    if filter_mode == 0 then
        return true
    end

    local choice =
        tostring(
            vote_record
            and vote_record.choice
            or ""
        ):upper()

    local team_number =
        math.floor(
            tonumber(
                vote_record
                and vote_record.team
                or 0
            ) or 0
        )

    if filter_mode == 1 then
        return choice == "YES"
    elseif filter_mode == 2 then
        return choice == "NO"
    elseif filter_mode == 3 then
        return team_number == 2
    elseif filter_mode == 4 then
        return team_number == 3
    elseif filter_mode == 5 then
        return team_number == 1
    end

    return true
end

function chat_spammer.get_vote_table_records(
    session
)
    local source_records =
        chat_spammer.get_vote_records(
            session
        )

    local filter_mode =
        chat_spammer.normalize_manual_vote_table_filter(
            chat_spammer.vote_manual_table_filter
        )

    local sort_mode =
        chat_spammer.normalize_manual_vote_table_sort(
            chat_spammer.vote_manual_table_sort
        )

    local rows = {}

    for record_index,
        vote_record in ipairs(
            source_records
        ) do

        if chat_spammer.vote_record_matches_table_filter(
            vote_record,
            filter_mode
        ) then
            table.insert(
                rows,
                {
                    record = vote_record,
                    recorded_order = record_index
                }
            )
        end
    end

    if sort_mode ~= 0 then
        table.sort(
            rows,
            function(left, right)
                local left_record = left.record or {}
                local right_record = right.record or {}

                local left_uid =
                    chat_spammer.vote_record_uid(
                        left_record
                    )

                local right_uid =
                    chat_spammer.vote_record_uid(
                        right_record
                    )

                local left_name =
                    tostring(
                        left_record.name or ""
                    ):lower()

                local right_name =
                    tostring(
                        right_record.name or ""
                    ):lower()

                local left_team =
                    chat_spammer.vote_record_team_label(
                        left_record
                    )

                local right_team =
                    chat_spammer.vote_record_team_label(
                        right_record
                    )

                local left_choice =
                    tostring(
                        left_record.choice or "UNKNOWN"
                    ):upper()

                local right_choice =
                    tostring(
                        right_record.choice or "UNKNOWN"
                    ):upper()

                local different = false
                local before = false

                if sort_mode == 1 then
                    different = left_uid ~= right_uid
                    before = left_uid < right_uid
                elseif sort_mode == 2 then
                    different = left_uid ~= right_uid
                    before = left_uid > right_uid
                elseif sort_mode == 3 then
                    different = left_name ~= right_name
                    before = left_name < right_name
                elseif sort_mode == 4 then
                    different = left_name ~= right_name
                    before = left_name > right_name
                elseif sort_mode == 5 then
                    different = left_team ~= right_team
                    before = left_team < right_team
                elseif sort_mode == 6
                    or sort_mode == 7 then

                    local wanted_choice =
                        sort_mode == 6
                        and "YES"
                        or "NO"

                    local left_rank =
                        left_choice == wanted_choice
                        and 0
                        or 1

                    local right_rank =
                        right_choice == wanted_choice
                        and 0
                        or 1

                    different = left_rank ~= right_rank
                    before = left_rank < right_rank
                end

                if different then
                    return before
                end

                if left_name ~= right_name then
                    return left_name < right_name
                end

                return (left.recorded_order or 0) <
                    (right.recorded_order or 0)
            end
        )
    end

    local records = {}

    for _, row in ipairs(rows) do
        table.insert(
            records,
            row.record
        )
    end

    return records
end

function chat_spammer.clear_remembered_vote()
    local history =
        type(chat_spammer.vote_history) == "table"
        and chat_spammer.vote_history
        or {}

    if #history > 0 then
        local selected_index =
            chat_spammer.normalize_vote_history_selection(
                chat_spammer.vote_history_selection
            ) + 1

        table.remove(
            history,
            selected_index
        )
    end

    chat_spammer.vote_history = history
    chat_spammer.vote_history_selection =
        chat_spammer.normalize_vote_history_selection(
            chat_spammer.vote_history_selection
        )

    chat_spammer.vote_remembered_session =
        history[
            chat_spammer.vote_history_selection + 1
        ]

    chat_spammer.vote_manual_player_selection = 0
    chat_spammer.vote_manual_clear_confirmation = false
    chat_spammer.vote_manual_last_status = ""
end

