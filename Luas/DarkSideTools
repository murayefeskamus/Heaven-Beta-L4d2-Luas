function normalize_saved_name_source(
    source_label
)
    local normalized =
        tostring(source_label or "Manual")
            :gsub("[\t\r\n]", " ")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

    if normalized == "" then
        normalized = "Manual"
    end

    return normalized
end

function format_saved_name_date(
    timestamp
)
    timestamp =
        math.floor(
            tonumber(timestamp) or 0
        )

    if timestamp <= 0
        or type(os) ~= "table"
        or type(os.date) ~= "function" then

        return "Unknown"
    end

    name_stealer.saved_name_date_cache =
        type(name_stealer.saved_name_date_cache) == "table"
        and name_stealer.saved_name_date_cache
        or {}

    local cache_key = tostring(timestamp)
    local cached_value =
        name_stealer.saved_name_date_cache[
            cache_key
        ]

    if cached_value ~= nil then
        return cached_value
    end

    local date_ok,
        formatted =
            pcall(
                os.date,
                "%H:%M | %d.%m.%Y",
                timestamp
            )

    if not date_ok
        or tostring(formatted or "") == "" then

        name_stealer.saved_name_date_cache[
            cache_key
        ] = "Unknown"

        return "Unknown"
    end

    formatted = tostring(formatted)

    name_stealer.saved_name_date_cache[
        cache_key
    ] = formatted

    return formatted
end

function load_saved_name_metadata()
    name_stealer.saved_name_metadata = {}

    if type(io) ~= "table"
        or type(io.open) ~= "function" then

        return false
    end

    local metadata_path =
        get_saved_names_metadata_path()

    local open_ok,
        file_handle =
            pcall(
                io.open,
                metadata_path,
                "r"
            )

    if not open_ok
        or not file_handle then

        return false
    end

    local read_ok =
        pcall(
            function()
                for file_line in file_handle:lines() do
                    local line =
                        tostring(file_line or "")
                            :gsub("\r$", "")

                    local normalized_key,
                        saved_at,
                        source =
                            line:match(
                                "^(.-)\t(%-?%d+)\t(.*)$"
                            )

                    normalized_key =
                        tostring(normalized_key or "")
                            :gsub("[\t\r\n]", " ")

                    if normalized_key ~= "" then
                        name_stealer.saved_name_metadata[
                            normalized_key
                        ] = {
                            saved_at =
                                math.max(
                                    0,
                                    math.floor(
                                        tonumber(saved_at) or 0
                                    )
                                ),
                            source =
                                normalize_saved_name_source(
                                    source == ""
                                    and "Legacy"
                                    or source
                                )
                        }
                    end
                end

                file_handle:close()
            end
        )

    if not read_ok then
        pcall(
            function()
                file_handle:close()
            end
        )

        name_stealer.saved_name_metadata = {}
        return false
    end

    return true
end

function ensure_saved_name_metadata_entries()
    local changed = false
    local retained = {}

    for _, saved_name in ipairs(
        name_stealer.saved_names or {}
    ) do
        local normalized_key =
            normalize_candidate_name_for_filter(
                saved_name
            )

        if normalized_key ~= "" then
            local metadata =
                name_stealer.saved_name_metadata[
                    normalized_key
                ]

            if type(metadata) ~= "table" then
                metadata = {
                    saved_at = 0,
                    source = "Legacy"
                }

                name_stealer.saved_name_metadata[
                    normalized_key
                ] = metadata

                changed = true
            end

            metadata.saved_at =
                math.max(
                    0,
                    math.floor(
                        tonumber(metadata.saved_at) or 0
                    )
                )

            metadata.source =
                normalize_saved_name_source(
                    metadata.source == nil
                    and "Legacy"
                    or metadata.source
                )

            retained[normalized_key] = true
        end
    end

    for normalized_key, _ in pairs(
        name_stealer.saved_name_metadata
    ) do
        if not retained[normalized_key] then
            name_stealer.saved_name_metadata[
                normalized_key
            ] = nil

            changed = true
        end
    end

    return changed
end

function save_saved_name_metadata()
    if type(io) ~= "table"
        or type(io.open) ~= "function" then

        return false
    end

    ensure_saved_name_metadata_entries()

    local metadata_path =
        get_saved_names_metadata_path()

    local open_ok,
        file_handle =
            pcall(
                io.open,
                metadata_path,
                "w"
            )

    if not open_ok
        or not file_handle then

        return false
    end

    local write_ok =
        pcall(
            function()
                for _, saved_name in ipairs(
                    name_stealer.saved_names or {}
                ) do
                    local normalized_key =
                        normalize_candidate_name_for_filter(
                            saved_name
                        )

                    if normalized_key ~= "" then
                        local metadata =
                            name_stealer.saved_name_metadata[
                                normalized_key
                            ] or {
                                saved_at = 0,
                                source = "Legacy"
                            }

                        file_handle:write(
                            tostring(normalized_key)
                                :gsub("[\t\r\n]", " "),
                            "\t",
                            tostring(
                                math.max(
                                    0,
                                    math.floor(
                                        tonumber(metadata.saved_at) or 0
                                    )
                                )
                            ),
                            "\t",
                            normalize_saved_name_source(
                                metadata.source
                            ),
                            "\n"
                        )
                    end
                end

                file_handle:flush()
                file_handle:close()
            end
        )

    if not write_ok then
        pcall(
            function()
                file_handle:close()
            end
        )

        return false
    end

    return true
end

function set_saved_name_metadata(
    saved_name,
    source_label,
    timestamp
)
    local normalized_key =
        normalize_candidate_name_for_filter(
            saved_name
        )

    if normalized_key == "" then
        return false
    end

    local existing =
        name_stealer.saved_name_metadata[
            normalized_key
        ]

    if type(existing) ~= "table" then
        existing = {}
        name_stealer.saved_name_metadata[
            normalized_key
        ] = existing
    end

    existing.saved_at =
        math.max(
            0,
            math.floor(
                tonumber(timestamp)
                or (
                    type(os) == "table"
                    and type(os.time) == "function"
                    and os.time()
                    or 0
                )
            )
        )

    existing.source =
        normalize_saved_name_source(
            source_label
        )

    return true
end

