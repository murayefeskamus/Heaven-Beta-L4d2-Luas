function ui.kill_tools.get_message_catalog(
    enabled_only
)
    local settings =
        ui.kill_tools.message_on_kill

    local catalog = {}

    for index = 1,
        #settings.messages do

        local message =
            tostring(
                settings.messages[index]
                or ""
            )

        local trimmed =
            message:gsub(
                "^%s+",
                ""
            ):gsub(
                "%s+$",
                ""
            )

        if not enabled_only
            or (
                settings.message_enabled[index] == true
                and trimmed ~= ""
            ) then

            catalog[#catalog + 1] = {
                kind = "custom",
                source_index = index,
                text = message
            }
        end
    end

    return catalog
end

