    function ui.network.clean_table_field(value)
        value = tostring(value or "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")
            :gsub("[\r\n|]", " ")
            :gsub("%s+", " ")

        local lower_value = value:lower()
        if value == "" or value == "-" or lower_value == "unknown" then
            return "-"
        end

        return value
    end

    function ui.network.get_current_server_ip_port()
        local address = tostring(ui.network.current_server_raw or "")

        if address == "" and type(get_server_address) == "function" then
            local ok, value = pcall(get_server_address)
            if ok then
                address = tostring(value or "")
            end
        end

        if address == "" and type(ui.lobby) == "table" and type(ui.lobby.overview) == "table" then
            address = tostring(ui.lobby.overview.server or "")
        end

        local ip = ""
        local port = ""

        if type(ui.network.extract_server_ip_port) == "function" then
            local ok, out_ip, out_port = pcall(ui.network.extract_server_ip_port, address)
            if ok then
                ip = tostring(out_ip or "")
                port = tostring(out_port or "")
            end
        elseif type(ui.network.extract_ipv4_address) == "function" then
            local ok, out_ip = pcall(ui.network.extract_ipv4_address, address)
            if ok then
                ip = tostring(out_ip or "")
            end
        end

        return address, ip, port
    end

    function ui.network.get_server_details_for_table()
        local address, ip, port = ui.network.get_current_server_ip_port()
        local details = nil
        local known = false
        local detecting = false

        if type(ui.network.get_server_geoip_details) == "function" then
            local ok, out_details, out_known, out_detecting =
                pcall(ui.network.get_server_geoip_details, address)

            if ok and type(out_details) == "table" then
                details = out_details
                known = out_known == true
                detecting = out_detecting == true
            end
        end

        details = type(details) == "table" and details or {}
        details.ip = tostring(details.ip or ip or "")
        details.port = tostring(details.port or port or "")

        if details.ip == "" then
            details.ip = tostring(ip or "")
        end

        if details.port == "" then
            details.port = tostring(port or "")
        end

        return address, details, known, detecting
    end

    function ui.network.format_geoip_coordinates(details)
        details = type(details) == "table" and details or {}

        local lat = ui.network.clean_table_field(details.lat)
        local lon = ui.network.clean_table_field(details.lon)

        if lat == "-" and lon == "-" then
            return "-"
        end

        return lat .. ", " .. lon
    end
end

