local spammer_preview_selection = 0
local stealer_manual_selection = 0
local stealer_save_target_selection = 0
local stealer_saved_name_selection = 0

function build_spammer_preview_options()
    spammer_cfg.ensure_name_vertical_modes()

    local signature_parts = {
        tostring(
            initial_in_game_name or ""
        ),
        tostring(
            spammer_cfg.custom_name or ""
        ),
        tostring(
            get_spammer_name_count()
        )
    }

    for index = 1,
        get_spammer_name_count() do

        signature_parts[#signature_parts + 1] =
            spammer_cfg.name_vertical_modes[index] ~= false
            and "V"
            or "H"

        signature_parts[#signature_parts + 1] =
            tostring(
                get_spammer_name(index) or ""
            )
    end

    local signature =
        table.concat(
            signature_parts,
            "\31"
        )

    return ui.performance.memoize_values(
        "spammer_preview_options",
        signature,
        function()
            local options = {}
            local source_indices = {}

            table.insert(
                options,
                "Initial name - " ..
                truncate_preview(
                    tostring(
                        initial_in_game_name
                        or "Unavailable"
                    ),
                    26
                )
            )

            source_indices[0] = 0

            for vertical_position, index in ipairs(
                spammer_cfg.get_name_indices_for_layout(
                    true
                )
            ) do
                if not spammer_cfg.is_name_field_empty(
                    index
                ) then

                    local configured_name =
                        tostring(
                            get_spammer_name(
                                index
                            ) or ""
                        )

                    table.insert(
                        options,
                        "Name " ..
                        tostring(vertical_position) ..
                        " - " ..
                        truncate_preview(
                            configured_name,
                            26
                        )
                    )

                    source_indices[
                        #options - 1
                    ] = index
                end
            end

            local custom_name =
                sanitize_name(
                    spammer_cfg.custom_name
                )

            custom_name =
                custom_name:gsub(
                    "^%s+",
                    ""
                ):gsub(
                    "%s+$",
                    ""
                )

            if custom_name ~= "" then
                table.insert(
                    options,
                    "One-time name - " ..
                    truncate_preview(
                        custom_name,
                        26
                    )
                )

                source_indices[
                    #options - 1
                ] = -1
            end

            return options,
                source_indices
        end,
        128
    )
end

function spammer_cfg.get_preview_selection_for_name_index(
    configured_index
)
    local options,
        source_indices =
            build_spammer_preview_options()

    for selection = 0,
        #options - 1 do

        if source_indices[selection]
            == configured_index then

            return selection
        end
    end

    return 0
end

function spammer_cfg.get_custom_preview_selection()
    local options,
        source_indices =
            build_spammer_preview_options()

    for selection = 0,
        #options - 1 do

        if source_indices[selection] == -1 then
            return selection
        end
    end

    return 0
end

function get_spammer_preview_name(
    preview_selection
)
    preview_selection =
        math.floor(
            tonumber(
                preview_selection
            ) or 0
        )

    local _,
        source_indices =
            build_spammer_preview_options()

    local source_index =
        source_indices[
            preview_selection
        ]

    if source_index == -1 then
        return tostring(
            spammer_cfg.custom_name or ""
        )
    elseif source_index
        and source_index > 0 then

        return tostring(
            get_spammer_name(
                source_index
            ) or ""
        )
    end

    return tostring(
        initial_in_game_name or ""
    )
end


function push_button_colors(text_r, text_g, text_b, button_r, button_g, button_b)
    if type(imgui.push_style_color) ~= "function"
        or type(imgui.pop_style_color) ~= "function" then

        return 0
    end

    local pushed = 0

    local overlay_alpha = 1.0

    if ui
        and ui.quotes
        and ui.quotes.rendering_overlay == true
        and ui.quotes.manual_opacity_fallback == true
        and ui.quotes.settings then

        overlay_alpha = 1.0
    end

    local function try_push(
        index,
        r,
        g,
        b,
        a,
        fade_surface
    )
        local final_alpha =
            tonumber(a) or 1.0

        if fade_surface == true then
            final_alpha =
                final_alpha *
                overlay_alpha
        end

        local ok = pcall(
            imgui.push_style_color,
            index,
            r,
            g,
            b,
            final_alpha
        )

        if ok then
            pushed = pushed + 1
        end
    end


    try_push(0, text_r, text_g, text_b, 1.0, false)
    try_push(21, button_r, button_g, button_b, 1.0, true)
    try_push(22, math.min(1.0, button_r + 0.10), math.min(1.0, button_g + 0.10), math.min(1.0, button_b + 0.10), 1.0, true)
    try_push(23, math.max(0.0, button_r - 0.08), math.max(0.0, button_g - 0.08), math.max(0.0, button_b - 0.08), 1.0, true)

    return pushed
end

function pop_button_colors(count)
    count = math.max(0, math.floor(tonumber(count) or 0))

    if count > 0
        and type(imgui.pop_style_color) == "function" then

        for _ = 1, count do
            pcall(imgui.pop_style_color)
        end
    end
end

