function ui.draw_activity_table(
    unique_id,
    rows,
    options
)
    rows =
        type(rows) == "table"
        and rows
        or {}

    options =
        type(options) == "table"
        and options
        or {}

    if tostring(unique_id) == "ChatActivityTable"
        and type(ui.kill_tools) == "table"
        and type(ui.kill_tools.get_activity_rows) == "function" then

        local kill_rows_ok,
            kill_rows =
                pcall(
                    ui.kill_tools.get_activity_rows
                )

        if kill_rows_ok
            and type(kill_rows) == "table" then

            table.insert(
                rows,
                {
                    label = "Kill Feed",
                    value = "Integrated activity",
                    color = {
                        0.75, 0.85, 1.0, 1.0
                    }
                }
            )

            for _, kill_row in ipairs(
                kill_rows
            ) do
                local copied_row = {
                    label =
                        "Kill feed - " ..
                        tostring(
                            kill_row.label or "Status"
                        ),
                    value =
                        tostring(
                            kill_row.value or ""
                        ),
                    color =
                        kill_row.color
                }

                table.insert(
                    rows,
                    copied_row
                )
            end
        end
    end

    local fixed_width =
        options.fixed_width == true

    local label_width =
        tonumber(options.label_width)
        or 112

    local value_width =
        tonumber(options.value_width)
        or 120

    if not fixed_width then
        for _, row in ipairs(rows) do
            label_width =
                math.max(
                    label_width,
                    ui.lobby.measure_text_width(
                        tostring(
                            row.label or ""
                        )
                    ) + 18
                )

            value_width =
                math.max(
                    value_width,
                    ui.lobby.measure_text_width(
                        tostring(
                            row.value or ""
                        )
                    ) + 18
                )
        end
    end

    label_width =
        math.min(
            210,
            math.max(
                80,
                label_width
            )
        )

    value_width =
        math.min(
            430,
            math.max(
                100,
                value_width
            )
        )

    local table_width =
        label_width +
        value_width +
        18

    local table_height =
        math.max(
            22,
            #rows * 20 + 4
        )

    local palette = nil

    if ui.enhancements
        and type(
            ui.enhancements.theme_palette
        ) == "function" then

        local palette_ok,
            palette_value =
                pcall(
                    ui.enhancements.theme_palette
                )

        if palette_ok
            and type(palette_value) == "table" then

            palette = palette_value
        end
    end

    local divider_color =
        palette
        and (
            palette.border
            or palette.separator
        )
        or {
            0.42,
            0.42,
            0.44
        }

    local table_open =
        imgui.begin_child(
            tostring(unique_id),
            table_width,
            table_height,
            false,
            0
        )

    if table_open then
        local start_x =
            ui.lobby.get_cursor_x()

        for row_index, row in ipairs(rows) do
            ui.lobby.set_cursor_x(
                start_x + 6
            )

            imgui.text(
                tostring(
                    row.label or ""
                )
            )

            imgui.same_line()
            ui.lobby.set_cursor_x(
                start_x + label_width
            )

            theme_text_colored(
                divider_color[1] or 0.42,
                divider_color[2] or 0.42,
                divider_color[3] or 0.44,
                1.0,
                "|"
            )

            imgui.same_line()
            ui.lobby.set_cursor_x(
                start_x + label_width + 12
            )

            local row_color =
                type(row.color) == "table"
                and row.color
                or nil

            if row_color then
                theme_text_colored(
                    row_color[1] or 1.0,
                    row_color[2] or 1.0,
                    row_color[3] or 1.0,
                    row_color[4] or 1.0,
                    tostring(
                        row.value or ""
                    )
                )
            else
                imgui.text(
                    tostring(
                        row.value or ""
                    )
                )
            end

            if row_index < #rows then
                imgui.separator()
            end
        end
    end

    imgui.end_child()
end

