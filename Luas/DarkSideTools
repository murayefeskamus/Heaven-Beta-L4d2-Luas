function get_next_stolen_name()
    if #name_stealer.names == 0 then
        return "None"
    end

    if name_stealer.current_index
        > #name_stealer.names then

        name_stealer.current_index = 1
    end

    return name_stealer.names[
        name_stealer.current_index
    ] or "None"
end

function refresh_stealer_names(local_player)
    local previous_next_name =
        get_next_stolen_name()

    local refreshed_names = {}
    local refreshed_bot_flags = {}
    local seen_names = {}

    name_stealer.refresh_requested = false
    name_stealer.last_refresh_time =
        get_time()

    if not local_player then
        name_stealer.names = {}
        name_stealer.bot_name_flags = {}
        name_stealer.lobby_players = {}
        name_stealer.manual_players = {}
        name_stealer.automatic_players = {}
        name_stealer.current_index = 1
        name_stealer.manual_selected_key = ""

        local connected =
            engine.is_in_game()
            and engine.is_connected()

        if not connected then
            name_stealer.player_overrides = {}
            name_stealer.last_lobby_server = ""
        end

        name_stealer.status =
            name_stealer.target_lock_enabled
            and "TARGET LOCKED"
            or (
                connected
                and "WAITING FOR PLAYER"
                or "NOT CONNECTED"
            )

        return
    end

    local local_team =
        local_player:get_team()


    local include_bots_in_cycle =
        name_stealer.ignore_bots ~= true

    local lobby_players =
        name_stealer.collect_lobby_player_records(
            local_player,
            include_bots_in_cycle
        )


    local manual_players =
        name_stealer.collect_lobby_player_records(
            local_player,
            true
        )

    local automatic_players = {}

    for _, player_record in ipairs(
        lobby_players
    ) do
        if name_stealer.should_use_player_record(
            player_record,
            local_team
        ) then
            table.insert(
                automatic_players,
                player_record
            )

            local clean_name =
                sanitize_name(
                    player_record.name
                )

            if clean_name ~= "" then
                local record_is_bot =
                    player_record.is_bot == true


                if refreshed_bot_flags[
                    clean_name
                ] == nil then

                    refreshed_bot_flags[
                        clean_name
                    ] = record_is_bot
                elseif refreshed_bot_flags[
                    clean_name
                ] == true
                    and not record_is_bot then

                    refreshed_bot_flags[
                        clean_name
                    ] = false
                end

                if not seen_names[
                    clean_name
                ] then
                    seen_names[
                        clean_name
                    ] = true

                    table.insert(
                        refreshed_names,
                        clean_name
                    )
                end
            end
        end
    end

    table.sort(
        refreshed_names,
        function(first_name, second_name)
            return first_name:lower()
                < second_name:lower()
        end
    )

    name_stealer.lobby_players =
        lobby_players

    name_stealer.manual_players =
        manual_players


    local active_player_keys = {}

    for _, player_record in ipairs(
        lobby_players
    ) do
        active_player_keys[
            tostring(player_record.key or "")
        ] = true
    end

    for player_key in pairs(
        name_stealer.player_overrides
    ) do
        if not active_player_keys[
            tostring(player_key)
        ] then
            name_stealer.player_overrides[
                player_key
            ] = nil
        end
    end

    local active_manual_keys = {}

    for _, player_record in ipairs(
        manual_players
    ) do
        active_manual_keys[
            tostring(player_record.key or "")
        ] = true
    end

    if name_stealer.manual_selected_key ~= ""
        and not active_manual_keys[
            tostring(
                name_stealer.manual_selected_key
            )
        ] then

        name_stealer.manual_selected_key = ""
    end

    name_stealer.automatic_players =
        automatic_players

    name_stealer.names =
        refreshed_names

    name_stealer.bot_name_flags =
        refreshed_bot_flags

    local preserved_index = nil

    if previous_next_name ~= "None" then
        for index, candidate
            in ipairs(name_stealer.names) do

            if candidate
                == previous_next_name then

                preserved_index = index
                break
            end
        end
    end

    if preserved_index then
        name_stealer.current_index =
            preserved_index
    elseif name_stealer.current_index
        > #name_stealer.names then

        name_stealer.current_index = 1
    end

    if name_stealer.target_lock_enabled then
        name_stealer.status =
            "TARGET LOCKED"
    elseif #name_stealer.names == 0 then
        name_stealer.current_index = 1
        name_stealer.status =
            "NO MATCHING PLAYERS"
    elseif name_stealer.enabled then
        name_stealer.status =
            "RUNNING"
    else
        name_stealer.status =
            "READY"
    end
end

function ensure_stealer_names_are_fresh(
    local_player,
    force
)
    local now =
        get_time()

    local should_refresh =
        force
        or name_stealer.refresh_requested
        or (
            name_stealer.last_refresh_time == 0.0
            and #name_stealer.names == 0
        )
        or (
            name_stealer.auto_update_names
            and now - name_stealer.last_refresh_time
                >= DARKSIDE_CONFIG.NAME_REFRESH_INTERVAL
        )

    if should_refresh then
        refresh_stealer_names(
            local_player
        )
    end
end

