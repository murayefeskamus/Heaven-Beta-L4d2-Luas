        auto_load_hint_palette.text_disabled[3],
        1.0,
        "Loads the first enabled configured slot once after this Lua loads."
    )

    local hint_palette =
        ui.enhancements.theme_palette()

    local changed_cycle_mode,
        cycle_mode_value =
            imgui.checkbox(
                "Use single cycle key",
                ui.heaven_configs.use_cycle_key == true
            )

    imgui.same_line()

    theme_text_colored(
        hint_palette.text_disabled[1],
        hint_palette.text_disabled[2],
        hint_palette.text_disabled[3],
        1.0,
        "Off: separate keys. On: cycle enabled configs."
    )

    if changed_cycle_mode then
        ui.heaven_configs.use_cycle_key =
            cycle_mode_value == true

        ui.heaven_configs.cancel_key_capture()
        ui.heaven_configs.cycle_key_was_down = true

        for index = 1, ui.heaven_configs.max_slots do
            ui.heaven_configs.hotkey_was_down[index] = true
        end

        ui.heaven_configs.last_status =
            ui.heaven_configs.use_cycle_key
            and "Cycle-key mode enabled."
            or "Separate-key mode enabled."

        ui.heaven_configs.last_status_error = false
        ui.heaven_configs.save_settings_now()
    end

    if ui.heaven_configs.use_cycle_key then
        imgui.text("Cycle key:")
        imgui.same_line()

        local waiting_for_cycle_key =
            ui.heaven_configs.waiting_for_cycle_key == true

        local cycle_key_label

        if waiting_for_cycle_key then
            cycle_key_label = "Press any key..."
        elseif ui.heaven_configs.cycle_key > 0 then
            cycle_key_label =
                ui.heaven_configs.format_key_badge_label(
                    ui.heaven_configs.cycle_key,
                    42
                )
        else
            cycle_key_label = "Key: Unbound"
        end

        local cycle_key_style =
            waiting_for_cycle_key
            and "key_waiting"
            or (
                ui.heaven_configs.cycle_key > 0
                and "key_bound"
                or "key_unbound"
            )

        if ui.heaven_configs.draw_action_button(
            cycle_key_label,
            "HeavenConfigCycleKey",
            cycle_key_style,
            true,
            120
        ) then
            ui.heaven_configs.begin_cycle_key_capture()
        end

        imgui.same_line()

        if ui.heaven_configs.draw_action_button(
            "Unbind",
            "HeavenConfigCycleKeyClear",
            "danger",
            ui.heaven_configs.cycle_key > 0,
            62
        ) then
            ui.heaven_configs.cycle_key = 0
            ui.heaven_configs.cycle_key_was_down = false

            if waiting_for_cycle_key then
                ui.heaven_configs.cancel_key_capture()
            end

            ui.heaven_configs.last_status =
                "Cycle key unbound."

            ui.heaven_configs.last_status_error = false
            ui.heaven_configs.save_settings_now()
        end
    end

    local detected_count =
        #ui.heaven_configs.detected_configs

    local visible_slot_count =
        ui.heaven_configs.visible_slot_count()

    if detected_count <= 0 then
        theme_text_colored(
            1.0, 0.35, 0.25, 1.0,
            ui.heaven_configs.scan_error ~= ""
            and ui.heaven_configs.scan_error
            or "No configs found."
        )
    end

    local controls_start_x =
        ui.lobby.get_cursor_x()

    local controls_start_y =
        ui.lobby.get_cursor_y()

    local all_selected =
        ui.heaven_configs.all_visible_slots_enabled()

    local toggle_label =
        all_selected
        and "Deselect all"
        or "Select all"

    local toggle_width =
        all_selected
        and 88
        or 78

    if ui.heaven_configs.draw_action_button(
        toggle_label,
        "HeavenConfigToggleAll",
        all_selected and "danger" or "success",
        visible_slot_count > 0,
        toggle_width
    ) then
        ui.heaven_configs.set_visible_slots_enabled(
            not all_selected
        )
    end

    imgui.same_line()

    if ui.heaven_configs.draw_action_button(
        "Refresh",
        "HeavenConfigRefresh",
        "primary",
        true,
        66
    ) then
