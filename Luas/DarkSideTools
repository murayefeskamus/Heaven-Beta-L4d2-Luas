function ui.favourites.draw_tab()
    local entries =
        ui.favourites.normalize_entries()

    if get_time() <
        ui.favourites.last_status_until
        and ui.favourites.last_status_error == true
        and ui.favourites.last_status ~= "" then

        theme_text_colored(
            1.0, 0.25, 0.25, 1.0,
            ui.favourites.last_status
        )

        draw_compact_gap()
    end

    if #entries == 0 then
        theme_text_colored(
            1.0, 0.25, 0.25, 1.0,
            "No favourites pinned."
        )

        theme_text_colored(
            0.62, 0.62, 0.65, 1.0,
            "Pin a section or a search result."
        )

        return
    end

    local groups = {}
    local group_order = {}

    for _, entry in ipairs(
        entries
    ) do
        local group_key =
            tostring(entry.tab_key) ..
            "|" ..
            tostring(entry.section_key)

        local group =
            groups[group_key]

        if not group then
            group = {
                tab_key =
                    tostring(entry.tab_key),
                section_key =
                    tostring(entry.section_key),
                entries = {}
            }

            groups[group_key] = group

            group_order[
                #group_order + 1
            ] = group_key
        end

        group.entries[
            #group.entries + 1
        ] = entry
    end

    local pending_unpin = ""
    local global_entry_index = 0
    local first_entry = true

    for _, group_key in ipairs(
        group_order
    ) do
        local group =
            groups[group_key]

        for _, entry in ipairs(
            group.entries
        ) do
            global_entry_index =
                global_entry_index + 1

            if not first_entry then
                ui.favourites.draw_entry_separator()
            end

            first_entry = false

            local unpin_clicked,
                jump_clicked =
                    ui.favourites.draw_entry_header(
                        entry,
                        global_entry_index
                    )

            if unpin_clicked then
                pending_unpin =
                    ui.favourites.entry_key(
                        entry
                    )
            end

            if jump_clicked then
                ui.favourites.jump_to_entry(
                    entry
                )
            end
        end

        local renderer =
            type(
                ui.favourites.renderer_cache[
                    group.tab_key
                ]
            ) == "table"
            and ui.favourites.renderer_cache[
                group.tab_key
            ][
                group.section_key
            ]
            or nil

        if type(renderer) == "function" then
            draw_compact_gap()

            if type(ui.setting_search) == "table"
                and type(
                    ui.setting_search.expand_section
                ) == "function" then

                ui.setting_search.expand_section(
                    group.tab_key,
                    group.section_key
                )
            end

            local previous_rendering =
                ui.favourites.rendering_tab

            local previous_consumed =
                ui.favourites.section_pin_consumed

            local previous_tool =
                ui.selected_tool

            local previous_capture_tab =
                type(ui.setting_search) == "table"
                and ui.setting_search.runtime_capture_tab
                or ""

            local previous_capture_section =
                type(ui.setting_search) == "table"
                and ui.setting_search.runtime_capture_section
                or ""

            ui.favourites.rendering_tab = true

            ui.favourites.section_pin_consumed =
                true

            ui.selected_tool =
                ui.favourites.tool_indices[
                    group.tab_key
                ]

            if type(ui.setting_search) == "table" then
                ui.setting_search.runtime_capture_tab =
                    group.tab_key

                ui.setting_search.runtime_capture_section =
                    group.section_key
            end

            local render_ok,
                render_error =
                    pcall(
                        renderer
                    )

            if type(ui.setting_search) == "table" then
                ui.setting_search.runtime_capture_tab =
                    previous_capture_tab

                ui.setting_search.runtime_capture_section =
                    previous_capture_section
            end

            ui.selected_tool =
                previous_tool

            ui.favourites.rendering_tab =
                previous_rendering

            ui.favourites.section_pin_consumed =
                previous_consumed

            if not render_ok then
                theme_text_colored(
                    1.0, 0.25, 0.25, 1.0,
                    "Favourite could not be rendered: " ..
                    tostring(render_error)
                )
            end
        else
            draw_compact_gap()

            theme_text_colored(
                0.58, 0.58, 0.60, 1.0,
                "Open the source tab once to activate it."
            )
        end
    end

    if pending_unpin ~= "" then
        ui.favourites.unpin_key(
            pending_unpin
        )
    end
end

