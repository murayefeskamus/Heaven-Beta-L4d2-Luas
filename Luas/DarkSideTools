function ui.control.update()
    ui.control.handle_toggle_key()

    if ui.control.resolve_active_mode() ~= 1
        or ui.control.aim.enabled ~= true
        or tonumber(ui.control.aim.mode) ~= 1 then
        if type(ui.control.aim_v2_legacy_update) == "function" then
            return ui.control.aim_v2_legacy_update()
        end
        return
    end

    ui.control.normalize_aim_v2_rebuilt_settings()
    local runtime = ui.control.runtime

    if not engine.is_in_game() or not engine.is_connected() then
        runtime.status = "Waiting for game"
        runtime.aim_v2_spawn_state = "Not in game"
        ui.control.finish_aim_v2_lock_session()
        return
    end

    local local_player = client.get_local_player()
    if not local_player then
        runtime.status = "Waiting for player"
        runtime.aim_v2_spawn_state = "Unavailable"
        return
    end

    local supported, _, _, spawn_state = ui.control.get_special_infected_identity(local_player)
    runtime.aim_v2_spawn_state = spawn_state

    if supported ~= true then
        runtime.status = "Infected team only"
        ui.control.finish_aim_v2_lock_session()
        return
    end

    if ui.control.is_action_key_down() then
        if runtime.lock_session_active == true
            and tonumber(runtime.lock_session_target_index) > 0 then
            runtime.status = string.format(
                "%s | Locked: %s",
                spawn_state,
                tostring(runtime.lock_session_target_name or "Survivor")
            )
        else
            runtime.status = spawn_state .. " | Searching target"
        end
    else
        if runtime.lock_session_active == true then
            ui.control.finish_aim_v2_lock_session()
        end
        runtime.status = string.format(
            "%s | Ready - hold %s",
            spawn_state,
            ui.control.get_key_name(ui.control.action_key)
        )
    end
end

function ui.control.aim_v2_should_show_circle()
    local settings = ui.control.aim.v2
    if ui.control.aim.enabled ~= true
        or tonumber(ui.control.aim.mode) ~= 1
        or settings.draw_fov_circle ~= true then
        return false
    end

    local mode = ui.control.aim_v2_simple_integer(settings.fov_circle_display_mode, 0, 0, 2)
    if mode == 1 and ui.control.resolve_active_mode() ~= 1 then return false end
    if mode == 2 and not ui.control.is_action_key_down() then return false end

    return engine.is_in_game() and engine.is_connected()
end

function ui.control.aim_v2_simple_draw_native_circle(x, y, radius, segments, red, green, blue, alpha)
    if type(draw) ~= "table" or type(draw.outlined_circle) ~= "function" then
        return false
    end

    local ok, result = pcall(
        draw.outlined_circle,
        math.floor(x + 0.5),
        math.floor(y + 0.5),
        math.floor(math.max(1.0, radius) + 0.5),
        segments,
        red, green, blue, alpha
    )

    return ok and result ~= false
end

function ui.control.aim_v2_simple_draw_line_circle(x, y, radius, segments, red, green, blue, alpha)
    if type(draw) ~= "table" or type(draw.line) ~= "function" then
        return false
    end

    local previous_x = x + radius
    local previous_y = y

    for segment = 1, segments do
        local angle = segment / segments * math.pi * 2.0
        local next_x = x + math.cos(angle) * radius
        local next_y = y + math.sin(angle) * radius
        local ok, result = pcall(
            draw.line,
            math.floor(previous_x + 0.5),
            math.floor(previous_y + 0.5),
            math.floor(next_x + 0.5),
            math.floor(next_y + 0.5),
            red, green, blue, alpha
        )
        if not ok or result == false then return false end
        previous_x, previous_y = next_x, next_y
    end

    return true
end

function ui.control.aim_v2_simple_draw_circle_any(x, y, radius, segments, red, green, blue, alpha)
    if ui.control.aim_v2_simple_draw_native_circle(
        x, y, radius, segments, red, green, blue, alpha
    ) then
        return true, "Native outlined_circle"
    end

    if ui.control.aim_v2_simple_draw_line_circle(
        x, y, radius, segments, red, green, blue, alpha
    ) then
        return true, "Connected draw.line fallback"
    end

    return false, "Unavailable"
end

function ui.control.draw_fov_circle()
    local settings = ui.control.normalize_aim_v2_rebuilt_settings()
    local runtime = ui.control.runtime

    if not ui.control.aim_v2_should_show_circle() then
        runtime.fov_circle_status = settings.draw_fov_circle and "Hidden" or "Disabled"
        runtime.fov_circle_renderer = "Not drawn"
        return false
    end

    local width, height = ui.control.aim_v2_get_paint_screen_size()
    if not width or not height then
        runtime.fov_circle_status = "Screen size unavailable"
        runtime.fov_circle_renderer = "Unavailable"
        return false
    end

    local center_x = width * 0.5
    local center_y = height * 0.5
    local radius = ui.control.calculate_fov_circle_radius(width, height, settings.fov)
        * settings.fov_circle_scale
    radius = ui.control.clamp(radius, 4.0, math.min(width, height) * 0.49)

    local locked = runtime.lock_session_active == true
        and tonumber(runtime.lock_session_target_index) > 0
    local color = settings.fov_circle_color_mode == 2 and locked
        and settings.fov_circle_locked_color
        or settings.fov_circle_unlocked_color
    color = ui.control.normalize_rgba_color(color, { 1.0, 1.0, 1.0, 1.0 })

    local red = math.floor(color[1] * 255.0 + 0.5)
    local green = math.floor(color[2] * 255.0 + 0.5)
    local blue = math.floor(color[3] * 255.0 + 0.5)
    local alpha = math.floor(settings.fov_circle_opacity * 255.0 + 0.5)
    local segments = 96
    local thickness = settings.fov_circle_thickness

    if settings.fov_circle_glow == true then
        local glow_strength = settings.fov_circle_glow_strength
        for ring = 3, 1, -1 do
            local glow_alpha = math.max(1, math.floor(alpha * glow_strength * (0.22 / ring) + 0.5))
            local glow_radius = radius + ring * 2.0
            ui.control.aim_v2_simple_draw_circle_any(
                center_x, center_y, glow_radius, segments,
                red, green, blue, glow_alpha
            )
        end
    end

    local all_ok = true
    local active_backend = "Unavailable"

    for layer = 0, thickness - 1 do
        local layer_radius = math.max(2.0, radius - layer)
        local layer_ok, layer_backend = ui.control.aim_v2_simple_draw_circle_any(
            center_x, center_y, layer_radius, segments,
            red, green, blue, alpha
        )

        if layer_ok then
            active_backend = layer_backend
        else
            all_ok = false
            break
        end
    end

    if settings.fov_circle_center_dot == true and all_ok then
        ui.control.aim_v2_simple_draw_circle_any(
            center_x, center_y, 3.0, 24,
            red, green, blue, alpha
        )
    end

    runtime.fov_circle_radius = radius
    runtime.fov_circle_state = locked and "Locked" or "Unlocked"
    runtime.fov_circle_selected_hex = ui.control.color_to_hex(color)
    runtime.fov_circle_submitted_hex = runtime.fov_circle_selected_hex
    runtime.fov_circle_predicted_hex = runtime.fov_circle_selected_hex
    runtime.fov_circle_draw_order = "Standard RGB"
    runtime.fov_circle_color_profile = "Native RGB"
    runtime.fov_circle_color_profile_status = "No LUT, inversion or channel swap"
    runtime.fov_circle_render_stage = "Paint"
    runtime.fov_circle_renderer = active_backend
    runtime.fov_circle_status = all_ok
        and string.format(
            "%s | %s | thickness %d",
            runtime.fov_circle_state,
            runtime.fov_circle_selected_hex,
            thickness
        )
        or "Circle renderer reported a failure"

    return all_ok
end

