                    is_active
                    and ui.heaven_configs.push_current_config_checkbox_colors()
                    or 0

                local changed_slot_enabled,
                    slot_enabled_value =
                        imgui.checkbox(
                            "##HeavenConfigSlotEnabled" .. tostring(index),
                            slot.enabled == true
                        )

                pop_neutral_combo_colors(
                    active_checkbox_colors
                )

