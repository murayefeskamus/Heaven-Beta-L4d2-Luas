        end_panel()
    end

    if begin_panel("STATUS") then
        draw_heading("LIVE DIAGNOSTICS")

    local locked =
        tonumber(ui.control.runtime.locked_target_index) > 0 and
        tostring(ui.control.runtime.target_name or "None") ~= "None"

