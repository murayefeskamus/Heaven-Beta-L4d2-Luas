function ui.heaven_configs.config_scan_preserve_status_refresh(
    force_refresh
)
    if type(ui.heaven_configs.refresh_config_list) ~= "function" then
        return 0
    end

    local previous_status = ui.heaven_configs.last_status
    local previous_error = ui.heaven_configs.last_status_error
    local previous_expires = ui.heaven_configs.last_status_expires_at
    local previous_seen = ui.heaven_configs.last_status_seen
    local previous_seen_error = ui.heaven_configs.last_status_seen_error

    local ok,
        result =
            pcall(
                ui.heaven_configs.refresh_config_list,
                force_refresh == true
            )

    if force_refresh == true then
        ui.heaven_configs.last_status = previous_status
        ui.heaven_configs.last_status_error = previous_error
        ui.heaven_configs.last_status_expires_at = previous_expires
        ui.heaven_configs.last_status_seen = previous_seen
        ui.heaven_configs.last_status_seen_error = previous_seen_error
    end

    if not ok then
        ui.heaven_configs.config_scan_background_scan.last_error =
            tostring(result or "config scan failed")
        return 0
    end

    return math.max(
        0,
        math.floor(
            tonumber(result) or 0
        )
    )
end

function ui.heaven_configs.config_scan_ensure_hotkey_config_list()
    if type(ui.heaven_configs) ~= "table" then
        return false
    end

    if type(ui.heaven_configs.normalize_settings) == "function" then
        pcall(ui.heaven_configs.normalize_settings)
    end

    if ui.heaven_configs.enabled ~= true then
        return false
    end

    local detected_count =
        type(ui.heaven_configs.detected_configs) == "table"
        and #ui.heaven_configs.detected_configs
        or 0

    if detected_count > 0 then
        ui.heaven_configs.config_scan_background_scan.initialized = true
        return true
    end

    local now = get_time()
    local scan_state = ui.heaven_configs.config_scan_background_scan

    if now < (tonumber(scan_state.next_scan_at) or 0.0) then
        return false
    end

    scan_state.attempts =
        (tonumber(scan_state.attempts) or 0) + 1

    local force_refresh =
        ui.heaven_configs.list_initialized == true
        or scan_state.attempts > 1

    local count =
        ui.heaven_configs.config_scan_preserve_status_refresh(
            force_refresh
        )

    if count > 0 then
        scan_state.initialized = true
        scan_state.next_scan_at = now + 10.0
        return true
    end

    scan_state.next_scan_at =
        now + math.min(
            5.0,
            0.75 + (tonumber(scan_state.attempts) or 1) * 0.50
        )

    return false
end

