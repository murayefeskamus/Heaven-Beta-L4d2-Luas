function ui.lobby.measure_text_width(
    text_value
)
    text_value = tostring(
        text_value or ""
    )

    local metric_cache_key =
        ui.performance.get_font_metric_signature() ..
        "\31" ..
        text_value

    return ui.performance.memoize_values(
        "imgui_text_width",
        metric_cache_key,
        function()
            if type(imgui.calc_text_size)
                == "function" then

                local success,
                    first,
                    second =
                        pcall(
                            imgui.calc_text_size,
                            text_value
                        )

                if success then
                    if type(first) == "number" then
                        return first
                    end

                    local x_ok,
                        x_value =
                            pcall(
                                function()
                                    return first.x
                                end
                            )

                    if x_ok
                        and type(x_value) == "number" then

                        return x_value
                    end

                    if type(second) == "number" then
                        return second
                    end
                end
            end

            return ui.lobby.count_real_name_characters(
                text_value
            ) * 6.5
        end,
        4096
    )
end

function ui.lobby.get_aligned_control_x(
    labels,
    padding
)
    local base_x =
        ui.lobby.get_cursor_x()

    local resolved_padding =
        tonumber(padding) or 10

    local signature_parts = {
        ui.performance.get_font_metric_signature(),
        tostring(resolved_padding)
    }

    if type(labels) == "table" then
        for _, label in ipairs(labels) do
            signature_parts[#signature_parts + 1] =
                tostring(label or "")
        end
    end

    local widest =
        ui.performance.memoize_values(
            "aligned_control_width",
            table.concat(
                signature_parts,
                "\31"
            ),
            function()
                local measured_widest = 0.0

                if type(labels) == "table" then
                    for _, label in ipairs(labels) do
                        measured_widest =
                            math.max(
                                measured_widest,
                                ui.lobby.measure_text_width(
                                    tostring(label or "")
                                )
                            )
                    end
                end

                return measured_widest
            end,
            512
        )

    return base_x +
        widest +
        resolved_padding
end

