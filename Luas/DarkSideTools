function ui.setting_search.get_attention_color(palette)
    palette = type(palette) == "table" and palette or {}

    local background =
        type(palette.background) == "table"
        and palette.background
        or { 0.05, 0.05, 0.05 }

    local accent =
        type(palette.accent) == "table"
        and palette.accent
        or { 0.20, 0.85, 1.00 }

    local candidates = {
        palette.active_tab_text,
        palette.combo_active,
        palette.slider_active,
        palette.header_active,
        palette.button_active,
        palette.section_text,
        palette.inactive_tab_text,
        palette.text,
        accent
    }

    local function color_distance(first, second)
        first = type(first) == "table" and first or { 0, 0, 0 }
        second = type(second) == "table" and second or { 0, 0, 0 }

        local red = (tonumber(first[1]) or 0) - (tonumber(second[1]) or 0)
        local green = (tonumber(first[2]) or 0) - (tonumber(second[2]) or 0)
        local blue = (tonumber(first[3]) or 0) - (tonumber(second[3]) or 0)

        return math.sqrt(
            red * red +
            green * green +
            blue * blue
        )
    end

    local best = accent
    local best_score = -1

    for _, candidate in ipairs(candidates) do
        if type(candidate) == "table" then
            local background_distance =
                color_distance(candidate, background)
            local accent_distance =
                color_distance(candidate, accent)

            local score =
                background_distance * 1.75 +
                accent_distance * 1.20

            if score > best_score then
                best = candidate
                best_score = score
            end
        end
    end

    return {
        math.max(0.0, math.min(1.0, tonumber(best[1]) or 1.0)),
        math.max(0.0, math.min(1.0, tonumber(best[2]) or 1.0)),
        math.max(0.0, math.min(1.0, tonumber(best[3]) or 1.0))
    }
end

