        return false
    end

    local safe_message = tostring(
        message or ""
    )

    safe_message = safe_message:gsub(
        "[\r\n]",
        " "
    )

    safe_message = safe_message:gsub(
        '"',
        "'"
    )

    if safe_message == "" then
