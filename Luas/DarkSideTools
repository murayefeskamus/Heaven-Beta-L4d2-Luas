    function ui.quotes.draw_settings_slider(
        label,
        unique_id,
        value,
        minimum,
        maximum,
        integer_mode,
        controls_x,
        hint
    )
        imgui.text(
            tostring(label)
        )
        imgui.same_line()
        ui.lobby.set_cursor_x(
            controls_x
        )
        imgui.push_item_width(180)

        local changed,
            new_value

        if integer_mode then
            changed,
                new_value =
                    imgui.slider_int(
                        "##" .. tostring(unique_id),
                        math.floor(tonumber(value) or 0),
                        math.floor(minimum),
                        math.floor(maximum)
                    )
        else
            changed,
                new_value =
                    imgui.slider_float(
                        "##" .. tostring(unique_id),
                        tonumber(value) or 0,
                        minimum,
                        maximum
                    )
        end

        imgui.pop_item_width()

        if hint
            and tostring(hint) ~= "" then

            local palette =
                ui.enhancements.theme_palette()

            theme_text_colored(
                palette.text_disabled[1],
                palette.text_disabled[2],
                palette.text_disabled[3],
                1.0,
                tostring(hint)
            )
        end

        return changed,
            new_value
    end

