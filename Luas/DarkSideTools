        )
    )
end

function ui.control.resolve_active_mode()
    local selected =
        math.floor(
            tonumber(
                ui.control.active_mode
            ) or 0
        )

    selected =
        selected == 1
        and 1
        or 0

    if selected == 0
        and ui.control.speed.enabled == true then

        ui.control.active_mode = 0
        return 0
    end

    if selected == 1
        and ui.control.aim.enabled == true then

        ui.control.active_mode = 1
        return 1
    end

    if ui.control.speed.enabled == true then
        ui.control.active_mode = 0
        return 0
    end

    if ui.control.aim.enabled == true then
        ui.control.active_mode = 1
        return 1
    end

    ui.control.active_mode = selected
    return selected
end

function ui.control.get_active_label()
    local speed_enabled =
        ui.control.speed.enabled == true

    local aim_enabled =
        ui.control.aim.enabled == true

    if not speed_enabled
        and not aim_enabled then

        return "Disabled"
    end

    local mode =
        ui.control.resolve_active_mode()

    if mode == 0
        and speed_enabled then

        return "Speed Limiter V" ..
            tostring(
                (tonumber(ui.control.speed.mode) or 0) + 1
            )
    end

    if aim_enabled then
        return "Aim Infected V" ..
            tostring(
                (tonumber(ui.control.aim.mode) or 0) + 1
            )
    end

    return "Speed Limiter V" ..
        tostring(
            (tonumber(ui.control.speed.mode) or 0) + 1
        )
end

function ui.control.is_active_enabled()
    local mode =
        ui.control.resolve_active_mode()

    if mode == 0 then
        return ui.control.speed.enabled == true
    end

    return ui.control.aim.enabled == true
end

function ui.control.is_engaged()
    return ui.control.is_active_enabled()
        and get_time() <=
            (tonumber(
                ui.control.runtime.status_hold_until
            ) or 0.0)
end

