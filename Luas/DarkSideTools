                    "LIVE TRACKING",
                    ui.lobby.players_expanded,
                    "LobbyPlayers",
                    #ui.lobby.players
                )

            if ui.lobby.players_expanded then
                if not ui.lobby.is_connected_to_server() then
                    ui.lobby.draw_disconnected_notice()
                else
                    imgui.text("Filter:")
                    imgui.same_line()
                    imgui.push_item_width(170)

                    local neutral_lobby_filter_colors =
                        push_neutral_combo_colors()

                    local changed_filter,
                        filter_value =
                            imgui.combo(
                                "##LobbyPlayerFilter",
                                ui.lobby.filter_index,
                                ui.lobby.filters
                            )

                    pop_neutral_combo_colors(
                        neutral_lobby_filter_colors
                    )

                    imgui.pop_item_width()

                    if changed_filter then
                        ui.lobby.filter_index =
                            filter_value
                    end

                    imgui.same_line()
                    imgui.text("Sort:")
                    imgui.same_line()
                    imgui.push_item_width(180)

                    local neutral_lobby_sort_colors =
                        push_neutral_combo_colors()

                    local changed_sort,
                        sort_value =
                            imgui.combo(
                                "##LobbyPlayerSort",
                                ui.lobby.sort_index,
                                ui.lobby.sort_modes
                            )

                    pop_neutral_combo_colors(
                        neutral_lobby_sort_colors
                    )

                    imgui.pop_item_width()

                    if changed_sort then
                        ui.lobby.set_sort_from_index(
                            sort_value
                        )
                    end

                    local displayed_players =
                        ui.lobby.get_filtered_players()

                    local human_players = {}
                    local bot_players = {}

                    for _, player_record in ipairs(
                        displayed_players
                    ) do
                        if player_record.is_bot then
                            table.insert(
                                bot_players,
                                player_record
                            )
                        else
                            table.insert(
                                human_players,
                                player_record
                            )
                        end
                    end

                    local human_content_rows =
                        #human_players > 0
                        and #human_players
                        or 1

                    local bot_content_rows =
                        #bot_players > 0
                        and #bot_players
                        or 1

                    local player_list_height =
                        34 +
                        20 +
                        human_content_rows * 25 +
                        6 +
                        20 +
                        bot_content_rows * 25 +
                        8

                    local final_player_column =
                        ui.lobby.player_table_columns[
                            #ui.lobby.player_table_columns
                        ]

                    local player_list_width =
                        final_player_column.offset +
                        final_player_column.width +
                        12

