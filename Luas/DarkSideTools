    local right_rows = {
        { section = "NETWORK STATUS" }
    }

    if not stats.connected
        or not stats.network_available then

        right_rows[#right_rows + 1] = {
            label = "Network",
            value = tostring(
                stats.status or "Waiting for network data..."
            ),
            color = { 0.70, 0.70, 0.72 }
