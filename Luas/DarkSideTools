    function ui.setting_search.runtime_visible_label(value)
        local label = tostring(value or "")

        if label == "" or label:find("^##") then
            return ""
        end

        label = label:gsub("##.*$", "")
        label = label:gsub("[%c]", " ")
        label = label:gsub("^%s+", ""):gsub("%s+$", "")
        label = label:gsub("%s*:%s*$", "")

        if label == ""
            or #label > 120
            or label:match("^%d+$")
            or label:find("\\", 1, true) then

            return ""
        end

        return label
    end

    function ui.setting_search.runtime_text_is_label(value)
        local raw = tostring(value or "")
        local visible = raw:gsub("##.*$", "")
        visible = visible:gsub("^%s+", ""):gsub("%s+$", "")

        if visible == "" then
            return false
        end

        if visible:match(":%s*$") then
            return true
        end

        if #visible <= 64
            and visible:match("^[%u%d][%u%d%s&/%-]+$") then

            return true
        end

        return false
    end

    function ui.setting_search.register_runtime_term(
        tab_key,
        section_key,
        label
    )
        tab_key = tostring(tab_key or "")
        section_key = tostring(section_key or "")
        label = ui.setting_search.runtime_visible_label(label)

        if tab_key == ""
            or section_key == ""
            or label == "" then

            return false
        end

        local normalized =
            ui.setting_search.normalize(label)

        if normalized == ""
            or ui.setting_search.runtime_button_labels[normalized] == true then

            return false
        end

        ui.setting_search.groups =
            type(ui.setting_search.groups) == "table"
            and ui.setting_search.groups
            or {}

        ui.setting_search.groups[tab_key] =
            type(ui.setting_search.groups[tab_key]) == "table"
            and ui.setting_search.groups[tab_key]
            or {}

        local terms =
            ui.setting_search.groups[tab_key][section_key]

        if type(terms) ~= "table" then
            terms = {}
            ui.setting_search.groups[tab_key][section_key] = terms
        end

        ui.setting_search.runtime_terms[tab_key] =
            type(ui.setting_search.runtime_terms[tab_key]) == "table"
            and ui.setting_search.runtime_terms[tab_key]
            or {}

        local lookup =
            ui.setting_search.runtime_terms[tab_key][section_key]

        if type(lookup) ~= "table" then
            lookup = {}

            for _, existing_term in ipairs(terms) do
                local existing_normalized =
                    ui.setting_search.normalize(
                        ui.setting_search.result_term_label(existing_term)
                    )

                if existing_normalized ~= "" then
                    lookup[existing_normalized] = true
                end
            end

            ui.setting_search.runtime_terms[tab_key][section_key] =
                lookup
        end

        if lookup[normalized] == true then
            return false
        end

        terms[#terms + 1] = label
        lookup[normalized] = true

        ui.setting_search.setting_search_match_match_query = nil
        ui.setting_search.setting_search_match_match_labels = {}
        ui.setting_search.setting_search_match_match_width_signature = ""

