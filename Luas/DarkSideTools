function ui.network.get_standalone_infected_prediction_rows(
    row_limit
)
    row_limit =
        math.max(
            1,
            math.min(
                4,
                math.floor(
                    tonumber(row_limit)
                    or tonumber(ui.lobby.infected_prediction_standalone_limit)
                    or 4
                )
            )
        )

    if type(ui.lobby.get_infected_player_predictions) ~= "function" then
        return {}, 0, false
    end

    local prediction =
        ui.lobby.get_infected_player_predictions()

    local rows = {}
    local total_real = 0

    for _, row in ipairs(
        type(prediction) == "table"
        and type(prediction.rows) == "table"
        and prediction.rows
        or {}
    ) do
        if type(row) == "table"
            and row.is_bot ~= true then

            total_real = total_real + 1

            if #rows < row_limit then
                rows[#rows + 1] = row
            end
        end
    end

    return rows,
        total_real,
        type(prediction) == "table"
        and prediction.used_future_wave == true
end

function ui.network.draw_prediction_segmented_row(
