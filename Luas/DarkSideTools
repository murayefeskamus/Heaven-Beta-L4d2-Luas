function ui.favourites.draw_section_pin_button(
    title,
    unique_id,
    fallback
)
    if ui.favourites.section_pin_consumed == true then
        return false
    end

    local tab_key =
        tostring(
            type(ui.setting_search) == "table"
            and ui.setting_search.runtime_capture_tab
            or ""
        )

    local section_key =
        tostring(
            type(ui.setting_search) == "table"
            and ui.setting_search.runtime_capture_section
            or ""
        )

    if tab_key == ""
        or section_key == ""
        or ui.favourites.tool_indices[
            tab_key
        ] == nil then

        return false
    end

    if fallback == true then
        return false
    end

    if ui.favourites.rendering_tab == true then
        local active_entry =
            ui.favourites.active_entry

        if type(active_entry) ~= "table"
            or tostring(active_entry.tab_key) ~= tab_key
            or tostring(active_entry.section_key) ~= section_key then

            return false
        end

        imgui.same_line()

        ui.favourites.section_pin_consumed =
            true

        ui.favourites.active_controls_drawn =
            true

        ui.favourites.draw_active_entry_controls(
            active_entry,
            ui.favourites.active_entry_index
        )

        return true
    end

    imgui.same_line()

    ui.favourites.section_pin_consumed =
        true

    local entry = {
        kind = "section",
        tab_key = tab_key,
        section_key = section_key,
        term = ""
    }

    local pinned =
        ui.favourites.is_pinned(
            entry
        )

    local pin_id =
        "FavouriteSection" ..
        tostring(tab_key) ..
        "_" ..
        tostring(section_key) ..
        "_" ..
        tostring(unique_id or title or "Section")

    if ui.favourites.draw_pin_button(
        "PIN",
        pin_id,
        pinned
    ) then
        ui.favourites.pin_section(
            tab_key,
            section_key
        )
    end

    return true
end

