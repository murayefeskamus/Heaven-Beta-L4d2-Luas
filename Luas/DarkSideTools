                    bind_label = "Press any key..."
                elseif slot.key > 0 then
                    bind_label =
                        ui.heaven_configs.format_key_badge_label(
                            slot.key,
                            42
                        )
                else
                    bind_label = "Key: Unbound"
                end

                local bind_style =
                    waiting_for_this_slot
                    and "key_waiting"
                    or (
                        slot.key > 0
                        and "key_bound"
                        or "key_unbound"
                    )

                local individual_keys_enabled =
                    ui.heaven_configs.use_cycle_key ~= true

                if ui.heaven_configs.draw_action_button(
                    bind_label,
