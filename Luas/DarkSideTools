    function ui.quotes.run_gui_search(
        find_next
    )
        local gui =
            ui.quotes.ui_state

        if #quotes == 0
            and not load_quotes() then

            ui.quotes.set_search_feedback(
                "File unavailable",
                3
            )

            return false
        end

        local raw_text =
            trim(
                gui.search_text
            )

        local mode_index =
            math.max(
                0,
                math.min(
                    #gui.search_modes - 1,
                    math.floor(
                        tonumber(
                            gui.search_mode_index
                        ) or 0
                    )
                )
            )

        local numeric_mode =
            mode_index == 3
            or mode_index == 4

        if raw_text == "" then
            status.message =
                "Invalid search"

            ui.quotes.set_search_feedback(
                numeric_mode
                and "Enter an ID"
                or "Enter a search value",
                3
            )

            return false
        end

        if numeric_mode
            and not raw_text:match(
                "^%d+$"
            ) then

            status.message =
                "Invalid ID"

            ui.quotes.set_search_feedback(
                "Numbers only",
                3
            )

            return false
        end

        if numeric_mode
            and #raw_text > 6 then

            status.message =
                "Invalid ID"

            ui.quotes.set_search_feedback(
                "ID is too long",
                3
            )

            return false
        end

        if mode_index == 0
            and raw_text:sub(
                1,
                1
            ) == "#"
            and not raw_text:match(
                "^#%d+$"
            ) then

            status.message =
                "Invalid quote ID"

            ui.quotes.set_search_feedback(
                "Invalid quote ID",
                3
            )

            return false
        end

        if mode_index == 0
            and raw_text == "@" then

            status.message =
                "Invalid player search"

            ui.quotes.set_search_feedback(
                "Enter a player ID or name",
                3
            )

            return false
        end

        if find_next
            and #gui.gui_search_state.matches > 0 then

            local selected_quote,
                result_position,
                result_total =
                    select_next_from_state(
                        gui.gui_search_state
                    )

            if selected_quote then
                return ui.quotes.set_gui_result(
                    selected_quote,
                    result_position,
                    result_total,
                    gui.gui_search_state.display_query,
                    gui.gui_search_state.mode
                )
            end
        end

        local direct_id = nil
        local player_id = nil
        local player_name_search = nil
        local request = nil
        local matches = nil

        if mode_index == 3 then
            direct_id =
                tonumber(
                    raw_text
                )
        elseif mode_index == 4 then
            player_id =
                tonumber(
                    raw_text
                )
        elseif mode_index == 5 then
            player_name_search =
                trim(raw_text)
        elseif mode_index == 0 then
            direct_id =
                tonumber(
                    raw_text:match(
                        "^#(%d+)$"
                    )
                )

            if not direct_id then
                player_id =
                    tonumber(
                        raw_text:match(
                            "^@(%d+)$"
                        )
                    )
            end

            if not direct_id
                and not player_id then

                player_name_search =
                    extract_player_name_search(
                        raw_text
                    )
            end
        end

        if direct_id then
            gui.gui_search_state.matches = {}

            local selected_quote =
                quotes_by_line[
                    direct_id
                ]

            if not selected_quote then
                gui.search_result = nil
                gui.search_result_total = 0
                status.message =
                    "Quote ID not found"

                ui.quotes.set_search_feedback(
                    "Quote ID not found",
                    3
                )

                return false
            end

            return ui.quotes.set_gui_result(
                selected_quote,
                1,
                1,
                "#" ..
                    tostring(
                        direct_id
                    ),
                "Quote ID"
            )
        end

        if player_id then
            local player_name =
                get_player_name_from_userid(
                    player_id
                )

            if not player_name
                or player_name == ""
                or player_name == "Unknown" then
                gui.search_result = nil
                gui.search_result_total = 0
                status.message =
                    "Player ID not found"

                ui.quotes.set_search_feedback(
                    "Player ID not found",
                    3
                )

                return false
            end

            matches =
                find_quotes_by_exact_player_name(
                    player_name
                )

            request = {
                mode = "Player ID",
                display =
                    player_name ..
                    " [ID: " ..
                    tostring(
                        player_id
                    ) ..
                    "]",
                key =
                    "gui-player:" ..
                    tostring(
                        player_id
                    ) ..
                    ":" ..
                    normalize_player_name_for_detection(
                        player_name
                    )
            }
        elseif player_name_search then
            matches =
                find_quotes_by_exact_player_name(
                    player_name_search
                )

            request = {
                mode = "Player Name",
                display = player_name_search,
                key = "gui-player-name:" ..
                    normalize_player_name_for_detection(
                        player_name_search
                    )
            }
        else
            local search_text =
                raw_text

            if mode_index == 2 then
                search_text =
                    '"' ..
                    raw_text:gsub(
                        '"',
                        "'"
                    ) ..
                    '"'
            end

            request =
                build_search_request(
                    search_text
                )

            if request then
                if mode_index == 1 then
                    request.mode =
                        "Keywords"
                elseif mode_index == 2 then
                    request.mode =
                        "Exact phrase"
                end

                matches =
                    find_matching_quotes(
                        request
                    )
            end
        end

        if not request then
            status.message =
                "Invalid search"

            ui.quotes.set_search_feedback(
                "Invalid search",
                3
            )

            return false
        end

        if not matches
            or #matches == 0 then

            gui.search_result = nil
            gui.search_result_total = 0

            status.last_search =
                request.display

            status.last_search_mode =
                request.mode

            status.last_search_matches = 0
            status.message =
                "No matches"

            ui.quotes.set_search_feedback(
                "No matches",
                3
            )

            return false
        end

        start_new_search(
            gui.gui_search_state,
            request,
            matches
        )

        local selected_quote,
            result_position,
            result_total =
                select_next_from_state(
                    gui.gui_search_state
                )

        return ui.quotes.set_gui_result(
            selected_quote,
            result_position,
            result_total,
            request.display,
            request.mode
        )
    end

