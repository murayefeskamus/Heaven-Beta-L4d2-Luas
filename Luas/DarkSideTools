                tonumber(
                    spammer_runtime.run_completed_cycles
                ) or 0
            )
        )
    end

    return 1
end

function spammer_cfg.get_cycle_limit_maximum()
    local _,
        remaining_requests,
        _,
        cycle_size,
        fresh_complete_cycles =
            spammer_cfg.get_request_budget_state(
                true
            )

    if cycle_size <= 0 then
        return spammer_cfg.get_cycle_limit_minimum()
    end

    if not spammer_cfg.enabled then
        return math.max(
            spammer_cfg.get_cycle_limit_minimum(),
            fresh_complete_cycles
        )
    end

    local cycle = nil

    if type(
        spammer_runtime.ensure_automation_cycle
    ) == "function" then

        cycle =
            spammer_runtime.ensure_automation_cycle()
    end

    if type(cycle) == "table"
        and #cycle > 0 then

        cycle_size = #cycle
    end

    local position =
        math.max(
            1,
            math.min(
                cycle_size,
                math.floor(
                    tonumber(
                        spammer_runtime.automation_cycle_position
                    ) or 1
                )
            )
        )

    local completed_cycles =
        math.max(
            0,
            math.floor(
                tonumber(
                    spammer_runtime.run_completed_cycles
                ) or 0
            )
        )

    local available_confirmations =
        remaining_requests +
        spammer_cfg.get_pending_request_credit()

    local names_to_finish_current_cycle =
        cycle_size -
        position +
        1

    local additional_cycles = 0

    if available_confirmations >=
        names_to_finish_current_cycle then

        additional_cycles =
            1 +
            math.floor(
                (
                    available_confirmations -
                    names_to_finish_current_cycle
                ) /
                cycle_size
            )
    end

    return math.max(
        spammer_cfg.get_cycle_limit_minimum(),
        completed_cycles +
        additional_cycles
    )
end

