function ui.network.extract_hostname_from_status_text(status_text)
    status_text =
        tostring(status_text or "")

    if status_text == "" then
        return ""
    end

    for line in status_text:gmatch("[^\r\n]+") do
        local hostname =
            line:match(
                "^%s*[Hh]ostname:%s*(.+)$"
            )

        if hostname ~= nil then
            hostname =
                ui.network.normalize_server_hostname_text(
                    hostname
                )

            if hostname ~= "" then
                return hostname
            end
        end
    end

    return ""
end

