function ui.control.calculate_fov_circle_radius(screen_width, screen_height, aim_fov)
    screen_width = math.max(1.0, tonumber(screen_width) or 1.0)
    screen_height = math.max(1.0, tonumber(screen_height) or 1.0)
    aim_fov = ui.control.clamp(tonumber(aim_fov) or 120.0, 1.0, 360.0)

    local half_minimum = math.min(screen_width, screen_height) * 0.485
    local half_diagonal = math.sqrt(
        screen_width * screen_width + screen_height * screen_height
    ) * 0.49

    local radius
    if aim_fov <= 180.0 then
        radius = half_minimum * (aim_fov / 180.0)
    else
        local extra = (aim_fov - 180.0) / 180.0
        radius = half_minimum + (half_diagonal - half_minimum) * extra
    end

    return math.max(4.0, radius)
end

function ui.control.aim_v2_should_show_circle()
    local settings = ui.control.normalize_aim_v2_rebuilt_settings()

    if ui.control.aim.enabled ~= true
        or tonumber(ui.control.aim.mode) ~= 1
        or settings.draw_fov_circle ~= true then
        return false
    end

    local mode = math.max(
        0,
        math.min(1, math.floor(tonumber(settings.fov_circle_display_mode) or 0))
    )

    if mode == 0 and ui.control.resolve_active_mode() ~= 1 then return false end
    if mode == 1 and not ui.control.is_action_key_down() then return false end

    return engine.is_in_game() and engine.is_connected()
end

function ui.control.aim_v2_draw_marker(
    marker,
    center_x,
    center_y,
    red,
    second,
    third,
    alpha
)
    marker = math.max(0, math.min(5, math.floor(tonumber(marker) or 0)))
    if marker == 0 then return true end

    local function line(x1, y1, x2, y2)
        if type(draw) ~= "table" or type(draw.line) ~= "function" then return false end
        local ok, result = pcall(
            draw.line,
            math.floor(x1 + 0.5),
            math.floor(y1 + 0.5),
            math.floor(x2 + 0.5),
            math.floor(y2 + 0.5),
            red, second, third, alpha
        )
        return ok and result ~= false
    end

    if marker == 1 then
        local ok = true
        for offset = -1, 1 do
            ok = line(center_x - 1, center_y + offset, center_x + 1, center_y + offset) and ok
        end
        return ok
    elseif marker == 2 then
        local ok = ui.control.aim_v2_simple_draw_circle_any(
            center_x, center_y, 3.0, 24,
            red, second, third, alpha
        )
        return ok == true
    elseif marker == 3 then
        return line(center_x - 4, center_y - 4, center_x + 4, center_y + 4)
            and line(center_x - 4, center_y + 4, center_x + 4, center_y - 4)
    elseif marker == 4 then
        return line(center_x - 5, center_y, center_x + 5, center_y)
            and line(center_x, center_y - 5, center_x, center_y + 5)
    end

    return line(center_x, center_y - 5, center_x + 5, center_y)
        and line(center_x + 5, center_y, center_x, center_y + 5)
        and line(center_x, center_y + 5, center_x - 5, center_y)
        and line(center_x - 5, center_y, center_x, center_y - 5)
end

function ui.control.draw_fov_circle()
    local settings = ui.control.normalize_aim_v2_rebuilt_settings()
    local runtime = ui.control.runtime

    if not ui.control.aim_v2_should_show_circle() then
        runtime.fov_circle_status = settings.draw_fov_circle and "Hidden" or "Disabled"
        runtime.fov_circle_renderer = "Not drawn"
        return false
    end

    local width, height = ui.control.aim_v2_get_paint_screen_size()
    if not width or not height then
        runtime.fov_circle_status = "Screen size unavailable"
        runtime.fov_circle_renderer = "Unavailable"
        return false
    end

    local center_x = width * 0.5
    local center_y = height * 0.5
    local radius = ui.control.calculate_fov_circle_radius(width, height, settings.fov)
        * settings.fov_circle_scale
    radius = ui.control.clamp(
        radius,
        4.0,
        math.sqrt(width * width + height * height) * 0.49
    )

    local locked = runtime.lock_session_active == true
        and tonumber(runtime.lock_session_target_index) > 0

    local color = settings.fov_circle_color_mode == 2 and locked
        and settings.fov_circle_locked_color
        or settings.fov_circle_unlocked_color
    color = ui.control.normalize_rgba_color(color, { 1.0, 1.0, 1.0, 1.0 })

    local red = math.floor(color[1] * 255.0 + 0.5)
    local green = math.floor(color[2] * 255.0 + 0.5)
    local blue = math.floor(color[3] * 255.0 + 0.5)

    local draw_red = red
    local draw_second = green
    local draw_third = blue

    local alpha = ui.control.clamp(
        (tonumber(settings.fov_circle_opacity_percent) or 0.0) / 100.0,
        0.0,
        1.0
    )
    local segments = 112
    local thickness = settings.fov_circle_thickness

    if settings.fov_circle_glow == true and alpha > 0 then
        local glow_strength = settings.fov_circle_glow_strength
        for ring = 3, 1, -1 do
            local glow_alpha = ui.control.clamp(
                alpha * glow_strength * (0.72 / ring),
                0.0,
                1.0
            )
            ui.control.aim_v2_simple_draw_circle_any(
                center_x,
                center_y,
                radius + ring * 2.0,
                segments,
                draw_red,
                draw_second,
                draw_third,
                glow_alpha
            )
        end
    end

    local all_ok = true
    local active_backend = "Unavailable"

    for layer = 0, thickness - 1 do
        local layer_radius = math.max(2.0, radius - layer)
        local layer_ok, layer_backend = ui.control.aim_v2_simple_draw_circle_any(
            center_x,
            center_y,
            layer_radius,
            segments,
            draw_red,
            draw_second,
            draw_third,
            alpha
        )

        if layer_ok then
            active_backend = layer_backend
        else
            all_ok = false
            break
        end
    end

    if all_ok and settings.fov_circle_center_marker ~= 0 then
        ui.control.aim_v2_draw_marker(
            settings.fov_circle_center_marker,
            center_x,
            center_y,
            draw_red,
            draw_second,
            draw_third,
            alpha
        )
    end

    runtime.fov_circle_radius = radius
    runtime.fov_circle_state = locked and "Locked" or "Ready"
    runtime.fov_circle_selected_hex = ui.control.color_to_hex(color)
    runtime.fov_circle_submitted_hex = runtime.fov_circle_selected_hex
    runtime.fov_circle_predicted_hex = runtime.fov_circle_selected_hex
    runtime.fov_circle_draw_order = "Standard RGB"
    runtime.fov_circle_color_profile = "Exact picker RGB"
    runtime.fov_circle_color_profile_status = "No channel swap or color compensation"
    runtime.fov_circle_render_stage = "Paint"
    runtime.fov_circle_renderer = active_backend
    runtime.fov_circle_status = all_ok
        and string.format(
            "%s | %s | %d%% | thickness %d",
            runtime.fov_circle_state,
            runtime.fov_circle_selected_hex,
            settings.fov_circle_opacity_percent,
            thickness
        )
        or "Circle renderer reported a failure"

    return all_ok
end

function ui.control.draw_aim_v2_color_editor(label, editor_key, color, default_color, controls_x)
    color = ui.control.normalize_rgba_color(color, default_color)
    default_color = ui.control.normalize_rgba_color(default_color, default_color)

    ui.control.ui_state.aim_v2_color_drafts =
        type(ui.control.ui_state.aim_v2_color_drafts) == "table"
        and ui.control.ui_state.aim_v2_color_drafts
        or {}

    local drafts = ui.control.ui_state.aim_v2_color_drafts
    local editor_open = ui.control.ui_state.aim_v2_color_editor == editor_key
    local draft = editor_open and drafts[editor_key] or nil

    if editor_open and type(draft) ~= "table" then
        draft = ui.control.aim_v2_copy_color(color)
        drafts[editor_key] = draft
    end

    local swatch_color = editor_open and draft or color
    swatch_color = ui.control.normalize_rgba_color(swatch_color, color)
    local swatch_text = ui.control.contrast_text_color(swatch_color)

    imgui.text(label)
    imgui.same_line()
    ui.lobby.set_cursor_x(controls_x)

    if colored_button(
        "          ##" .. editor_key .. "Swatch",
        swatch_text[1], swatch_text[2], swatch_text[3],
        swatch_color[1], swatch_color[2], swatch_color[3]
    ) and not editor_open then
        ui.control.ui_state.aim_v2_color_editor = editor_key
        drafts[editor_key] = ui.control.aim_v2_copy_color(color)
        draft = drafts[editor_key]
        editor_open = true
    end

    ui.control.draw_option_hint(
        editor_open
            and "Choose a color, then save or cancel."
            or "Click the color swatch to edit."
    )

    if editor_open then
        draft = ui.control.normalize_rgba_color(
            drafts[editor_key],
            color
        )

        local selected_index = ui.control.aim_v2_nearest_palette_index(draft)

        imgui.text("Color:")
        imgui.same_line()
        ui.lobby.set_cursor_x(controls_x)
        imgui.push_item_width(190)
        local changed, new_index = imgui.slider_int(
            "##" .. editor_key .. "Color",
            selected_index,
            1,
            #ui.control.aim_v2_color_palette
        )
        imgui.pop_item_width()

        if changed then
            local entry = ui.control.aim_v2_color_palette[
                ui.control.aim_v2_clamp_level(
                    new_index,
                    selected_index,
                    #ui.control.aim_v2_color_palette
                )
            ]
            draft = ui.control.aim_v2_copy_color(entry.rgb)
            drafts[editor_key] = draft
            selected_index = new_index
        end

        ui.control.draw_option_hint(
            "The circle changes only after Save is pressed."
        )

        local changed_from_saved =
            math.abs((draft[1] or 0.0) - (color[1] or 0.0)) > 0.0005
            or math.abs((draft[2] or 0.0) - (color[2] or 0.0)) > 0.0005
            or math.abs((draft[3] or 0.0) - (color[3] or 0.0)) > 0.0005

        if changed_from_saved then
            if colored_button(
                "Save##" .. editor_key .. "Save",
                1.0, 1.0, 1.0,
                0.18, 0.48, 0.24
            ) then
                color = ui.control.aim_v2_copy_color(draft)
                drafts[editor_key] = nil
                ui.control.ui_state.aim_v2_color_editor = ""
                ui.control.runtime.aim_v2_color_notice = "Color saved."
                ui.control.runtime.aim_v2_color_notice_until = get_time() + 2.5
            end
        else
            disabled_button("Save##" .. editor_key .. "SaveDisabled")
        end

        imgui.same_line()
        if colored_button(
            "Cancel##" .. editor_key .. "Cancel",
            1.0, 1.0, 1.0,
            0.30, 0.30, 0.30
        ) then
            drafts[editor_key] = nil
            ui.control.ui_state.aim_v2_color_editor = ""
        end
    end

    return color
end

