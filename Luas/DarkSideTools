function ui.control.aim_guided_poll_cycle_key(settings)
    local runtime = ui.control.runtime
    local key_value = math.floor(tonumber(settings.target_cycle_key) or 0)

    if key_value <= 0
        or ui.control.waiting_for_target_cycle_key
        or ui.input_safety.block_runtime_hotkeys()
        or type(input) ~= "table"
        or type(input.is_key_down) ~= "function" then

        runtime.target_cycle_key_was_down = false
        runtime.target_cycle_repeat_next_at = 0.0
        return false
    end

    local key_ok, key_down = pcall(input.is_key_down, key_value)
    key_down = key_ok and key_down == true

    local hold_session_active =
        runtime.lock_session_active == true
        and ui.control.is_action_key_down()

    if not key_down or not hold_session_active then
        runtime.target_cycle_key_was_down = key_down
        runtime.target_cycle_repeat_next_at = 0.0
        return false
    end

    local now = get_time()

    if runtime.target_cycle_key_was_down ~= true then
        runtime.target_cycle_key_was_down = true
        runtime.target_cycle_repeat_next_at = now + 0.28
        return true
    end

    if now >= (tonumber(runtime.target_cycle_repeat_next_at) or 0.0) then
        runtime.target_cycle_repeat_next_at = now + 0.12
        return true
    end

    return false
end

