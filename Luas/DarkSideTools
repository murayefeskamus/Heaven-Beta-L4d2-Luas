function spammer_cfg.get_request_budget_state(
    align_to_complete_cycles
)
    local raw_limit,
        restore_reserve =
            spammer_cfg.get_automation_request_limit()

    local cycle_size =
        spammer_cfg.get_automation_cycle_size()

    local complete_cycles = 0
    local safe_budget = raw_limit

    if cycle_size > 0 then
        complete_cycles =
            math.floor(
                raw_limit /
                cycle_size
            )

        if align_to_complete_cycles == true then


            safe_budget =
                complete_cycles *
                cycle_size
        end
    elseif align_to_complete_cycles == true then
        safe_budget = 0
    end

    local used_requests = 0

    if spammer_cfg.enabled then
        used_requests =
            spammer_cfg.get_run_request_count()
    end

    local remaining_requests =
        math.max(
            0,
            safe_budget -
            used_requests
        )

    return safe_budget,
        remaining_requests,
        used_requests,
        cycle_size,
        complete_cycles,
        restore_reserve,
        raw_limit
end

