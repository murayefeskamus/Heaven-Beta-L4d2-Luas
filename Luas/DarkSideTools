    if role_value ~= ""
        and role_value ~= "Unknown"
        and role_value ~= "Unavailable"
        and role_value ~= team_identity then

        team_identity =
            team_identity .. " (" .. role_value .. ")"
    end

    local identity_fields = {
        "Name: " .. tostring(player_record.name),
        "UID: " .. userid_text,
        "Team: " .. team_identity,
        "State: " .. state_text,
        "HP: " ..
            (
                player_record.health ~= nil
                and tostring(player_record.health)
                or "N/A"
            ),
        "K: " ..
            tostring(player_record.kills or 0) ..
            ", D: " ..
            tostring(player_record.deaths or 0) ..
            ", K/D: " ..
            ui.lobby.format_kd_ratio(
