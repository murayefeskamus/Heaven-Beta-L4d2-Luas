        ui.control.active_mode = mode
        ui.control.reset_aim_v2_tracking(true)
        ui.control.runtime.status_hold_until = 0.0
        ui.control.runtime.last_mode_change_time = get_time()
        ui.control.runtime.status = "Ready"
