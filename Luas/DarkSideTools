function name_reverser.clamp_workshop_input(text)
    local clean_name =
        clean_name_for_reverse(
            text
        )

    local fitted_characters = {}
    local used_bytes = 0
    local truncated = false

    for _, character in ipairs(
        split_utf8_characters(
            clean_name
        )
    ) do
        if #fitted_characters >=
            DARKSIDE_CONFIG.MAX_NAME_CHARACTERS
            or used_bytes + #character >
                DARKSIDE_CONFIG.MAX_NAME_LENGTH then

            truncated = true
            break
        end

        table.insert(
            fitted_characters,
            character
        )

        used_bytes =
            used_bytes + #character
    end

    local fitted_name =
        table.concat(
            fitted_characters
        )

    return fitted_name,
        truncated or fitted_name ~= clean_name,
        #fitted_characters,
        used_bytes
end

function name_reverser.get_workshop_input_character_limit(text)
    local fitted_name,
        _,
        character_count,
        used_bytes =
            name_reverser.clamp_workshop_input(
                text
            )

    local characters =
        split_utf8_characters(
            fitted_name
        )

    local projected_character_bytes = 1

    if #characters > 0 then
        projected_character_bytes =
            math.max(
                1,
                #characters[
                    #characters
                ]
            )
    end

    local remaining_bytes =
        math.max(
            0,
            DARKSIDE_CONFIG.MAX_NAME_LENGTH -
            used_bytes
        )

    local byte_limited_maximum =
        character_count +
        math.floor(
            remaining_bytes /
            projected_character_bytes
        )

    return math.max(
        character_count,
        math.min(
            DARKSIDE_CONFIG.MAX_NAME_CHARACTERS,
            byte_limited_maximum
        )
    )
end

do
    local uncached_workshop_clamp =
        name_reverser.clamp_workshop_input

    local uncached_workshop_limit =
        name_reverser.get_workshop_input_character_limit

    name_reverser.clamp_workshop_input =
        function(text_value)
            local cache_key =
                tostring(text_value or "")

            return ui.performance.memoize_values(
                "name_workshop_clamp",
                cache_key,
                function()
                    return uncached_workshop_clamp(
                        text_value
                    )
                end,
                384
            )
        end

    name_reverser.get_workshop_input_character_limit =
        function(text_value)
            local cache_key =
                tostring(text_value or "")

            return ui.performance.memoize_values(
                "name_workshop_character_limit",
                cache_key,
                function()
                    return uncached_workshop_limit(
                        text_value
                    )
                end,
                384
            )
        end
end

