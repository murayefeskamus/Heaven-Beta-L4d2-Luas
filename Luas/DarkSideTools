function ui.control.get_target_point_position(player, target_point, incapacitated, settings)
    if not player then return nil end

    local origin = ui.lobby.call_method(player, "get_origin")
    if not origin then return nil end

    local eye = ui.lobby.call_method(player, "get_eye_position")
    if not eye then
        eye = vector.new(
            tonumber(origin.x) or 0.0,
            tonumber(origin.y) or 0.0,
            (tonumber(origin.z) or 0.0) + (incapacitated and 34.0 or 64.0)
        )
    end

    target_point = math.max(
        0,
        math.min(2, math.floor(tonumber(target_point) or 2))
    )

    if incapacitated
        and settings
        and settings.incapacitated_center_mass == true then
        target_point = 2
    end

    local origin_x = tonumber(origin.x) or 0.0
    local origin_y = tonumber(origin.y) or 0.0
    local origin_z = tonumber(origin.z) or 0.0
    local eye_x = tonumber(eye.x) or origin_x
    local eye_y = tonumber(eye.y) or origin_y
    local eye_z = tonumber(eye.z) or origin_z

    local minimum_height = incapacitated and 28.0 or 52.0
    local maximum_height = incapacitated and 48.0 or 76.0
    local body_height = ui.control.clamp(eye_z - origin_z, minimum_height, maximum_height)

    local ratio
    if target_point == 0 then
        ratio = 1.0
    elseif target_point == 1 then
        ratio = 0.72
    else
        ratio = 0.54
    end

    local position_x = origin_x + (eye_x - origin_x) * ratio
    local position_y = origin_y + (eye_y - origin_y) * ratio
    local position_z = origin_z + body_height * ratio

    if target_point == 0 then
        position_x = eye_x
        position_y = eye_y
        position_z = math.max(position_z, eye_z - 1.0)
    elseif target_point == 1 then
        position_z = math.max(position_z, origin_z + minimum_height * 0.70)
    else
        position_z = math.max(position_z, origin_z + minimum_height * 0.50)
    end

    return vector.new(position_x, position_y, position_z)
end

function ui.control.aim_v2_dynamic_prediction_time(settings, distance, velocity_x, velocity_y)
    if settings.prediction ~= true then return 0.0 end

    local level = ui.control.aim_v2_clamp_level(
        settings.prediction_strength_level,
        5,
        10
    )

    local maximum_time = 0.012 + (level - 1) * 0.0105
    local speed = math.sqrt(
        (tonumber(velocity_x) or 0.0) ^ 2 +
        (tonumber(velocity_y) or 0.0) ^ 2
    )

    distance = math.max(0.0, tonumber(distance) or 0.0)

    local close_gate = ui.control.clamp((distance - 52.0) / 150.0, 0.0, 1.0)
    local distance_factor = ui.control.clamp((distance - 90.0) / 1900.0, 0.0, 1.0)
    local speed_factor = ui.control.clamp(speed / 480.0, 0.0, 1.0)

    local prediction_time = maximum_time *
        (0.12 + distance_factor * 0.58 + speed_factor * 0.30) *
        close_gate

    if distance <= 64.0 then
        prediction_time = 0.0
    end

    return ui.control.clamp(prediction_time, 0.0, maximum_time)
end

function ui.control.aim_v2_simple_build_target(local_player, target_index, settings, current_angles, held)
    local player = entity.get_by_index(target_index)
    if not player then return nil end

    local local_index = tonumber(ui.lobby.call_method(local_player, "get_index")) or -1
    local player_index = tonumber(ui.lobby.call_method(player, "get_index")) or -1
    local team = tonumber(ui.lobby.call_method(player, "get_team")) or 0

    if player_index ~= tonumber(target_index)
        or player_index == local_index
        or team ~= 2 then
        return nil
    end

    local incapacitated, hanging = ui.control.get_survivor_state(player)

    if held ~= true then
        local valid = ui.control.is_valid_survivor(
            player,
            local_index,
            settings.target_incapacitated == true,
            settings.target_hanging == true
        )
        if valid ~= true then return nil end
    end

    local eye_position = ui.control.aim_v2_simple_get_eye_position(local_player)
    local target_origin = ui.lobby.call_method(player, "get_origin")
    if not eye_position or not target_origin then return nil end

    local aim_position = ui.control.get_target_point_position(
        player,
        settings.target_point,
        incapacitated,
        settings
    )
    if not aim_position then return nil end

    local distance = vector.distance(eye_position, target_origin)
    if held ~= true and distance > settings.max_distance then return nil end

    if settings.visible_only == true and held ~= true then
        local visible = ui.control.is_target_visible(
            local_player,
            player,
            eye_position,
            aim_position,
            target_index
        )
        if visible ~= true then return nil end
    end

    local velocity_x = 0.0
    local velocity_y = 0.0
    local target_velocity = ui.lobby.call_method(player, "get_velocity")

    if target_velocity then
        velocity_x = tonumber(target_velocity.x) or 0.0
        velocity_y = tonumber(target_velocity.y) or 0.0
    end

    if settings.relative_prediction == true then
        local local_velocity = ui.lobby.call_method(local_player, "get_velocity")
        if local_velocity then
            velocity_x = velocity_x - (tonumber(local_velocity.x) or 0.0)
            velocity_y = velocity_y - (tonumber(local_velocity.y) or 0.0)
        end
    end

    local prediction_time = ui.control.aim_v2_dynamic_prediction_time(
        settings,
        distance,
        velocity_x,
        velocity_y
    )

    if prediction_time > 0.0 then
        aim_position = vector.new(
            (tonumber(aim_position.x) or 0.0) + velocity_x * prediction_time,
            (tonumber(aim_position.y) or 0.0) + velocity_y * prediction_time,
            tonumber(aim_position.z) or 0.0
        )
    end

    if held == true
        and distance < 150.0
        and ui.control.runtime.simple_cached_aim_position then

        local cached_z = tonumber(ui.control.runtime.simple_cached_aim_position.z)
        if cached_z then
            local live_z = tonumber(aim_position.z) or cached_z
            aim_position = vector.new(
                tonumber(aim_position.x) or 0.0,
                tonumber(aim_position.y) or 0.0,
                cached_z * 0.24 + live_z * 0.76
            )
        end
    end

    local aim_angle = ui.control.calculate_angle(eye_position, aim_position)
    if not aim_angle then return nil end

    local target_fov = ui.control.get_fov(current_angles, aim_angle)
    if held ~= true and target_fov > settings.fov then return nil end

    return {
        player = player,
        index = target_index,
        userid = ui.control.aim_v2_simple_get_userid(player),
        aim_position = aim_position,
        target_origin = target_origin,
        aim_angle = aim_angle,
        distance = distance,
        fov = target_fov,
        prediction_time = prediction_time,
        incapacitated = incapacitated == true,
        hanging = hanging == true,
        held = held == true,
        score = target_fov + math.min(distance / 1000.0, 8.0) * 0.25
    }
end

function ui.control.stabilize_aim_v2_angles(current_angles, target, settings)
    local delta_time = ui.control.aim_v2_simple_frame_delta()
    local smooth = tonumber(settings.smooth) or 1.0

    local factor = smooth <= 1.001
        and 1.0
        or ui.control.clamp((delta_time * 60.0) / smooth, 0.0, 1.0)

    local distance = tonumber(target.distance) or 9999.0
    local contact_boost = ui.control.clamp((180.0 - distance) / 130.0, 0.0, 1.0)
    factor = math.max(factor, contact_boost * 0.58 + 0.34)
    factor = ui.control.clamp(factor, 0.0, 1.0)

    local pitch_delta = ui.control.normalize_angle(target.aim_angle.x - current_angles.x)
    local yaw_delta = ui.control.normalize_angle(target.aim_angle.y - current_angles.y)

    return vector.new(
        ui.control.clamp(current_angles.x + pitch_delta * factor, -89.0, 89.0),
        ui.control.normalize_angle(current_angles.y + yaw_delta * factor),
        0.0
    )
end

