function build_spoofed_name(
    name,
    force_zero_width_prefix
)
    local clean_name =
        sanitize_name(name)

    if clean_name == "" then
        return nil
    end

    local should_use_zero_width_prefix =
        force_zero_width_prefix == true
        or name_stealer.use_zero_width_prefix == true

    if not should_use_zero_width_prefix then
        return clean_name
    end

    if #DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX + #clean_name
        <= DARKSIDE_CONFIG.MAX_NAME_LENGTH then

        return DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX ..
            clean_name
    end

    return clean_name
end

function split_utf8_characters(text)
    text =
        tostring(text or "")

    local characters = {}
    local index = 1
    local text_length = #text

    while index <= text_length do
        local first_byte =
            text:byte(index)

        local character_length = 1

        if first_byte
            and first_byte >= 0xF0
            and first_byte <= 0xF7 then

            character_length = 4
        elseif first_byte
            and first_byte >= 0xE0
            and first_byte <= 0xEF then

            character_length = 3
        elseif first_byte
            and first_byte >= 0xC0
            and first_byte <= 0xDF then

            character_length = 2
        end

        local final_index =
            math.min(
                text_length,
                index + character_length - 1
            )

        table.insert(
            characters,
            text:sub(
                index,
                final_index
            )
        )

        index =
            final_index + 1
    end

    return characters
end

function spammer_cfg.limit_name_characters(
    value,
    maximum_characters
)
    local clean_value =
        sanitize_name(
            value
        )

    maximum_characters =
        math.max(
            0,
            math.floor(
                tonumber(
                    maximum_characters
                ) or 0
            )
        )

    local characters =
        split_utf8_characters(
            clean_value
        )

    if #characters <= maximum_characters then
        return clean_value,
            #characters,
            false
    end

    local limited = {}

    for index = 1,
        maximum_characters do

        limited[index] =
            characters[index]
    end

    return table.concat(
        limited
    ),
        maximum_characters,
        true
end

function spammer_cfg.get_name_character_count(
    value
)
    return #split_utf8_characters(
        sanitize_name(
            value
        )
    )
end

do
