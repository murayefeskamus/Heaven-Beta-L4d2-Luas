    )

    return ok and result ~= false
end

function ui.control.aim_safe_draw_circle_lines(
    center_x, center_y, radius, segments,
    red, green, blue, alpha
)
    local previous_x = center_x + radius
    local previous_y = center_y

    for segment = 1, segments do
        local angle = segment / segments * math.pi * 2.0
        local next_x = center_x + math.cos(angle) * radius
        local next_y = center_y + math.sin(angle) * radius

        if not ui.control.aim_safe_draw_line(
            previous_x, previous_y, next_x, next_y,
            red, green, blue, alpha
        ) then
            return false
        end

        previous_x = next_x
        previous_y = next_y
    end

    return true
end

function ui.control.aim_safe_draw_marker(
    marker, center_x, center_y,
    red, green, blue, alpha
)
    marker = math.floor(tonumber(marker) or 0)
    if marker <= 0 then return true end

    local function line(x1, y1, x2, y2)
        return ui.control.aim_safe_draw_line(
            x1, y1, x2, y2,
            red, green, blue, alpha
        )
    end

    if marker == 1 then
        return line(center_x - 1, center_y, center_x + 1, center_y)
            and line(center_x, center_y - 1, center_x, center_y + 1)
    elseif marker == 2 then
        return ui.control.aim_safe_draw_circle_lines(
            center_x, center_y, 3.0, 24,
            red, green, blue, alpha
        )
    elseif marker == 3 then
        return line(center_x - 4, center_y - 4, center_x + 4, center_y + 4)
            and line(center_x - 4, center_y + 4, center_x + 4, center_y - 4)
    elseif marker == 4 then
        return line(center_x - 5, center_y, center_x + 5, center_y)
            and line(center_x, center_y - 5, center_x, center_y + 5)
    end

    return line(center_x, center_y - 5, center_x + 5, center_y)
        and line(center_x + 5, center_y, center_x, center_y + 5)
        and line(center_x, center_y + 5, center_x - 5, center_y)
        and line(center_x - 5, center_y, center_x, center_y - 5)
end

function ui.control.draw_fov_circle()
    local settings = ui.control.normalize_aim_v2_rebuilt_settings()
    local runtime = ui.control.runtime

    if not ui.control.aim_v2_should_show_circle() then
        runtime.fov_circle_status = settings.draw_fov_circle and "Hidden" or "Disabled"
        runtime.fov_circle_renderer = "Not drawn"
        return false
    end

    local metrics = ui.control.aim_boundary_screen_metrics(settings)
    if not metrics then
        runtime.fov_circle_status = "Screen size unavailable"
        runtime.fov_circle_renderer = "Unavailable"
        return false
    end

    local locked = runtime.lock_session_active == true
        and tonumber(runtime.lock_session_target_index) > 0
    local color = settings.fov_circle_color_mode == 2 and locked
        and settings.fov_circle_locked_color
        or settings.fov_circle_unlocked_color
    color = ui.control.normalize_rgba_color(
        color,
        { 1.0, 1.0, 1.0, 1.0 }
    )

    local red = color[1]
    local green = color[2]
    local blue = color[3]
    local alpha = ui.control.clamp(
        (tonumber(settings.fov_circle_opacity_percent) or 0.0) / 100.0,
        0.0,
        1.0
    )
    local segments = 112
    local thickness = math.max(
        1,
        math.min(5, math.floor(tonumber(settings.fov_circle_thickness) or 1))
    )
    local all_ok = true

    if settings.fov_circle_glow == true and alpha > 0.0 then
        local glow_strength = tonumber(settings.fov_circle_glow_strength) or 0.0
        for ring = 3, 1, -1 do
            local glow_alpha = ui.control.clamp(
                alpha * glow_strength * (0.72 / ring),
                0.0,
                1.0
            )
            ui.control.aim_safe_draw_circle_lines(
                metrics.center_x,
                metrics.center_y,
                metrics.radius + ring * 2.0,
                segments,
                red,
                green,
                blue,
                glow_alpha
            )
        end
    end

    for layer = 0, thickness - 1 do
        if not ui.control.aim_safe_draw_circle_lines(
            metrics.center_x,
            metrics.center_y,
            math.max(2.0, metrics.radius - layer),
            segments,
            red,
            green,
            blue,
            alpha
        ) then
            all_ok = false
            break
        end
    end

    if all_ok and settings.fov_circle_center_marker ~= 0 then
        all_ok = ui.control.aim_safe_draw_marker(
            settings.fov_circle_center_marker,
            metrics.center_x,
            metrics.center_y,
            red,
            green,
            blue,
            alpha
        ) == true
    end

    runtime.fov_circle_radius = metrics.radius
    runtime.fov_circle_state = locked and "Locked" or "Ready"
    runtime.fov_circle_selected_hex = ui.control.color_to_hex(color)
    runtime.fov_circle_submitted_hex = string.format(
        "Float RGBA %.3f, %.3f, %.3f, %.3f",
        red, green, blue, alpha
    )
    runtime.fov_circle_predicted_hex = runtime.fov_circle_selected_hex
    runtime.fov_circle_draw_order = "Native normalized RGB"
    runtime.fov_circle_color_profile = "Exact picker RGB"
    runtime.fov_circle_color_profile_status =
        "Direct 0.0-1.0 RGBA; no byte conversion, inversion or channel swap"
    runtime.fov_circle_render_stage = "Paint"
    runtime.fov_circle_renderer = "Connected draw.line - normalized RGBA"
    runtime.fov_circle_status = all_ok
        and string.format(
            "%s | %d%% | native RGB",
            runtime.fov_circle_state,
            settings.fov_circle_opacity_percent
        )
        or "Circle draw.line renderer failed"

    return all_ok
end

