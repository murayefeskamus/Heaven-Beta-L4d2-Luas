function ui.voice_control.get_voice_id(player_record)
    if type(player_record) ~= "table" then
        return 0
    end

    return math.max(
        0,
        math.floor(tonumber(player_record.entity_index) or 0)
    )
end

function ui.voice_control.get_player_state_key(player_record)
    player_record =
        type(player_record) == "table"
        and player_record
        or {}

    local userid =
        math.floor(tonumber(player_record.userid) or 0)

    if userid > 0 then
        return "uid:" .. tostring(userid)
    end

    local voice_id =
        ui.voice_control.get_voice_id(player_record)

    return "voice:" .. tostring(voice_id) ..
        "|name:" ..
        tostring(player_record.name or "Unknown"):lower()
end

function ui.voice_control.is_player_tracked_muted(player_record)
    local state_key =
        ui.voice_control.get_player_state_key(player_record)

    return ui.voice_control.player_mute_state[state_key] == true
end

function ui.voice_control.set_player_tracked_muted(player_record, muted)
    local state_key =
        ui.voice_control.get_player_state_key(player_record)

    ui.voice_control.player_mute_state[state_key] = muted == true
end

function ui.voice_control.player_is_supported(player_record)
    if type(player_record) ~= "table" then
        return false, "Select a player first."
    end

    if player_record.is_local == true then
        return false, "You cannot mute yourself."
    end

    if player_record.is_bot == true then
        return false, "Bots cannot be muted."
    end

    if ui.voice_control.get_voice_id(player_record) <= 0 then
        return false, "Voice ID unavailable."
    end

    return true, ""
end

function ui.voice_control.get_remote_human_players()
    local players = {}

    for _, player_record in ipairs(ui.lobby.players or {}) do
        local supported =
            ui.voice_control.player_is_supported(player_record)

        if supported then
            players[#players + 1] = player_record
        end
    end

    table.sort(
        players,
        function(left, right)
            return ui.voice_control.get_voice_id(left)
                < ui.voice_control.get_voice_id(right)
        end
    )

    return players
end

function ui.voice_control.copy_console_command(command_text, from_chat)
    command_text = tostring(command_text or "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")

    if command_text == "" then
        local message = "No command was prepared."
        ui.voice_control.set_status(message, true)

        if from_chat then
            ui.voice_control.queue_command_response({ message })
        end

        return false
    end

    local copied = false

    if type(ui.network) == "table"
        and type(ui.network.set_clipboard_text_process_free) == "function" then

        local ok, result = pcall(
            ui.network.set_clipboard_text_process_free,
            command_text
        )

        copied = ok and result == true
    end

    ui.voice_control.last_prepared_command = command_text

    local message

    if copied then
        message =
            "Command copied. Paste it in the console."
    else
        message =
            "Clipboard unavailable. Run: " .. command_text
    end

    ui.voice_control.set_status(message, not copied, 7.0)

    if from_chat then
        ui.voice_control.queue_command_response({ message })
    end

    return copied
end

function ui.voice_control.mute_player(player_record, from_chat)
