function alternating_case_text(
    text,
    start_with_upper
)
    text =
        tostring(text or "")

    local output = {}
    local make_upper =
        start_with_upper ~= false

    for index = 1, #text do
        local character =
            text:sub(
                index,
                index
            )

        local byte_value =
            character:byte()

        if byte_value
            and (
                (
                    byte_value >= string.byte("A")
                    and byte_value <= string.byte("Z")
                )
                or (
                    byte_value >= string.byte("a")
                    and byte_value <= string.byte("z")
                )
            ) then

            if make_upper then
                character =
                    character:upper()
            else
                character =
                    character:lower()
            end

            make_upper =
                not make_upper
        end

        table.insert(
            output,
            character
        )
    end

    return table.concat(
        output
    )
end

function shuffle_name_text(text)
    local characters =
        split_utf8_characters(
            clean_name_for_reverse(
                text
            )
        )

    if #characters <= 1 then
        return table.concat(
            characters
        )
    end

    local original =
        table.concat(
            characters
        )

    for index = #characters,
        2,
        -1 do

        local swap_index =
            math.random(
                1,
                index
            )

        characters[index],
        characters[swap_index] =
            characters[swap_index],
            characters[index]
    end

    local shuffled =
        table.concat(
            characters
        )


    if shuffled == original then
        local different_index = nil

        for index = 2,
            #characters do

            if characters[index]
                ~= characters[1] then

                different_index = index
                break
            end
        end

        if different_index then
            characters[1],
            characters[different_index] =
                characters[different_index],
                characters[1]

            shuffled =
                table.concat(
                    characters
                )
        end
    end

    return shuffled
end

function build_palindrome_name(text)
