    end

    local userid = 0
    local spoken_text = ""

    pcall(function()
        userid = tonumber(event:get_int("userid")) or 0
    end)

    pcall(function()
        spoken_text = tostring(event:get_string("text") or "")
    end)

    local normalized = spoken_text
        :gsub("^%s+", "")
        :gsub("%s+$", "")
        :lower()

    if normalized ~= ui.saved_name_matches_command then
        return
    end

    if userid <= 0 then
        return
    end

    if type(ui.enhancements) == "table"
        and type(ui.enhancements.command_allowed) == "function"
        and not ui.enhancements.command_allowed(
            "savedmatches",
            userid,
            false
        ) then

        return
    end

    ui.lobby.queue_chat_messages(
        ui.lobby.build_saved_name_match_messages()
    )
end



