function ui.enhancements.theme_colors_equal(
    first,
    second
)
    for _, field_name in ipairs({
        "accent",
        "background",
        "child",
        "button",
        "text"
    }) do
        for channel = 1, 3 do
            local first_value =
                tonumber(
                    first
                    and first[field_name]
                    and first[field_name][channel]
                ) or 0.0

            local second_value =
                tonumber(
                    second
                    and second[field_name]
                    and second[field_name][channel]
                ) or 0.0

            if math.abs(
                first_value -
                second_value
            ) > 0.0001 then

                return false
            end
        end
    end

    return true
end

