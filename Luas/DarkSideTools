function ui.console.print(message)
    message = tostring(message or "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")

    if message == "" then
        return false
    end

    local category = "Dark Side Tools"
    local body = message

    local category_map = {
        ["Name Tools"] = "Names",
        ["Name Spammer"] = "Name Spammer",
        ["Name Workshop"] = "Name Workshop",
        ["Name Stealer"] = "Name Stealer",
        ["Chat Spammer"] = "Chat Spammer",
        ["Lobby & Network"] = "Game & Net",
        ["L4D2 Quotes"] = "Quotes",
        ["DST Quotes"] = "Quotes",
        ["Quotes"] = "Quotes",
        ["DST Config Hotkeys"] = "Heaven Configs",
        ["DST"] = "Dark Side Tools"
    }

    local tagged_category,
        tagged_body =
            body:match(
                "^%[([^%]]+)%]%s*(.*)$"
            )

    if tagged_category then
        category =
            category_map[tagged_category]
            or tagged_category

        body = tagged_body
    end

    body = body
        :gsub("Initial name locked from ", "Original name captured from ")
        :gsub("Cannot ", "Unable to ")
        :gsub("could not ", "was unable to ")
        :gsub("Could not ", "Unable to ")

    local formatted =
        category == "Dark Side Tools"
        and ("[DST] " .. body)
        or ("[DST | " .. category .. "] " .. body)

    _G.__HEAVEN_FRIENDLY_CONSOLE =
        _G.__HEAVEN_FRIENDLY_CONSOLE or {
            messages = {},
            cleanup_at = 0.0
        }

    local registry =
        _G.__HEAVEN_FRIENDLY_CONSOLE

    local now = get_time()
    local previous =
        tonumber(
            registry.messages[formatted]
        ) or -1000.0

    local structural_line =
        body:match("^[-=_%s]+$") ~= nil

    if not structural_line
        and now - previous < 2.0 then

        return false
    end

    registry.messages[formatted] = now

    if now >=
        (
            tonumber(registry.cleanup_at)
            or 0.0
        ) then

        registry.cleanup_at = now + 30.0

        for old_message,
            seen_at in pairs(
                registry.messages
            ) do

            if now -
                (
                    tonumber(seen_at)
                    or 0.0
                ) > 60.0 then

                registry.messages[old_message] = nil
            end
        end
    end

    if type(client) == "table"
        and type(client.print) == "function" then

        local print_ok =
            pcall(
                client.print,
                formatted
            )

        return print_ok
    end

    return false
end

function ui.performance.should_capture_window_state(
    capture_key,
    force_capture
)
    capture_key = tostring(capture_key or "window")

    if force_capture == true then
        ui.performance.next_window_capture[capture_key] =
            get_time() + ui.performance.window_capture_interval

        return true
    end

    local now = get_time()
    local next_capture =
        tonumber(
            ui.performance.next_window_capture[capture_key]
        ) or 0.0

    if now < next_capture then
        return false
    end

    ui.performance.next_window_capture[capture_key] =
        now + ui.performance.window_capture_interval

    return true
end

