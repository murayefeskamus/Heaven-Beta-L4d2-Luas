function ui.lobby.truncate_utf8_chat_message(
    text_value,
    byte_limit
)
    text_value = tostring(text_value or "")
    byte_limit = math.max(
        0,
        math.floor(
            tonumber(byte_limit) or 118
        )
    )

    if #text_value <= byte_limit then
        return text_value
    end

    if byte_limit <= 3 then
        return text_value:sub(1, byte_limit)
    end

    local content_limit = byte_limit - 3
    local index = 1
    local last_complete_byte = 0

    while index <= #text_value do
        local first_byte = string.byte(
            text_value,
            index
        )

        if not first_byte then
            break
        end

        local character_length = 1

        if first_byte >= 240 then
            character_length = 4
        elseif first_byte >= 224 then
            character_length = 3
        elseif first_byte >= 192 then
            character_length = 2
        end

        local character_end =
            index + character_length - 1

        if character_end > content_limit
            or character_end > #text_value then

            break
        end

        last_complete_byte = character_end
        index = character_end + 1
    end

    return text_value:sub(
        1,
        last_complete_byte
    ) .. "..."
end

function ui.lobby.prefix_command_message(
    tool_label,
    message
)
    tool_label = tostring(
        tool_label or "Dark Side Tools"
    ):upper()

    message = tostring(message or "")

    local prefix = "[" .. tool_label .. "] "
    local existing_prefix =
        message:sub(1, #prefix)

    if existing_prefix:upper() == prefix then
        return ui.lobby.truncate_utf8_chat_message(
            prefix .. message:sub(#prefix + 1),
            118
        )
    end

    return ui.lobby.truncate_utf8_chat_message(
        prefix .. message,
        118
    )
end

function ui.lobby.prefix_command_messages(
    tool_label,
    messages
)
    local output = {}
    local first_message = true

    for _, message in ipairs(
        type(messages) == "table"
        and messages
        or {}
    ) do
        message = tostring(message or "")

        if message ~= "" then
            if first_message then
                output[#output + 1] =
                    ui.lobby.prefix_command_message(
                        tool_label,
                        message
                    )

                first_message = false
            else
                output[#output + 1] =
                    ui.lobby.truncate_utf8_chat_message(
                        message,
                        118
                    )
            end
        end
    end

    return output
end

