                tostring(value or "")

            return ui.performance.memoize_values(
                "spammer_name_character_count",
                cache_key,
                function()
                    return uncached_name_character_count(
                        value
                    )
                end,
                768
            )
        end
end

function reverse_utf8_text(text)
    local characters =
        split_utf8_characters(
            text
        )

    local left = 1
    local right = #characters

    while left < right do
        characters[left],
        characters[right] =
            characters[right],
            characters[left]

        left = left + 1
        right = right - 1
    end

    return table.concat(
        characters
    )
end

function truncate_name_utf8(
    text,
    byte_limit
)
    text =
        tostring(text or "")

    byte_limit =
        math.max(
            0,
            tonumber(byte_limit) or 0
        )

    if #text <= byte_limit then
        return text,
            false
    end

    local output = {}
    local used_bytes = 0

    for _, character in ipairs(
        split_utf8_characters(
            text
        )
    ) do
        if used_bytes + #character
            > byte_limit then

            break
        end

        table.insert(
            output,
            character
        )

        used_bytes =
            used_bytes +
            #character
    end

    return table.concat(
        output
    ),
        true
end

function clean_name_for_reverse(name)
    local clean_name =
        sanitize_name(
            name
        )


    while clean_name:sub(
        1,
        #DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX
    ) == DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX do

        clean_name =
            clean_name:sub(
                #DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX + 1
            )
    end

    if clean_name:sub(
        1,
        #DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR
    ) == DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR then

        clean_name =
            clean_name:sub(
                #DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR + 1
            )
    end

    return clean_name
end


function spammer_runtime.normalize_visible_name_for_compare(name)
    local normalized =
        tostring(
            name or ""
        )

    while normalized:sub(
        1,
        #DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX
    ) == DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX do

        normalized =
            normalized:sub(
                #DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX + 1
            )
    end

    if normalized:sub(
        1,
        #DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR
    ) == DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR then

        normalized =
            normalized:sub(
                #DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR + 1
            )
    end

    normalized =
        normalized:gsub(
            "\r\n",
            " "
        ):gsub(
            "[\r\n]+",
            " "
        ):gsub(
            '"',
            "'"
        ):gsub(
            "%s+",
            " "
        ):gsub(
            "^[ 	]+",
            ""
        ):gsub(
            "[ 	]+$",
            ""
        )

    return normalized
end

function spammer_runtime.names_match_for_tracking(
    first_name,
    second_name
)
    local first_normalized =
        spammer_runtime.normalize_visible_name_for_compare(
            first_name
        )

    local second_normalized =
        spammer_runtime.normalize_visible_name_for_compare(
            second_name
        )

    if first_normalized == ""
        or second_normalized == "" then

        return false
    end

    if first_normalized ==
        second_normalized then

        return true
    end


    local first_compact =
        first_normalized:gsub(
            "%s+",
            ""
        )

    local second_compact =
        second_normalized:gsub(
            "%s+",
            ""
        )

    return first_compact ~= ""
        and first_compact ==
            second_compact
end

