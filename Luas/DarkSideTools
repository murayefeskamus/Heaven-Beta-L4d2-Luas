    function ui.quotes.handle_player_say(
        userid,
        message,
        is_local
    )
        if not settings.enabled then
            return false
        end

        userid = tonumber(userid) or 0
        message = tostring(message or "")

        if userid <= 0
            or message == "" then

            return false
        end


        local sender_is_local =
            quote_sender_is_local(
                userid,
                is_local
            )

        if acknowledge_quote_change_message(
            message
        ) then

            return true
        end

        if looks_like_quote_help_output_line(
            message
        ) then

            return true
        end

        mark_player_activity(
            userid
        )

        if not sender_is_local then
            observe_remote_quote_response(
                userid,
                message
            )

            local local_management_command =
                select(
                    1,
                    is_local_only_quote_management_command(
                        message
                    )
                )

            if local_management_command then
                ui.console.print(
                    "[DST Quotes] Ignored remote management quote command."
                )

                return true
            end

            if not remote_quote_deferred_processing
                and queue_remote_public_quote_command(
                    userid,
                    message
                ) then

                return true
            end
        end

        local is_save_command =
            select(
                1,
                extract_command_argument(
                    message,
                    settings.save_command
                )
            )

        if is_save_command then
            if not sender_is_local then
                ui.console.print(
                    "[DST Quotes] Blocked another player's !save command."
                )

                queue_all_chat_message(
                    "Command blocked: you do not have permission to use !save."
                )

                return true
            end

            save_quote_from_chat(
                message,
                userid
            )

            return true
        end

        local is_delete_command =
            select(
                1,
                extract_command_argument(
                    message,
                    settings.delete_command
                )
            )

        if is_delete_command then
            if not sender_is_local then
                ui.console.print(
                    "[DST Quotes] Blocked another player's !delete command."
                )

                queue_all_chat_message(
                    "Command blocked: you do not have permission to use !delete."
                )

                return true
            end

            delete_quote_from_chat(
                message
            )

            return true
        end

        if quote_help_from_chat(
            userid,
            message,
            sender_is_local
        ) then
            return true
        end

        if find_random_from_chat(
            userid,
            message,
            sender_is_local
        ) then
            return true
        end

        if find_next_from_chat(
            userid,
            message,
            sender_is_local
        ) then
            return true
        end

        if find_quote_from_chat(
            userid,
            message,
            sender_is_local
        ) then
            return true
        end

        return false
    end

    local function execute_pending_remote_quote_command(
        queued_command
    )
        if type(queued_command) ~= "table" then
            return false
        end

        if not settings.enabled then
            return false
        end

        local userid =
            tonumber(queued_command.userid) or 0

        local message =
            tostring(queued_command.message or "")

        if userid <= 0
            or message == "" then

            return false
        end

        remote_quote_deferred_processing = true

        local original_delay =
            tonumber(settings.command_response_delay) or 0.0

        settings.command_response_delay =
            math.max(
                0.05,
                math.min(
                    0.15,
                    original_delay
                )
            )

        local ok,
            handled =
                pcall(
                    function()
                        if queued_command.command_key == "quotehelp" then
                            return quote_help_from_chat(
                                userid,
                                message,
                                false
                            )
                        end

                        if queued_command.command_key == "findrandom" then
                            return find_random_from_chat(
                                userid,
                                message,
                                false
                            )
                        end

                        if queued_command.command_key == "findnext" then
                            return find_next_from_chat(
                                userid,
                                message,
                                false
                            )
                        end

                        if queued_command.command_key == "find" then
                            return find_quote_from_chat(
                                userid,
                                message,
                                false
                            )
                        end

                        return false
                    end
                )

        settings.command_response_delay =
            original_delay

        remote_quote_deferred_processing = false

        if not ok then
            ui.console.print(
                "[DST Quotes] Deferred public command failed: " ..
                tostring(handled)
            )

            return false
        end

        return handled == true
    end

    local function process_pending_remote_quote_commands()
        cleanup_detected_remote_dst_quote_users()

        if #remote_quote_command_queue == 0 then
            return false
        end

        local now =
            get_time()

        local remaining_queue = {}
        local processed_any = false

        for _, queued_command in ipairs(
            remote_quote_command_queue
        ) do
            local keep_queued = false

            if type(queued_command) == "table"
                and queued_command.cancelled ~= true then

                local execute_at =
                    tonumber(queued_command.execute_at) or 0.0

                if now >= execute_at then
                    execute_pending_remote_quote_command(
                        queued_command
                    )

                    processed_any = true
                elseif now -
                    (tonumber(queued_command.queued_at) or now)
                    <= 8.0 then

                    keep_queued = true
                end
            end

            if keep_queued then
                remaining_queue[
                    #remaining_queue + 1
                ] = queued_command
            end
        end

        remote_quote_command_queue =
            remaining_queue

        return processed_any
    end

