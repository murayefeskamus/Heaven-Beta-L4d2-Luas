                    ui.preset_symbols_expanded,
                    "PresetSymbols",
                    get_enabled_hardcoded_chat_message_count()
                )

            if ui.preset_symbols_expanded then
                local all_presets_enabled =
                    chat_spammer.are_all_presets_enabled()

                if all_presets_enabled then
                    if colored_button(
                        "Deselect All##ChatPresetSymbols",
                        1.0, 1.0, 1.0,
                        0.55, 0.08, 0.08
                    ) then
                        chat_spammer.set_all_presets_enabled(
                            false
                        )
                        stop_chat_spammer_if_no_messages_enabled()
                    end
                else
                    if colored_button(
                        "Select All##ChatPresetSymbols",
                        1.0, 1.0, 1.0,
                        0.08, 0.42, 0.12
                    ) then
                        chat_spammer.set_all_presets_enabled(
                            true
                        )
                    end
                end

                local enabled_preset_count =
                    get_enabled_hardcoded_chat_message_count()

                imgui.text("Enabled presets:")
                imgui.same_line()

                if enabled_preset_count > 0 then
                    theme_text_colored(
                        0.2, 1.0, 0.2, 1.0,
                        tostring(
                            enabled_preset_count
                        )
                    )
                else
                    theme_text_colored(
                        0.65, 0.65, 0.65, 1.0,
                        "None"
                    )
                end

                theme_text_colored(
                    0.65, 0.65, 0.65, 1.0,
                    "Checked presets are added to the Chat Spammer cycle."
                )

                local preset_preview_width = 0
                local preset_button_padding = 16
                local preset_button_spacing = 4
                local preset_checkbox_width = 20
                local preset_label_spacing = 8

                local function get_preset_button_width(
                    visible_label
                )
                    return
                        ui.lobby.measure_text_width(
                            visible_label
                        ) +
                        preset_button_padding
                end

                local default_action_width =
                    get_preset_button_width(
                        "Use as Name"
                    ) +
                    preset_button_spacing +
                    get_preset_button_width(
                        "Vertical"
                    )

                for preview_index = 1,
                    get_hardcoded_chat_message_count() do

                    local preview_entry =
                        get_hardcoded_chat_message_entry(
                            preview_index
                        )

                    local preview_text =
                        tostring(
                            preview_entry.preview or
                            "Unicode symbol pattern."
                        )

                    local preview_label =
                        tostring(
                            preview_entry.label or
                            (
                                "Hardcoded symbol message " ..
                                tostring(
                                    preview_index
                                )
                            )
                        )

                    local required_row_width =
                        preset_checkbox_width +
                        ui.lobby.measure_text_width(
                            preview_label
                        ) +
                        preset_label_spacing +
                        default_action_width

                    preset_preview_width =
                        math.max(
                            preset_preview_width,
                            get_multiline_preview_width(
                                preview_text
                            ),
                            required_row_width
                        )
                end

                for index = 1,
                    get_hardcoded_chat_message_count() do

                    local entry =
                        get_hardcoded_chat_message_entry(
                            index
                        )

                    local preset_row_start_x =
                        ui.lobby.get_cursor_x()

                    local changed_enabled,
                        enabled_value =
                            imgui.checkbox(
                                tostring(
                                    entry.label or
                                    (
                                        "Hardcoded symbol message " ..
                                        tostring(index)
                                    )
                                ) ..
                                "##HardcodedChatMessage" ..
                                tostring(index),
                                is_hardcoded_chat_message_enabled(
                                    index
                                )
                            )

                    if changed_enabled then
                        set_hardcoded_chat_message_enabled(
                            index,
                            enabled_value
                        )

                        stop_chat_spammer_if_no_messages_enabled()
                    end

                    local preset_vertical_active =
                        chat_spammer.is_chat_name_vertical_for(
                            "preset",
                            index
                        )

                    local preset_horizontal_active =
                        chat_spammer.is_chat_name_horizontal_for(
                            "preset",
                            index
                        )

                    local preset_action_width = 0

                    if preset_vertical_active then
                        preset_action_width =
                            get_preset_button_width(
                                "Horizontal"
                            )
                    elseif preset_horizontal_active then
                        preset_action_width =
                            get_preset_button_width(
                                "Vertical"
                            )
                    else
                        preset_action_width =
                            default_action_width
                    end

                    imgui.same_line()

                    ui.lobby.set_cursor_x(
                        preset_row_start_x +
                        preset_preview_width -
                        preset_action_width
                    )

                    if preset_vertical_active then
                        if colored_button(
                            "Horizontal##PresetSymbolName" ..
                            tostring(index),
                            0.15, 1.0, 1.0,
                            0.05, 0.30, 0.34
                        ) then
                            chat_spammer.apply_preset_symbol_as_name(
                                entry,
                                false,
                                index
                            )
                        end
                    elseif preset_horizontal_active then
                        if colored_button(
                            "Vertical##PresetSymbolVertical" ..
                            tostring(index),
                            1.0, 1.0, 1.0,
                            0.30, 0.20, 0.48
                        ) then
                            chat_spammer.apply_preset_symbol_as_name(
                                entry,
                                true,
                                index
                            )
                        end
                    else
                        if colored_button(
                            "Use as Name##PresetSymbolName" ..
                            tostring(index),
                            0.15, 1.0, 1.0,
                            0.05, 0.30, 0.34
                        ) then
                            chat_spammer.apply_preset_symbol_as_name(
                                entry,
                                false,
                                index
                            )
                        end

                        imgui.same_line()

                        if colored_button(
                            "Vertical##PresetSymbolVertical" ..
                            tostring(index),
                            1.0, 1.0, 1.0,
                            0.30, 0.20, 0.48
                        ) then
                            chat_spammer.apply_preset_symbol_as_name(
                                entry,
                                true,
                                index
                            )
                        end
                    end

                    local preview_open =
                        imgui.begin_child(
                            "DarkSideHardcodedSymbolPreview" ..
                            tostring(index),
                            preset_preview_width,
                            36,
                            true,
                            0
                        )

                    if preview_open then
                        chat_spammer.draw_hardcoded_chat_message_preview(
                            entry
                        )
                    end

                    imgui.end_child()
                end
            end
        end,
