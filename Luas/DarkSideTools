            detail_fields,
            "Special Infected: " ..
                tostring(
                    player_record.special_kills or 0
                )
        )

        table.insert(
            detail_fields,
            "Commons: " ..
                tostring(
                    player_record.common_kills or 0
                )
        )

        table.insert(
            detail_fields,
            "Tanks: " ..
                tostring(
                    player_record.tank_kills or 0
                )
        )

        table.insert(
            detail_fields,
            "Witches: " ..
                tostring(
                    player_record.witch_kills or 0
                )
        )
    elseif player_record.team == 3 then
        table.insert(
            detail_fields,
            "Dmg: " ..
                tostring(
                    player_record.si_damage_total or 0
                )
        )
    end

    if not player_record.is_bot then
        table.insert(
            detail_fields,
            "Chat: " ..
                ui.lobby.format_count(
                    player_record.chat_messages or 0,
                    "msg",
                    "messages"
                )
        )

        table.insert(
            detail_fields,
            "Rejoins: " ..
                tostring(
                    player_record.reconnects or 0
                )
