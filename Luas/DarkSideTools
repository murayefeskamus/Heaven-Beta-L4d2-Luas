function ui.lobby.record_name_change(
    player_record,
    old_name,
    new_name,
    now
)
    if not player_record then
        return false
    end

    old_name = tostring(old_name or "")
    new_name = tostring(new_name or "")

    if old_name == ""
        or new_name == ""
        or old_name == new_name then

        return false
    end

    now = tonumber(now) or get_time()

    player_record.name_history =
        type(player_record.name_history) == "table"
        and player_record.name_history
        or {}

    table.insert(
        player_record.name_history,
        1,
        {
            timestamp = ui.lobby.history_timestamp(),
            time_value = now,
            old_name = old_name,
            new_name = new_name
        }
    )

    while #player_record.name_history >
        math.max(
            1,
            tonumber(ui.lobby.max_name_history) or 50
        ) do

        table.remove(
            player_record.name_history
        )
    end

    player_record.name_changes =
        (tonumber(player_record.name_changes) or 0) + 1

    ui.lobby.add_history(
        "NAME",
        old_name ..
            " changed name to " ..
            new_name
    )

    return true
end

function ui.lobby.add_history(
    event_type,
    message
)
    event_type =
        tostring(
            event_type or "INFO"
        )

    message =
        tostring(
            message or ""
        )

    if message == "" then
        return
    end

    local now =
        get_time()

    local latest =
        ui.lobby.history[1]

    if latest
        and latest.event_type == event_type
        and latest.message == message
        and now -
            (
                latest.time_value or 0
            ) < 0.35 then

        return
    end

    table.insert(
        ui.lobby.history,
        1,
        {
            timestamp =
                ui.lobby.history_timestamp(),
            time_value = now,
            event_type = event_type,
            message = message
        }
    )

    while #ui.lobby.history
        > ui.lobby.max_history do

        table.remove(
            ui.lobby.history
        )
    end
end

