        ui.heaven_configs.native.state = "Not checked"
        ui.heaven_configs.native.error = ""
        ui.heaven_configs.native.last_attempt = 0.0
        ui.heaven_configs.refresh_config_list(true)
    end

    imgui.same_line()
    ui.heaven_configs.draw_inline_status()

    local controls_row_height = 24

