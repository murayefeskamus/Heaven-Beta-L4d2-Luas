        math.max(
            #left_rows,
            #right_rows
        )

    local table_width = 860

    if type(imgui.get_window_width) == "function" then
        local width_ok,
            window_width =
                pcall(
                    imgui.get_window_width
                )

        if width_ok
            and tonumber(window_width) then

            table_width =
                math.max(
                    620,
                    math.min(
                        900,
                        tonumber(window_width) -
                            ui.lobby.get_cursor_x() -
                            24
                    )
                )
        end
    end

    local left_label_width = 92
    local right_label_width = 112

    local available_value_width =
        math.max(
            340,
            table_width -
                left_label_width -
                right_label_width -
                56
        )

    local left_value_width =
        math.floor(
            available_value_width * 0.48
        )

    local center_divider_x =
        left_label_width +
        left_value_width +
        20

    local right_label_x =
        center_divider_x + 14

    local right_divider_x =
        right_label_x +
        right_label_width

    local right_value_x =
        right_divider_x + 12

    local table_height =
        2 + row_count * 20

    local table_open =
        imgui.begin_child(
            "ServerAndNetworkingInformationTable",
            table_width,
            table_height,
            false,
            0
        )

    if table_open then
        local start_x =
            ui.lobby.get_cursor_x()

        local palette =
            ui.enhancements.theme_palette()

        local section_slots = {
            ["SERVER INFO"] = 1,
            ["NETWORK STATUS"] = 2,
            ["LATENCY"] = 3,
            ["PACKETS"] = 4,
            ["TRAFFIC"] = 5
        }

        local function draw_at(
            row_state,
            x_offset,
            value,
            red,
            green,
            blue
        )
            if row_state.started then
                imgui.same_line()
            end

            ui.lobby.set_cursor_x(
                start_x + x_offset
            )

            theme_text_colored(
                tonumber(red) or 1.0,
                tonumber(green) or 1.0,
                tonumber(blue) or 1.0,
                1.0,
                tostring(value or "")
            )

            row_state.started = true
        end

        local function draw_fragment(
            row_state,
            value,
            red,
            green,
            blue
        )
            if row_state.started then
                imgui.same_line()
            end

            theme_text_colored(
                tonumber(red) or 1.0,
                tonumber(green) or 1.0,
                tonumber(blue) or 1.0,
                1.0,
                tostring(value or "")
            )

            row_state.started = true
        end

        local function draw_side(
            row_state,
            row,
            label_x,
            divider_x,
            value_x,
            is_left
        )
            if not row then
                return
            end

            if row.section then
                local section_name =
                    tostring(row.section)

                local section_red,
                    section_green,
                    section_blue =
                        ui.get_theme_table_title_color(
                            section_name,
                            section_slots[section_name]
                            or 1
                        )

                local section_color = {
                    section_red,
                    section_green,
                    section_blue
                }

                draw_at(
                    row_state,
                    label_x,
                    row.section,
                    tonumber(section_color[1]) or 1.0,
                    tonumber(section_color[2]) or 1.0,
                    tonumber(section_color[3]) or 1.0
                )

                return
            end

            draw_at(
                row_state,
                label_x,
                row.label,
                0.75, 0.75, 0.78
            )

            draw_at(
                row_state,
                divider_x,
                "|",
                0.42, 0.42, 0.44
            )

            if is_left
                and row.special == "population" then

                draw_at(
                    row_state,
                    value_x,
                    "Players:",
                    1.0, 1.0, 1.0
                )

                draw_fragment(
                    row_state,
                    tostring(overview.humans or 0),
                    0.20, 1.0, 0.20
                )

                draw_fragment(
                    row_state,
                    "| Bots:",
                    1.0, 1.0, 1.0
                )

                draw_fragment(
                    row_state,
                    tostring(overview.bots or 0),
                    0.20, 1.0, 0.20
                )
            elseif is_left
                and row.special == "status" then

                draw_at(
                    row_state,
                    value_x,
                    "Alive:",
                    1.0, 1.0, 1.0
                )

                draw_fragment(
                    row_state,
                    tostring(overview.alive or 0),
                    0.20, 1.0, 0.20
                )

                draw_fragment(
                    row_state,
                    "| Dead:",
                    1.0, 1.0, 1.0
                )

                draw_fragment(
                    row_state,
                    tostring(overview.dead or 0),
                    1.0, 0.35, 0.35
                )
            else
                local value_color =
                    type(row.color) == "table"
                    and row.color
                    or { 1.0, 1.0, 1.0 }

                draw_at(
                    row_state,
                    value_x,
                    row.value,
                    value_color[1],
                    value_color[2],
                    value_color[3]
                )
            end
        end

        for row_index = 1, row_count do
            local row_state = {
                started = false
            }

            draw_side(
                row_state,
                left_rows[row_index],
                8,
                left_label_width,
                left_label_width + 12,
                true
            )

            draw_at(
                row_state,
                center_divider_x,
                "|",
                0.42, 0.42, 0.44
            )

            draw_side(
                row_state,
                right_rows[row_index],
                right_label_x,
                right_divider_x,
                right_value_x,
                false
            )

            imgui.separator()
        end
    end

    imgui.end_child()
    ui.lobby.compact_after_child(4)

    return table_width
end

function ui.enhancements.local_player_team()
    local local_player =
        client.get_local_player()

    if not local_player then
        return 0
    end

    local ok,
        team_value =
            pcall(
                function()
                    return local_player:get_team()
                end
            )

    if ok then
        return tonumber(team_value) or 0
    end

    return 0
end

function ui.enhancements.say_alert(
    message
)
    if not is_game_ready() then
        return false
    end

    message =
        tostring(message or ""):gsub(
            '"',
            "'"
        ):gsub(
            "[\r\n]",
            " "
        )

    client.execnormal(
        'say "' ..
        message ..
        '"'
    )

    return true
end

function ui.enhancements.reset_boss_alerts(
    boss_name
)


    if boss_name == nil
        or boss_name == "Tank" then

        ui.enhancements.alerts.tank_announced = false
    end
end

function ui.enhancements.prepare_boss_alert_server()
    local alerts =
        ui.enhancements.alerts

    local current_server =
        get_server_address()

    if current_server == "" then
        current_server = "CONNECTED SERVER"
    end

    if alerts.connected_server ~= current_server then
        alerts.connected_server = current_server
        alerts.tank_announced = false
        alerts.recent_infected_spawns = {}
        ui.lobby.pending_infected_spawns = {}
        ui.lobby.pending_infected_class_queries = {}
        ui.lobby.infected_spawn_scan_states = {}
        ui.lobby.infected_spawn_scan_next = 0.0
    end
end

function ui.enhancements.handle_tank_spawn(
    event_name,
    event
)
    ui.enhancements.prepare_boss_alert_server()

    if ui.enhancements.alerts.tank_announced == true then
        return
    end

    local userid =
        ui.lobby.get_event_int(
            event,
            "userid"
        )

    if userid > 0 then
        ui.enhancements.queue_verified_infected_spawn(
            userid,
            8
        )
    end


    ui.lobby.infected_spawn_scan_next = 0.0
end

function ui.enhancements.event_player_name(
    event,
    field_name
)
    local userid =
        ui.lobby.get_event_int(
            event,
            field_name or "userid"
        )

    local record =
        ui.lobby.find_player_by_userid(
            userid
        )

    if record then
        return tostring(record.name)
    end

    return get_player_name_from_userid(
        userid
    ) or (
        "User ID " ..
        tostring(userid)
    )
end

function ui.enhancements.handle_vote_event(
    event_name,
    event
)
    local event_lower =
        tostring(event_name or ""):lower()

    local issue =
        ui.lobby.get_event_string(
            event,
            "issue"
        )

    if issue == "" then
        issue =
            ui.lobby.get_event_string(
                event,
                "type"
            )
    end

    if issue == "" then
        issue =
            ui.lobby.get_event_string(
                event,
                "param1"
            )
    end

    local caller =
        ui.enhancements.event_player_name(
            event,
            "userid"
        )

    if event_lower == "vote_cast"
        or event_lower == "vote_cast_yes"
        or event_lower == "vote_cast_no" then

        local vote_actor_name =
            chat_spammer.get_vote_actor(
                event
            )

        if vote_actor_name
            and vote_actor_name ~= "" then

            caller = vote_actor_name
        end
    end

    local message = ""

    if event_lower == "vote_started" then
        ui.enhancements.vote_tracking.active_issue =
            issue ~= ""
            and issue
            or "Unknown vote"

        ui.enhancements.vote_tracking.active_caller =
            caller

        message =
            "Vote started"

        if issue ~= "" then
            message =
                message ..
                ": " ..
                issue
        end

        if caller
            and caller ~= "User ID 0" then
            message =
                message ..
                " | Caller: " ..
                caller
        end
    elseif event_lower == "vote_passed" then
        message =
            "Vote passed: " ..
            (
                issue ~= ""
                and issue
                or ui.enhancements.vote_tracking.active_issue
                or "Unknown vote"
            )
    elseif event_lower == "vote_failed"
        or event_lower == "callvote_failed" then

        message =
            "Vote failed: " ..
            (
                issue ~= ""
                and issue
                or ui.enhancements.vote_tracking.active_issue
                or "Unknown vote"
            )
    elseif event_lower == "vote_ended" then
        message =
            "Vote ended: " ..
            (
                issue ~= ""
                and issue
                or ui.enhancements.vote_tracking.active_issue
                or "Unknown vote"
            )
    elseif event_lower == "vote_cast_yes" then
        message =
            tostring(caller) ..
            " voted YES"
    elseif event_lower == "vote_cast_no" then
        message =
            tostring(caller) ..
            " voted NO"
    elseif event_lower == "vote_cast" then
        local option =
            ui.lobby.get_event_int(
                event,
                "vote_option"
            )

        message =
            tostring(caller) ..
            " cast vote option " ..
            tostring(option)
    else
        local yes_votes =
            ui.lobby.get_event_int(
                event,
                "yesVotes"
            )

        local no_votes =
            ui.lobby.get_event_int(
                event,
                "noVotes"
            )

        message =
            "Vote updated: Yes " ..
            tostring(yes_votes) ..
            " | No " ..
            tostring(no_votes)
    end

    ui.lobby.add_history(
        "VOTE",
        message
    )

    chat_spammer.relay_vote_event(
        event_name,
        event,
        message
    )
end

function ui.enhancements.handle_extra_event(
    event_name,
    event
)
    local lower_name =
        tostring(event_name or ""):lower()

    if lower_name == "tank_spawn" then
        ui.enhancements.handle_tank_spawn(
            event_name,
            event
        )

        return
    elseif lower_name == "tank_killed" then
        ui.enhancements.reset_boss_alerts(
            "Tank"
        )

        return
    elseif lower_name:find(
        "^vote_"
    )
        or lower_name == "callvote_failed" then

        ui.enhancements.handle_vote_event(
            event_name,
            event
        )

        return
    elseif lower_name == "round_start" then
        ui.enhancements.reset_boss_alerts()
        ui.enhancements.alerts.recent_infected_spawns = {}
        ui.lobby.pending_infected_spawns = {}
        ui.lobby.pending_infected_class_queries = {}
        ui.lobby.infected_spawn_scan_states = {}
        ui.lobby.infected_spawn_scan_next = 0.0

        ui.lobby.add_history(
            "ROUND",
            "Round started"
        )
    elseif lower_name == "round_end" then
        ui.lobby.add_history(
            "ROUND",
            "Round ended"
        )
    elseif lower_name == "mission_lost" then
        ui.lobby.add_history(
            "ROUND",
            "Mission lost"
        )
    elseif lower_name == "finale_start" then
        ui.lobby.add_history(
            "FINALE",
            "Finale started"
        )
    elseif lower_name == "finale_win" then
        ui.lobby.add_history(
            "FINALE",
            "Finale completed"
        )
    elseif lower_name == "map_transition" then
        ui.enhancements.reset_boss_alerts()
        ui.lobby.force_refresh = true

        ui.lobby.add_history(
            "MAP",
            "Map transition started"
        )
    elseif lower_name == "game_newmap" then
        ui.enhancements.reset_boss_alerts()
        ui.lobby.force_refresh = true

        ui.lobby.add_history(
            "MAP",
            "New map event detected"
        )
    elseif lower_name == "player_afk" then
        ui.lobby.add_history(
            "AFK",
            ui.enhancements.event_player_name(
                event,
                "player"
            ) ..
            " went AFK"
        )
    elseif lower_name == "player_bot_replace" then
        ui.lobby.add_history(
            "REPLACE",
            "A bot replaced a player"
        )
    elseif lower_name == "bot_player_replace" then
        ui.lobby.add_history(
            "REPLACE",
            "A player replaced a bot"
        )
    elseif lower_name == "player_say" then
        local userid =
            ui.lobby.get_event_int(
                event,
                "userid"
            )

        local spoken_text =
            ui.lobby.get_event_string(
                event,
                "text"
            )

        if spoken_text ~= "" then
            ui.lobby.add_history(
                "CHAT",
                ui.enhancements.event_player_name(
                    event,
                    "userid"
                ) ..
                ": " ..
                truncate_preview(
                    spoken_text,
                    90
                )
            )
        end
    elseif lower_name == "player_death" then
        local victim_userid =
            ui.lobby.get_event_int(
                event,
                "userid"
            )

        local victim_record =
            ui.lobby.find_player_by_userid(
                victim_userid
            )

        if victim_record
            and tostring(
                victim_record.class_name or ""
            ) == "Tank" then

            ui.enhancements.reset_boss_alerts(
                "Tank"
            )
        end
    elseif lower_name == "player_spawn" then
        local userid =
            ui.lobby.get_event_int(
                event,
                "userid"
            )


        ui.enhancements.queue_verified_infected_spawn(
            userid,
            nil
        )

        ui.lobby.infected_spawn_scan_next = 0.0
    end
end

