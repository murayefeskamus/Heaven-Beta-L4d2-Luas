function ui.voice_control.read_open_mic(force_refresh)
    local now = get_time()

    if force_refresh ~= true
        and type(ui.voice_control.open_mic_enabled) == "boolean"
        and now < ui.voice_control.open_mic_checked_at + 0.50 then

        return ui.voice_control.open_mic_enabled
    end

    local voice_cvar = nil
    local find_ok, found_cvar = pcall(cvar.find, "voice_vox")

    if find_ok then
        voice_cvar = found_cvar
    end

    if not voice_cvar then
        ui.voice_control.open_mic_enabled = nil
        ui.voice_control.open_mic_checked_at = now
        return nil
    end

    local read_ok, value = pcall(cvar.get_int, voice_cvar)

    if not read_ok then
        ui.voice_control.open_mic_enabled = nil
        ui.voice_control.open_mic_checked_at = now
        return nil
    end

    ui.voice_control.open_mic_enabled =
        (tonumber(value) or 0) ~= 0
    ui.voice_control.open_mic_checked_at = now

    return ui.voice_control.open_mic_enabled
end

function ui.voice_control.set_open_mic(enabled, from_chat)
    enabled = enabled == true

    local requested_label = enabled and "Open Mic" or "Push to Talk"
    local current = ui.voice_control.read_open_mic(true)

    if current == enabled then
        if from_chat then
            ui.voice_control.queue_command_response({
                "Voice mode: " .. requested_label .. "."
            })
        end

        return true
    end

    local find_ok, voice_cvar = pcall(cvar.find, "voice_vox")

    if not find_ok or not voice_cvar then
        local message = "Voice mode control is unavailable."
        ui.voice_control.set_status(message, true)
        if from_chat then
            ui.voice_control.queue_command_response({ message })
        end
        return false
    end

    local set_ok = pcall(
        cvar.set_int,
        voice_cvar,
        enabled and 1 or 0
    )

    ui.voice_control.open_mic_checked_at = 0.0
    local actual = ui.voice_control.read_open_mic(true)
    local success = set_ok and actual == enabled

    local message = success
        and ("Voice mode: " .. requested_label .. ".")
        or "Voice mode change failed."

    if not success then
        ui.voice_control.set_status(
            message,
            true
        )
    end

    if from_chat then
        ui.voice_control.queue_command_response({ message })
    end

    return success
end

function ui.voice_control.resolve_command_target(argument_text, requester)
    argument_text = tostring(argument_text or "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")

    if argument_text == "" then
        return ui.lobby.get_selected_player()
    end

    local numeric = argument_text:match("^#(%d+)$")
        or argument_text:match("^@(%d+)$")
        or argument_text:match("^(%d+)$")

    if numeric then
        numeric = tonumber(numeric) or 0

        for _, player_record in ipairs(ui.lobby.players or {}) do
            if (tonumber(player_record.entity_index) or 0) == numeric
                or (tonumber(player_record.userid) or 0) == numeric then

                return player_record
            end
        end
    end

    local wanted = argument_text:gsub("^@", ""):lower()
    local exact = nil
    local partial = nil

    for _, player_record in ipairs(ui.lobby.players or {}) do
        local name = tostring(player_record.name or "")
        local lower_name = name:lower()

        if lower_name == wanted then
            exact = player_record
            break
        elseif not partial
            and lower_name:find(wanted, 1, true) then

            partial = player_record
        end
    end

    return exact or partial
end

function ui.voice_control.permission_key(command_name)
    local mapping = {
        ["!mute"] = "voice_mute",
        ["!unmute"] = "voice_unmute",
        ["!muteall"] = "voice_muteall",
        ["!unmuteall"] = "voice_unmuteall",
        ["!mutelist"] = "voice_mutelist",
        ["!voice"] = "voice_style",
        ["!voiceon"] = "voice_style",
        ["!voiceoff"] = "voice_style"
    }

    return mapping[tostring(command_name or ""):lower()]
end

function ui.voice_control.handle_chat_command(userid, spoken_text)
    local command_name, argument_text =
        tostring(spoken_text or ""):match("^(%S+)%s*(.-)%s*$")

    command_name = tostring(command_name or ""):lower()

    local permission_key =
        ui.voice_control.permission_key(command_name)

    if not permission_key then
        return false
    end

    if not ui.enhancements.command_allowed(
        permission_key,
        userid,
        false
    ) then
        return true
    end

    local requester =
        ui.lobby.find_player_by_userid(userid)

    if command_name == "!mute"
        or command_name == "!unmute" then

        local target =
            ui.voice_control.resolve_command_target(
                argument_text,
                requester
            )

        if not target then
            ui.voice_control.queue_command_response({
                "Player not found. Use " .. command_name ..
                " @name/@UserID/#VoiceID."
            })
            return true
        end

        if command_name == "!mute" then
            ui.voice_control.mute_player(target, true)
        else
            ui.voice_control.unmute_player(target, true)
        end

        return true
    end

    if command_name == "!muteall" then
        ui.voice_control.set_all_players_muted(true, true)
        return true
    end

    if command_name == "!unmuteall" then
        ui.voice_control.set_all_players_muted(false, true)
        return true
    end

    if command_name == "!mutelist" then
        ui.voice_control.show_mute_list(true)
        return true
    end

    local voice_action = tostring(argument_text or "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
        :lower()

    if command_name == "!voiceon" then
        voice_action = "on"
    elseif command_name == "!voiceoff" then
        voice_action = "off"
    end

    if voice_action == "on"
        or voice_action == "open"
        or voice_action == "openmic"
        or voice_action == "open-mic"
        or voice_action == "1" then

        ui.voice_control.set_open_mic(true, true)
        return true
    end

    if voice_action == "off"
        or voice_action == "ptt"
        or voice_action == "push"
        or voice_action == "pushtotalk"
        or voice_action == "push-to-talk"
        or voice_action == "0" then

        ui.voice_control.set_open_mic(false, true)
        return true
    end

    ui.voice_control.queue_command_response({
        "Usage: !voice on/off."
    })

    return true
end

