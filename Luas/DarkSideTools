                            math.min(
                                430,
                                selected_combo_width
                            )

                        imgui.text("Select player:")
                        imgui.same_line()
                        imgui.push_item_width(
                            selected_combo_width
                        )

                        local neutral_player_details_colors =
                            push_neutral_combo_colors()

                        local changed_selected,
                            selected_value =
                                imgui.combo(
                                    "##LobbySelectedPlayerCombo",
                                    selected_combo_index,
                                    selection_labels
                                )

