local function file_ends_with_newline()
    local file =
        io.open(settings.quote_file, "rb")

    if not file then
        return true
    end

    local size =
        file:seek("end")

    if not size or size == 0 then
        file:close()
        return true
    end

    file:seek(
        "set",
        size - 1
    )

    local final_character =
        file:read(1)

    file:close()

    return final_character == "\n"
        or final_character == "\r"
end

local function append_quote_to_file(quote)
    if not io or not io.open then
        ui.console.print(
            "[L4D2 Quotes] File access is unavailable."
        )

        return false
    end

    local needs_newline =
        not file_ends_with_newline()

    local file, error_message =
        io.open(
            settings.quote_file,
            "ab"
        )

    if not file then
        ui.console.print(
            "[L4D2 Quotes] Could not save quote: " ..
            tostring(error_message)
        )

        return false
    end

    if needs_newline then
        file:write("\n")
    end

    file:write(quote)
    file:write("\n")
    file:close()

    return true
end

local function remove_quote_line(
    line_number
)
    if not io
        or not io.open then

        return false,
            "File access is unavailable."
    end

    line_number =
        math.floor(
            tonumber(line_number) or 0
        )

    local input,
        read_error =
            io.open(
                settings.quote_file,
                "r"
            )

    if not input then
        return false,
            "Could not open quote file: " ..
            tostring(read_error)
    end

    local lines = {}

    for line in input:lines() do
        if trim(line) ~= "" then
            lines[
                #lines + 1
            ] = line
        end
    end

    input:close()

    if line_number < 1
        or line_number > #lines then

        return false,
            "Quote ID does not exist."
    end

    table.remove(
        lines,
        line_number
    )

    return write_quote_lines(
        lines
    )
end


local function save_quote_from_chat(message, userid)
    local matched, quote =
        extract_command_argument(
            message,
            settings.save_command
        )

    if not matched then
        return false
    end

    quote = trim(quote)

    if quote ~= ""
        and not extract_quoted_person(quote) then

        local author_name = nil

        if userid
            and tonumber(userid)
            and tonumber(userid) > 0 then

            author_name = get_player_name_from_userid(
                tonumber(userid)
            )
        end

        if not author_name
            or author_name == ""
            or author_name == "Unknown" then

            author_name = get_current_player_name()
        end

        author_name = trim(author_name or "")

        if author_name ~= ""
            and author_name ~= "Unknown" then

            quote = author_name .. ": " .. quote
        end
    end

    if quote == "" then
        status.message =
            "Invalid save input"

        local invalid_message =
            "Invalid input, use !save <quote>"

        ui.console.print(
            "[L4D2 Quotes] " ..
            invalid_message
        )

        ui.quotes.queue_reliable_messages(
            { invalid_message },
            settings.command_response_delay
        )

        return true
    end

    local duplicate_id =
        quote_lookup[
            normalize_quote_text(quote)
        ]

    if duplicate_id then
        status.message =
            "Duplicate quote"

        status.last_number =
            duplicate_id

        local duplicate_message =
            string.format(
                "Quote already exists as #%d.",
                duplicate_id
            )

        ui.console.print(
            "[L4D2 Quotes] " ..
            duplicate_message
        )

        ui.quotes.queue_reliable_messages(
            { duplicate_message },
            settings.command_response_delay
        )

        return true
    end

    if not append_quote_to_file(quote) then
        status.message = "Save failed"

        ui.quotes.queue_reliable_messages(
            { "Failed to save a quote." },
            settings.command_response_delay
        )

        return true
    end

    if not load_quotes() then
        status.message =
            "Saved, reload failed"

        ui.console.print(
            "[L4D2 Quotes] Quote saved, but reload failed."
        )

        ui.quotes.queue_reliable_messages(
            { "Quote saved, but reload failed." },
            settings.command_response_delay
        )

        return true
    end

    local saved_number =
        total_file_lines

    status.last_number =
        saved_number

    status.message = "Quote saved"

    local confirmation =
        string.format(
            "Saved quote #%d.",
            saved_number
        )

    ui.console.print(
        "[L4D2 Quotes] " ..
        confirmation
    )


    announce_quote_change(
        confirmation,
        1.10
    )

    return true
end


local function delete_quote_from_chat(message)
    local matched, raw_id =
        extract_command_argument(
            message,
            settings.delete_command
        )

    if not matched then
        return false
    end

    raw_id =
        trim(raw_id)

