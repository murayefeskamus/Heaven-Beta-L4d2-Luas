local function player_info_is_bot(
    player_info,
    player_index,
    player_entity
)
    player_index =
        tonumber(player_index) or 0


    if ui.lobby
        and type(
            ui.lobby.players
        ) == "table" then

        local info_userid =
            player_info
            and (
                player_info.userid
                or player_info.user_id
                or player_info.userID
                or player_info.UserID
            )
            or nil

        for _,
            record in ipairs(
                ui.lobby.players
            ) do

            if (
                player_index > 0
                and tonumber(
                    record.entity_index
                ) == player_index
            )
                or (
                    info_userid
                    and tonumber(
                        record.userid
                    ) == tonumber(
                        info_userid
                    )
                ) then

                return record.is_bot == true
            end
        end
    end

    if not player_info then
        return false
    end

    local boolean_fields = {
        "fakeplayer",
        "fake_player",
        "is_fake_player",
        "is_fake_client",
        "fakeclient",
        "fake_client",
        "is_bot",
        "isBot",
        "bot"
    }

    for _,
        field_name in ipairs(
            boolean_fields
        ) do

        local value =
            player_info[
                field_name
            ]

        local normalized =
            tostring(
                value or ""
            ):lower()

        if value == true
            or value == 1
            or normalized == "true"
            or normalized == "1"
            or normalized == "bot"
            or normalized == "[bot]" then

            return true
        end
    end


    if player_index > 0
        and not player_entity
        and type(entity) == "table"
        and type(
            entity.get_by_index
        ) == "function" then

        local entity_ok,
            resolved_entity =
                pcall(
                    entity.get_by_index,
                    player_index
                )

        if entity_ok then
            player_entity =
                resolved_entity
        end
    end

    if name_stealer
        and type(
            name_stealer.is_player_bot
        ) == "function"
        and player_index > 0 then

        local bot_ok,
            bot_value =
                pcall(
                    name_stealer.is_player_bot,
                    player_index,
                    player_entity
                )

        if bot_ok then
            return bot_value == true
        end
    end


    local entity_team =
        get_player_entity_team_number(
            player_entity
        )

    if entity_team == 3
        and is_excluded_survivor_bot_name(
            player_info.name
        ) then

        return false
    end

    return is_default_l4d2_bot_name(
        player_info.name
    )
end

local function get_player_name_from_userid(
    userid
)
    userid =
        tonumber(userid) or 0

    if userid <= 0 then
        return "Unknown"
    end

    local player_index =
        engine.get_player_for_userid(
            userid
        )

    if not player_index then
        return "Unknown"
    end

    local success,
        player_info =
            pcall(
                engine.get_player_info,
                player_index
            )

    if not success
        or not player_info
        or not player_info.name
        or player_info.name == "" then

        return "Unknown"
    end

    local player_entity = nil

    if type(entity) == "table"
        and type(
            entity.get_by_index
        ) == "function" then

        local entity_ok,
            entity_value =
                pcall(
                    entity.get_by_index,
                    player_index
                )

        if entity_ok then
            player_entity =
                entity_value
        end
    end

    if player_info_is_bot(
        player_info,
        player_index,
        player_entity
    ) then

        return "Unknown"
    end

    return tostring(
        player_info.name
    )
end

local function get_max_player_slots()
    local success, max_clients =
        pcall(engine.get_max_clients)

    if success
        and max_clients
        and max_clients > 0 then

        return max_clients
    end

    return 32
end

local function find_userid_from_player_index(player_index)
    if not player_index then
        return nil
    end

    for candidate_userid = 1, 4096 do
        local success, candidate_index =
            pcall(
                engine.get_player_for_userid,
                candidate_userid
            )

        if success
            and candidate_index
            and candidate_index == player_index then

            return candidate_userid
        end
    end

    return nil
end

local function read_player_info_userid(player_info)
    if not player_info then
        return nil
    end

    return player_info.userid
        or player_info.user_id
        or player_info.userID
        or player_info.UserID
end

local function get_current_players()
    local current_time =
        os.clock()

    if current_time -
        last_player_cache_time < 1 then

        return cached_current_players
    end

    last_player_cache_time =
        current_time

    cached_current_players = {}

    if not engine.is_in_game()
        or not engine.is_connected() then

        return cached_current_players
    end

    local max_slots =
        get_max_player_slots()

    for player_index = 1,
        max_slots do

        local success,
            player_info =
                pcall(
                    engine.get_player_info,
                    player_index
                )

        if success
            and player_info
            and player_info.name
            and player_info.name ~= "" then

            local player_entity = nil

            if type(entity) == "table"
                and type(
                    entity.get_by_index
                ) == "function" then

                local entity_ok,
                    entity_value =
                        pcall(
                            entity.get_by_index,
                            player_index
                        )

                if entity_ok then
                    player_entity =
                        entity_value
                end
            end

            if not player_info_is_bot(
                player_info,
                player_index,
                player_entity
            ) then

                local userid =
                    read_player_info_userid(
                        player_info
                    )

                if not userid then
                    userid =
                        find_userid_from_player_index(
                            player_index
                        )
                end

                userid =
                    tonumber(userid) or 0

                if userid > 0 then
                    cached_current_players[
                        #cached_current_players + 1
                    ] = {
                        userid = userid,
                        name = tostring(
                            player_info.name
                        ),
                        player_index =
                            player_index
                    }
                end
            end
        end
    end

    table.sort(
        cached_current_players,
        function(first, second)
            return (
                tonumber(
                    first.userid
                ) or 0
            ) < (
                tonumber(
                    second.userid
                ) or 0
            )
        end
    )

    return cached_current_players
end


local function can_use_find_command(userid, is_local)

    if is_local then
        return true
    end

    local current_time =
        os.time()

    local cooldown_started =
        find_cooldowns[userid] or 0

    local elapsed =
        current_time - cooldown_started

    if elapsed < settings.find_cooldown_seconds then
        local remaining =
            settings.find_cooldown_seconds - elapsed


        if cooldown_notices[userid]
            ~= cooldown_started then

            cooldown_notices[userid] =
                cooldown_started

            queue_all_chat_message(
                string.format(
                    "Please wait %d second(s) before using the command again.",
                    remaining
                )
            )
        end

        status.message = "Cooldown active"

        ui.console.print(
            string.format(
                "[L4D2 Quotes] UserID %d is on !find cooldown for %d more second(s).",
                userid,
                remaining
            )
        )

        return false
    end

    find_cooldowns[userid] =
        current_time

    cooldown_notices[userid] =
        nil

    return true
end

