            tonumber(ui.control.runtime.target_fov) or 0.0,
            tonumber(ui.control.runtime.target_distance) or 0.0
        ),
        diagnostic_color
    )
    draw_diagnostic(
        "Prediction:",
        string.format(
            "%.3f s | confidence %.0f%%",
            tonumber(ui.control.runtime.prediction_time_used) or 0.0,
