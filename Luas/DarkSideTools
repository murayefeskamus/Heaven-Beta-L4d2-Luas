function ui.network.safe_get_cvar_string(cvar_name)
    if type(cvar) ~= "table"
        or type(cvar.find) ~= "function"
        or type(cvar.get_string) ~= "function" then

        return ""
    end

    local find_ok,
        handle =
            pcall(
                cvar.find,
                tostring(cvar_name or "")
            )

    if not find_ok
        or not handle
        or handle == 0 then

        return ""
    end

    local value_ok,
        value =
            pcall(
                cvar.get_string,
                handle
            )

    if not value_ok then
        return ""
    end

    return tostring(value or "")
end


