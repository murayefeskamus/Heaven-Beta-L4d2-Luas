function ui.lobby.resolve_event_player(
    event,
    userid_fields,
    entity_fields
)
    for _, field_name in ipairs(
        userid_fields or {}
    ) do
        local value =
            ui.lobby.get_event_int(
                event,
                field_name
            )

        if value > 0 then
            local by_userid =
                ui.lobby.find_player_by_userid(
                    value
                )

            if by_userid then
                return by_userid
            end


            local mapped_ok,
                mapped_entity_index =
                    pcall(
                        engine.get_player_for_userid,
                        value
                    )

            if mapped_ok
                and mapped_entity_index
                and tonumber(mapped_entity_index)
                and tonumber(mapped_entity_index) > 0 then

                local mapped_player =
                    ui.lobby.find_player_by_entity_index(
                        tonumber(mapped_entity_index)
                    )

                if mapped_player then
                    return mapped_player
                end
            end


            local by_entity =
                ui.lobby.find_player_by_entity_index(
                    value
                )

            if by_entity then
                return by_entity
            end
        end
    end

    for _, field_name in ipairs(
        entity_fields or {}
    ) do
        local entity_index =
            ui.lobby.get_event_int(
                event,
                field_name
            )

        if entity_index > 0 then
            local by_entity =
                ui.lobby.find_player_by_entity_index(
                    entity_index
                )

            if by_entity then
                return by_entity
            end
        end
    end

    return nil
end

function ui.lobby.find_cached_activity_for_record(
    player_record
)
    if not player_record then
        return nil
    end

    local direct =
        ui.lobby.activity_cache[
            player_record.key
        ]

    if direct then
        return direct
    end

    local userid =
        tonumber(
            player_record.userid
        ) or 0

    if userid <= 0 then
        return nil
    end

    for _, cached in pairs(
        ui.lobby.activity_cache
    ) do
        if cached
            and cached.is_bot ~= true
            and player_record.is_bot ~= true
            and tonumber(cached.userid) == userid then

            return cached
        end
    end

    return nil
end

function ui.lobby.update_activity_cache(
    player_record
)
    if not player_record
        or not player_record.key then

        return
    end

    local cached =
        ui.lobby.activity_cache[
            player_record.key
        ] or {}

    cached.first_seen =
        player_record.first_seen
        or cached.first_seen
        or get_time()

    cached.userid =
        player_record.userid
        or cached.userid
        or 0


    cached.is_bot =
        player_record.is_bot == true

    cached.chat_messages =
        player_record.chat_messages
        or 0

    cached.kills =
        player_record.kills
        or 0

    cached.deaths =
        player_record.deaths
        or 0

    cached.common_kills =
        player_record.common_kills
        or 0

    cached.special_kills =
        player_record.special_kills
        or 0

    cached.tank_kills =
        player_record.tank_kills
        or 0

    cached.witch_kills =
        player_record.witch_kills
        or 0

    cached.weapon_kills =
        ui.lobby.merge_counter_totals(
            cached.weapon_kills,
            player_record.weapon_kills
        )

    player_record.weapon_kills =
        cached.weapon_kills

    cached.si_damage_by_class =
        player_record.si_damage_by_class
        or {}

    cached.si_damage_total =
        player_record.si_damage_total
        or 0

    cached.reconnects =
        player_record.reconnects
        or 0

    cached.name_changes =
        player_record.name_changes
        or 0

    cached.name_history =
        player_record.name_history
        or cached.name_history
        or {}

    player_record.name_history =
        cached.name_history

    if player_record.health ~= nil then
        cached.health =
            player_record.health
    end

    cached.last_name =
        player_record.name

    ui.lobby.activity_cache[
        player_record.key
    ] = cached
end

function ui.lobby.mark_player_disconnected(
    event
)
    local userid =
        ui.lobby.get_event_int(
            event,
            "userid"
        )

    if userid <= 0 then
        return
    end

    ui.lobby.recent_deaths[
        userid
    ] = nil

    local prediction_identity =
        "uid:" .. tostring(userid)

    local known_players =
        ui.lobby.infected_prediction_known_players

    if type(known_players) == "table" then
        if type(known_players.records) == "table" then
            known_players.records[prediction_identity] = nil
        end

        if type(known_players.stable_order) == "table" then
            known_players.stable_order[prediction_identity] = nil
        end

        if type(known_players.order) == "table" then
            local active_order = {}

            for _, identity in ipairs(known_players.order) do
                if tostring(identity) ~= prediction_identity then
                    active_order[#active_order + 1] = identity
                end
            end

            known_players.order = active_order
        end
    end

    local prediction_model =
        ui.lobby.infected_prediction_model

    if type(prediction_model) == "table"
        and type(prediction_model.players) == "table" then

        prediction_model.players[prediction_identity] = nil
        prediction_model.revision =
            math.max(0, tonumber(prediction_model.revision) or 0) + 1
    end

    if type(ui.lobby.pending_infected_spawns) == "table" then
        ui.lobby.pending_infected_spawns[tostring(userid)] = nil
    end

    if type(ui.lobby.infected_spawn_scan_states) == "table" then
        ui.lobby.infected_spawn_scan_states[prediction_identity] = nil
    end

    ui.lobby.infected_prediction_cache = nil
    ui.lobby.infected_player_prediction_cache = nil
    ui.lobby.infected_prediction_cache_at = 0.0
    ui.lobby.infected_player_prediction_cache_at = 0.0

    local player_record =
        ui.lobby.find_player_by_userid(
            userid
        )

    if not player_record then
        return
    end

    ui.lobby.update_activity_cache(
        player_record
    )

    local cached =
        ui.lobby.activity_cache[
            player_record.key
        ]

    if cached then
        cached.temporary_death = false
        cached.last_left = get_time()
    end
end

function ui.lobby.find_player_for_command(
    query,
    requester
)
    query = tostring(query or "")
    query = query:gsub("^%s+", ""):gsub("%s+$", "")
    query = query:gsub('^"(.*)"$', "%1")

    if query == "" or query:lower() == "me" then
        return requester
    end

    local numeric_text =
        (query:gsub("^#", ""))

    local numeric_query =
        tonumber(
            numeric_text
        )

    if numeric_query then
        numeric_query = math.floor(numeric_query)

        for _, player_record in ipairs(
            ui.lobby.players
        ) do
            if player_record.userid == numeric_query then
                return player_record
            end
        end

        for _, player_record in ipairs(
            ui.lobby.players
        ) do
            if player_record.entity_index == numeric_query then
                return player_record
            end
        end
    end

    local lowered_query = query:lower()
    local partial_match = nil
    local partial_count = 0

    for _, player_record in ipairs(
        ui.lobby.players
    ) do
        local lowered_name =
            tostring(player_record.name or ""):lower()

        if lowered_name == lowered_query then
            return player_record
        end

        if lowered_name:find(
            lowered_query,
            1,
            true
        ) then
            partial_match = player_record
            partial_count = partial_count + 1
        end
    end

    if partial_count == 1 then
        return partial_match
    end

    return nil
end

function ui.lobby.playerinfo_is_allowed(
    requester,
    target
)
    if not requester or not target then
        return false
    end

    if requester.is_local then
        return true
    end

    if requester.key == target.key then
        return true
    end

    if target.is_bot then
        return true
    end

    return requester.team == target.team
end

function ui.lobby.handle_playerinfo_command(
    userid,
    spoken_text
)
    spoken_text = tostring(spoken_text or "")

    local command,
        argument =
            spoken_text:match(
                "^%s*(![%w_]+)%s*(.-)%s*$"
            )

    if not command
        or command:lower() ~= "!playerinfo" then

        return false
    end

    local requester =
        ui.lobby.find_player_by_userid(
            userid
        )

    if not requester then
        ui.lobby.refresh(true)

        requester =
            ui.lobby.find_player_by_userid(
                userid
            )
    end

    if not requester then
        ui.lobby.queue_command_messages("Player Info", {
            "Player information is still loading. Try again in a moment."
        })

        return true
    end

    argument =
        tostring(argument or ""):gsub(
            "^%s+",
            ""
        ):gsub(
            "%s+$",
            ""
        )

    local target_query = ""

    if argument ~= "" then
        if argument:sub(1, 1) ~= "@" then
            ui.lobby.queue_command_messages("Player Info", {
                "Usage: !playerinfo or !playerinfo @name/@UserID"
            })

            return true
        end

        target_query =
            argument:sub(2):gsub(
                "^%s+",
                ""
            ):gsub(
                "%s+$",
                ""
            )

        if target_query == "" then
            ui.lobby.queue_command_messages("Player Info", {
                "Usage: !playerinfo or !playerinfo @name/@UserID"
            })

            return true
        end
    end

    local target =
        ui.lobby.find_player_for_command(
            target_query,
            requester
        )

    if not target then
        ui.lobby.queue_command_messages("Player Info", {
            "Player not found. Use !playerinfo @name or !playerinfo @UserID."
        })

        return true
    end

    if not ui.lobby.playerinfo_is_allowed(
        requester,
        target
    ) then
        ui.lobby.queue_command_messages("Player Info", {
            "You are not allowed to execute this command."
        })

        return true
    end

    ui.lobby.print_player(
        target
    )

    return true
end

function ui.lobby.get_zombieclass_command_context(
    userid
)
    local requester =
        ui.lobby.find_player_by_userid(
            userid
        )

    local local_record = nil

    for _, player_record in ipairs(
        ui.lobby.players
    ) do
        if player_record.is_local then
            local_record = player_record
            break
        end
    end

    if not requester
        or not local_record then

        ui.lobby.refresh(true)

        requester =
            ui.lobby.find_player_by_userid(
                userid
            )

        for _, player_record in ipairs(
            ui.lobby.players
        ) do
            if player_record.is_local then
                local_record = player_record
                break
            end
        end
    end

    local owner_request =
        is_local_player_userid(
            userid
        )

    if owner_request
        and not requester then

        requester = local_record
    end

    return requester,
        local_record,
        owner_request,
        ui.lobby.zombieclass_response_uses_team_chat(
            userid
        )
