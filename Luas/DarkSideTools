function ui.lobby.draw_player_table_header()
    local start_x =
        ui.lobby.get_cursor_x()

    imgui.separator()

    for index, column in ipairs(
        ui.lobby.player_table_columns
    ) do
        local sort_key =
            tostring(column.sort_key or "")


        local header_label =
            tostring(column.label or "")


        local estimated_button_width =
            ui.lobby.measure_text_width(
                header_label
            ) + 16


        estimated_button_width =
            math.min(
                estimated_button_width,
                math.max(
                    1,
                    column.width - 6
                )
            )

        if index > 1 then
            imgui.same_line()
        end

        ui.lobby.set_cursor_x(
            start_x +
            column.offset +
            math.max(
                0,
                (
                    column.width -
                    estimated_button_width
                ) * 0.5
            )
        )

        local header_r,
            header_g,
            header_b =
                ui.get_theme_table_header_color()

        local header_text_pushed =
            type(imgui.push_style_color) == "function"
            and pcall(
                imgui.push_style_color,
                0,
                header_r, header_g, header_b, 1.0
            )

        local header_clicked =
            imgui.button(
                header_label ..
                    "##LobbySortHeader_" ..
                    tostring(index)
            )

        if header_text_pushed
            and type(imgui.pop_style_color) == "function" then

            pcall(
                imgui.pop_style_color
            )
        end

        if header_clicked then
            ui.lobby.set_sort(
                sort_key
            )
        end

        local next_column =
            ui.lobby.player_table_columns[
                index + 1
            ]

        if next_column then
            ui.lobby.draw_player_table_divider(
                start_x,
                next_column.offset
            )
        end
    end

    imgui.separator()
end


