    local melee_identifiers = {
        melee = true,
        chainsaw = true,
        fireaxe = true,
        frying_pan = true,
        machete = true,
        baseball_bat = true,
        cricket_bat = true,
        crowbar = true,
        electric_guitar = true,
        golfclub = true,
        katana = true,
        knife = true,
        tonfa = true,
        pitchfork = true,
        shovel = true,
        riotshield = true
    }

    return melee_identifiers[
