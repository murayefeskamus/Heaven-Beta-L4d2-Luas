function spammer_cfg.build_balanced_long_word_lines(
    word,
    safe_budget
)
    local characters =
        spammer_cfg.smart_vertical_split_utf8(
            word
        )

    local best_lines = nil
    local best_count = 0
    local best_blank_lines = 0

    for character_count = 1,
        #characters do

        local target_rows = 1

        if character_count > 1 then
            target_rows =
                math.max(
                    2,
                    math.ceil(
                        character_count /
                        DARKSIDE_CONFIG.SMART_VERTICAL_TARGET_ROW_WIDTH
                    )
                )
        end

        if target_rows >
            DARKSIDE_CONFIG.SMART_VERTICAL_MAX_ROWS then

            break
        end

        local base_size =
            math.floor(
                character_count /
                target_rows
            )

        local remainder =
            character_count %
            target_rows

        local lines = {}
        local character_index = 1

        for row_index = 1,
            target_rows do

            local row_size =
                base_size +
                (
                    row_index <= remainder
                    and 1
                    or 0
                )

            local row_parts = {}

            for _ = 1, row_size do
                table.insert(
                    row_parts,
                    characters[
                        character_index
                    ]
                )

                character_index =
                    character_index + 1
            end

            table.insert(
                lines,
                table.concat(
                    row_parts
                )
            )
        end

        local leading_blank_lines =
            spammer_cfg.get_smart_vertical_auto_blank_lines(
                lines
            )

        local payload =
            table.concat(
                lines,
                "\r"
            )

        if #payload +
            leading_blank_lines <=
            safe_budget then

            best_lines = lines
            best_count = character_count
            best_blank_lines =
                leading_blank_lines
        else


            break
        end
    end

    if not best_lines then
        return nil,
            "",
            true,
            0
    end

    local visible_parts = {}

    for index = 1, best_count do
        table.insert(
            visible_parts,
            characters[index]
        )
    end

    return best_lines,
        table.concat(
            visible_parts
        ),
        best_count < #characters,
        best_blank_lines
end

function spammer_cfg.smart_vertical_build_rows(
    words,
    row_count
)
    local word_count = #words
    local character_lengths = {}
    local prefix_lengths = {
        [0] = 0
    }

    for index, word in ipairs(words) do
        character_lengths[index] =
            spammer_cfg.smart_vertical_character_count(
                word
            )

        prefix_lengths[index] =
            prefix_lengths[index - 1] +
            character_lengths[index]
    end

    local total_visible_length =
        prefix_lengths[word_count] +
        math.max(
            0,
            word_count - 1
        )

    local ideal_line_length =
        total_visible_length /
        math.max(
            1,
            row_count
        )

    local costs = {
        [0] = {
            [0] = 0
        }
    }

    local previous_breaks = {}

    for row_index = 1,
        row_count do

        costs[row_index] = {}
        previous_breaks[row_index] = {}

        local minimum_end = row_index
        local maximum_end =
            word_count -
            (
                row_count -
                row_index
            )

        for ending_word = minimum_end,
            maximum_end do

            local best_cost = nil
            local best_previous_end = nil

            for previous_end = row_index - 1,
                ending_word - 1 do

                local previous_cost =
                    costs[row_index - 1][
                        previous_end
                    ]

                if previous_cost ~= nil then
                    local words_on_row =
                        ending_word -
                        previous_end

                    local line_length =
                        prefix_lengths[ending_word] -
                        prefix_lengths[previous_end] +
                        words_on_row - 1

                    local deviation =
                        line_length -
                        ideal_line_length

                    local overflow =
                        math.max(
                            0,
                            line_length -
                            DARKSIDE_CONFIG.SMART_VERTICAL_TARGET_ROW_WIDTH
                        )

                    local candidate_cost =
                        previous_cost +
                        deviation * deviation +
                        overflow * overflow * 3

                    if best_cost == nil
                        or candidate_cost < best_cost then

                        best_cost = candidate_cost
                        best_previous_end = previous_end
                    end
                end
            end

            if best_cost ~= nil then
                costs[row_index][ending_word] =
                    best_cost

                previous_breaks[row_index][ending_word] =
                    best_previous_end
            end
        end
    end

    local final_cost =
        costs[row_count]
        and costs[row_count][word_count]
        or nil

    if final_cost == nil then
        return nil,
            nil
    end

    local row_sizes = {}
    local ending_word = word_count

    for row_index = row_count,
        1,
        -1 do

        local previous_end =
            previous_breaks[row_index][
                ending_word
            ]

        if previous_end == nil then
            return nil,
                nil
        end

        table.insert(
            row_sizes,
            1,
            ending_word -
            previous_end
        )

        ending_word = previous_end
    end

    local lines = {}
    local word_index = 1
    local maximum_line_length = 0

    for _, words_on_row in ipairs(
        row_sizes
    ) do
        local line_words = {}

        for _ = 1, words_on_row do
            local word = words[word_index]

            if word then
                table.insert(
                    line_words,
                    word
                )

                word_index =
                    word_index + 1
            end
        end

        local line =
            table.concat(
                line_words,
                " "
            )

        maximum_line_length =
            math.max(
                maximum_line_length,
                spammer_cfg.smart_vertical_character_count(
                    line
                )
            )

        table.insert(
            lines,
            line
        )
    end

    local width_penalty =
        math.abs(
            maximum_line_length -
            DARKSIDE_CONFIG.SMART_VERTICAL_TARGET_ROW_WIDTH
        ) * 0.35

    local row_penalty =
        row_count * 0.20

    return lines,
        final_cost +
        width_penalty +
        row_penalty
end

function spammer_cfg.wrap_smart_vertical_words(
    words,
    safe_budget
)
    local word_count = #words

    if word_count <= 1 then
        return nil,
            0
    end

    local minimum_rows = 2

    local maximum_rows =
        math.min(
            DARKSIDE_CONFIG.SMART_VERTICAL_MAX_ROWS,
            word_count
        )

    local best_lines = nil
    local best_score = nil
    local best_blank_lines = 0

    for row_count = minimum_rows,
        maximum_rows do

        local lines,
            score =
                spammer_cfg.smart_vertical_build_rows(
                    words,
                    row_count
                )

        if lines then
            local leading_blank_lines =
                spammer_cfg.get_smart_vertical_auto_blank_lines(
                    lines
                )

            local encoded_lines =
                table.concat(
                    lines,
                    "\r"
                )

            local candidate_fits =
                #encoded_lines +
                leading_blank_lines <=
                safe_budget

            if candidate_fits
                and (
                    best_score == nil
                    or score < best_score
                ) then

                best_lines = lines
                best_score = score
                best_blank_lines =
                    leading_blank_lines
            end
        end
    end

    return best_lines,
        best_blank_lines
end

function spammer_cfg.build_smart_vertical_name(target_name_str)
    local normalized_phrase =
        spammer_cfg.normalize_smart_vertical_phrase(
            target_name_str
        )

    if normalized_phrase == "" then
        return nil,
            false,
            0,
            "(empty)",
            "",
            0,
            0,
            0,
            0
    end

    local safe_budget,
        prefix =
            spammer_cfg.get_smart_vertical_safe_budget()

    if safe_budget <= 0 then
        return nil,
            true,
            0,
            "(no safe name space)",
            "",
            0,
            0,
            0,
            0
    end

    local words = {}

    for word in normalized_phrase:gmatch(
        "%S+"
    ) do
        table.insert(
            words,
            word
        )
    end

    local lines = nil
    local visible_name = ""
    local truncated = false
    local fitted_word_count = 0
    local leading_blank_lines = 0

    if #words <= 1 then
        lines,
            visible_name,
            truncated,
            leading_blank_lines =
                spammer_cfg.build_balanced_long_word_lines(
                    words[1] or normalized_phrase,
                    safe_budget
                )

        fitted_word_count =
            visible_name ~= ""
            and 1
            or 0
    else
        local fitted_words = {}
        local fitted_lines = nil
        local fitted_blank_lines = 0

        for word_index = 1,
            #words do

            local candidate_words = {}

            for candidate_index = 1,
                word_index do

                table.insert(
                    candidate_words,
                    words[candidate_index]
                )
            end

            local candidate_lines = nil
            local candidate_blank_lines = 0

            if #candidate_words == 1 then
                local candidate_visible = ""
                local candidate_truncated = true

                candidate_lines,
                    candidate_visible,
                    candidate_truncated,
                    candidate_blank_lines =
                        spammer_cfg.build_balanced_long_word_lines(
                            candidate_words[1],
                            safe_budget
                        )

                if candidate_truncated
                    or candidate_visible ~=
                        candidate_words[1] then

                    candidate_lines = nil
                end
            else
                candidate_lines,
                    candidate_blank_lines =
                        spammer_cfg.wrap_smart_vertical_words(
                            candidate_words,
                            safe_budget
                        )
            end

            if candidate_lines then
                fitted_words = candidate_words
                fitted_lines = candidate_lines
                fitted_blank_lines =
                    candidate_blank_lines
            else


                break
            end
        end

        if #fitted_words > 0
            and fitted_lines then

            lines = fitted_lines
            leading_blank_lines =
                fitted_blank_lines

            visible_name =
                table.concat(
                    fitted_words,
                    " "
                )

            fitted_word_count =
                #fitted_words

            truncated =
                #fitted_words <
                #words
        else
            lines,
                visible_name,
                truncated,
                leading_blank_lines =
                    spammer_cfg.build_balanced_long_word_lines(
                        words[1],
                        safe_budget
                    )

            fitted_word_count =
                visible_name ~= ""
                and 1
                or 0
        end
    end

    if not lines
        or #lines == 0
        or visible_name == "" then

        return nil,
            true,
            0,
            "(could not fit)",
            "",
            0,
            0,
            0,
            0
    end

    local encoded_lines =
        table.concat(
            lines,
            "\r"
        )

    local final_message =
        prefix ..
        string.rep(
            "\r",
            leading_blank_lines
        ) ..
        encoded_lines

    if #final_message >
        DARKSIDE_CONFIG.SMART_VERTICAL_SAFE_PAYLOAD_BYTES then

        return nil,
            true,
            0,
            "(could not fit)",
            "",
            0,
            0,
            0,
            leading_blank_lines
    end


    spammer_cfg.smart_vertical_leading_blank_lines =
        leading_blank_lines

    local preview =
        string.rep(
            "-\n",
            leading_blank_lines
        ) ..
        table.concat(
            lines,
            "\n"
        )

    local visible_length =
        spammer_cfg.smart_vertical_character_count(
            visible_name
        )

    return final_message,
        truncated,
        visible_length,
        preview,
        visible_name,
        #lines,
        fitted_word_count,
        #final_message,
        leading_blank_lines
end

function spammer_cfg.smart_vertical_input_fits(text)
    local normalized =
        spammer_cfg.normalize_smart_vertical_phrase(
            text
        )

    if normalized == "" then
        return true
    end

    local final_message,
        truncated,
        _,
        _,
        visible_name =
            spammer_cfg.build_smart_vertical_name(
                normalized
            )

    return final_message ~= nil
        and truncated ~= true
        and visible_name == normalized
end

function spammer_cfg.clamp_smart_vertical_input(text)
    local editable_text =
        spammer_cfg.normalize_smart_vertical_input_text(
            text
        )

    if editable_text == "" then
        return "",
            false
    end

    local has_trailing_space =
        editable_text:sub(
            -1
        ) == " "

    local normalized_phrase =
        spammer_cfg.normalize_smart_vertical_phrase(
            editable_text
        )

    if has_trailing_space then


        if normalized_phrase ~= ""
            and spammer_cfg.smart_vertical_input_fits(
                normalized_phrase ..
                " a"
            ) then

            return normalized_phrase ..
                " ",
                false
        end

        editable_text = normalized_phrase
    end

    if spammer_cfg.smart_vertical_input_fits(
        editable_text
    ) then

        return editable_text,
            false
    end

    local characters =
        spammer_cfg.smart_vertical_split_utf8(
            editable_text
        )

    while #characters > 0 do
        table.remove(
            characters
        )

        local candidate =
            spammer_cfg.normalize_smart_vertical_input_text(
                table.concat(
                    characters
                )
            )

        local candidate_phrase =
            spammer_cfg.normalize_smart_vertical_phrase(
                candidate
            )

        if candidate_phrase == ""
            or spammer_cfg.smart_vertical_input_fits(
                candidate_phrase
            ) then

            return candidate_phrase,
                true
        end
    end

    return "",
        true
end


function spammer_cfg.get_smart_vertical_character_limit(text)
    local editable_text =
        spammer_cfg.normalize_smart_vertical_input_text(
            text
        )

    local normalized_phrase =
        spammer_cfg.normalize_smart_vertical_phrase(
            editable_text
        )

    if normalized_phrase ~= ""
        and not spammer_cfg.smart_vertical_input_fits(
            normalized_phrase
        ) then

        normalized_phrase =
            spammer_cfg.clamp_smart_vertical_input(
                normalized_phrase
            )
    end

    local phrase_mode =
        editable_text:find(
            " ",
            1,
            true
        ) ~= nil

    local probe = normalized_phrase

    if phrase_mode
        and editable_text:sub(
            -1
        ) == " " then

        probe =
            normalized_phrase ~= ""
            and normalized_phrase ..
                " a"
            or "a"
    end

    local maximum_count =
        spammer_cfg.smart_vertical_character_count(
            probe
        )

    for _ = 1,
        DARKSIDE_CONFIG.SPAMMER_NAME_INPUT_BUFFER_SIZE do

        local test_candidate =
            probe ..
            "a"

        if not spammer_cfg.smart_vertical_input_fits(
            test_candidate
        ) then
            break
        end

        probe = test_candidate
        maximum_count =
            spammer_cfg.smart_vertical_character_count(
                probe
            )
    end

    return maximum_count
end


function spammer_cfg.get_smart_vertical_input_byte_limit(text)
    local fitted_text =
        spammer_cfg.clamp_smart_vertical_input(
            text
        )

    fitted_text =
        tostring(
            fitted_text or ""
        )

    local probe = fitted_text
    local maximum_bytes = #probe

    for _ = 1,
        DARKSIDE_CONFIG.SPAMMER_NAME_INPUT_BUFFER_SIZE do

        local candidate =
            probe .. "a"

        local fitted_candidate =
            spammer_cfg.clamp_smart_vertical_input(
                candidate
            )

        if fitted_candidate ~= candidate then
            break
        end

        probe = candidate
        maximum_bytes = #probe
    end

    return math.max(
        #fitted_text,
        maximum_bytes
    )
end

