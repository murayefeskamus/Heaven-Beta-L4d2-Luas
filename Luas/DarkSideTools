function ui.network.format_duration(seconds)
    seconds =
        math.max(
            0,
            math.floor(
                tonumber(seconds) or 0
            )
        )

    local hours =
        math.floor(
            seconds / 3600
        )

    local minutes =
        math.floor(
            (seconds % 3600) / 60
        )

    local remaining_seconds =
        seconds % 60

    return string.format(
        "%02d:%02d:%02d",
        hours,
        minutes,
        remaining_seconds
    )
end

function ui.network.is_local_server_address(address)
    address =
        tostring(address or ""):lower()

    return address == "loopback"
        or address == "localhost"
        or address == "::1"
        or address == "[::1]"
        or address:match("^127%.") ~= nil
end

function ui.network.get_server_display_address(address)
    address =
        tostring(address or "")

    if ui.network.is_local_server_address(
        address
    ) then
        return "Local server"
    end

    if address == ""
        or address == "Unknown"
        or address == "CONNECTED SERVER" then

        return "Connected server"
    end

    return address
end

function ui.network.extract_ipv4_address(address)
    address =
        tostring(address or "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

    local ip_address =
        address:match(
            "(%d+%.%d+%.%d+%.%d+)"
        ) or ""

    if ip_address == "" then
        return ""
    end

    if ui.network.ipv4_to_number ~= nil
        and ui.network.ipv4_to_number(ip_address) == nil then

        return ""
    end

    return ip_address
end

function ui.network.is_private_ipv4_address(ip_address)
    ip_address =
        tostring(ip_address or "")

    local a, b =
        ip_address:match(
            "^(%d+)%.(%d+)%.%d+%.%d+$"
        )

    a = tonumber(a) or -1
    b = tonumber(b) or -1

    if a == 10 then
        return true
    end

    if a == 127 then
        return true
    end

    if a == 192 and b == 168 then
        return true
    end

    if a == 172 and b >= 16 and b <= 31 then
        return true
    end

    if a == 169 and b == 254 then
        return true
    end

    return false
end

