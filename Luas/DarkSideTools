local performance_unpack_values =
    table.unpack or unpack

function performance_pack_values(...)
    return {
        n = select("#", ...),
        ...
    }
end

function ui.performance.memoize_values(
    bucket_name,
    cache_key,
    builder,
    maximum_entries
)
    bucket_name =
        tostring(bucket_name or "default")

    cache_key =
        tostring(cache_key or "")

    maximum_entries =
        math.max(
            8,
            math.floor(
                tonumber(maximum_entries) or
                tonumber(ui.performance.memo_default_limit) or
                512
            )
        )

    ui.performance.memo_caches =
        type(ui.performance.memo_caches) == "table"
        and ui.performance.memo_caches
        or {}

    local bucket =
        ui.performance.memo_caches[bucket_name]

    if type(bucket) ~= "table" then
        bucket = {
            values = {},
            order = {}
        }

        ui.performance.memo_caches[bucket_name] =
            bucket
    end

    bucket.values =
        type(bucket.values) == "table"
        and bucket.values
        or {}

    bucket.order =
        type(bucket.order) == "table"
        and bucket.order
        or {}

    local cached =
        bucket.values[cache_key]

    if type(cached) == "table"
        and cached.n ~= nil then

        return performance_unpack_values(
            cached,
            1,
            cached.n
        )
    end

    local built =
        performance_pack_values(
            builder()
        )

    bucket.values[cache_key] = built
    bucket.order[#bucket.order + 1] =
        cache_key

    while #bucket.order > maximum_entries do
        local oldest_key =
            table.remove(
                bucket.order,
                1
            )

        if oldest_key ~= cache_key then
            bucket.values[oldest_key] = nil
        end
    end

    return performance_unpack_values(
        built,
        1,
        built.n
    )
end

function ui.performance.clear_memo_cache(
    bucket_name
)
    if type(ui.performance.memo_caches) ~= "table" then
        ui.performance.memo_caches = {}
        return
    end

    if bucket_name == nil then
        ui.performance.memo_caches = {}
        return
    end

    ui.performance.memo_caches[
        tostring(bucket_name)
    ] = nil
end

function ui.performance.get_font_metric_signature()
    local theme =
        type(ui.enhancements) == "table"
        and type(ui.enhancements.theme) == "table"
        and ui.enhancements.theme
        or {}

    local preset_index =
        math.floor(
            tonumber(theme.font_preset_index) or 0
        )

    local resolved_scale = 1.0

    if preset_index == 1 then
        resolved_scale = 0.88
    elseif preset_index == 2 then
        resolved_scale = 1.18
    elseif preset_index == 3 then
        resolved_scale =
            math.max(
                0.70,
                math.min(
                    1.50,
                    tonumber(theme.font_scale) or 1.0
                )
            )
    end

    return tostring(preset_index) ..
        "|" ..
        string.format(
            "%.3f",
            resolved_scale
        )
end

