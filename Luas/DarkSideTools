function chat_spammer.classify_team_number(
    team_number
)
    team_number =
        math.floor(
            tonumber(team_number) or 0
        )

    local local_team =
        chat_spammer.get_local_team_number()


    if team_number <= 1
        or local_team <= 1 then

        return "unknown_team"
    end

    if team_number == local_team then
        return "my_team"
    end

    return "enemy_team"
end

