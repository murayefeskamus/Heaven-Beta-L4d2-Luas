function chat_spammer.get_event_int_any(
    event,
    field_names
)
    if not event
        or type(field_names) ~= "table" then

        return 0
    end

    for _, field_name in ipairs(
        field_names
    ) do
        local value_ok,
            value =
                pcall(
                    function()
                        return event:get_int(
                            field_name
                        )
                    end
                )

        value =
            value_ok
            and tonumber(value)
            or nil

        if value
            and value > 0 then

            return math.floor(value)
        end
    end

    return 0
end

function chat_spammer.get_vote_actor(
    event
)
    local userid =
        chat_spammer.get_event_int_any(
            event,
            {
                "userid",
                "voter",
                "player_userid",
                "user_id"
            }
        )

    local player_index =
        chat_spammer.get_event_int_any(
            event,
            {
                "entityid",
                "entity_index",
                "player",
                "index"
            }
        )

    if player_index <= 0
        and userid > 0 then

        pcall(
            function()
                player_index =
                    tonumber(
                        engine.get_player_for_userid(
                            userid
                        )
                    ) or 0
            end
        )
    end

    local player_name = nil

    if userid > 0 then
        player_name =
            get_player_name_from_userid(
                userid
            )
    end

    if (not player_name
        or player_name == "")
        and player_index > 0 then

        local info_ok,
            player_info =
                pcall(
                    engine.get_player_info,
                    player_index
                )

        if info_ok
            and player_info
            and player_info.name then

            player_name =
                tostring(
                    player_info.name
                )
        end

        if not player_name
            or player_name == "" then

            local entity_ok,
                player_entity =
                    pcall(
                        entity.get_by_index,
                        player_index
                    )

            if entity_ok
                and player_entity then

                pcall(
                    function()
                        player_name =
                            tostring(
                                player_entity:get_name()
                                or ""
                            )
                    end
                )
            end
        end
    end

    if not player_name
        or player_name == "" then

        player_name =
            userid > 0
            and (
