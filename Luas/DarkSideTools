function encode_preference_text(text_value)
    text_value =
        tostring(text_value or "")

    return (
        text_value:gsub(
            ".",
            function(character)
                return string.format(
                    "%02X",
                    string.byte(character)
                )
            end
        )
    )
end

function decode_preference_text(encoded_value)
    encoded_value =
        tostring(encoded_value or "")

    if #encoded_value % 2 ~= 0
        or not encoded_value:match(
            "^[0-9A-Fa-f]*$"
        ) then

        return nil
    end

    return (
        encoded_value:gsub(
            "(%x%x)",
            function(pair)
                return string.char(
                    tonumber(
                        pair,
                        16
                    )
                )
            end
        )
    )
end

function save_chat_spammer_preferences()
    if type(io) ~= "table"
        or type(io.open) ~= "function" then

        return false
    end

    local open_ok,
        file =
            pcall(
                io.open,
                DARKSIDE_CONFIG.CHAT_SPAMMER_PREFERENCES_PATH,
                "w"
            )

    if not open_ok
        or not file then

        return false
    end

    local write_ok =
        pcall(
            function()
                file:write(
                    "# Dark Side Tools Chat Spammer preferences\n"
                )

                file:write(
                    "version=1\n"
                )

                file:write(
                    "saved_name_announcement_text=" ..
                    encode_preference_text(
                        name_stealer.announce_saved_name_template
                    ) ..
                    "\n"
                )

                file:write(
                    "active_count=" ..
                    tostring(
                        #chat_spammer.messages
                    ) ..
                    "\n"
                )

                for index = 1,
                    #chat_spammer.messages do

                    file:write(
                        "active_enabled_" ..
                        tostring(index) ..
                        "=" ..
                        (
                            chat_spammer.message_enabled[
                                index
                            ] == true
                            and "1"
                            or "0"
                        ) ..
                        "\n"
                    )

                    file:write(
                        "active_text_" ..
                        tostring(index) ..
                        "=" ..
                        encode_preference_text(
                            chat_spammer.messages[
                                index
                            ]
                        ) ..
                        "\n"
                    )
                end

                file:write(
                    "removed_count=" ..
                    tostring(
                        #chat_spammer.removed_messages
                    ) ..
                    "\n"
                )

                for index = 1,
                    #chat_spammer.removed_messages do

                    file:write(
                        "removed_enabled_" ..
                        tostring(index) ..
                        "=" ..
                        (
                            chat_spammer.removed_message_enabled[
                                index
                            ] == true
                            and "1"
                            or "0"
                        ) ..
                        "\n"
                    )

                    file:write(
                        "removed_text_" ..
                        tostring(index) ..
                        "=" ..
                        encode_preference_text(
                            chat_spammer.removed_messages[
                                index
                            ]
                        ) ..
                        "\n"
                    )
                end

                file:flush()
                file:close()
            end
        )

    if not write_ok then
        pcall(
            function()
                file:close()
            end
        )

        return false
    end

    return true
end

function load_chat_spammer_preferences()
    if type(io) ~= "table"
        or type(io.open) ~= "function" then

        return false
    end

    local open_ok,
        file =
            pcall(
                io.open,
                DARKSIDE_CONFIG.CHAT_SPAMMER_PREFERENCES_PATH,
                "r"
            )

    if not open_ok
        or not file then

        return false
    end

    local read_ok,
        contents =
            pcall(
                function()
                    return file:read("*a")
                end
            )

    pcall(
        function()
            file:close()
        end
    )

    if not read_ok
        or type(contents) ~= "string" then

        return false
    end

    local values = {}

    for line in contents:gmatch(
        "[^\r\n]+"
    ) do
        local key,
            value =
                line:match(
                    "^([%w_]+)=(.*)$"
                )

        if key then
            values[key] =
                value
        end
    end

    local saved_announcement_text =
        decode_preference_text(
            values.saved_name_announcement_text
            or ""
        )

    if saved_announcement_text ~= nil
        and values.saved_name_announcement_text ~= nil then

        name_stealer.announce_saved_name_template =
            saved_announcement_text
    end

    local active_count =
        tonumber(
            values.active_count
        )

    if not active_count then
        return false
    end

    active_count =
        math.max(
            1,
            math.min(
                DARKSIDE_CONFIG.MAX_CHAT_MESSAGES,
                math.floor(
                    active_count
                )
            )
        )

    local loaded_messages = {}
    local loaded_enabled = {}

    for index = 1,
        active_count do

        local decoded_message =
            decode_preference_text(
                values[
                    "active_text_" ..
                    tostring(index)
                ] or ""
            )

        if decoded_message == nil then
            return false
        end

        loaded_messages[
            index
        ] = decoded_message

        loaded_enabled[
            index
        ] =
            values[
                "active_enabled_" ..
                tostring(index)
            ] == "1"
    end

    local removed_count =
        tonumber(
            values.removed_count
        ) or 0

    removed_count =
        math.max(
            0,
            math.min(
                DARKSIDE_CONFIG.MAX_CHAT_MESSAGES,
                math.floor(
                    removed_count
                )
            )
        )

    local loaded_removed_messages = {}
    local loaded_removed_enabled = {}

    for index = 1,
        removed_count do

        local decoded_message =
            decode_preference_text(
                values[
                    "removed_text_" ..
                    tostring(index)
                ] or ""
            )

        if decoded_message == nil then
            return false
        end

        loaded_removed_messages[
            index
        ] = decoded_message

        loaded_removed_enabled[
            index
        ] =
            values[
                "removed_enabled_" ..
                tostring(index)
            ] == "1"
    end

    chat_spammer.messages =
        loaded_messages

    chat_spammer.message_enabled =
        loaded_enabled

    chat_spammer.removed_messages =
        loaded_removed_messages

    chat_spammer.removed_message_enabled =
        loaded_removed_enabled

    chat_spammer.current_index = 1

    return true
end


