function spammer_runtime.finish_cycle_limit(
    reason
)
    if not spammer_cfg.enabled then
        return false
    end

    reason =
        tostring(
            reason or "Configured limit"
        )

    local should_restore =
        spammer_cfg.restore_initial_on_limit == true

    local restored = false

    if should_restore then
        restored =
            reset_name_to_initial(
                true
            )
    else
        stop_name_spammer()
    end

    spammer_runtime.run_limit_reached = true
    spammer_runtime.run_limit_reason = reason
    spammer_runtime.run_limit_restored =
        restored == true

    if should_restore then
        spammer_runtime.status =
            restored
            and "LIMIT REACHED - NAME RESTORED"
            or "LIMIT REACHED - RESTORE FAILED"
    else
        spammer_runtime.status =
            "LIMIT REACHED"
    end

    ui.console.print(
        "[Name Spammer] Automatic limit reached: " ..
        reason ..
        "." ..
        (
            should_restore
            and (
                restored
                and " Original name restored."
                or " Original name could not be restored."
            )
            or ""
        )
    )

    return true
end

function confirm_pending_spammer_name(
    observed_name,
    source
)
    if not spammer_runtime.pending_message then
        return false
    end

    local expected =
        normalize_name_for_compare(
            spammer_runtime.pending_message
        )

    local observed =
        normalize_name_for_compare(
            observed_name
        )

    if observed == ""
        or observed ~= expected then

        return false
    end

    spammer_runtime.last_observed_name =
        observed_name

    spammer_runtime.last_observed_at =
        get_time()

    spammer_runtime.confirmed_changes =
        spammer_runtime.confirmed_changes + 1

    spammer_runtime.last_confirmation_source =
        source or "Unknown"

    spammer_runtime.pending_message = nil
    spammer_runtime.pending_label = "None"
    spammer_runtime.pending_attempts = 0

    spammer_runtime.rate_limited = false
    spammer_runtime.status = "RUNNING"

    spammer_runtime.run_confirmed_changes =
        spammer_runtime.run_confirmed_changes + 1

    local next_index,
        completed_cycle =
            spammer_runtime.advance_automation_cycle()

    if completed_cycle then
        spammer_runtime.run_completed_cycles =
            spammer_runtime.run_completed_cycles + 1
    end

    local limit_reason =
        spammer_runtime.get_cycle_limit_reached_reason()

    if limit_reason then
        spammer_runtime.finish_cycle_limit(
            limit_reason
        )
    end

    return true
end

