function ui.tab_layout.normalize_order()
    local normalized = {}
    local seen = {}

    for _, tab_key in ipairs(
        ui.tab_layout.order
    ) do
        tab_key =
            tostring(tab_key or "")

        if ui.tab_layout.definitions[tab_key]
            and seen[tab_key] ~= true then

            normalized[#normalized + 1] =
                tab_key

            seen[tab_key] = true
        end
    end

    for _, tab_key in ipairs(
        ui.tab_layout.default_order
    ) do
        if seen[tab_key] ~= true then
            normalized[#normalized + 1] =
                tab_key

            seen[tab_key] = true
        end
    end

    ui.tab_layout.order = normalized
    return normalized
end

function ui.tab_layout.move(
    from_index,
    to_index
)
    local order =
        ui.tab_layout.normalize_order()

    from_index =
        math.floor(
            tonumber(from_index) or 0
        )

    to_index =
        math.floor(
            tonumber(to_index) or 0
        )

    if from_index < 1
        or from_index > #order then

        return false
    end

    to_index =
        math.max(
            1,
            math.min(
                #order,
                to_index
            )
        )

    if from_index == to_index then
        return false
    end

    local tab_key =
        table.remove(
            order,
            from_index
        )

    table.insert(
        order,
        to_index,
        tab_key
    )

    ui.tab_layout.order = order

    local definition =
        ui.tab_layout.definitions[tab_key]

    ui.tab_layout.last_status =
        tostring(
            definition
            and definition.label
            or tab_key
        ) ..
        " moved to position " ..
        tostring(to_index) ..
        "."

    ui.tab_layout.last_status_until =
        get_time() + 2.5

    return true
end

function ui.tab_layout.is_default()
    local current =
        ui.tab_layout.normalize_order()

    if #current ~=
        #ui.tab_layout.default_order then

        return false
    end

    for index,
        tab_key in ipairs(
            ui.tab_layout.default_order
        ) do

        if tostring(current[index]) ~=
            tostring(tab_key) then

            return false
        end
    end

    return true
end

function ui.tab_layout.reset()
    ui.tab_layout.order = {}

    for index,
        tab_key in ipairs(
            ui.tab_layout.default_order
        ) do

        ui.tab_layout.order[index] =
            tab_key
    end

    ui.tab_layout.last_status =
        "Default tab order restored."

    ui.tab_layout.last_status_until =
        get_time() + 2.5
end

