        local config_name =
            slot
            and ui.heaven_configs.clean_config_name(
                slot.config_name
            )
            or ""

        local available = false

        if config_name ~= "" then
            if type(ui.heaven_configs.config_is_detected) == "function"
                and ui.heaven_configs.config_is_detected(
                    config_name
                ) then

                available = true
            elseif type(ui.heaven_configs.config_file_exists) == "function"
                and ui.heaven_configs.config_file_exists(
                    config_name
                ) then

                available = true
            end
        end

        if slot
            and slot.enabled == true
            and config_name ~= ""
            and available == true then

            cycle_slots[#cycle_slots + 1] = index
        end
    end

    return cycle_slots
end

