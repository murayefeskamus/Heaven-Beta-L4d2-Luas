function ui.network.calculate_overlay_label_width(
    detailed
)
    local display =
        detailed == true
        and ui.network.display.detailed
        or ui.network.display.compact

    local order =
        detailed == true
        and ui.network.order.detailed
        or ui.network.order.compact

    local maximum_width = 0

    for _, key in ipairs(
        type(order) == "table"
        and order
        or {}
    ) do
        if type(display) == "table"
            and display[key] == true
            and key ~= "copy_button"
            and key ~= "player_ids" then

            local label =
                ui.network.get_overlay_row_label(
                    key
                )

            if label ~= "" then
                maximum_width =
                    math.max(
                        maximum_width,
                        ui.lobby.measure_text_width(
                            label
                        )
                    )
            end
        end
    end


    if type(display) == "table"
        and display.player_ids == true then

        for _, player_record in ipairs(
            ui.lobby.players or {}
        ) do
            local userid_text =
                tonumber(player_record.userid) or 0

            local label =
                userid_text > 0
                and (
                    "ID " ..
                    tostring(
                        math.floor(userid_text)
                    )
                )
                or "ID N/A"

            maximum_width =
                math.max(
                    maximum_width,
                    ui.lobby.measure_text_width(
                        label
                    )
                )
        end
    end


    return math.max(
        58,
        math.min(
            142,
            maximum_width + 9
        )
    )
end

