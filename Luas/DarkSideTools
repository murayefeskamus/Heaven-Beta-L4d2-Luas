function ui.control.aim_v2_try_native_circle(draw_list, center_x, center_y, radius, color, segments)
    if draw_list == nil then
        return false
    end

    local packed = ui.control.color_to_abgr(color)
    local method_names = { "add_circle", "AddCircle", "circle" }

    for _, method_name in ipairs(method_names) do
        local method = nil
        local method_ok = pcall(function()
            method = draw_list[method_name]
        end)

        if method_ok and type(method) == "function" then
            local calls = {
                { draw_list, center_x, center_y, radius, packed, segments, 1.0 },
                { draw_list, { center_x, center_y }, radius, packed, segments, 1.0 },
                { draw_list, { x = center_x, y = center_y }, radius, packed, segments, 1.0 },
                { center_x, center_y, radius, packed, segments, 1.0 },
                { { center_x, center_y }, radius, packed, segments, 1.0 },
                { { x = center_x, y = center_y }, radius, packed, segments, 1.0 }
            }

            for _, arguments in ipairs(calls) do
                local call_ok, result = pcall(method, table.unpack(arguments))
                if call_ok and result ~= false then
                    return true
                end
            end
        end
    end

    return false
end

function ui.control.aim_v2_submit_line(draw_list, x1, y1, x2, y2, packed)
    if draw_list == nil then
        return false
    end

    local engine_state = ui.control.aim_v2_engine

    local function call_signature(method, signature)
        if signature == 1 then
            return pcall(method, draw_list, x1, y1, x2, y2, packed, 1.0)
        elseif signature == 2 then
            return pcall(method, draw_list, { x1, y1 }, { x2, y2 }, packed, 1.0)
        elseif signature == 3 then
            return pcall(method, draw_list, { x = x1, y = y1 }, { x = x2, y = y2 }, packed, 1.0)
        elseif signature == 4 then
            return pcall(method, x1, y1, x2, y2, packed, 1.0)
        elseif signature == 5 then
            return pcall(method, { x1, y1 }, { x2, y2 }, packed, 1.0)
        end
        return pcall(method, { x = x1, y = y1 }, { x = x2, y = y2 }, packed, 1.0)
    end

    local cached_name = engine_state.line_method_name
    local cached_signature = tonumber(engine_state.line_signature)

    if cached_name and cached_signature then
        local cached_method = nil
        local method_ok = pcall(function()
            cached_method = draw_list[cached_name]
        end)

        if method_ok and type(cached_method) == "function" then
            local ok, result = call_signature(cached_method, cached_signature)
            if ok and result ~= false then
                return true
            end
        end

        engine_state.line_method_name = nil
        engine_state.line_signature = nil
    end

    for _, method_name in ipairs({ "add_line", "AddLine", "line" }) do
        local method = nil
        local method_ok = pcall(function()
            method = draw_list[method_name]
        end)

        if method_ok and type(method) == "function" then
            for signature = 1, 6 do
                local ok, result = call_signature(method, signature)
                if ok and result ~= false then
                    engine_state.line_method_name = method_name
                    engine_state.line_signature = signature
                    return true
                end
            end
        end
    end

    return false
end

function ui.control.aim_v2_draw_continuous_circle(draw_list, center_x, center_y, radius, color, segments, thickness)
    if draw_list == nil then
        return false, "Unavailable"
    end

    segments = math.max(48, math.min(180, math.floor(tonumber(segments) or 120)))
    thickness = math.max(1, math.min(5, math.floor(tonumber(thickness) or 2)))
    local packed = ui.control.color_to_abgr(color)

    local first_line_ok = nil
    for layer = 1, thickness do
        local offset = (layer - (thickness + 1) * 0.5) * 0.90
        local ring_radius = math.max(1.0, radius + offset)

        for segment = 0, segments - 1 do
            local angle_a = segment / segments * math.pi * 2.0
            local angle_b = (segment + 1) / segments * math.pi * 2.0
            local x1 = center_x + math.cos(angle_a) * ring_radius
            local y1 = center_y + math.sin(angle_a) * ring_radius
            local x2 = center_x + math.cos(angle_b) * ring_radius
            local y2 = center_y + math.sin(angle_b) * ring_radius

            local line_ok = ui.control.aim_v2_submit_line(
                draw_list,
                x1, y1, x2, y2,
                packed
            )

            if first_line_ok == nil then
                first_line_ok = line_ok
            end

            if not line_ok then
                first_line_ok = false
                break
            end
        end

        if first_line_ok == false then
            break
        end
    end

    if first_line_ok == true then
        return true, "ImGui continuous line"
    end

    local native_ok = true
    for layer = 1, thickness do
        local offset = (layer - (thickness + 1) * 0.5) * 0.90
        if not ui.control.aim_v2_try_native_circle(
            draw_list,
            center_x,
            center_y,
            math.max(1.0, radius + offset),
            color,
            segments
        ) then
            native_ok = false
            break
        end
    end

    return native_ok, native_ok and "ImGui native outline" or "Unavailable"
end

function ui.control.draw_fov_circle_overlay()
    local engine_state = ui.control.aim_v2_engine
    if engine_state.overlay_requested ~= true then
        return false
    end

    local settings = ui.control.aim.v2
    local width, height = ui.control.aim_v2_get_screen_size()
    local center_x = width * 0.5
    local center_y = height * 0.5
    local radius = ui.control.calculate_fov_circle_radius(width, height, settings.fov)
        * ui.control.clamp(settings.fov_circle_scale, 0.50, 1.35)

    local locked = ui.control.has_aim_v2_session_target()
    local selected_color = ui.control.resolve_fov_circle_color(settings, locked)

    if not selected_color then
        local palette = ui.control.get_aim_v2_visual_palette()
        selected_color = locked and palette.locked or palette.idle
    end

    selected_color = ui.control.normalize_rgba_color(
        selected_color,
        { 1.0, 1.0, 1.0, 1.0 }
    )
    selected_color[4] = ui.control.clamp(settings.fov_circle_opacity, 0.15, 1.0)

    local segments = math.max(48, math.min(180, math.floor(tonumber(settings.fov_circle_segments) or 120)))
    local thickness = math.max(1, math.min(5, math.floor(tonumber(settings.fov_circle_thickness) or 2)))

    ui.control.runtime.fov_circle_radius = radius
    ui.control.runtime.fov_circle_state = locked and "Locked" or "Unlocked"
    ui.control.runtime.fov_circle_selected_hex = ui.control.color_to_hex(selected_color)
    ui.control.runtime.fov_circle_submitted_hex = ui.control.runtime.fov_circle_selected_hex
    ui.control.runtime.fov_circle_predicted_hex = ui.control.runtime.fov_circle_selected_hex
    ui.control.runtime.fov_circle_color_profile = "Exact ImGui RGB"
    ui.control.runtime.fov_circle_color_profile_status = "Continuous post-filter outline"

    ui.control.aim_v2_set_next_overlay_window(width, height)

    local flags = 1 + 2 + 4 + 8 + 32 + 128 + 256 + 512 + 4096 + 8192 + 262144 + 524288
    local opened_ok, window_open = pcall(
        imgui.begin,
        "###DST_AimV2_PostFilterCircle",
        flags
    )

    if not opened_ok then
        engine_state.overlay_error = "ImGui overlay window unavailable"
        ui.control.runtime.fov_circle_status = engine_state.overlay_error
        return false
    end

    local draw_list = nil
    if type(imgui.get_foreground_draw_list) == "function" then
        local list_ok, list = pcall(imgui.get_foreground_draw_list)
        if list_ok then draw_list = list end
    end
    if not draw_list and type(imgui.get_window_draw_list) == "function" then
        local list_ok, list = pcall(imgui.get_window_draw_list)
        if list_ok then draw_list = list end
    end

    local drawn = false
    local backend = "Unavailable"

    if draw_list then
        if settings.fov_circle_glow == true then
            local glow_strength = ui.control.clamp(settings.fov_circle_glow_strength, 0.0, 1.0)
            for ring = 3, 1, -1 do
                local glow_color = {
                    selected_color[1], selected_color[2], selected_color[3],
                    selected_color[4] * glow_strength * (0.16 / ring)
                }
                ui.control.aim_v2_draw_continuous_circle(
                    draw_list,
                    center_x,
                    center_y,
                    radius + thickness + ring * 1.8,
                    glow_color,
                    math.min(segments, 120),
                    1
                )
            end
        end

        drawn, backend = ui.control.aim_v2_draw_continuous_circle(
            draw_list,
            center_x,
            center_y,
            radius,
            selected_color,
            segments,
            thickness
        )

        if settings.fov_circle_center_dot == true and drawn then
            local packed = ui.control.color_to_abgr(selected_color)
            local marker_size = 4.0 + thickness * 0.5
            ui.control.aim_v2_submit_line(
                draw_list,
                center_x - marker_size, center_y,
                center_x + marker_size, center_y,
                packed
            )
            ui.control.aim_v2_submit_line(
                draw_list,
                center_x, center_y - marker_size,
                center_x, center_y + marker_size,
                packed
            )
        end
    end

    pcall(imgui["end"])

    engine_state.overlay_backend = drawn and backend or "Failed"
    ui.control.runtime.fov_circle_renderer = engine_state.overlay_backend
    ui.control.runtime.fov_circle_status = drawn
        and string.format(
            "%s | %s | %d px | %d px thick | %d segments",
            locked and "Locked" or "Unlocked",
            ui.control.color_to_hex(selected_color),
            math.floor(radius + 0.5),
            thickness,
            segments
        )
        or "Continuous circle-line backend unavailable"

    return drawn
end

function ui.control.draw_aim_v2_color_editor(label, editor_key, color, default_color, controls_x)
    color = ui.control.normalize_rgba_color(color, default_color)
    local hex = ui.control.color_to_hex(color)
    local text_color = ui.control.contrast_text_color(color)

    imgui.text(label)
    imgui.same_line()
    ui.lobby.set_cursor_x(controls_x)

    if colored_button(
        ((ui.control.ui_state.aim_v2_color_editor == editor_key) and "DONE " or "EDIT ") .. hex .. "##" .. editor_key,
        text_color[1], text_color[2], text_color[3],
        color[1], color[2], color[3]
    ) then
        ui.control.ui_state.aim_v2_color_editor =
            ui.control.ui_state.aim_v2_color_editor == editor_key and "" or editor_key
    end

    ui.control.draw_option_hint("Opens the color editor; the HEX value is the exact circle RGB.")

    if ui.control.ui_state.aim_v2_color_editor == editor_key then
        local hue, saturation, value = ui.control.rgb_to_hsv(color)

        imgui.text("Hue:")
        imgui.same_line()
        ui.lobby.set_cursor_x(controls_x)
        imgui.push_item_width(190)
        local changed_h, new_h = imgui.slider_float("##" .. editor_key .. "Hue", hue, 0.0, 1.0)
        imgui.pop_item_width()
        ui.control.draw_option_hint("Selects the base color family across the full spectrum.")

        imgui.text("Saturation:")
        imgui.same_line()
        ui.lobby.set_cursor_x(controls_x)
        imgui.push_item_width(190)
        local changed_s, new_s = imgui.slider_float("##" .. editor_key .. "Sat", saturation, 0.0, 1.0)
        imgui.pop_item_width()
        ui.control.draw_option_hint("Controls color intensity; 0 is gray and 1 is fully saturated.")

        imgui.text("Brightness:")
        imgui.same_line()
        ui.lobby.set_cursor_x(controls_x)
        imgui.push_item_width(190)
        local changed_v, new_v = imgui.slider_float("##" .. editor_key .. "Val", value, 0.0, 1.0)
        imgui.pop_item_width()
        ui.control.draw_option_hint("Controls lightness; higher values are easier to see on dark maps.")

        if changed_h or changed_s or changed_v then
            color = ui.control.hsv_to_rgb(
                changed_h and new_h or hue,
                changed_s and new_s or saturation,
                changed_v and new_v or value
            )
            color[4] = 1.0
        end

        theme_text_colored(
            color[1], color[2], color[3], 1.0,
            string.format(
                "%s  |  RGB %d, %d, %d",
                ui.control.color_to_hex(color),
                math.floor(color[1] * 255 + 0.5),
                math.floor(color[2] * 255 + 0.5),
                math.floor(color[3] * 255 + 0.5)
            )
        )

        if colored_button("RESET COLOR##" .. editor_key, 1.0, 1.0, 1.0, 0.30, 0.30, 0.30) then
            color = ui.control.normalize_rgba_color(default_color, default_color)
        end
        ui.control.draw_option_hint("Restores this state color to its default value.")
    end

    return color
end

