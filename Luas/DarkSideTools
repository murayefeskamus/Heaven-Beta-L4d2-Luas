local function geo85_trim(value)
    return tostring(value or "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function geo85_clean(value)
    return geo85_trim(value)
        :gsub("[\r\n|]", " ")
        :gsub("%s+", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function geo85_parse_kv_line(line)
    local details = {}
    line = tostring(line or "")
        :gsub("^\239\187\191", "")
        :gsub("[\r\n]+", " ")

    for key, value in line:gmatch("([^|=]+)=([^|]*)") do
        key = geo85_trim(key)
        value = geo85_clean(value)
        if key ~= "" then
            details[key] = value
        end
    end

    return details
end

local function geo85_quote_path(path)
    return '"' .. tostring(path or ""):gsub('"', '') .. '"'
end

local function geo85_get_env(name)
    if type(os) == "table" and type(os.getenv) == "function" then
        local ok, value = pcall(os.getenv, name)
        if ok and value and tostring(value) ~= "" then
            return tostring(value)
        end
    end
    return ""
end

local function geo85_join_path(directory, file_name)
    directory = tostring(directory or "")
    file_name = tostring(file_name or "")
    if directory:sub(-1) == "\\" then
        return directory .. file_name
    end
    return directory .. "\\" .. file_name
end

local function geo85_try_mkdir(directory)
    directory = tostring(directory or "")
    if directory == "" then
        return false
    end

    if type(os) == "table" and type(os.execute) == "function" then
        pcall(os.execute,
            'cmd.exe /C if not exist ' ..
            geo85_quote_path(directory) ..
            ' mkdir ' ..
            geo85_quote_path(directory) ..
            ' >NUL 2>NUL'
        )
    end

    if type(io) ~= "table" or type(io.open) ~= "function" then
        return true
    end

    local test_path = geo85_join_path(directory, "__dst_geoip_write_test.tmp")
    local ok, file = pcall(io.open, test_path, "wb")
    if ok and file then
        pcall(function()
            file:write("ok")
            file:close()
        end)
        if type(os) == "table" and type(os.remove) == "function" then
            pcall(os.remove, test_path)
        end
        return true
    end

    return false
end

