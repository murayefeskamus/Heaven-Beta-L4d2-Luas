                theme_text_colored(
                    0.20, 1.0, 0.20, 1.0,
                    tostring(
                        overview.bots or 0
                    )
                )
            elseif row.special == "status" then
                begin_value_cell()

                theme_text_colored(
                    1.0, 1.0, 1.0, 1.0,
                    "Alive:"
                )

                imgui.same_line()

                theme_text_colored(
                    0.20, 1.0, 0.20, 1.0,
                    tostring(
                        overview.alive or 0
                    )
                )

                imgui.same_line()

                theme_text_colored(
                    1.0, 1.0, 1.0, 1.0,
                    "| Dead:"
                )

                imgui.same_line()

                theme_text_colored(
                    1.0, 0.35, 0.35, 1.0,
                    tostring(
                        overview.dead or 0
                    )
                )
            else
                draw_left_text(
                    label_width + 4,
                    row.value,
                    1.0, 1.0, 1.0,
                    false
                )
            end

            imgui.separator()
        end
    end

    imgui.end_child()
    ui.lobby.compact_after_child(4)
end

function ui.enhancements.draw_server_networking_info_table(
    overview
)
    overview = overview or ui.lobby.overview

    local stats = ui.network.stats or {}

    local left_rows = {
        { section = "SERVER INFO" },
        { label = "Server", value = tostring(overview.server or "Unavailable") },
        { label = "Map", value = tostring(overview.map or "Unavailable") },
        { label = "Map code", value = tostring(overview.map_code or "Unavailable") },
        { label = "Population", special = "population" },
        { label = "Status", special = "status" },
        { label = "Mode", value = tostring(overview.mode or "Unavailable") }
    }

    if overview.show_difficulty then
        table.insert(
            left_rows,
            {
                label = "Difficulty",
                value = tostring(overview.difficulty or "Unavailable")
            }
        )
    end

    table.insert(
        left_rows,
        {
            label = "Session time",
            value = ui.lobby.connected
                and ui.lobby.format_duration(
                    get_time() - ui.lobby.session_started_at
                )
                or "00:00"
        }
