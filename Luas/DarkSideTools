function ui.lobby.build_saved_name_match_messages()
    local matches =
        type(ui.network) == "table"
        and type(ui.network.get_stolen_lobby_name_matches) == "function"
        and ui.network.get_stolen_lobby_name_matches()
        or {}

    local messages = {}

    if type(matches) ~= "table"
        or #matches == 0 then

        messages = {
            "No names from your saved list were found in the current lobby."
        }
    else
        local clean_matches = {}

        for _, player_name in ipairs(matches) do
            local clean_name = tostring(player_name or "")
                :gsub("[\r\n]", " ")
                :gsub("^%s+", "")
                :gsub("%s+$", "")

            if clean_name ~= "" then
                clean_matches[#clean_matches + 1] = clean_name
            end
        end

        local match_count = #clean_matches

        if match_count == 0 then
            messages = {
                "No names from your saved list were found in the current lobby."
            }
        else
            local intro =
                match_count == 1
                and "Found 1 lobby player whose name is in your saved list: "
                or (
                    "Found " ..
                    tostring(match_count) ..
                    " lobby players whose names are in your saved list: "
                )

            local current = intro
            local first_line_limit = 90
            local continuation_limit = 112

            for _, clean_name in ipairs(clean_matches) do
                local separator = ", "

                if current == intro
                    or current == "" then
                    separator = ""
                end

                local candidate =
                    tostring(current) ..
                    tostring(separator) ..
                    tostring(clean_name)

                local limit =
                    #messages == 0
                    and first_line_limit
                    or continuation_limit

                if #candidate <= limit then
                    current = candidate
                else
                    if current ~= "" then
                        messages[#messages + 1] = current
                    end

                    current = tostring(clean_name)
                end
            end

            if current ~= "" then
                messages[#messages + 1] = current
            end
        end
    end

    return ui.lobby.prefix_command_messages(
        "Name Stealer",
        messages
    )
end

