function ui.lobby.append_chat_message(
    message,
    team_only,
    initial_delay
)
    if not is_game_ready() then
        ui.console.print(
            "[Lobby & Network] Cannot queue chat while disconnected."
        )

        return false
    end

    local safe_message =
        tostring(
            message or ""
        ):gsub(
            "[\r\n]",
            " "
        ):gsub(
            '"',
            "'"
        )

    if safe_message == "" then
        return false
    end

    if type(ui.lobby.pending_chat_messages) ~= "table" then
        ui.lobby.pending_chat_messages = {}
    end

    local queue_was_empty =
        #ui.lobby.pending_chat_messages == 0

    table.insert(
        ui.lobby.pending_chat_messages,
        {
            text = safe_message,
            team_only = team_only == true,
            attempts = 0,
            source = "single"
        }
    )

    if queue_was_empty then
        ui.lobby.next_chat_send_time =
            get_time() +
            math.max(
                0.0,
                tonumber(initial_delay) or 0.05
            )
    end

    return true
end


function ui.lobby.process_chat_queue()
    if not is_game_ready() then
        ui.lobby.pending_chat_messages = {}
        ui.lobby.next_chat_send_time = 0.0
        return
    end

    if type(ui.lobby.pending_chat_messages) ~= "table"
        or #ui.lobby.pending_chat_messages == 0 then

        return
    end

    local now = get_time()

    if now < ui.lobby.next_chat_send_time then
        return
    end

    if chat_spammer
        and chat_spammer.automatic_chat_lane_used_this_frame == true then

        ui.lobby.next_chat_send_time = now + 0.05
        return
    end

    local next_message =
        ui.lobby.pending_chat_messages[1]

    local message_text = next_message
    local team_only = false
    local attempts = 0

    if type(next_message) == "table" then
        message_text = next_message.text
        team_only = next_message.team_only == true
        attempts =
            math.max(
                0,
                math.floor(
                    tonumber(next_message.attempts) or 0
                )
            )
    end

    local sent = false

    if message_text
        and tostring(message_text) ~= "" then

        if team_only then
            sent =
                ui.lobby.send_team_chat(
                    message_text
                ) == true
        else
            sent =
                ui.lobby.send_all_chat(
                    message_text
                ) == true
        end
    else
        sent = true
    end

    if sent then
        table.remove(
            ui.lobby.pending_chat_messages,
            1
        )

        if chat_spammer then
            chat_spammer.automatic_chat_lane_used_this_frame = true
        end

        ui.lobby.next_chat_send_time =
            now + ui.lobby.chat_send_interval
    else
        attempts = attempts + 1

        if type(next_message) == "table" then
            next_message.attempts = attempts
        end

        if attempts >= 3 then
            table.remove(
                ui.lobby.pending_chat_messages,
                1
            )

            ui.console.print(
                "[Lobby & Network] Chat message failed after 3 attempts."
            )
        end

        ui.lobby.next_chat_send_time =
            now + 0.25
    end
end


function ui.lobby.queue_chat_messages(
    messages
)
    if type(messages) ~= "table"
        or #messages == 0 then

        return false
    end

    if not is_game_ready() then
        ui.console.print(
            "[Lobby & Network] Cannot send chat while disconnected."
        )

        return false
    end

    ui.lobby.pending_chat_messages = {}

    for _, message in ipairs(
        messages
    ) do
        message = tostring(
            message or ""
        )

        message = message:gsub(
            "[\r\n]",
            " "
        )

        if message ~= "" then
            table.insert(
                ui.lobby.pending_chat_messages,
                message
            )
        end
    end


    ui.lobby.next_chat_send_time =
        get_time() + 1.25

    return #ui.lobby.pending_chat_messages > 0
end

