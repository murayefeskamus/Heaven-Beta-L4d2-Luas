        aim_palette.active
    )
    draw_diagnostic(
        "Stabilizer:",
        string.format(
            "step %.2f deg | retention %.0f%%",
            tonumber(ui.control.runtime.last_tracking_step) or 0.0,
            ui.control.clamp(ui.control.runtime.last_tracking_retention, 0.0, 1.0) * 100.0
        ),
        aim_palette.setting
    )
    draw_diagnostic(
        "Adaptive engine:",
        string.format(
            "%s | %s | FOV %.0f | range %.0f",
            tostring(ui.control.runtime.smart_class or "Neutral"),
            tostring(ui.control.runtime.smart_profile or "Off"),
            tonumber(ui.control.runtime.effective_fov) or 0.0,
            tonumber(ui.control.runtime.effective_max_distance) or 0.0
        ),
        aim_palette.setting
    )
    draw_diagnostic(
        "Lock confidence:",
        string.format(
            "%.0f%% | effective smoothing %.2f",
            ui.control.clamp(ui.control.runtime.target_confidence, 0.0, 1.0) * 100.0,
            tonumber(ui.control.runtime.effective_smoothing) or 0.0
        ),
        diagnostic_color
    )

    draw_diagnostic(
        "Pursuit navigation:",
        string.format(
            "%s | %.0f u | clearance %.0f%% | steer %+.0f deg | lead %.2f s",
            tostring(ui.control.runtime.pursuit_status or "Disabled"),
            tonumber(ui.control.runtime.pursuit_distance) or 0.0,
            ui.control.clamp(ui.control.runtime.pursuit_clearance, 0.0, 1.0) * 100.0,
            tonumber(ui.control.runtime.pursuit_heading_offset) or 0.0,
            tonumber(ui.control.runtime.pursuit_target_lead_used) or 0.0
        ),
        ui.control.runtime.pursuit_active and aim_palette.active or aim_palette.idle
    )

    draw_diagnostic(
        "Pursuit recovery:",
        string.format(
            "attempts %d | jump API %s",
            math.floor(tonumber(ui.control.runtime.pursuit_recovery_attempts) or 0),
            tostring(ui.control.runtime.pursuit_jump_supported or "Unknown")
        ),
        aim_palette.setting
    )

    draw_diagnostic(
        "FOV visual:",
        tostring(ui.control.runtime.fov_circle_status or "Ready") ..
        " | " .. tostring(ui.control.runtime.fov_circle_state or "Idle") ..
        " | " .. tostring(ui.control.runtime.fov_circle_renderer or "Not drawn") ..
        " | " .. tostring(ui.control.runtime.fov_circle_render_stage or "Unknown stage"),
        diagnostic_color
    )

    draw_diagnostic(
        "Circle colors:",
        ui.control.aim_fov_circle_color_modes[
            (tonumber(aim_settings.fov_circle_color_mode) or 0) + 1
        ] or "Theme-adaptive states",
        diagnostic_color
    )

    draw_diagnostic(
        "Color output:",
        tostring(ui.control.runtime.fov_circle_draw_order or "Heaven RBG compatibility") ..
        " | picker " .. tostring(ui.control.runtime.fov_circle_selected_hex or "#FFFFFF") ..
        " | circle " .. tostring(ui.control.runtime.fov_circle_submitted_hex or "#FFFFFF"),
        diagnostic_color
    )

    draw_hint("Live values for tuning and troubleshooting.")
    draw_scenario("Use this section while tuning; the Performance preset reduces visual cost but keeps essential status values available.")
        end_panel()
    end

    ui.control.pop_aim_v2_style_colors(style_count)
    ui.control.rendering_aim_v2 = false
end

