        local timeout = math.max(8.0, tonumber(ui.network.server_region_online_lookup_timeout) or 20.0)

        if active_ip == ip_address and active_age < timeout then
            return true
        end

        if active_age < timeout then
            return false
        end

        ui.network.server_region_online_lookup_active_ip = ""
        ui.network.server_region_online_lookup_active_path = ""
        ui.network.cleanup_geoip_transient_files()
    end

    if type(os) ~= "table" or type(os.execute) ~= "function" then
        ui.network.server_region_online_lookup_status = "OS execute unavailable."
        return false
    end

    local output_path = ui.network.get_geoip_online_result_path(ip_address)
    local ps_path = ui.network.get_geoip_online_script_path()
    local vbs_path = ui.network.get_geoip_online_vbs_path()

    ui.network.cleanup_geoip_transient_files()

    local ps_command = ui.network.build_geoip_online_lookup_powershell(ip_address, output_path)
    local ps_written = false
    local vbs_written = false

    if type(io) == "table" and type(io.open) == "function" then
        local ps_ok, ps_file = pcall(io.open, ps_path, "wb")
        if ps_ok and ps_file then
            ps_written = pcall(function() ps_file:write(ps_command) end) == true
            pcall(function() ps_file:close() end)
        end

        local safe_ps = ps_path:gsub('"', '""')
        local vbs_command =
            'Set sh = CreateObject("WScript.Shell")\r\n' ..
            'sh.Run "powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File ""' ..
            safe_ps ..
            '""", 0, False\r\n'

        local vbs_ok, vbs_file = pcall(io.open, vbs_path, "wb")
        if vbs_ok and vbs_file then
            vbs_written = pcall(function() vbs_file:write(vbs_command) end) == true
            pcall(function() vbs_file:close() end)
        end
    end

    if ps_written ~= true then
        ui.network.server_region_online_lookup_status =
            "Lookup script write failed: " .. tostring(ps_path)
        return false
    end

    local shell_command
    if vbs_written == true then
        shell_command = 'wscript.exe ' .. geo85_quote_path(vbs_path)
    else
        shell_command =
            'powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File ' ..
            geo85_quote_path(ps_path)
    end

    local ok = pcall(os.execute, shell_command)
    if ok then
        ui.network.server_region_online_lookup_last_start = now
        ui.network.server_region_online_lookup_active_ip = ip_address
        ui.network.server_region_online_lookup_active_path = output_path
        ui.network.server_region_online_lookup_started_at = now
        ui.network.server_region_online_lookup_status =
            "GeoIP lookup started for " .. ip_address .. "."
        return true
    end

    ui.network.server_region_online_lookup_status = "GeoIP lookup start failed."
    return false
end

function ui.network.read_geoip_online_lookup_result(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)

    if ip_address == "" or type(io) ~= "table" or type(io.open) ~= "function" then
        return ""
    end

    local active_ip = tostring(ui.network.server_region_online_lookup_active_ip or "")
    if active_ip ~= ip_address then
        return ""
    end

    local path = tostring(ui.network.server_region_online_lookup_active_path or "")
    if path == "" then
        path = ui.network.get_geoip_online_result_path(ip_address)
    end

    local file_ok, file = pcall(io.open, path, "rb")
    if not file_ok or not file then
        local age = os.clock() - (tonumber(ui.network.server_region_online_lookup_started_at) or 0.0)
        local timeout = math.max(8.0, tonumber(ui.network.server_region_online_lookup_timeout) or 20.0)

        if age >= timeout then
            ui.network.server_region_online_lookup_active_ip = ""
            ui.network.server_region_online_lookup_active_path = ""
            ui.network.server_region_online_lookup_status =
                "GeoIP lookup timed out."

            ui.network.cleanup_geoip_transient_files()

            if type(ui.network.server_region_online_lookup_next_retry) ~= "table" then
                ui.network.server_region_online_lookup_next_retry = {}
            end

            ui.network.server_region_online_lookup_next_retry[ip_address] =
                os.clock() + math.max(120.0, tonumber(ui.network.server_region_online_lookup_retry_interval) or 600.0)
        end

        return ""
    end

    local read_ok, content = pcall(function() return file:read("*a") end)
    pcall(function() file:close() end)

    if not read_ok then
        return ""
    end

    content = tostring(content or "")
        :gsub("^\239\187\191", "")
        :gsub("[\r\n]+", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")

    if content == "" then
        return ""
    end

    ui.network.server_region_online_lookup_active_ip = ""
    ui.network.server_region_online_lookup_active_path = ""

    local status = content:match("^([^|]+)") or ""
    if status == "OK" then
        local details = geo85_parse_kv_line(content)
        details = ui.network.normalize_geoip_detail(details, ip_address)

        ui.network.cleanup_geoip_transient_files()

        if ui.network.cache_geoip_online_details(ip_address, details) then
            return tostring(details.country or "")
        end
    end

    local error_message = content:match("message=([^|]+)") or "Unknown error"
    ui.network.server_region_online_lookup_status =
        "GeoIP lookup failed: " .. tostring(error_message)

    ui.network.cleanup_geoip_transient_files()

    if type(ui.network.server_region_online_lookup_next_retry) ~= "table" then
        ui.network.server_region_online_lookup_next_retry = {}
    end

    ui.network.server_region_online_lookup_next_retry[ip_address] =
        os.clock() + math.max(120.0, tonumber(ui.network.server_region_online_lookup_retry_interval) or 600.0)

    return ""
end

