function ui.section_layout.normalize_order(
    tab_key
)
    local normalized =
        ui.favourites.previous_normalize_section_order(
            tab_key
        )

    tab_key =
        tostring(tab_key or "")

    if tab_key == "settings" then
        local tab_order_index = 0
        local section_order_index = 0

        for index,
            section_key in ipairs(
                normalized
            ) do

            if section_key == "tab_order" then
                tab_order_index = index
            elseif section_key == "section_order" then
                section_order_index = index
            end
        end

        if tab_order_index > 0
            and section_order_index > 0
            and tab_order_index > section_order_index then

            local tab_order_key =
                table.remove(
                    normalized,
                    tab_order_index
                )

            table.insert(
                normalized,
                section_order_index,
                tab_order_key
            )

            ui.section_layout.orders[
                tab_key
            ] = normalized
        end
    end

    return normalized
end

