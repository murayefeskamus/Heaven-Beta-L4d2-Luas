function ui.control.update()
    ui.control.handle_toggle_key()

    local now =
        get_time()

    if now <
        (tonumber(
            ui.control.next_status_update
        ) or 0.0) then

        return
    end

    ui.control.next_status_update =
        now + 0.10

    ui.control.normalize_settings()

    if not ui.control.is_active_enabled() then
        ui.control.runtime.status = "Disabled"
        ui.control.reset_aim_v2_tracking(true)
        ui.control.runtime.target_fov = 0.0
        ui.control.runtime.target_distance = 0.0
        ui.control.runtime.prediction_time_used = 0.0
        ui.control.runtime.target_state = "None"
        return
    end

    if ui.control.is_engaged() then
        return
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        ui.control.runtime.status = "Waiting for game"
        ui.control.runtime.target_name = "None"
        return
    end

    local local_player =
        client.get_local_player()

    if not local_player then
        ui.control.runtime.status = "Waiting for player"
        return
    end

    local alive_ok,
        alive =
            pcall(
                function()
                    return local_player:is_alive()
                end
            )

    if not alive_ok
        or not alive then

        ui.control.runtime.status = "Player is dead"
        ui.control.runtime.target_name = "None"
        return
    end

    if ui.control.resolve_active_mode() == 1 then
        local team_ok,
            team =
                pcall(
                    function()
                        return local_player:get_team()
                    end
                )

        if not team_ok
            or team ~= 3 then

            ui.control.runtime.status = "Infected only"
            ui.control.reset_aim_v2_tracking(true)
            return
        end
    end

    local control_hold_active =
        ui.control.is_action_key_down()

    if ui.control.resolve_active_mode() == 1
        and ui.control.aim.mode == 1 then

        control_hold_active =
            ui.control.is_aim_v2_session_hold_active(
                ui.control.aim.v2
            )
    end

    if control_hold_active then
        ui.control.runtime.status =
            ui.control.active_mode == 0
            and "Monitoring speed"
            or "Searching target"
    else
        ui.control.runtime.status =
            "Ready - hold " ..
            ui.control.get_key_name(
                ui.control.action_key
            )

        if ui.control.resolve_active_mode() == 1 then
            ui.control.reset_aim_v2_tracking(true)
            ui.control.runtime.target_fov = 0.0
            ui.control.runtime.target_distance = 0.0
            ui.control.runtime.prediction_time_used = 0.0
            ui.control.runtime.target_state = "None"
        end
    end
end

function ui.control.apply_speed_limit(
    command,
    local_player
)
    if not ui.control.speed.enabled
        or not ui.control.is_action_key_down() then

        return false
    end

    local mode =
        tonumber(
            ui.control.speed.mode
        ) == 1
        and 1
        or 0

    local settings =
        mode == 1
        and ui.control.speed.v2
        or ui.control.speed.v1

    local velocity_ok,
        velocity =
            pcall(
                function()
                    return local_player:get_velocity()
                end
            )

    if not velocity_ok
        or not velocity then

        ui.control.runtime.status = "Velocity unavailable"
        return false
    end

    local current_speed =
        math.sqrt(
            velocity.x * velocity.x +
            velocity.y * velocity.y
        )

    local effective_limit =
        tonumber(settings.max_speed) or 10.0

    if settings.halve_on_diagonal
        and ui.control.movement_key_count() >= 2 then

        effective_limit =
            effective_limit * 0.705
    end

    ui.control.runtime.current_speed =
        current_speed

    ui.control.runtime.effective_limit =
        effective_limit

    if current_speed <= effective_limit
        or effective_limit <= 0.0 then

        if not ui.control.is_engaged() then
            ui.control.runtime.status =
                string.format(
                    "Within limit: %.1f / %.1f u/s",
                    current_speed,
                    effective_limit
                )
        end

        return false
    end

    local scale =
        effective_limit /
        math.max(
            current_speed,
            0.001
        )

    if mode == 1 then
        scale =
            scale * scale * scale

        if current_speed >=
            effective_limit * 1.25 then

            scale = 0.0
        end
    end

    local forward_ok,
        forward_move =
            pcall(
                function()
                    return command:get_forwardmove()
                end
            )

    local side_ok,
        side_move =
            pcall(
                function()
                    return command:get_sidemove()
                end
            )

    if not forward_ok
        or not side_ok then

        ui.control.runtime.status = "Movement command unavailable"
        return false
    end

    command:set_forwardmove(
        forward_move * scale
    )

    command:set_sidemove(
        side_move * scale
    )

    ui.control.mark_engaged(
        string.format(
            "Limiting: %.1f -> %.1f u/s",
            current_speed,
            effective_limit
        )
    )

    return true
end

function ui.control.get_survivor_state(
    player
)
    local incapacitated = false
    local hanging = false

    if not player then
        return incapacitated,
            hanging
    end

    local incapacitated_value =
        ui.lobby.call_method(
            player,
            "is_incapacitated"
        )

    if incapacitated_value == nil then
        incapacitated_value =
            ui.lobby.call_method(
                player,
                "get_prop",
                "m_isIncapacitated"
            )
    end

    incapacitated =
        incapacitated_value == true
        or incapacitated_value == 1
        or tostring(
            incapacitated_value
        ):lower() == "true"

    local hanging_value =
        ui.lobby.call_method(
            player,
            "get_prop",
            "m_isHangingFromLedge"
        )

    if hanging_value == nil then
        hanging_value =
            ui.lobby.call_method(
                player,
                "get_prop",
                "m_isFallingFromLedge"
            )
    end

    hanging =
        hanging_value == true
        or hanging_value == 1
        or tostring(
            hanging_value
        ):lower() == "true"

    return incapacitated,
        hanging
end

function ui.control.is_valid_survivor(
    player,
    local_index,
    allow_incapacitated,
    allow_hanging
)
    if not player then
        return false
    end

    local player_index =
        tonumber(
            ui.lobby.call_method(
                player,
                "get_index"
            )
        )

    if not player_index
        or player_index == local_index then

        return false
    end

    local alive_value =
        ui.lobby.call_method(
            player,
            "is_alive"
        )

    local alive =
        alive_value == true
        or alive_value == 1
        or tostring(
            alive_value
        ):lower() == "true"

    if not alive then
        return false
    end

    local team =
        tonumber(
            ui.lobby.call_method(
                player,
                "get_team"
            )
        )

    if team ~= 2 then
        return false
    end

    local incapacitated,
        hanging =
            ui.control.get_survivor_state(
                player
            )

    if hanging
        and allow_hanging ~= true then

        return false
    end

    if incapacitated
        and allow_incapacitated ~= true then

        return false
    end

    return true,
        incapacitated,
        hanging
end

function ui.control.get_camera_fov()
    local camera_fov = 90.0

    if type(cvar) == "table"
        and type(cvar.find) == "function" then

        local cvar_ok,
            fov_cvar =
                pcall(
                    cvar.find,
                    "fov_desired"
                )

        if cvar_ok
            and fov_cvar
            and fov_cvar ~= 0 then

            local getters = {
                "get_float",
                "get_int",
                "get_string"
            }

            for _, getter_name in ipairs(
                getters
            ) do
                local getter =
                    cvar[getter_name]

                if type(getter) == "function" then
                    local value_ok,
                        value =
                            pcall(
                                getter,
                                fov_cvar
                            )

                    value =
                        value_ok
                        and tonumber(value)
                        or nil

                    if value
                        and value > 1.0 then

                        camera_fov = value
                        break
                    end
                end
            end
        end
    end

    return ui.control.clamp(
        camera_fov,
        60.0,
        140.0
    )
end

function ui.control.calculate_fov_circle_radius(
    screen_width,
    screen_height,
    aim_fov
)
    screen_width =
        math.max(
            1.0,
            tonumber(screen_width) or 1.0
        )

    screen_height =
        math.max(
            1.0,
            tonumber(screen_height) or 1.0
        )

    local normalized_fov =
        ui.control.clamp(
            aim_fov,
            1.0,
            180.0
        ) / 180.0

    local radius =
        math.min(
            screen_width,
            screen_height
        ) * 0.485 * normalized_fov

    return math.max(
        4.0,
        radius
    )
end

function ui.control.draw_fov_circle()
    local settings =
        ui.control.aim
        and ui.control.aim.v2
        or nil

    if not settings
        or settings.draw_fov_circle ~= true then

        ui.control.runtime.fov_circle_status =
            "Disabled"

        ui.control.runtime.fov_circle_renderer =
            "Not drawn"

        return
    end

    if ui.control.aim.enabled ~= true then
        ui.control.runtime.fov_circle_status =
            "Aim disabled"
        return
    end

    if tonumber(ui.control.aim.mode) ~= 1 then
        ui.control.runtime.fov_circle_status =
            "Select V2"
        return
    end

    local display_mode =
        math.max(
            0,
            math.min(
                2,
                math.floor(
                    tonumber(
                        settings.fov_circle_display_mode
                    ) or 0
                )
            )
        )

    if display_mode == 1
        and ui.control.resolve_active_mode() ~= 1 then

        ui.control.runtime.fov_circle_status =
            "Aim tool not selected"

        return
    end

    if display_mode == 2
        and not ui.control.is_action_key_down() then

        ui.control.runtime.fov_circle_status =
            "Hold " ..
            ui.control.get_key_name(
                ui.control.action_key
            )

        return
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        ui.control.runtime.fov_circle_status =
            "Waiting for game"

        return
    end

    if type(draw) ~= "table" then
        ui.control.runtime.fov_circle_status =
            "Draw API unavailable"
        return
    end

    local size_ok,
        first_size,
        second_size =
            pcall(
                engine.get_screen_size
            )

    if not size_ok then
        ui.control.runtime.fov_circle_status =
            "Screen size unavailable"
        return
    end

    local screen_width =
        tonumber(first_size)

    local screen_height =
        tonumber(second_size)

    if type(first_size) == "table" then
        screen_width =
            tonumber(
                first_size.x
                or first_size.width
                or first_size[1]
            )

        screen_height =
            tonumber(
                first_size.y
                or first_size.height
                or first_size[2]
            )
    end

    if not screen_width
        or not screen_height
        or screen_width <= 0
        or screen_height <= 0 then

        ui.control.runtime.fov_circle_status =
            "Invalid screen size"

        return
    end

    local radius =
        ui.control.calculate_fov_circle_radius(
            screen_width,
            screen_height,
            settings.fov
        ) *
        ui.control.clamp(
            settings.fov_circle_scale,
            0.50,
            1.35
        )

    radius =
        ui.control.clamp(
            radius,
            4.0,
            math.sqrt(
                screen_width * screen_width +
                screen_height * screen_height
            ) * 0.48
        )

    ui.control.runtime.fov_circle_radius =
        radius

    local aim_palette =
        ui.control.get_aim_v2_visual_palette()

    local has_locked_target =
        ui.control.has_aim_v2_session_target()

    local circle_state = "Idle"

    if has_locked_target then
        circle_state = "Locked"
    elseif ui.control.is_action_key_down() then
        circle_state = "Active"
    elseif ui.control.resolve_active_mode() == 1 then
        circle_state = "Selected"
    end

    local circle_color =
        ui.control.resolve_fov_circle_color(
            settings,
            circle_state == "Locked"
        )

    if not circle_color then
        if circle_state == "Locked" then
            circle_color = aim_palette.locked
        elseif circle_state == "Active" then
            circle_color = aim_palette.active
        elseif circle_state == "Selected" then
            circle_color = aim_palette.setting
        else
            circle_color = aim_palette.idle
        end
    end

    ui.control.runtime.fov_circle_state = circle_state

    local display_color = ui.control.normalize_rgba_color(
        circle_color,
        { 1.0, 1.0, 1.0, 1.0 }
    )

    local render_color,
        filter_compensated,
        color_profile,
        predicted_color,
        color_error =
            ui.control.get_fov_circle_render_color(
                display_color,
                settings
            )

    local draw_red,
        draw_second,
        draw_third,
        draw_order =
            ui.control.get_fov_circle_draw_channels(
                render_color,
                settings
            )

    local center_x =
        math.floor(
            screen_width * 0.5 + 0.5
        )

    local center_y =
        math.floor(
            screen_height * 0.5 + 0.5
        )

    local thickness =
        math.max(
            1,
            math.floor(
                tonumber(
                    settings.fov_circle_thickness
                ) or 1
            )
        )

    local segments =
        math.max(
            24,
            math.floor(
                tonumber(
                    settings.fov_circle_segments
                ) or 80
            )
        )

    local opacity =
        math.floor(
            ui.control.clamp(
                settings.fov_circle_opacity,
                0.15,
                1.0
            ) * 255 + 0.5
        )

    local color_mode = math.max(
        0,
        math.min(
            2,
            math.floor(tonumber(settings.fov_circle_color_mode) or 2)
        )
    )

    if color_mode == 0 then
        if circle_state == "Idle" then
            opacity = math.max(36, math.floor(opacity * 0.62 + 0.5))
        elseif circle_state == "Selected" then
            opacity = math.max(90, math.floor(opacity * 0.78 + 0.5))
        elseif circle_state == "Active" then
            opacity = math.max(180, opacity)
        elseif circle_state == "Locked" then
            opacity = math.max(230, opacity)
            thickness = math.min(5, thickness + 1)
        end
    elseif circle_state == "Locked" then
        thickness = math.min(5, thickness + 1)
    end

    local draw_succeeded = false
    local renderer = "None"

    if settings.fov_circle_glow == true
        and type(draw.line) == "function" then

        local glow_strength =
            ui.control.clamp(
                settings.fov_circle_glow_strength,
                0.0,
                1.0
            )

        for glow_ring = 1, 3 do
            local glow_radius =
                radius +
                thickness * 0.5 +
                glow_ring * 1.35

            local glow_alpha =
                math.max(
                    1,
                    math.floor(
                        opacity *
                        glow_strength *
                        (0.30 / glow_ring) +
                        0.5
                    )
                )

            local previous_x =
                math.floor(center_x + glow_radius + 0.5)

            local previous_y = center_y

            for segment_index = 1, segments do
                local angle =
                    segment_index / segments * math.pi * 2.0

                local next_x =
                    math.floor(
                        center_x +
                        math.cos(angle) * glow_radius +
                        0.5
                    )

                local next_y =
                    math.floor(
                        center_y +
                        math.sin(angle) * glow_radius +
                        0.5
                    )

                pcall(
                    draw.line,
                    previous_x,
                    previous_y,
                    next_x,
                    next_y,
                    draw_red,
                    draw_second,
                    draw_third,
                    glow_alpha
                )

                previous_x = next_x
                previous_y = next_y
            end
        end
    end

    if type(draw.line) == "function" then
        local all_lines_ok = true

        for line_index = 1,
            thickness do

            local ring_radius =
                math.max(
                    2.0,
                    radius +
                    line_index -
                    (thickness + 1) * 0.5
                )

            local previous_x =
                math.floor(
                    center_x + ring_radius + 0.5
                )

            local previous_y =
                center_y

            for segment_index = 1,
                segments do

                local angle =
                    segment_index /
                    segments *
                    math.pi * 2.0

                local next_x =
                    math.floor(
                        center_x +
                        math.cos(angle) * ring_radius +
                        0.5
                    )

                local next_y =
                    math.floor(
                        center_y +
                        math.sin(angle) * ring_radius +
                        0.5
                    )

                local line_ok,
                    line_result =
                        pcall(
                            draw.line,
                            previous_x,
                            previous_y,
                            next_x,
                            next_y,
                            draw_red,
                            draw_second,
                            draw_third,
                            opacity
                        )

                if not line_ok
                    or line_result == false then

                    all_lines_ok = false
                    break
                end

                previous_x = next_x
                previous_y = next_y
            end

            if not all_lines_ok then
                break
            end
        end

        if all_lines_ok then
            draw_succeeded = true
            renderer = "Compatibility lines"
        end
    end

    if not draw_succeeded then
        local circle_function =
            type(draw.outlined_circle) == "function"
            and draw.outlined_circle
            or draw.circle

        if type(circle_function) == "function" then
            for line_index = 1,
                thickness do

                local offset =
                    line_index -
                    (thickness + 1) * 0.5

                local circle_ok,
                    circle_result =
                        pcall(
                            circle_function,
                            center_x,
                            center_y,
                            math.floor(
                                math.max(
                                    2.0,
                                    radius + offset
                                ) + 0.5
                            ),
                            segments,
                            draw_red,
                            draw_second,
                            draw_third,
                            opacity
                        )

                if circle_ok
                    and circle_result ~= false then

                    draw_succeeded = true
                end
            end

            if draw_succeeded then
                renderer = "Native circle"
            end
        end
    end

    if settings.fov_circle_center_dot
        and type(draw.line) == "function" then

        pcall(
            draw.line,
            center_x - 4,
            center_y,
            center_x + 4,
            center_y,
            draw_red,
            draw_second,
            draw_third,
            opacity
        )

        pcall(
            draw.line,
            center_x,
            center_y - 4,
            center_x,
            center_y + 4,
            draw_red,
            draw_second,
            draw_third,
            opacity
        )
    elseif settings.fov_circle_center_dot
        and type(draw.rect) == "function" then

        pcall(
            draw.rect,
            center_x - 1,
            center_y - 1,
            3,
            3,
            draw_red,
            draw_second,
            draw_third,
            opacity
        )
    end

    ui.control.runtime.fov_circle_renderer =
        renderer

    ui.control.runtime.fov_circle_render_stage =
        "Paint - " .. tostring(draw_order or "Direct RGB")

    ui.control.runtime.fov_circle_status =
        draw_succeeded
        and (
            "Visible - " ..
            tostring(math.floor(radius + 0.5)) ..
            " px | " ..
            tostring(ui.control.runtime.fov_circle_state or "Idle") ..
            " | " .. ui.control.color_to_hex(display_color) ..
            " | " .. tostring(draw_order or "Direct RGB")
        )
        or "Draw call failed"
end

