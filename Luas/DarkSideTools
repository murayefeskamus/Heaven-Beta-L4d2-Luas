function ui.control.get_target_point_position(
    player,
    target_point,
    incapacitated,
    settings
)
    local origin =
        ui.lobby.call_method(
            player,
            "get_origin"
        )

    local eye_position =
        ui.lobby.call_method(
            player,
            "get_eye_position"
        )

    if not origin then
        return nil
    end

    if not eye_position then
        return origin
    end

    target_point =
        math.max(
            0,
            math.min(
                2,
                math.floor(
                    tonumber(target_point) or 0
                )
            )
        )

    if incapacitated
        and settings
        and settings.incapacitated_center_mass == true then

        target_point = 2
    end

    if target_point == 0 then
        return eye_position
    end

    local height_factor =
        target_point == 1
        and 0.68
        or 0.45

    return vector.new(
        origin.x +
            (eye_position.x - origin.x) * height_factor,
        origin.y +
            (eye_position.y - origin.y) * height_factor,
        origin.z +
            (eye_position.z - origin.z) * height_factor
    )
end

