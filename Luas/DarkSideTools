function ui.network.read_server_region_status_probe(address)
    address =
        tostring(address or "")

    if address == ""
        or type(io) ~= "table"
        or type(io.open) ~= "function" then

        return ""
    end

    local path =
        ui.network.get_server_region_status_probe_path()

    local file_ok,
        file =
            pcall(
                io.open,
                path,
                "rb"
            )

    if not file_ok
        or not file then

        return ""
    end

    local read_ok,
        content =
            pcall(
                function()
                    return file:read("*a")
                end
            )

    pcall(
        function()
            file:close()
        end
    )

    if not read_ok then
        return ""
    end

    local hostname =
        ui.network.extract_hostname_from_status_text(
            content
        )

    if hostname ~= "" then
        ui.network.server_region_status_hostname = hostname
        ui.network.server_region_status_address = address
        ui.network.server_region_status_last_error = ""
    end

    return hostname
end

function ui.network.start_server_region_status_probe(address)
    address =
        tostring(address or "")

    if address == ""
        or type(client) ~= "table"
        or type(client.execnormal) ~= "function" then

        return false
    end

    local path =
        ui.network.get_server_region_status_probe_path()

    if type(os) == "table"
        and type(os.remove) == "function" then

        pcall(
            os.remove,
            path
        )
    end

    local previous_logfile =
        ui.network.safe_get_cvar_string(
            "con_logfile"
        )

    local restore_target =
        previous_logfile ~= ""
        and previous_logfile
        or ""

    local command =
        "con_logfile " ..
        ui.network.console_quote(path) ..
        "; status; con_logfile " ..
        ui.network.console_quote(restore_target)

    local command_ok =
        pcall(
            client.execnormal,
            command
        )

    if command_ok then
        ui.network.server_region_status_probe_active = true
        ui.network.server_region_status_probe_started_at =
            os.clock()
        ui.network.server_region_status_address = address
        ui.network.server_region_status_last_error = ""
        return true
    end

    ui.network.server_region_status_last_error =
        "Status command failed."

    return false
end

function ui.network.get_status_server_hostname(address)
    address =
        tostring(address or "")

    if address == ""
        or address == "Unknown"
        or address == "CONNECTED SERVER" then

        ui.network.server_region_status_probe_active = false
        ui.network.server_region_status_hostname = ""
        ui.network.server_region_status_address = ""
        return ""
    end

    local now =
        os.clock()

    if ui.network.server_region_status_address == address then
        local cached_hostname =
            tostring(
                ui.network.server_region_status_hostname or ""
            )

        if cached_hostname ~= "" then
            return cached_hostname
        end
    end

    if ui.network.server_region_status_probe_active == true then
        local probe_age =
            now -
            (
                tonumber(
                    ui.network.server_region_status_probe_started_at
                ) or 0.0
            )

        if probe_age >= 0.20 then
            local hostname =
                ui.network.read_server_region_status_probe(
                    address
                )

            if hostname ~= "" then
                ui.network.server_region_status_probe_active = false
                ui.network.server_region_status_next_probe =
                    now +
                    math.max(
                        10.0,
                        tonumber(
                            ui.network.server_region_status_probe_interval
                        ) or 30.0
                    )

                return hostname
            end
        end

        if probe_age < 2.50 then
            return ""
        end

        ui.network.server_region_status_probe_active = false
        ui.network.server_region_status_last_error =
            "Status hostname unavailable."
        ui.network.server_region_status_next_probe =
            now +
            math.max(
                10.0,
                tonumber(
                    ui.network.server_region_status_probe_interval
                ) or 30.0
            )
    end

    local next_probe =
        tonumber(
            ui.network.server_region_status_next_probe
        ) or 0.0

    if now >= next_probe then
        ui.network.server_region_status_next_probe =
            now +
            math.max(
                10.0,
                tonumber(
                    ui.network.server_region_status_probe_interval
                ) or 30.0
            )

        ui.network.start_server_region_status_probe(
            address
        )
    end

    return ""
end

function ui.network.get_cached_server_hostname(address)
    address =
        tostring(address or "")

    if address == ""
        or address == "Unknown"
        or address == "CONNECTED SERVER" then

        ui.network.server_region_hostname = ""
        ui.network.server_region_hostname_address = ""
        return ""
    end

    local now =
        os.clock()

    local next_probe =
        tonumber(
            ui.network.server_region_hostname_next_probe
        ) or 0.0

    if ui.network.server_region_hostname_address == address
        and now < next_probe then

        local cached_hostname =
            tostring(
                ui.network.server_region_hostname or ""
            )

        local status_hostname =
            ui.network.get_status_server_hostname(
                address
            )

        if status_hostname ~= "" then
            ui.network.server_region_hostname = status_hostname
            return status_hostname
        end

        return cached_hostname
    end

    ui.network.server_region_hostname_address = address
    ui.network.server_region_hostname_next_probe =
        now +
        math.max(
            1.0,
            math.min(
                10.0,
                tonumber(
                    ui.network.server_region_hostname_probe_interval
                ) or 2.0
            )
        )

    local status_hostname =
        ui.network.get_status_server_hostname(
            address
        )

    local cvar_hostname =
        ui.network.safe_get_cvar_string(
            "hostname"
        )

    cvar_hostname =
        ui.network.normalize_server_hostname_text(
            cvar_hostname
        )

    local hostname =
        status_hostname ~= ""
        and status_hostname
        or cvar_hostname

    ui.network.server_region_hostname = hostname

    return hostname
end

