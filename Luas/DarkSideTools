function ui.window_master.handle_key()
    if ui.window_master.enabled ~= true
        or ui.input_safety.block_runtime_hotkeys()
        or type(input) ~= "table"
        or type(input.is_key_down) ~= "function" then

        ui.window_master.key_was_down = false
        return false
    end

    if type(ui.keybinds) == "table"
        and type(ui.keybinds.capture) == "table"
        and tostring(
            ui.keybinds.capture.id or ""
        ) ~= "" then

        local capture_key_ok,
            capture_key_down =
                pcall(
                    input.is_key_down,
                    ui.window_master.toggle_key
                )

        ui.window_master.key_was_down =
            capture_key_ok
            and capture_key_down == true

        return false
    end

    local key_ok,
        key_down =
            pcall(
                input.is_key_down,
                ui.window_master.toggle_key
            )

    key_down =
        key_ok
        and key_down == true

    if ui.window_master.suppress_until_release == true then
        ui.window_master.key_was_down = key_down

        if not key_down then
            ui.window_master.suppress_until_release = false
        end

        return false
    end

    if key_down
        and ui.window_master.key_was_down ~= true then

        ui.window_master.toggle_all_views()
    end

    ui.window_master.key_was_down = key_down
    return key_down
end

