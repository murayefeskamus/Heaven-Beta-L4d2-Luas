                    section_blue =
                        ui.get_theme_table_title_color(
                            section_name,
                            section_slots[section_name]
                            or 1
                        )

                draw_at(
                    row_state,
                    label_x,
                    row.section,
                    section_red,
                    section_green,
                    section_blue
                )

                return
            end

            draw_at(
                row_state,
                label_x,
                row.label,
                0.75, 0.75, 0.78
            )

            draw_at(
                row_state,
                divider_x,
                "|",
                0.42, 0.42, 0.44
            )

            if is_left
                and row.special == "population" then

                draw_at(
                    row_state,
                    value_x,
                    "Players:",
                    1.0, 1.0, 1.0
                )

                draw_fragment(
                    row_state,
                    tostring(overview.humans or 0),
                    0.20, 1.0, 0.20
                )

                draw_fragment(
                    row_state,
                    "| Bots:",
                    1.0, 1.0, 1.0
                )

                draw_fragment(
                    row_state,
                    tostring(overview.bots or 0),
                    0.20, 1.0, 0.20
                )
            elseif is_left
                and row.special == "status" then

                draw_at(
                    row_state,
                    value_x,
                    "Alive:",
                    1.0, 1.0, 1.0
                )

                draw_fragment(
                    row_state,
                    tostring(overview.alive or 0),
                    0.20, 1.0, 0.20
                )

                draw_fragment(
                    row_state,
                    "| Dead:",
                    1.0, 1.0, 1.0
                )

                draw_fragment(
                    row_state,
                    tostring(overview.dead or 0),
                    1.0, 0.35, 0.35
                )
            else
                local value_color =
                    type(row.color) == "table"
                    and row.color
                    or { 1.0, 1.0, 1.0 }

                draw_at(
                    row_state,
                    value_x,
                    row.value,
                    value_color[1],
                    value_color[2],
                    value_color[3]
                )
            end
        end

        for row_index = 1, row_count do
            local row_state = {
                started = false
            }

            draw_side(
                row_state,
                left_rows[row_index],
                8,
                left_label_width,
                left_label_width + 12,
                true
            )

            draw_at(
                row_state,
                center_divider_x,
                "|",
                0.42, 0.42, 0.44
            )

            draw_side(
                row_state,
                right_rows[row_index],
                right_label_x,
                right_divider_x,
                right_value_x,
                false
            )

            imgui.separator()
        end
    end

    imgui.end_child()
    ui.lobby.compact_after_child(4)

    return table_width
end

