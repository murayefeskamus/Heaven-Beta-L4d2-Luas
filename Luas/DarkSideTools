function ui.command_response_owner_lock.enforce_permission_defaults()
    if type(ui.enhancements) ~= "table"
        or type(ui.enhancements.command_control) ~= "table"
        or type(ui.enhancements.command_control.permissions) ~= "table" then

        return
    end

    local permissions =
        ui.enhancements.command_control.permissions

    local legacy_keys = {
        "serverinfo",
        "playerinfo",
        "team_surv",
        "team_inf",
        "zombieclass",
        "zombieclasses",
        "savedmatches"
    }

    local legacy_forced_state = true

    for _, command_key in ipairs(
        legacy_keys
    ) do
        local permission =
            permissions[command_key]

        if type(permission) ~= "table"
            or permission.enabled ~= true
            or permission.lua_only ~= true
            or permission.everyone == true
            or permission.same_team == true then

            legacy_forced_state = false
            break
        end
    end

    if not legacy_forced_state then
        return
    end

    local sensible_defaults = {
        serverinfo = {
            everyone = true,
            same_team = false,
            lua_only = false
        },
        playerinfo = {
            everyone = true,
            same_team = false,
            lua_only = false
        },
        team_surv = {
            everyone = true,
            same_team = false,
            lua_only = false
        },
        team_inf = {
            everyone = false,
            same_team = true,
            lua_only = false
        },
        zombieclass = {
            everyone = false,
            same_team = true,
            lua_only = false
        },
        zombieclasses = {
            everyone = false,
            same_team = true,
            lua_only = false
        },
        savedmatches = {
            everyone = false,
            same_team = false,
            lua_only = true
        }
    }

    for command_key,
        access in pairs(
            sensible_defaults
        ) do

        local permission =
            permissions[command_key]

        if type(permission) == "table" then
            permission.enabled = true
            permission.everyone =
                access.everyone == true
            permission.same_team =
                access.same_team == true
            permission.lua_only =
                access.lua_only == true
        end
    end
end

