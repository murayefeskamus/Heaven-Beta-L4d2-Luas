function name_reverser.infer_name_case_label(name)
    local core_name =
        strip_known_name_decorations(
            name
        )

    local letters = {}
    local all_upper = true
    local all_lower = true

    for index = 1, #core_name do
        local character =
            core_name:sub(
                index,
                index
            )

        local byte_value =
            character:byte()

        if byte_value
            and (
                (
                    byte_value >= string.byte("A")
                    and byte_value <= string.byte("Z")
                )
                or (
                    byte_value >= string.byte("a")
                    and byte_value <= string.byte("z")
                )
            ) then

            table.insert(
                letters,
                character
            )

            if character ~= character:upper() then
                all_upper = false
            end

            if character ~= character:lower() then
                all_lower = false
            end
        end
    end

    if #letters == 0 then
        return "Original"
    end

    if all_upper then
        return "UPPERCASE"
    end

    if all_lower then
        return "lowercase"
    end

    local alternating_upper = true
    local alternating_lower = true

    for index, character in ipairs(
        letters
    ) do
        local should_be_upper =
            index % 2 == 1

        if should_be_upper then
            if character ~= character:upper() then
                alternating_upper = false
            end

            if character ~= character:lower() then
                alternating_lower = false
            end
        else
            if character ~= character:lower() then
                alternating_upper = false
            end

            if character ~= character:upper() then
                alternating_lower = false
            end
        end
    end

    if alternating_upper then
        return "Alternating - Upper first"
    end

    if alternating_lower then
        return "Alternating - Lower first"
    end

    return "Mixed"
end

function spammer_runtime.get_current_name_details(
    current_name,
    current_layout
)
    local clean_current_name =
        clean_name_for_reverse(
            current_name
