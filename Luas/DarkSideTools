function post_to_all_chat_immediately(
    message,
    preserve_double_quotes
)
    if not message or message == "" then
        return false
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        return false
    end

    if preserve_double_quotes == true then


        local raw_message =
            tostring(message):gsub("[\r\n;]", " ")

        client.execnormal(
            "say " .. raw_message
        )

        return true
    end

    local outgoing_message =
        prepare_for_chat(message)

    client.execnormal(
        'say "' .. outgoing_message .. '"'
    )

    return true
end

