                palette.button_active
            },
            4.5
        )

    ui.performance.theme_palette_cache = palette
    ui.performance.theme_palette_signature =
        palette_signature

    ui.enhancements.publish_theme_bridge(
        palette,
        palette_signature
    )

    return palette
end

function ui.enhancements.push_theme_color(index, color)
    if type(imgui.push_style_color) ~= "function" then
        return false
    end

    local ok =
        pcall(
            imgui.push_style_color,
            index,
            color[1],
            color[2],
            color[3],
            color[4] or 1.0
        )

    if ok then
        ui.enhancements.theme.pushed_colors =
            ui.enhancements.theme.pushed_colors + 1
    end

    return ok
end

function ui.enhancements.apply_theme()
    local theme =
        ui.enhancements.theme

    theme.pushed_colors = 0

    local palette =
        ui.enhancements.theme_palette()

    local style_colors = {
        { 0, palette.text },
        { 1, palette.text_disabled },
        { 2, palette.background },
        { 3, palette.child },
        { 4, palette.popup },
        { 5, palette.border },
        { 6, { 0.0, 0.0, 0.0, 0.0 } },
        { 7, palette.frame },
        { 8, palette.frame_hovered },
        { 9, palette.frame_active },
        { 10, palette.title },
        { 11, palette.title_active },
        { 12, palette.title },
        { 13, palette.menubar },
        { 14, palette.scrollbar_bg },
        { 15, palette.scrollbar_grab },
        { 16, palette.scrollbar_hovered },
        { 17, palette.scrollbar_active },
        { 18, palette.checkmark },
        { 19, palette.slider },
        { 20, palette.slider_active },
        { 21, palette.button },
        { 22, palette.button_hovered },
        { 23, palette.button_active },
        { 24, palette.header },
        { 25, palette.header_hovered },
        { 26, palette.header_active },
        { 27, palette.separator },
        { 28, palette.separator_hovered },
        { 29, palette.separator_active },
        { 30, palette.resize },
        { 31, palette.resize_hovered },
        { 32, palette.resize_active },
        { 33, palette.tab },
        { 34, palette.tab_hovered },
        { 35, palette.tab_active },
        { 36, palette.tab_unfocused },
        { 37, palette.tab_unfocused_active }
    }

    for _, style_entry in ipairs(
        style_colors
    ) do
        ui.enhancements.push_theme_color(
            style_entry[1],
            style_entry[2]
        )
    end

    local requested_scale = 1.0

    if theme.font_preset_index == 1 then
        requested_scale = 0.88
    elseif theme.font_preset_index == 2 then
        requested_scale = 1.18
    elseif theme.font_preset_index == 3 then
        requested_scale =
            math.max(
                0.70,
                math.min(
                    1.50,
                    tonumber(theme.font_scale) or 1.0
                )
            )
    end

    if type(imgui.set_window_font_scale) == "function" then
        pcall(
            imgui.set_window_font_scale,
            requested_scale
        )
    elseif requested_scale ~= 1.0
        and not theme.warned_font_scale then

        theme.warned_font_scale = true
    end
end

function ui.enhancements.pop_theme()
    local count =
        math.max(
            0,
            math.floor(
                tonumber(
                    ui.enhancements.theme.pushed_colors
                ) or 0
            )
        )

    if count > 0
        and type(imgui.pop_style_color) == "function" then

        for _ = 1, count do
            pcall(
                imgui.pop_style_color
            )
        end
    end

    if type(imgui.set_window_font_scale) == "function" then
        pcall(
            imgui.set_window_font_scale,
            1.0
        )
    end

    ui.enhancements.theme.pushed_colors = 0
end

function ui.enhancements.draw_rgb_editor(
    label,
    color,
    unique_id
)
    imgui.text(
        tostring(label) .. ":"
    )

    local changed_any = false

    local channel_labels = {
        "R:",
        "G:",
        "B:"
    }

    for channel = 1, 3 do
        if channel > 1 then
            imgui.same_line()
        end

        local channel_colors = {
            { 1.0, 0.20, 0.20 },
            { 0.20, 1.0, 0.20 },
            { 0.25, 0.55, 1.0 }
        }

        local channel_color =
            channel_colors[channel]

        imgui.text_colored(
            channel_color[1],
            channel_color[2],
            channel_color[3],
            1.0,
            channel_labels[channel]
        )

        imgui.same_line()
        imgui.push_item_width(92)

        local changed,
            value =
                imgui.slider_float(
                    "##" ..
                        tostring(unique_id) ..
                        tostring(channel),
                    tonumber(color[channel]) or 0.0,
                    0.0,
                    1.0
                )

        imgui.pop_item_width()

        if changed then
            color[channel] =
                math.max(
                    0.0,
                    math.min(
                        1.0,
                        value
                    )
                )

            changed_any = true
        end
    end

    return changed_any
end

function ui.enhancements.draw_theme_settings()
    local theme =
        ui.enhancements.theme

    theme.expanded =
        draw_collapsible_section(
            "THEME AND APPEARANCE",
            theme.expanded,
            "AdvancedTheme"
        )

    if not theme.expanded then
        return
    end

    local theme_controls_x =
        ui.lobby.get_aligned_control_x(
            {
                "Theme:",
                "Font preset:",
                "Font scale:",
                "Override target:"
            },
            10
        )

    imgui.text("Theme:")
    imgui.same_line()

    ui.lobby.set_cursor_x(
        theme_controls_x
    )

    imgui.push_item_width(230)

    local neutral_theme_colors =
        push_neutral_combo_colors()

    local changed_theme,
        theme_value =
            imgui.combo(
                "##AdvancedThemePreset",
                theme.theme_index,
                theme.themes
            )

    pop_neutral_combo_colors(
        neutral_theme_colors
    )

    imgui.pop_item_width()

    if changed_theme then
        theme.theme_index =
            theme_value
    end

    local preset =
        ui.enhancements.get_theme_preset(
            theme.theme_index
        )

    local palette =
        ui.enhancements.theme_palette()

    theme_text_colored(
        palette.text_disabled[1],
        palette.text_disabled[2],
        palette.text_disabled[3],
        1.0,
        tostring(
            preset.description or
            palette.description or
            ""
        )
    )
    draw_compact_gap()

    imgui.text("Font preset:")
    imgui.same_line()

    ui.lobby.set_cursor_x(
        theme_controls_x
    )

    imgui.push_item_width(230)

    local neutral_font_colors =
        push_neutral_combo_colors()

    local changed_font,
        font_value =
            imgui.combo(
                "##AdvancedFontPreset",
                theme.font_preset_index,
                theme.font_presets
            )

    pop_neutral_combo_colors(
        neutral_font_colors
    )

    imgui.pop_item_width()

    if changed_font then
        theme.font_preset_index =
            font_value
    end

    if theme.font_preset_index == 3 then
        imgui.text("Custom font scale:")
        imgui.same_line()

        ui.lobby.set_cursor_x(
            theme_controls_x
        )

        imgui.push_item_width(230)

        local changed_scale,
            scale_value =
                imgui.slider_float(
                    "##AdvancedFontScale",
                    theme.font_scale,
                    0.70,
                    1.50
                )

        imgui.pop_item_width()

        if changed_scale then
            theme.font_scale =
                scale_value
        end
    end

    draw_compact_gap()

    theme_text_colored(
        palette.section_text[1],
        palette.section_text[2],
        palette.section_text[3],
        1.0,
        "SELECTED THEME COLORS"
    )

    local editor =
        ui.enhancements.get_theme_editor_core(
            theme.theme_index
        )

    local colors_changed = false

    colors_changed =
        ui.enhancements.draw_rgb_editor(
            "Accent",
            editor.accent,
            "SelectedThemeAccent"
        ) or colors_changed

    colors_changed =
        ui.enhancements.draw_rgb_editor(
            "Background",
            editor.background,
            "SelectedThemeBackground"
        ) or colors_changed

    colors_changed =
        ui.enhancements.draw_rgb_editor(
            "Panel / table",
            editor.child,
            "SelectedThemePanel"
        ) or colors_changed

    colors_changed =
        ui.enhancements.draw_rgb_editor(
            "Controls",
            editor.button,
            "SelectedThemeControls"
        ) or colors_changed

    colors_changed =
        ui.enhancements.draw_rgb_editor(
            "Text",
            editor.text,
            "SelectedThemeText"
        ) or colors_changed

    if colors_changed then
        ui.enhancements.commit_theme_editor(
            theme.theme_index
        )
    end

    local has_customization =
        ui.enhancements.theme_has_customization(
            theme.theme_index
        )

    if has_customization then
        local restore_background =
            palette.active_tab or
            palette.accent or
            palette.button

        local restore_text =
            palette.active_tab_text or
            palette.text

        if colored_button(
            "Restore Selected Theme",
            restore_text[1],
            restore_text[2],
            restore_text[3],
            restore_background[1],
            restore_background[2],
            restore_background[3]
        ) then
            ui.enhancements.restore_selected_theme(
                theme.theme_index
            )
        end
    else
        disabled_button(
            "Restore Selected Theme"
        )
    end

    imgui.same_line()

    theme_text_colored(
        palette.text_disabled[1],
        palette.text_disabled[2],
        palette.text_disabled[3],
        1.0,
        has_customization
            and "Modified colors are saved in DSTsettings."
            or "Using the verified default palette."
    )


end

