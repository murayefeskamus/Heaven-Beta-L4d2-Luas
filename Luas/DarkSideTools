        tostring(slot_index or "auto")

    return ui.performance.memoize_values(
        "theme_table_title_colors",
        cache_key,
        function()
            local function clamp(value)
                return math.max(
                    0.0,
                    math.min(
                        1.0,
                        tonumber(value) or 0.0
                    )
                )
            end

            local function luminance(color)
                local function channel(value)
                    value = clamp(value)

                    if value <= 0.03928 then
                        return value / 12.92
                    end

                    return (
                        (value + 0.055) / 1.055
                    ) ^ 2.4
                end

                return
                    channel(color[1]) * 0.2126 +
                    channel(color[2]) * 0.7152 +
                    channel(color[3]) * 0.0722
            end

            local function contrast(first, second)
                local first_luminance =
                    luminance(first)

                local second_luminance =
                    luminance(second)

                local brighter =
                    math.max(
                        first_luminance,
                        second_luminance
                    )

                local darker =
                    math.min(
                        first_luminance,
                        second_luminance
                    )

                return
                    (brighter + 0.05) /
                    (darker + 0.05)
            end

            local function distance(first, second)
                local red =
                    clamp(first[1]) -
                    clamp(second[1])

                local green =
                    clamp(first[2]) -
                    clamp(second[2])

                local blue =
                    clamp(first[3]) -
                    clamp(second[3])

                return math.sqrt(
                    red * red +
                    green * green +
                    blue * blue
                )
            end

            local function rgb_to_hsv(red, green, blue)
                red = clamp(red)
                green = clamp(green)
                blue = clamp(blue)

                local maximum =
                    math.max(red, green, blue)

                local minimum =
                    math.min(red, green, blue)

                local delta =
                    maximum - minimum

                local hue = 0.0

                if delta > 0.0001 then
                    if maximum == red then
                        hue =
                            ((green - blue) / delta) % 6
                    elseif maximum == green then
                        hue =
                            (blue - red) / delta + 2
                    else
                        hue =
                            (red - green) / delta + 4
                    end

                    hue =
                        (hue / 6) % 1
                end

                local saturation =
                    maximum <= 0.0001
                    and 0.0
                    or delta / maximum

                return hue,
                    saturation,
                    maximum
            end

            local function hsv_to_rgb(hue, saturation, value)
                hue =
                    (tonumber(hue) or 0.0) % 1

                saturation = clamp(saturation)
                value = clamp(value)

                local scaled = hue * 6
                local sector = math.floor(scaled)
                local fraction = scaled - sector
                local p = value * (1 - saturation)
                local q = value * (1 - fraction * saturation)
                local t = value * (1 - (1 - fraction) * saturation)

                sector = sector % 6

                if sector == 0 then
                    return { value, t, p }
                elseif sector == 1 then
                    return { q, value, p }
                elseif sector == 2 then
                    return { p, value, t }
                elseif sector == 3 then
                    return { p, q, value }
                elseif sector == 4 then
                    return { t, p, value }
                end

                return { value, p, q }
            end

            local background =
                type(palette.child) == "table"
                and palette.child
                or (
                    type(palette.background) == "table"
                    and palette.background
                    or { 0.08, 0.08, 0.09 }
                )

            local section_color =
                type(palette.section_text) == "table"
                and palette.section_text
                or (
                    type(palette.accent_text) == "table"
                    and palette.accent_text
                    or { 0.90, 0.68, 0.20 }
                )

            local accent =
                type(palette.accent) == "table"
                and palette.accent
                or section_color

            local base_hue =
                rgb_to_hsv(
                    accent[1],
                    accent[2],
                    accent[3]
                )

            local hash = 0

            for index = 1, #title_value do
                hash =
                    (
                        hash * 33 +
                        title_value:byte(index)
                    ) % 104729
            end

            local offsets = {
                0.34,
                0.56,
                0.16,
                0.76,
                0.91,
                0.45,
                0.66
            }

            local resolved_slot =
                math.max(
                    1,
                    math.floor(
                        tonumber(slot_index) or
                        (hash % #offsets) + 1
                    )
                )

            local hue =
                (
                    base_hue +
                    offsets[
                        ((resolved_slot - 1) % #offsets) + 1
                    ] +
                    (hash % 17) / 360
                ) % 1

            local is_light =
                palette.light == true
                or luminance(background) > 0.52

            local saturation =
                is_light
                and 0.82
                or 0.72

            local value =
                is_light
                and 0.46
                or 0.96

            local candidate =
                hsv_to_rgb(
                    hue,
                    saturation,
                    value
                )

            if distance(
                candidate,
                section_color
            ) < 0.30 then

                hue =
                    (hue + 0.37) % 1

                candidate =
                    hsv_to_rgb(
                        hue,
                        saturation,
                        value
                    )
            end

            local attempts = 0

            while contrast(
                candidate,
                background
            ) < 4.0
                and attempts < 10 do

                attempts = attempts + 1

                if is_light then
                    value =
                        math.max(
                            0.18,
                            value - 0.04
                        )
                else
                    value =
                        math.min(
                            1.0,
                            value + 0.02
                        )

                    saturation =
                        math.max(
                            0.48,
                            saturation - 0.025
                        )
                end

                candidate =
                    hsv_to_rgb(
                        hue,
                        saturation,
                        value
                    )
            end

            if distance(
                candidate,
                section_color
            ) < 0.22 then

                candidate =
                    hsv_to_rgb(
                        (hue + 0.50) % 1,
                        saturation,
                        value
                    )
            end

            return
                clamp(candidate[1]),
                clamp(candidate[2]),
                clamp(candidate[3])
        end,
        192
    )
end

