function ui.enhancements.publish_theme_bridge(
    palette,
    palette_signature
)
    if type(palette) ~= "table" then
        return false
    end

    local theme =
        ui.enhancements.theme

    local theme_index =
        math.floor(
            tonumber(
                theme.theme_index
            ) or 0
        )

    local preset =
        ui.enhancements.get_theme_preset(
            theme_index
        )

    local font_scale = 1.0

    if theme.font_preset_index == 1 then
        font_scale = 0.88
    elseif theme.font_preset_index == 2 then
        font_scale = 1.18
    elseif theme.font_preset_index == 3 then
        font_scale =
            math.max(
                0.70,
                math.min(
                    1.50,
                    tonumber(theme.font_scale) or 1.0
                )
            )
    end

    local resolved_signature =
        tostring(
            palette_signature or
            ui.performance.theme_palette_signature or
            ""
        ) ..
        "|" ..
        string.format(
            "%.4f",
            font_scale
        )

    local existing_bridge =
        _G.__DARK_SIDE_TOOLS_THEME_BRIDGE

    if ui.enhancements.last_theme_bridge_signature ==
        resolved_signature
        and type(existing_bridge) == "table"
        and type(existing_bridge.palette) == "table" then

        return true
    end

    local function copy_bridge_value(
        value
    )
        if type(value) ~= "table" then
            return value
        end

        local copied = {}

        for key,
            nested_value in pairs(value) do

            if type(nested_value) == "table" then
                copied[key] =
                    copy_bridge_value(
                        nested_value
                    )
            else
                copied[key] =
                    nested_value
            end
        end

        return copied
    end

    local bridge =
        _G.__DARK_SIDE_TOOLS_THEME_BRIDGE

    if type(bridge) ~= "table" then
        bridge = {}
    end

    bridge.version = 2
    bridge.theme_index = theme_index
    bridge.theme_name =
        tostring(
            preset.name or
            palette.name or
            "Unknown"
        )
    bridge.theme_count =
        #theme.themes
    bridge.font_scale = font_scale
    bridge.palette =
        copy_bridge_value(
            palette
        )
    bridge.signature =
        resolved_signature
    bridge.updated_at = os.clock()

    _G.__DARK_SIDE_TOOLS_THEME_BRIDGE = bridge

    ui.enhancements.last_theme_bridge_signature =
        bridge.signature

    if type(io) ~= "table"
        or type(io.open) ~= "function" then

        return true
    end

    local open_ok,
        bridge_file =
            pcall(
                io.open,
                "C:\\Heaven-L4D2\\DSTThemeBridge",
                "w"
            )

    if not open_ok
        or not bridge_file then

        return true
    end

    local function serialize_bridge_value(
        value,
        depth
    )
        depth =
            math.max(
                0,
                math.floor(
                    tonumber(depth) or 0
                )
            )

        local value_type =
            type(value)

        if value_type == "number" then
            return string.format(
                "%.9g",
                value
            )
        elseif value_type == "boolean" then
            return value
                and "true"
                or "false"
        elseif value_type == "string" then
            return string.format(
                "%q",
                value
            )
        elseif value_type ~= "table" then
            return "nil"
        end

        local keys = {}

        for key in pairs(value) do
            keys[#keys + 1] = key
        end

        table.sort(
            keys,
            function(first, second)
                if type(first) == type(second) then
                    return tostring(first) < tostring(second)
                end

                return type(first) < type(second)
            end
        )

        local indent =
            string.rep(
                "    ",
                depth
            )

        local child_indent =
            string.rep(
                "    ",
                depth + 1
            )

        local parts = {
            "{"
        }

        for _, key in ipairs(keys) do
            local key_text = nil

            if type(key) == "number" then
                key_text =
                    "[" ..
                    tostring(key) ..
                    "]"
            else
                key_text =
                    "[" ..
                    string.format(
                        "%q",
                        tostring(key)
                    ) ..
                    "]"
            end

            parts[#parts + 1] =
                "\n" ..
                child_indent ..
                key_text ..
                " = " ..
                serialize_bridge_value(
                    value[key],
                    depth + 1
                ) ..
                ","
        end

        parts[#parts + 1] =
            "\n" ..
            indent ..
            "}"

        return table.concat(parts)
    end

    pcall(
        function()
            bridge_file:write(
                "return ",
                serialize_bridge_value(
                    bridge,
                    0
                ),
                "\n"
            )
        end
    )

    pcall(
        function()
            bridge_file:close()
        end
    )

    return true
end

function ui.enhancements.theme_palette()
    if ui.performance.palette_frame_lock == true
        and type(
            ui.performance.theme_palette_cache
        ) == "table" then

        return ui.performance.theme_palette_cache
    end

    local theme =
        ui.enhancements.theme

    local cache_now = os.clock()

    if ui.performance.theme_palette_cache ~= nil
        and cache_now <
            (tonumber(
                ui.performance.next_theme_palette_check
            ) or 0.0) then

        ui.enhancements.publish_theme_bridge(
            ui.performance.theme_palette_cache,
            ui.performance.theme_palette_signature
        )

        return ui.performance.theme_palette_cache
    end

    local function append_signature_color(
        parts,
        color
    )
        color =
            type(color) == "table"
            and color
            or {}

        parts[#parts + 1] = string.format(
            "%.4f,%.4f,%.4f,%.4f",
            tonumber(color[1]) or 0.0,
            tonumber(color[2]) or 0.0,
            tonumber(color[3]) or 0.0,
            tonumber(color[4]) or 1.0
        )
    end

    local signature_parts = {
        tostring(
            math.floor(
                tonumber(theme.theme_index) or 0
            )
        )
    }

    local signature_preset =
        ui.enhancements.get_theme_preset(
            theme.theme_index
        )

    if signature_preset.custom == true then
        signature_parts[#signature_parts + 1] = "custom"

        append_signature_color(
            signature_parts,
            theme.custom.accent
        )

        append_signature_color(
            signature_parts,
            theme.custom.background
        )

        append_signature_color(
            signature_parts,
            theme.custom.table
        )

        append_signature_color(
            signature_parts,
            theme.custom.button
        )

        append_signature_color(
            signature_parts,
            theme.custom.text
        )
    else
        local signature_key =
            ui.enhancements.get_theme_override_key(
                theme.theme_index
            )

        local signature_override =
            theme.overrides[
                signature_key
            ]

        if type(signature_override) == "table" then
            signature_parts[#signature_parts + 1] = "override"

            for _, field_name in ipairs({
                "accent",
                "background",
                "child",
                "button",
                "text"
            }) do
                append_signature_color(
                    signature_parts,
                    signature_override[field_name]
                )
            end
        else
            signature_parts[#signature_parts + 1] = "default"
        end
    end

    local palette_signature =
        table.concat(
            signature_parts,
            "|"
        )

    ui.performance.next_theme_palette_check =
        cache_now + 0.10

    if ui.performance.theme_palette_cache ~= nil
        and palette_signature ==
            ui.performance.theme_palette_signature then

        ui.enhancements.publish_theme_bridge(
            ui.performance.theme_palette_cache,
            palette_signature
        )

        return ui.performance.theme_palette_cache
    end

    local function clamp(
        value
    )
        return math.max(
            0.0,
            math.min(
                1.0,
                tonumber(value) or 0.0
            )
        )
    end

    local function copy_palette(
        source_palette
    )
        local result = {}

        for key, value in pairs(
            source_palette or {}
        ) do
            if type(value) == "table" then
                result[key] =
                    ui.enhancements.copy_theme_color(
                        value
                    )
            else
                result[key] =
                    value
            end
        end

        return result
    end

    local function mix(
        first,
        second,
        amount
    )
        amount =
            clamp(amount)

        return {
            clamp(
                first[1] +
                (
                    second[1] -
                    first[1]
                ) * amount
            ),
            clamp(
                first[2] +
                (
                    second[2] -
                    first[2]
                ) * amount
            ),
            clamp(
                first[3] +
                (
                    second[3] -
                    first[3]
                ) * amount
            )
        }
    end

    local function lighten(
        color,
        amount
    )
        return mix(
            color,
            { 1.0, 1.0, 1.0 },
            amount
        )
    end

    local function darken(
        color,
        amount
    )
        return mix(
            color,
            { 0.0, 0.0, 0.0 },
            amount
        )
    end

    local function srgb_to_linear(
        value
    )
        value = clamp(value)

        if value <= 0.04045 then
            return value / 12.92
        end

        return (
            (value + 0.055) / 1.055
        ) ^ 2.4
    end

    local function relative_luminance(
        color
    )
        color =
            type(color) == "table"
            and color
            or { 0.0, 0.0, 0.0 }

        return
            srgb_to_linear(color[1]) * 0.2126 +
            srgb_to_linear(color[2]) * 0.7152 +
            srgb_to_linear(color[3]) * 0.0722
    end

    local function contrast_ratio(
        first,
        second
    )
        local first_luminance =
            relative_luminance(first)

        local second_luminance =
            relative_luminance(second)

        local brighter =
            math.max(
                first_luminance,
                second_luminance
            )

        local darker =
            math.min(
                first_luminance,
                second_luminance
            )

        return
            (brighter + 0.05) /
            (darker + 0.05)
    end

    local function minimum_surface_contrast(
        foreground,
        surfaces
    )
        local minimum = 100.0
        local found_surface = false

        for _, surface in ipairs(
            surfaces or {}
        ) do
            if type(surface) == "table" then
                found_surface = true
                minimum =
                    math.min(
                        minimum,
                        contrast_ratio(
                            foreground,
                            surface
                        )
                    )
            end
        end

        return found_surface
            and minimum
            or 1.0
    end

    local function best_neutral_for_surfaces(
        surfaces
    )
        local dark = {
            0.015,
            0.018,
            0.024
        }

        local light = {
            0.985,
            0.990,
            1.000
        }

        if minimum_surface_contrast(
            dark,
            surfaces
        ) >= minimum_surface_contrast(
            light,
            surfaces
        ) then

            return dark
        end

        return light
    end

    local function ensure_text_contrast(
        foreground,
        surfaces,
        minimum_ratio
    )
        foreground =
            ui.enhancements.copy_theme_color(
                foreground
            )

        minimum_ratio =
            tonumber(minimum_ratio) or 4.5

        if minimum_surface_contrast(
            foreground,
            surfaces
        ) >= minimum_ratio then

            return foreground
        end

        local target =
            best_neutral_for_surfaces(
                surfaces
            )

        for step = 1, 32 do
            local candidate =
                mix(
                    foreground,
                    target,
                    step / 32
                )

            if minimum_surface_contrast(
                candidate,
                surfaces
            ) >= minimum_ratio then

                return candidate
            end
        end

        return target
    end

    local function ensure_surface_contrast(
        surface,
        text_color,
        anchor_surface,
        minimum_ratio
    )
        surface =
            ui.enhancements.copy_theme_color(
                surface
            )

        minimum_ratio =
            tonumber(minimum_ratio) or 4.5

        if contrast_ratio(
            text_color,
            surface
        ) >= minimum_ratio then

            return surface
        end

        anchor_surface =
            type(anchor_surface) == "table"
            and anchor_surface
            or { 0.0, 0.0, 0.0 }

        for step = 1, 28 do
            local candidate =
                mix(
                    surface,
                    anchor_surface,
                    step / 28
                )

            if contrast_ratio(
                text_color,
                candidate
            ) >= minimum_ratio then

                return candidate
            end
        end

        return
            relative_luminance(text_color) >= 0.50
            and { 0.010, 0.012, 0.016 }
            or { 0.985, 0.990, 1.000 }
    end

    local function contrast_text(
        color
    )
        return
            best_neutral_for_surfaces({
                color
            })
    end

    local theme_index =
        math.floor(
            tonumber(
                theme.theme_index
            ) or 0
        )

    local preset =
        ui.enhancements.get_theme_preset(
            theme_index
        )

    local palette = nil

    if preset.custom == true then
        local custom_background =
            ui.enhancements.copy_theme_color(
                theme.custom.background
            )

        local custom_child =
            ui.enhancements.copy_theme_color(
                theme.custom.table
            )

        local custom_button =
            ui.enhancements.copy_theme_color(
                theme.custom.button
            )

        local custom_text =
            ui.enhancements.copy_theme_color(
                theme.custom.text
            )

        local luminance =
            custom_background[1] * 0.2126 +
            custom_background[2] * 0.7152 +
            custom_background[3] * 0.0722

        local is_light =
            luminance >= 0.62

        palette = {
            name = preset.name,
            description = preset.description,
            family = preset.family,
            light = is_light,
            accent =
                ui.enhancements.copy_theme_color(
