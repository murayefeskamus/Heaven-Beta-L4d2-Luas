            bots = 0,
            alive = 0,
            dead = 0,
            kills = 0,
            special_kills = 0,
            common_kills = 0,
            tank_kills = 0,
            witch_kills = 0,
            deaths = 0
        }

    local total =
        (summary.humans or 0) +
        (summary.bots or 0)

