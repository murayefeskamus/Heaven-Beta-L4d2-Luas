            1,
            2
        )

    if prefix ~= "V|"
        and prefix ~= "H|" then

        return "",
            nil
    end

    return spammer_runtime.normalize_name_for_restore_compare(
        applied_key:sub(3)
    ),
        prefix == "V|"
        and "Vertical"
        or "Horizontal"
end

function spammer_runtime.is_initial_horizontal_name_active(
    force_refresh
)
    capture_initial_in_game_name()

    local initial_name =
        spammer_runtime.normalize_name_for_restore_compare(
            initial_in_game_name
        )

    if initial_name == ""
        or initial_name:find(
            "[\r\n]"
        ) then

        spammer_runtime.restore_name_disabled = false
        spammer_runtime.restore_name_check_time = 0.0
        spammer_runtime.restore_name_assumed_until = 0.0
        return false
    end

    local now = get_time()

    local last_check =
        tonumber(
            spammer_runtime.restore_name_check_time
        ) or 0.0

    if force_refresh ~= true
        and last_check > 0.0
        and now - last_check <
            (
                tonumber(
                    spammer_runtime.restore_name_check_interval
                ) or 0.20
            ) then

        return spammer_runtime.restore_name_disabled == true
    end

    if now <
        (
            tonumber(
                spammer_runtime.restore_name_assumed_until
            ) or 0.0
        ) then

        return spammer_runtime.set_restore_name_state(
            true,
            now
        )
    end

    local tracked_name,
        tracked_layout =
            spammer_runtime.get_tracked_applied_name()

    local requested_name =
        spammer_runtime.normalize_name_for_restore_compare(
            spammer_runtime.last_requested_visible_name
        )

    local requested_at =
        tonumber(
            spammer_runtime.last_requested_at
        ) or 0.0


    if requested_name ~= ""
        and requested_at > 0.0
        and now - requested_at <= 2.5 then

        local requested_is_initial =
            requested_name == initial_name
            and tracked_layout ~= "Vertical"

        return spammer_runtime.set_restore_name_state(
            requested_is_initial,
            now
        )
    end

    local raw_name =
        spammer_runtime.normalize_name_for_restore_compare(
            spammer_runtime.get_raw_name_cvar()
        )

    local player_name =
        spammer_runtime.normalize_name_for_restore_compare(
            get_current_player_name()
        )

    local observed_name = ""
    local observed_at =
        tonumber(
            spammer_runtime.last_observed_at
        ) or 0.0


    if observed_at > 0.0
        and now - observed_at <= 8.0 then

        observed_name =
            spammer_runtime.normalize_name_for_restore_compare(
                spammer_runtime.last_observed_name
            )
    end

    local live_sources = {
        raw_name,
        player_name,
        observed_name
    }

    local live_initial_matches = 0
    local live_non_initial_matches = 0
    local live_source_count = 0

    for _, current_name in ipairs(
        live_sources
    ) do
        if current_name ~= "" then
            live_source_count =
                live_source_count + 1

            local is_horizontal_initial =
                current_name == initial_name
                and not current_name:find(
                    "[\r\n]"
                )

            if is_horizontal_initial then
                live_initial_matches =
                    live_initial_matches + 1
            else
                live_non_initial_matches =
                    live_non_initial_matches + 1
            end
        end
    end


    if live_non_initial_matches > 0 then
        return spammer_runtime.set_restore_name_state(
            false,
            now
        )
    end

    if tracked_name ~= "" then
        local tracked_is_initial =
            tracked_name == initial_name
            and tracked_layout == "Horizontal"

        if not tracked_is_initial then


            if tracked_layout == "Vertical" then
                return spammer_runtime.set_restore_name_state(
                    false,
                    now
                )
            end


            if live_initial_matches >= 2 then
                spammer_runtime.preview_applied_key = nil
                spammer_runtime.clear_current_name_metadata()

                return spammer_runtime.set_restore_name_state(
                    true,
                    now
                )
            end

            return spammer_runtime.set_restore_name_state(
                false,
                now
            )
        end
    end

    if live_initial_matches > 0 then
        return spammer_runtime.set_restore_name_state(
            true,
            now
        )
    end

    if tracked_name ~= "" then
        return spammer_runtime.set_restore_name_state(
            tracked_name == initial_name
            and tracked_layout == "Horizontal",
            now
        )
    end


    return spammer_runtime.set_restore_name_state(
        false,
        now
    )
end

