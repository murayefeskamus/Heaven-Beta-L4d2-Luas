    local min_x, min_y =
        ui.setting_search.setting_search_match_read_vec2(min_first, min_second)

    if min_x == nil or min_y == nil then
        return nil
    end

    local max_x, max_y = nil, nil

    if type(imgui.get_item_rect_max) == "function" then
        local ok_max, max_first, max_second = pcall(imgui.get_item_rect_max)
        if ok_max then
            max_x, max_y =
                ui.setting_search.setting_search_match_read_vec2(max_first, max_second)
        end
    end

    if max_x == nil then
        max_x = min_x + 220.0
    end

    if max_y == nil then
        local line_height = 19.0
        if type(imgui.get_frame_height) == "function" then
            local ok_height, height = pcall(imgui.get_frame_height)
            if ok_height then
                line_height = tonumber(height) or line_height
            end
        end
        max_y = min_y + line_height
    end

    return {
        min_x = min_x,
        min_y = min_y,
        max_x = max_x,
        max_y = max_y
    }
end

function ui.setting_search.setting_search_match_call_draw_list_method(
    draw_list,
    method_names,
    argument_sets
)
    if draw_list == nil then
        return false
    end

    for _, method_name in ipairs(method_names or {}) do
        local method = draw_list[method_name]
        if type(method) == "function" then
            for _, arguments in ipairs(argument_sets or {}) do
                local ok = pcall(
                    method,
                    draw_list,
                    ui.setting_search.exact_unpack(
                        arguments,
                        1,
                        arguments.n or #arguments
                    )
                )

                if ok then
                    return true
                end
            end
        end
    end

    return false
end

