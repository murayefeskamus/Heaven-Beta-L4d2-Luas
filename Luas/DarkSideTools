function ui.control.stabilize_aim_v2_angles(
    current_angles,
    target,
    settings
)
    local raw_target =
        target and target.aim_angle

    if not current_angles
        or not raw_target then

        return raw_target or current_angles
    end

    if settings.tracking_stabilizer ~= true then
        ui.control.runtime.filtered_target_index =
            tonumber(target.index) or 0

        ui.control.runtime.filtered_target_angle =
            vector.new(
                raw_target.x,
                raw_target.y,
                0.0
            )

        ui.control.runtime.deadzone_holding = false

        return ui.control.smooth_angles_v2(
            current_angles,
            raw_target,
            ui.control.get_effective_smoothing(
                settings,
                target
            )
        )
    end

    local target_index =
        tonumber(target.index) or 0

    local previous =
        ui.control.runtime.filtered_target_angle

    if target_index ~=
        (tonumber(
            ui.control.runtime.filtered_target_index
        ) or 0)
        or not previous then

        previous =
            vector.new(
                raw_target.x,
                raw_target.y,
                0.0
            )

        ui.control.runtime.filtered_target_index =
            target_index

        ui.control.runtime.deadzone_holding = false
    end

    local normalized_error =
        ui.control.clamp(
            (tonumber(target.fov) or 0.0) /
            math.max(
                tonumber(settings.fov) or 1.0,
                1.0
            ),
            0.0,
            1.0
        )

    local configured_stability =
        ui.control.clamp(
            settings.tracking_stability,
            0.0,
            0.92
        )

    local retention =
        configured_stability *
        (1.0 - normalized_error * 0.85)

    if target.grace == true then
        retention = math.max(
            retention,
            0.88
        )
    end

    retention =
        ui.control.clamp(
            retention,
            0.0,
            0.96
        )

    local filtered =
        vector.new(
            previous.x +
                ui.control.normalize_angle(
                    raw_target.x - previous.x
                ) * (1.0 - retention),
            ui.control.normalize_angle(
                previous.y +
                    ui.control.normalize_angle(
                        raw_target.y - previous.y
                    ) * (1.0 - retention)
            ),
            0.0
        )

    ui.control.runtime.filtered_target_angle =
        filtered

    ui.control.runtime.last_tracking_retention =
        retention

    local delta_pitch =
        ui.control.normalize_angle(
            filtered.x - current_angles.x
        )

    local delta_yaw =
        ui.control.normalize_angle(
            filtered.y - current_angles.y
        )

    local angular_error =
        math.sqrt(
            delta_pitch * delta_pitch +
            delta_yaw * delta_yaw
        )

    local deadzone =
        ui.control.clamp(
            settings.aim_deadzone,
            0.0,
            1.0
        )

    local release_zone =
        deadzone +
        ui.control.clamp(
            settings.deadzone_hysteresis,
            0.0,
            0.50
        )

    if ui.control.runtime.deadzone_holding == true then
        if angular_error <= release_zone then
            ui.control.runtime.last_tracking_step = 0.0
            return current_angles
        end

        ui.control.runtime.deadzone_holding = false
    elseif angular_error <= deadzone then
        ui.control.runtime.deadzone_holding = true
        ui.control.runtime.last_tracking_step = 0.0
        return current_angles
    end

    local effective_smoothing =
        ui.control.get_effective_smoothing(
            settings,
            target
        )

    local correction_factor =
        math.min(
            1.0,
            1.0 /
            math.max(
                effective_smoothing,
                1.0
            )
        )

    local micro_zone =
        ui.control.clamp(
            settings.micro_correction_zone,
            0.10,
            5.0
        )

    if angular_error < micro_zone then
        local normalized_micro =
            ui.control.clamp(
                angular_error / micro_zone,
                0.0,
                1.0
            )

        local minimum_response =
            ui.control.clamp(
                settings.micro_correction_strength,
                0.05,
                1.0
            )

        local micro_response =
            minimum_response +
            (1.0 - minimum_response) *
            normalized_micro * normalized_micro

        correction_factor =
            correction_factor * micro_response
    end

    local step_pitch =
        delta_pitch * correction_factor

    local step_yaw =
        delta_yaw * correction_factor

    local step_magnitude =
        math.sqrt(
            step_pitch * step_pitch +
            step_yaw * step_yaw
        )

    local maximum_step =
        ui.control.clamp(
            settings.maximum_angular_step,
            1.0,
            90.0
        )

    if step_magnitude > maximum_step
        and step_magnitude > 0.0001 then

        local step_scale =
            maximum_step / step_magnitude

        step_pitch = step_pitch * step_scale
        step_yaw = step_yaw * step_scale
        step_magnitude = maximum_step
    end

    ui.control.runtime.last_tracking_step =
        step_magnitude

    return vector.new(
        ui.control.clamp(
            current_angles.x + step_pitch,
            -89.0,
            89.0
        ),
        ui.control.normalize_angle(
            current_angles.y + step_yaw
        ),
        0.0
    )
end

function ui.control.movement_key_count()
    local count = 0

    for _, movement_key in ipairs({
        keys.KEY_W or 0x57,
        keys.KEY_A or 0x41,
        keys.KEY_S or 0x53,
        keys.KEY_D or 0x44
    }) do
        local key_ok,
            key_down =
                pcall(
                    input.is_key_down,
                    movement_key
                )

        if key_ok
            and key_down == true then

            count = count + 1
        end
    end

    return count
end

function ui.control.is_action_key_down()
    if ui.input_safety.block_runtime_hotkeys() then
        return false
    end

    if type(input) ~= "table"
        or type(input.is_key_down) ~= "function" then

        return false
    end

    local key_ok,
        key_down =
