function ui.lobby.normalize_weapon_identifier(
    weapon_name
)
    weapon_name =
        tostring(
            weapon_name or ""
        ):lower()

    weapon_name =
        weapon_name:gsub(
            "^weapon_",
            ""
        ):gsub(
            "_spawn$",
            ""
        ):gsub(
            "^melee_",
            ""
        ):gsub(
            "%s+",
            "_"
        ):gsub(
            "%-",
            "_"
        )

    local aliases = {
        ["shotgun_pump"] = "pumpshotgun",
        ["pump_shotgun"] = "pumpshotgun",
        ["auto_shotgun"] = "autoshotgun",
        ["dual_pistol"] = "dual_pistols",
        ["pistols"] = "dual_pistols",
        ["magnum"] = "pistol_magnum",
        ["deagle"] = "pistol_magnum",
        ["fire_axe"] = "fireaxe",
        ["fryingpan"] = "frying_pan",
        ["baseballbat"] = "baseball_bat",
        ["cricketbat"] = "cricket_bat",
        ["electricguitar"] = "electric_guitar",
        ["golf_club"] = "golfclub",
        ["nightstick"] = "tonfa"
    }

    return aliases[weapon_name]
        or weapon_name
end

function ui.lobby.get_weapon_display_name(
    weapon_name
)
    local normalized =
        ui.lobby.normalize_weapon_identifier(
