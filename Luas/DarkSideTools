function ui.control.aim_boundary_draw_circle_lines(
    center_x,
    center_y,
    radius,
    segments,
    red,
    green,
    blue,
    alpha
)
    local previous_x = center_x + radius
    local previous_y = center_y

    for segment = 1, segments do
        local angle = segment / segments * math.pi * 2.0
        local next_x = center_x + math.cos(angle) * radius
        local next_y = center_y + math.sin(angle) * radius

        if not ui.control.aim_boundary_draw_line(
            previous_x,
            previous_y,
            next_x,
            next_y,
            red,
            green,
            blue,
            alpha
        ) then
            return false
        end

        previous_x = next_x
        previous_y = next_y
    end

    return true
end

function ui.control.aim_boundary_draw_marker(
    marker,
    center_x,
    center_y,
    red,
    green,
    blue,
    alpha
)
    marker = math.floor(tonumber(marker) or 0)
    if marker <= 0 then return true end

    local function line(x1, y1, x2, y2)
        return ui.control.aim_boundary_draw_line(
            x1, y1, x2, y2,
            red, green, blue, alpha
        )
    end

    if marker == 1 then
        return line(center_x - 1, center_y, center_x + 1, center_y)
            and line(center_x, center_y - 1, center_x, center_y + 1)
    elseif marker == 2 then
        return ui.control.aim_boundary_draw_circle_lines(
            center_x, center_y, 3.0, 24,
            red, green, blue, alpha
        )
    elseif marker == 3 then
        return line(center_x - 4, center_y - 4, center_x + 4, center_y + 4)
            and line(center_x - 4, center_y + 4, center_x + 4, center_y - 4)
    elseif marker == 4 then
        return line(center_x - 5, center_y, center_x + 5, center_y)
            and line(center_x, center_y - 5, center_x, center_y + 5)
    end

    return line(center_x, center_y - 5, center_x + 5, center_y)
        and line(center_x + 5, center_y, center_x, center_y + 5)
        and line(center_x, center_y + 5, center_x - 5, center_y)
        and line(center_x - 5, center_y, center_x, center_y - 5)
end

