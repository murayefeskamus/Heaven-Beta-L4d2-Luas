        mix(
            palette.header,
            palette.accent,
            palette.light
                and 0.20
                or 0.30
        )

    palette.header_active =
        palette.header_active or
        mix(
            palette.header,
            palette.accent,
            palette.light
                and 0.36
                or 0.46
        )

    palette.combo =
        palette.combo or
        palette.frame

    palette.combo_hovered =
        palette.combo_hovered or
        palette.frame_hovered

    palette.combo_active =
        palette.combo_active or
        palette.frame_active

    palette.border =
        palette.border or
        (
            palette.light
            and darken(
                palette.child,
                0.24
            )
            or lighten(
                palette.child,
                0.22
            )
        )

    palette.title =
        palette.title or
        mix(
            palette.background,
            palette.child,
            0.55
        )

    palette.title_active =
        palette.title_active or
        mix(
            palette.title,
            palette.accent,
            palette.light
                and 0.10
                or 0.18
        )

    palette.menubar =
        palette.menubar or
        palette.child

    palette.scrollbar_bg =
        palette.scrollbar_bg or
        palette.background

    palette.scrollbar_grab =
        palette.scrollbar_grab or
        mix(
            palette.frame,
            palette.accent,
            palette.light
                and 0.20
                or 0.30
        )

    palette.scrollbar_hovered =
        palette.scrollbar_hovered or
        mix(
            palette.scrollbar_grab,
            palette.accent,
            0.36
        )

    palette.scrollbar_active =
        palette.scrollbar_active or
        mix(
            palette.scrollbar_grab,
            palette.accent,
            0.58
        )

    palette.checkmark =
        palette.checkmark or
        palette.accent

    palette.slider =
        palette.slider or
        palette.accent

    palette.slider_active =
        palette.slider_active or
        lighten(
            palette.accent,
            palette.light
                and 0.06
                or 0.15
        )

    palette.separator =
