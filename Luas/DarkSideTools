        right_rows[#right_rows + 1] = {
            label = "Timeout limit",
            value = string.format(
                "%.1f seconds",
                tonumber(stats.timeout_seconds) or 0.0
            ),
            color = { 0.85, 0.85, 0.88 }
        }

        right_rows[#right_rows + 1] = { section = "LATENCY" }

        right_rows[#right_rows + 1] = {
            label = "Ping out",
            value = string.format(
                "%.1f ms",
                tonumber(stats.ping_out_ms) or 0.0
            ),
            color = { ping_r, ping_g, ping_b }
        }

        right_rows[#right_rows + 1] = {
            label = "Ping in",
            value = string.format(
                "%.1f ms",
                tonumber(stats.ping_in_ms) or 0.0
            ),
            color = { ping_r, ping_g, ping_b }
        }

        right_rows[#right_rows + 1] = {
            label = "Rolling average",
            value = string.format(
                "%.1f ms",
                tonumber(stats.average_ping_ms) or 0.0
            ),
            color = { ping_r, ping_g, ping_b }
        }

        right_rows[#right_rows + 1] = {
            label = "Jitter",
            value = string.format(
                "%.1f ms",
                tonumber(stats.jitter_ms) or 0.0
            ),
            color = { jitter_r, jitter_g, jitter_b }
        }

        right_rows[#right_rows + 1] = {
            label = "Peak ping",
            value = string.format(
