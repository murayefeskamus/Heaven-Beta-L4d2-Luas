    for excluded_name in pairs(
        EXCLUDED_SURVIVOR_BOT_NAMES
    ) do
        if #bot_name_key >= #excluded_name
            and bot_name_key:sub(
                -#excluded_name
            ) == excluded_name then

            return true
        end
    end

    return false
end

function get_player_entity_team_number(player)
    if not player then
        return 0
    end

    local method_attempts = {
        function()
            return player:get_team()
        end,
        function()
            return player:get_prop("m_iTeamNum")
        end
    }

    for _, method_attempt in ipairs(
        method_attempts
    ) do
        local ok, value =
            pcall(
                method_attempt
            )

        local team_number =
            tonumber(value) or 0

        if ok and team_number > 0 then
            return team_number
        end
    end

    return 0
end


function name_stealer.is_player_bot(
    player_index,
    player
)
    player_index =
        tonumber(player_index) or 0

    if player_index <= 0 then
        return false
    end

    local info_ok,
        player_info =
            pcall(
                engine.get_player_info,
                player_index
            )

    if info_ok
        and player_info then

        local boolean_fields = {
            "fakeplayer",
            "fake_player",
            "is_fake_player",
            "is_fake_client",
            "fakeclient",
            "fake_client",
            "is_bot",
            "isBot",
            "bot"
        }

        for _, field_name in ipairs(
            boolean_fields
        ) do
            local field_ok,
                field_value =
                    pcall(
                        function()
                            return player_info[
                                field_name
                            ]
                        end
                    )

            if field_ok
                and field_value ~= nil then

                local normalized_value =
                    tostring(
                        field_value
                    ):lower()

                if field_value == true
                    or field_value == 1
                    or normalized_value == "true"
                    or normalized_value == "1"
                    or normalized_value == "bot"
                    or normalized_value == "[bot]" then

                    return true
                end
            end
        end

    end

    if player then
        local method_names = {
            "is_bot",
            "isBot",
            "is_fake_player",
            "is_fake_client"
        }

        for _, method_name in ipairs(
            method_names
        ) do
            local method_ok,
                method_value =
                    pcall(
                        function()
                            return player[
                                method_name
                            ]
                        end
                    )

            if method_ok
                and type(method_value)
                    == "function" then

                local call_ok,
                    call_value =
                        pcall(
                            method_value,
                            player
                        )

                if call_ok
                    and (
                        call_value == true
                        or call_value == 1
                        or tostring(
                            call_value
                        ):lower() == "true"
                    ) then

                    return true
                end
            end
        end
    end


    local fallback_name = nil

    if player_info
        and player_info.name then

        fallback_name =
            tostring(
                player_info.name
            )
    end

    if (
        not fallback_name
        or fallback_name == ""
    ) and player then

        local name_ok,
            entity_name =
                pcall(
                    function()
                        return player:get_name()
                    end
                )

        if name_ok
            and entity_name then

            fallback_name =
                tostring(
                    entity_name
                )
        end
    end


    if is_excluded_bot_name(
        fallback_name
    ) then
        local fallback_team =
            get_player_entity_team_number(
                player
            )

        if fallback_team == 3
            and is_excluded_survivor_bot_name(
                fallback_name
            ) then

            return false
        end

        return true
    end


    return false
end

