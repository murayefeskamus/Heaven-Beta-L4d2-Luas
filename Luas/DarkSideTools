function chat_spammer.get_remembered_vote_session()
    local history =
        type(chat_spammer.vote_history) == "table"
        and chat_spammer.vote_history
        or {}

    if #history > 0 then
        chat_spammer.vote_history_selection =
            chat_spammer.normalize_vote_history_selection(
                chat_spammer.vote_history_selection
            )

        local selected_session =
            history[
                chat_spammer.vote_history_selection + 1
            ]

        if type(selected_session) == "table"
            and (tonumber(selected_session.started_at) or 0.0) > 0.0 then

            chat_spammer.vote_remembered_session =
                selected_session

            return selected_session
        end
    end

    local session =
        chat_spammer.vote_remembered_session

    if type(session) ~= "table"
        or (tonumber(session.started_at) or 0.0) <= 0.0 then

        return nil
    end

    return session
end

function chat_spammer.vote_session_has_results(
    session
)
    if type(session) ~= "table" then
        return false
    end

    return #(session.order or {}) > 0
        or (tonumber(session.server_yes) or 0) > 0
        or (tonumber(session.server_no) or 0) > 0
        or (tonumber(session.server_total) or 0) > 0
end

function chat_spammer.vote_session_is_finished(
    session
)
    return type(session) == "table"
        and (
            (tonumber(session.finalized_at) or 0.0) > 0.0
            or tostring(session.final_status or "") ~= ""
        )
end

function chat_spammer.get_vote_records(
    session
)
    session = type(session) == "table"
        and session
        or chat_spammer.get_remembered_vote_session()

    local records = {}

    if type(session) ~= "table" then
        return records
    end

    for _, actor_key in ipairs(session.order or {}) do
        local vote = session.votes
            and session.votes[actor_key]
            or nil

        if type(vote) == "table" then
            table.insert(
                records,
                vote
            )
        end
    end

    return records
end

