function ui.lobby.get_health_color(
    health_value
)
    local health =
        tonumber(health_value)

    if health == nil then
        return 1.0, 1.0, 1.0
    elseif health >= 75 then
        return 0.20, 1.00, 0.20
    elseif health >= 40 then
        return 1.00, 0.85, 0.25
    elseif health > 0 then
        return 1.00, 0.55, 0.20
    end

    return 0.55, 0.55, 0.55
end

