function on_game_event(event_name, event)
    if not event then
        return
    end

    if event_name == "player_connect"
        or event_name == "player_disconnect"
        or event_name == "player_team"
        or event_name == "player_spawn"
        or event_name == "player_death"
        or event_name == "player_bot_replace"
        or event_name == "bot_player_replace"
        or event_name == "round_start"
        or event_name == "player_changename" then

        ui.lobby.force_refresh = true


        name_stealer.refresh_requested = true
    end

    if event_name == "player_disconnect" then
        name_stealer.handle_target_disconnect(
            event
        )

        ui.lobby.mark_player_disconnected(
            event
        )
    elseif event_name == "player_death" then
        ui.lobby.record_death_event(
            event
        )
    elseif event_name == "player_hurt"
        or event_name == "player_hurt_concise" then

        ui.lobby.record_special_infected_damage(
            event,
            event_name
        )
    elseif event_name == "infected_death" then
        ui.lobby.record_common_infected_death(
            event
        )
    elseif event_name == "weapon_fire" then
        ui.lobby.record_weapon_observation(
            event,
            "weapon"
        )
    elseif event_name == "infected_decapitated" then
        ui.lobby.record_weapon_observation(
            event,
            "weapon"
        )
    elseif event_name == "tank_killed" then
        ui.lobby.record_tank_killed_event(
            event
        )
    elseif event_name == "witch_killed" then
        ui.lobby.record_witch_killed_event(
            event
        )
    end

    if event_name == "player_say" then
        local userid = 0

        local userid_ok,
            userid_value =
                pcall(
                    function()
                        return event:get_int(
                            "userid"
                        )
                    end
                )

        if userid_ok then
            userid =
                tonumber(
                    userid_value
                ) or 0
        end

        local text_ok,
            text_value =
                pcall(
                    function()
                        return event:get_string(
                            "text"
                        )
                    end
                )

        local spoken_text =
            text_ok
            and text_value
            and tostring(
                text_value
            )
            or ""

        if spoken_text == ""
            or userid <= 0 then

            return
        end

        ui.lobby.record_chat(
            userid
        )

        local sender_is_local =
            is_local_player_userid(
                userid
            )

        if sender_is_local then
            confirm_chat_message(
                spoken_text
            )
        end

        if ui.quotes
            and type(
                ui.quotes.handle_player_say
            ) == "function"
            and ui.quotes.handle_player_say(
                userid,
                spoken_text,
                sender_is_local
            ) then

            return
        end

        if ui.lobby.handle_zombieclasses_command(
            userid,
            spoken_text
        ) then
            return
        end

        if ui.lobby.handle_zombieclass_command(
            userid,
            spoken_text
        ) then
            return
        end

        if ui.lobby.handle_playerinfo_command(
            userid,
            spoken_text
        ) then
            return
        end

        if ui.lobby.handle_serverinfo_command(
            userid,
            spoken_text
        ) then
            return
        end

        if ui.lobby.handle_team_summary_command(
            userid,
            spoken_text
        ) then
            return
        end

        if sender_is_local then
            return
        end

        if not chat_spammer.parrot_mode_enabled then
            return
        end

        if chat_spammer.is_parrot_loop_message(
            spoken_text
        ) then
            return
        end

        local author_name =
            get_player_name_from_userid(
                userid
            ) or "Player"

        if not chat_spammer.parrot_message_is_allowed(
            author_name,
            spoken_text
        ) then
            return
        end

        local source_is_team_chat =
            get_player_say_team_only(
                event
            )

        local parrot_route,
            parrot_source_class =
                chat_spammer.get_parrot_route_for_source(
                    userid,
                    source_is_team_chat
                )


        if parrot_route == 0 then
            return
        end

        local parrot_output =
            spoken_text

        if chat_spammer.parrot_output_mode == 1 then
            parrot_output =
                author_name ..
                ": " ..
                spoken_text
        end


        local parrot_message =
            chat_spammer.apply_parrot_case_shape(
                parrot_output
            )

        local loop_safe_parrot_message =
            chat_spammer.build_loop_safe_parrot_message(
                parrot_message
            )

        if chat_spammer.send_to_route(
            loop_safe_parrot_message,
            parrot_route,
            true
        ) then
            chat_spammer.remember_parrot_exchange(
                spoken_text,
                parrot_message
            )

            chat_spammer.last_parrot_message =
                parrot_message

            chat_spammer.parrot_messages_sent =
                chat_spammer.parrot_messages_sent + 1
        end

        return
    end

    if event_name ~= "player_changename" then
        return
    end

    local userid = 0

    local userid_ok, userid_value =
        pcall(
            function()
                return event:get_int(
                    "userid"
                )
            end
        )

    if userid_ok then
        userid =
            tonumber(userid_value) or 0
    end

    local name_ok, name_value =
        pcall(
            function()
                return event:get_string(
                    "newname"
                )
            end
        )

    local is_local_change =
        is_local_player_userid(
            userid
        )


    if userid > 0
        and name_ok
        and name_value
        and tostring(name_value) ~= "" then

        local tracked_player =
            ui.lobby.find_player_by_userid(
                userid
            )

        if tracked_player then
            local old_name_ok,
                old_name_value =
                    pcall(
                        function()
                            return event:get_string(
                                "oldname"
                            )
                        end
                    )

            local previous_name =
                old_name_ok
                and old_name_value
                and tostring(old_name_value) ~= ""
                and tostring(old_name_value)
                or tostring(
                    tracked_player.name or ""
                )

            local changed_name =
                tostring(name_value)

            if ui.lobby.record_name_change(
                tracked_player,
                previous_name,
                changed_name,
                get_time()
            ) then
                tracked_player.name =
                    changed_name

                ui.lobby.update_activity_cache(
                    tracked_player
                )
            end
        end
    end

    if not is_local_change then
        if name_ok
            and name_value
            and name_value ~= "" then

            name_stealer.handle_target_name_change(
                userid,
                tostring(name_value)
            )
        end

        if name_stealer.auto_name_steal_enabled
            and name_ok
            and name_value
            and name_value ~= "" then

            local index_ok, changed_player_index =
                pcall(
                    engine.get_player_for_userid,
                    userid
                )

            if index_ok
                and changed_player_index
                and changed_player_index > 0 then

                local changed_player =
                    entity.get_by_index(
                        changed_player_index
                    )

                if changed_player
                    and not name_stealer.is_player_bot(
                        changed_player_index,
                        changed_player
                    ) then

                    save_auto_stolen_name_to_file(
                        tostring(
                            name_value
                        )
                    )
                end
            end
        end

        return
    end


    if name_ok
        and name_value
        and name_value ~= "" then

        local new_name =
            tostring(name_value)


        name_stealer.complete_silent_steal_after_name_change(
            new_name
        )

        local tracked_key =
            tostring(
                spammer_runtime.preview_applied_key
                or ""
            )

        local tracked_name = ""

        if tracked_key:sub(1, 2) == "V|"
            or tracked_key:sub(1, 2) == "H|" then

            tracked_name =
                clean_name_for_reverse(
                    tracked_key:sub(3)
                )
        end

        if tracked_name ~= ""
            and not spammer_runtime.names_match_for_tracking(
                new_name,
                tracked_name
            ) then

            spammer_runtime.preview_applied_key = nil
            spammer_runtime.original_name_vertical_active = false
            spammer_runtime.custom_name_vertical_active = false
            spammer_runtime.clear_current_name_metadata()
        end

        spammer_runtime.last_observed_name =
            new_name

        spammer_runtime.last_observed_at =
            get_time()


        spammer_runtime.restore_name_check_time = 0.0
        spammer_runtime.clear_requested_name()

        confirm_pending_spammer_name(
            new_name,
            "player_changename event"
        )
    end
end


