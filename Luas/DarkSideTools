function ui.favourites.jump_to_entry(
    entry
)
    entry =
        type(entry) == "table"
        and entry
        or {}

    local tab_key =
        tostring(entry.tab_key or "")

    local section_key =
        tostring(entry.section_key or "")

    local tool_index =
        ui.favourites.tool_indices[
            tab_key
        ]

    if tool_index == nil then
        ui.favourites.set_status(
            "The source tab is unavailable.",
            true
        )

        return false
    end

    if tostring(entry.kind) == "setting"
        and type(ui.setting_search) == "table"
        and type(
            ui.setting_search.refresh_matches
        ) == "function"
        and type(
            ui.setting_search.open_selected
        ) == "function" then

        ui.setting_search.query =
            tostring(entry.term or "")

        ui.setting_search.refresh_matches()

        local target_normalized =
            ui.setting_search.normalize(
                entry.term
            )

        for index,
            result in ipairs(
                ui.setting_search.matches
                or {}
            ) do

            if tostring(result.tab_key) ==
                tab_key
                and tostring(
                    result.section_key
                ) == section_key
                and ui.setting_search.normalize(
                    result.display_term
                    or result.term
                ) == target_normalized then

                ui.setting_search.selected_match =
                    index

                return ui.setting_search.open_selected()
            end
        end
    end

    ui.selected_tool =
        tool_index

    if tool_index == 4 then
        ui.lobby.force_refresh = true
    end

    if type(ui.setting_search) == "table"
        and type(
            ui.setting_search.expand_section
        ) == "function" then

        ui.setting_search.expand_section(
            tab_key,
            section_key
        )

        ui.setting_search.pending_tab =
            tab_key

        ui.setting_search.pending_section =
            section_key

        ui.setting_search.pending_frames = 1
    end

    return true
end

