function ui.heaven_configs.update_hotkeys()
    if ui.input_safety.block_runtime_hotkeys() then
        for index = 1, ui.heaven_configs.max_slots do
            ui.heaven_configs.hotkey_was_down[index] = false
        end

        ui.heaven_configs.cycle_key_was_down = false
        return
    end

    if type(input) ~= "table" then
        return
    end

    local can_read_down =
        type(input.is_key_down) == "function"

    local can_read_pressed =
        type(input.is_key_pressed) == "function"

    if not can_read_down and not can_read_pressed then
        return
    end

    local blocked =
        ui.heaven_configs.enabled ~= true
        or ui.heaven_configs.waiting_for_key_slot > 0
        or ui.heaven_configs.waiting_for_cycle_key == true
        or (
            type(ui.window_hotkeys) == "table"
            and tostring(
                ui.window_hotkeys.waiting_target
                or ""
            ) ~= ""
        )
        or ui.control.waiting_for_key == true
        or ui.control.waiting_for_pursuit_key == true

    local now = get_time()

    if ui.heaven_configs.use_cycle_key == true then
        local key_value =
            math.floor(
                tonumber(
                    ui.heaven_configs.cycle_key
                ) or 0
            )

        local is_down = false
        local pressed = false

        if key_value > 0 then
            if can_read_down then
                local down_ok,
                    down_result =
                        pcall(
                            input.is_key_down,
                            key_value
                        )

                is_down = down_ok and down_result == true
                pressed =
                    is_down
                    and ui.heaven_configs.cycle_key_was_down ~= true
            else
                local pressed_ok,
                    pressed_result =
                        pcall(
                            input.is_key_pressed,
                            key_value
                        )

                pressed = pressed_ok and pressed_result == true
                is_down = pressed
            end
        end

        if blocked then
            ui.heaven_configs.cycle_key_was_down = is_down
        elseif key_value > 0
            and pressed
            and now >=
                (tonumber(ui.heaven_configs.next_switch_time) or 0.0)
            and not ui.heaven_configs.reserved_key_reason(
                key_value
            ) then

            ui.heaven_configs.cycle_key_was_down = true
            ui.heaven_configs.next_switch_time =
                now +
                math.max(
                    0.10,
                    tonumber(ui.heaven_configs.switch_cooldown) or 0.35
                )

            ui.heaven_configs.cycle_next_enabled_config()
        else
            ui.heaven_configs.cycle_key_was_down = is_down
        end

        return
    end

    for index = 1, ui.heaven_configs.max_slots do
        local slot = ui.heaven_configs.slots[index]
        local key_value =
            slot
            and math.floor(tonumber(slot.key) or 0)
            or 0

        local is_down = false
        local pressed = false

        if key_value > 0 then
            if can_read_down then
                local down_ok,
                    down_result =
                        pcall(
                            input.is_key_down,
                            key_value
                        )

                is_down = down_ok and down_result == true
                pressed =
                    is_down
                    and ui.heaven_configs.hotkey_was_down[index] ~= true
            else
                local pressed_ok,
                    pressed_result =
                        pcall(
                            input.is_key_pressed,
                            key_value
                        )

                pressed = pressed_ok and pressed_result == true
                is_down = pressed
            end
        end

        if blocked then
            ui.heaven_configs.hotkey_was_down[index] = is_down
        elseif slot
            and slot.enabled == true
            and key_value > 0
            and pressed
            and now >=
                (tonumber(ui.heaven_configs.next_switch_time) or 0.0)
            and ui.heaven_configs.clean_config_name(
                slot.config_name
            ) ~= ""
            and not ui.heaven_configs.reserved_key_reason(
                key_value
            ) then

            ui.heaven_configs.hotkey_was_down[index] = true
            ui.heaven_configs.next_switch_time =
                now +
                math.max(
                    0.10,
                    tonumber(ui.heaven_configs.switch_cooldown) or 0.35
                )

            ui.heaven_configs.apply_slot(
                index,
                "hotkey"
            )

            return
        else
            ui.heaven_configs.hotkey_was_down[index] = is_down
        end
    end
end

function ui.heaven_configs.open_config_folder()
    ui.heaven_configs.last_status =
        tostring(ui.heaven_configs.config_directory)

    ui.heaven_configs.last_status_error = false
    return false
end

function ui.heaven_configs.combo_items_for_slot(
    slot
)
    local items = {}
    local selected_index = 0
    local current_name =
        ui.heaven_configs.clean_config_name(
            slot
            and slot.config_name
            or ""
        )

    for index, entry in ipairs(
        ui.heaven_configs.detected_configs
    ) do
        local entry_name =
            ui.heaven_configs.clean_config_name(
                entry.name
            )

        items[#items + 1] = entry_name

        if current_name ~= ""
            and entry_name:lower() == current_name:lower() then

            selected_index = index - 1
        end
    end

    return items,
        selected_index
end

function ui.heaven_configs.draw_inline_status()
    local now = get_time()

    local status_text =
        tostring(
            ui.heaven_configs.last_status
            or ""
        )

    local status_error =
        ui.heaven_configs.last_status_error == true

    if status_text ~=
            tostring(
                ui.heaven_configs.last_status_seen
                or ""
            )
        or status_error ~=
            (
                ui.heaven_configs.last_status_seen_error == true
            ) then

        ui.heaven_configs.last_status_seen =
            status_text

        ui.heaven_configs.last_status_seen_error =
            status_error

        if status_text ~= "" then
            local duration =
                status_error
                and (
                    tonumber(
                        ui.heaven_configs.error_status_duration
                    ) or 4.0
                )
                or (
                    tonumber(
                        ui.heaven_configs.status_duration
                    ) or 3.0
                )

            ui.heaven_configs.last_status_expires_at =
                now + math.max(0.5, duration)
        else
            ui.heaven_configs.last_status_expires_at = 0.0
        end
    end

    local status_active =
        status_text ~= ""
        and (
            ui.heaven_configs.waiting_for_key_slot > 0
            or ui.heaven_configs.waiting_for_cycle_key == true
            or now <=
                (
                    tonumber(
                        ui.heaven_configs.last_status_expires_at
                    ) or 0.0
                )
        )

    if status_text ~= ""
        and not status_active then

        ui.heaven_configs.last_status = ""
        ui.heaven_configs.last_status_error = false
        ui.heaven_configs.last_status_expires_at = 0.0
        ui.heaven_configs.last_status_seen = ""
        ui.heaven_configs.last_status_seen_error = false
        status_text = ""
        status_error = false
    end

    if status_text ~= "" then
        if status_error then
            theme_text_colored(
                1.0, 0.25, 0.25, 1.0,
                status_text
            )
        else
            ui.draw_theme_accent_text(
                status_text
            )
        end

        return
    end

    local current_config,
        has_current_config =
            ui.heaven_configs.get_current_config_display()

    if has_current_config then
        theme_text_colored(
            0.25, 1.0, 0.35, 1.0,
            "Current config: " .. current_config
        )
    end
end

