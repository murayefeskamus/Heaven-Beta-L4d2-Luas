function ui.setting_search.refresh_matches()
    local raw_query = tostring(ui.setting_search.query or "")

    if ui.setting_search.setting_search_match_match_query == raw_query
        and type(ui.setting_search.matches) == "table"
        and type(ui.setting_search.setting_search_match_match_labels) == "table" then

        ui.setting_search.selected_match =
            math.max(
                1,
                math.min(
                    #ui.setting_search.matches > 0
                        and #ui.setting_search.matches
                        or 1,
                    math.floor(
                        tonumber(ui.setting_search.selected_match) or 1
                    )
                )
            )
        return
    end

    ui.setting_search.setting_search_match_base_refresh_matches()
    ui.setting_search.setting_search_match_match_query = raw_query
    ui.setting_search.setting_search_match_match_labels = {}

    for index, result in ipairs(ui.setting_search.matches or {}) do
        ui.setting_search.setting_search_match_match_labels[index] =
            tostring(result.display or "")
