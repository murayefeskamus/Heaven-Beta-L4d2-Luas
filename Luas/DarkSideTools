function spammer_cfg.build_maximum_width_name(text)
    local clean_name =
        spammer_cfg.normalize_max_width_name(
            text
        )

    if clean_name == "" then
        local prefix =
            spammer_cfg.use_color_char
            and DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR
            or ""

        return nil,
            false,
            0,
            "(empty)",
            "",
            0,
            DARKSIDE_CONFIG.MAX_NAME_LENGTH -
                #prefix
    end

    local fitted_text,
        truncated =
            spammer_cfg.clamp_max_width_input(
                clean_name
            )

    local characters =
        spammer_cfg.smart_vertical_split_utf8(
            fitted_text
        )

    if #characters == 0 then
        return nil,
            true,
            0,
            "(could not fit)",
            "",
            0,
            0
    end

    local prefix =
        spammer_cfg.use_color_char
        and DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR
        or ""

    local available_bytes =
        DARKSIDE_CONFIG.MAX_NAME_LENGTH -
        #prefix

    local character_bytes = 0

    for _, character in ipairs(characters) do
        character_bytes =
            character_bytes +
            #character
    end

    local gap_count =
        math.max(
            0,
            #characters - 1
        )

    local output_parts = {}

    if gap_count == 0 then
        table.insert(
            output_parts,
            characters[1]
        )
    else
        local total_space_bytes =
            math.max(
                gap_count,
                available_bytes -
                character_bytes
            )

        local base_spaces =
            math.floor(
                total_space_bytes /
                gap_count
            )

        local extra_spaces =
            total_space_bytes %
            gap_count

        for index, character in ipairs(
            characters
        ) do
            table.insert(
                output_parts,
                character
            )

            if index <= gap_count then
                local gap_spaces =
                    base_spaces +
                    (
                        index <= extra_spaces
                        and 1
                        or 0
                    )

                table.insert(
                    output_parts,
                    string.rep(
                        " ",
                        gap_spaces
                    )
                )
            end
        end
    end

    local visible_name =
        table.concat(
            output_parts
        )

    local final_message =
        prefix ..
        visible_name

    if #final_message >
        DARKSIDE_CONFIG.MAX_NAME_LENGTH then

        return nil,
            true,
            0,
            "(could not fit)",
            "",
            0,
            0
    end

    return final_message,
        truncated,
        #characters,
        visible_name,
        visible_name,
        #visible_name,
        available_bytes
end

