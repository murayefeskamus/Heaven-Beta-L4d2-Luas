function ui.install_server_geoip_details_panel()
ui.network.server_region_online_lookup_retry_interval = 600.0
ui.network.server_region_online_lookup_timeout = 20.0
ui.network.server_region_online_lookup_min_interval = 1.50
ui.network.server_region_online_lookup_last_start =
    tonumber(ui.network.server_region_online_lookup_last_start) or 0.0
ui.network.server_geoip_details_cache_loaded =
    ui.network.server_geoip_details_cache_loaded == true
ui.network.server_geoip_details_cache =
    type(ui.network.server_geoip_details_cache) == "table"
    and ui.network.server_geoip_details_cache
    or {}

local function dst_geo_trim(value)
    return tostring(value or "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function dst_geo_clean(value)
    value = dst_geo_trim(value)
    value = value:gsub("[\r\n|]", " ")
        :gsub("%s+", " ")
    return dst_geo_trim(value)
end

local function dst_geo_escape_cache(value)
    return dst_geo_clean(value):gsub("|", "/")
end

local function dst_geo_field(value)
    value = dst_geo_clean(value)
    if value == "" then
        return "-"
    end
    return value
end

local function dst_geo_parse_kv_line(line)
    local details = {}
    line = tostring(line or "")
        :gsub("^\239\187\191", "")
        :gsub("[\r\n]+", " ")

    for key, value in line:gmatch("([^|=]+)=([^|]*)") do
        key = dst_geo_trim(key)
        value = dst_geo_clean(value)
        if key ~= "" then
            details[key] = value
        end
    end

    return details
end

function ui.network.extract_server_ip_port(address)
    address = tostring(address or "")

    local ip, port = address:match(
        "(%d+%.%d+%.%d+%.%d+)%s*:%s*(%d+)"
    )

    ip = ip or ui.network.extract_ipv4_address(address)
    port = port or ""

    return tostring(ip or ""), tostring(port or "")
end

function ui.network.normalize_geoip_detail(details, fallback_ip)
    details = type(details) == "table" and details or {}

    local output = {}
    output.query = ui.network.extract_ipv4_address(
        details.query or fallback_ip or ""
    )
    output.country = ui.network.normalize_geoip_country_label(
        details.country or details.countryName or details.country_name or ""
    )
    output.countryCode = dst_geo_clean(
        details.countryCode or details.country_code or details.cc or ""
    )
    output.region = dst_geo_clean(details.region or "")
    output.regionName = dst_geo_clean(
        details.regionName or details.region_name or ""
    )
    output.city = dst_geo_clean(details.city or "")
    output.zip = dst_geo_clean(details.zip or details.postal or "")
    output.lat = dst_geo_clean(details.lat or details.latitude or "")
    output.lon = dst_geo_clean(details.lon or details.lng or details.longitude or "")
    output.timezone = dst_geo_clean(details.timezone or details.tz or "")
    output.offset = dst_geo_clean(details.offset or "")
    output.isp = dst_geo_clean(details.isp or "")
    output.org = dst_geo_clean(details.org or details.organization or "")
    output.source = dst_geo_clean(details.source or "")
    output.currentTime = dst_geo_clean(details.currentTime or details.current_time or "")
    output.cached_at = dst_geo_clean(details.cached_at or "")

    if output.country == "" and output.countryCode ~= "" then
        output.country = ui.network.normalize_geoip_country_label(output.countryCode)
    end

    if output.query == "" then
        output.query = ui.network.extract_ipv4_address(fallback_ip or "")
    end

    return output
end

function ui.network.geoip_detail_has_country(details)
    return type(details) == "table"
        and dst_geo_clean(details.country or "") ~= ""
end

function ui.network.format_geoip_country_value(details)
    details = type(details) == "table" and details or {}

    local city = dst_geo_clean(details.city or "")
    local country = dst_geo_clean(details.country or "")

    if city ~= "" and country ~= "" then
        return city .. ", " .. country
    end

    if country ~= "" then
        return country
    end

    if city ~= "" then
        return city
    end

    return "Unknown"
end

function ui.network.format_geoip_current_time(details)
    details = type(details) == "table" and details or {}

    local offset = tonumber(details.offset)
    if offset ~= nil
        and type(os) == "table"
        and type(os.time) == "function"
        and type(os.date) == "function" then

        local timestamp = os.time() + offset
        local ok, formatted = pcall(os.date, "!%H:%M:%S %d-%m-%Y (%A)", timestamp)

        if ok and formatted and tostring(formatted) ~= "" then
            return tostring(formatted)
        end
    end

    local direct = dst_geo_clean(details.currentTime or "")
    if direct ~= "" then
        return direct
    end

    return "-"
end

function ui.network.load_geoip_online_cache()
    if ui.network.server_geoip_details_cache_loaded == true then
        return
    end

    ui.network.server_geoip_details_cache_loaded = true
    ui.network.server_geoip_details_cache =
        type(ui.network.server_geoip_details_cache) == "table"
        and ui.network.server_geoip_details_cache
        or {}
    ui.network.server_region_online_lookup_cache =
        type(ui.network.server_region_online_lookup_cache) == "table"
        and ui.network.server_region_online_lookup_cache
        or {}
    ui.network.server_region_online_lookup_cache_loaded = true

    if type(io) ~= "table" or type(io.open) ~= "function" then
        return
    end

    local path = ui.network.get_geoip_online_cache_path()
    local file_ok, file = pcall(io.open, path, "rb")

    if not file_ok or not file then
        return
    end

    for line in file:lines() do
        line = tostring(line or "")
            :gsub("^\239\187\191", "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

        if line ~= "" and not line:match("^#") then
            local ip = line:match("^(%d+%.%d+%.%d+%.%d+)|")
            local details = {}

            if ip then
                details = dst_geo_parse_kv_line(line)
            else
                local old_ip, old_country =
                    line:match("^(%d+%.%d+%.%d+%.%d+)%s*,%s*([^,]+)")
                if old_ip and old_country then
                    ip = old_ip
                    details.country = old_country
                    details.query = old_ip
                    details.source = "legacy-cache"
                end
            end

            ip = ui.network.extract_ipv4_address(ip or details.query or "")
            details = ui.network.normalize_geoip_detail(details, ip)

            if ip ~= "" and ui.network.geoip_detail_has_country(details) then
                ui.network.server_geoip_details_cache[ip] = details
                ui.network.server_region_online_lookup_cache[ip] = details.country
            end
        end
    end

    pcall(function() file:close() end)
end

function ui.network.save_geoip_online_cache()
    if type(io) ~= "table" or type(io.open) ~= "function" then
        return false
    end

    local cache =
        type(ui.network.server_geoip_details_cache) == "table"
        and ui.network.server_geoip_details_cache
        or {}

    local path = ui.network.get_geoip_online_cache_path()
    local file_ok, file = pcall(io.open, path, "wb")

    if not file_ok or not file then
        return false
    end

    local keys = {}
    for ip, details in pairs(cache) do
        if ui.network.extract_ipv4_address(ip) ~= ""
            and ui.network.geoip_detail_has_country(details) then
            keys[#keys + 1] = tostring(ip)
        end
    end

    table.sort(keys)

    pcall(function()
        file:write("# DarkSideTools cached IP geolocation details\n")
        file:write("# ip|country=...|regionName=...|city=...|zip=...|lat=...|lon=...|timezone=...|offset=...|isp=...|org=...|source=...\n")

        for _, ip in ipairs(keys) do
            local d = ui.network.normalize_geoip_detail(cache[ip], ip)
            file:write(
                ip ..
                "|query=" .. dst_geo_escape_cache(d.query) ..
                "|country=" .. dst_geo_escape_cache(d.country) ..
                "|countryCode=" .. dst_geo_escape_cache(d.countryCode) ..
                "|region=" .. dst_geo_escape_cache(d.region) ..
                "|regionName=" .. dst_geo_escape_cache(d.regionName) ..
                "|city=" .. dst_geo_escape_cache(d.city) ..
                "|zip=" .. dst_geo_escape_cache(d.zip) ..
                "|lat=" .. dst_geo_escape_cache(d.lat) ..
                "|lon=" .. dst_geo_escape_cache(d.lon) ..
                "|timezone=" .. dst_geo_escape_cache(d.timezone) ..
                "|offset=" .. dst_geo_escape_cache(d.offset) ..
                "|isp=" .. dst_geo_escape_cache(d.isp) ..
                "|org=" .. dst_geo_escape_cache(d.org) ..
                "|source=" .. dst_geo_escape_cache(d.source) ..
                "|cached_at=" .. tostring(os.time and os.time() or 0) ..
                "\n"
            )
        end
    end)

    pcall(function() file:close() end)
    return true
end

function ui.network.cache_geoip_online_details(ip_address, details)
    ip_address = ui.network.extract_ipv4_address(ip_address)
    details = ui.network.normalize_geoip_detail(details, ip_address)

    if ip_address == "" or not ui.network.geoip_detail_has_country(details) then
        return false
    end

    ui.network.load_geoip_online_cache()
    ui.network.server_geoip_details_cache[ip_address] = details
    ui.network.server_region_online_lookup_cache[ip_address] = details.country
    ui.network.server_region_online_lookup_status =
        "Resolved " .. ip_address .. " as " .. ui.network.format_geoip_country_value(details) .. "."
    ui.network.save_geoip_online_cache()
    return true
end

function ui.network.cache_geoip_online_country(ip_address, country)
    return ui.network.cache_geoip_online_details(
        ip_address,
        {
            query = ip_address,
            country = country,
            source = "country-cache"
        }
    )
end

function ui.network.get_geoip_details_from_online_cache(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)

    if ip_address == "" then
        return nil
    end

    ui.network.load_geoip_online_cache()

    local cache =
        type(ui.network.server_geoip_details_cache) == "table"
        and ui.network.server_geoip_details_cache
        or {}

    local details = cache[ip_address]

    if ui.network.geoip_detail_has_country(details) then
        return ui.network.normalize_geoip_detail(details, ip_address)
    end

    return nil
end

function ui.network.get_geoip_country_from_online_cache(ip_address)
    local details = ui.network.get_geoip_details_from_online_cache(ip_address)
    return details and tostring(details.country or "") or ""
end

function ui.network.build_geoip_online_lookup_powershell(ip_address, output_path)
    local ip = ui.network.escape_powershell_single_quoted(
        ui.network.extract_ipv4_address(ip_address)
    )
    local out = ui.network.escape_powershell_single_quoted(output_path)

    return table.concat({
        "$ErrorActionPreference='SilentlyContinue'",
        "$ProgressPreference='SilentlyContinue'",
        "$ip='" .. ip .. "'",
        "$out='" .. out .. "'",
        "New-Item -ItemType Directory -Force -Path (Split-Path $out) | Out-Null",
        "$fields='status,message,country,countryCode,region,regionName,city,zip,lat,lon,timezone,offset,isp,org,query'",
        "$uri='http://ip-api.com/json/'+$ip+'?fields='+$fields",
        "function C($v){ if($null -eq $v){ return '' }; return ([string]$v).Replace('|','/').Replace(\"`r\",' ').Replace(\"`n\",' ').Trim() }",
        "try {",
        "  $r = Invoke-RestMethod -Method Get -Uri $uri -TimeoutSec 10 -Headers @{ 'User-Agent'='DarkSideTools GeoIP' }",
        "  if(($null -eq $r) -or ([string]$r.status).ToLower() -ne 'success') { throw ('lookup failed: ' + [string]$r.message) }",
        "  $local = ''",
        "  $culture = [System.Globalization.CultureInfo]::InvariantCulture",
        "  if($null -ne $r.offset -and ([string]$r.offset) -ne '') { $local = [DateTimeOffset]::FromUnixTimeSeconds(([DateTimeOffset]::UtcNow.ToUnixTimeSeconds() + [int]$r.offset)).ToString('HH:mm:ss dd-MM-yyyy (dddd)', $culture) }",
        "  $parts = @( 'OK', ('source=ip-api'), ('query='+(C $r.query)), ('country='+(C $r.country)), ('countryCode='+(C $r.countryCode)), ('region='+(C $r.region)), ('regionName='+(C $r.regionName)), ('city='+(C $r.city)), ('zip='+(C $r.zip)), ('lat='+(C $r.lat)), ('lon='+(C $r.lon)), ('timezone='+(C $r.timezone)), ('offset='+(C $r.offset)), ('isp='+(C $r.isp)), ('org='+(C $r.org)), ('currentTime='+(C $local)) )",
        "  Set-Content -Path $out -Value ($parts -join '|') -Encoding UTF8",
        "} catch {",
        "  Set-Content -Path $out -Value ('ERR|message=' + (C $_.Exception.Message)) -Encoding UTF8",
        "}"
    }, "\r\n")
end

function ui.network.get_geoip_lookup_vbs_path(output_path)
    return tostring(output_path or ""):gsub("%.txt$", ".vbs")
end

function ui.network.start_geoip_online_lookup(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)

    if ui.network.server_region_online_lookup_enabled ~= true
        or ip_address == ""
        or ui.network.ipv4_to_number(ip_address) == nil
        or ui.network.is_private_ipv4_address(ip_address) then
        return false
    end

    if ui.network.get_geoip_details_from_online_cache(ip_address) ~= nil then
        return true
    end

    local now = os.clock()
    local last_start = tonumber(ui.network.server_region_online_lookup_last_start) or 0.0
    local min_interval = math.max(1.5, tonumber(ui.network.server_region_online_lookup_min_interval) or 1.5)

    if now - last_start < min_interval then
        return false
    end

    local next_retry = 0.0
    if type(ui.network.server_region_online_lookup_next_retry) == "table" then
        next_retry = tonumber(ui.network.server_region_online_lookup_next_retry[ip_address]) or 0.0
    end

    if next_retry > 0.0 and now < next_retry then
        return false
    end

    local active_ip = tostring(ui.network.server_region_online_lookup_active_ip or "")
    if active_ip ~= "" then
        local active_age = now - (tonumber(ui.network.server_region_online_lookup_started_at) or 0.0)
        local timeout = math.max(8.0, tonumber(ui.network.server_region_online_lookup_timeout) or 20.0)

        if active_ip == ip_address and active_age < timeout then
            return true
        end

        if active_age < timeout then
            return false
        end

        ui.network.server_region_online_lookup_active_ip = ""
        ui.network.server_region_online_lookup_active_path = ""
    end

    if type(os) ~= "table" or type(os.execute) ~= "function" then
        ui.network.server_region_online_lookup_status = "OS execute unavailable."
        return false
    end

    local output_path = ui.network.get_geoip_online_result_path(ip_address)
    local ps_path = output_path:gsub("%.txt$", ".ps1")
    local vbs_path = ui.network.get_geoip_lookup_vbs_path(output_path)

    if type(os.remove) == "function" then
        pcall(os.remove, output_path)
    end

    local ps_command = ui.network.build_geoip_online_lookup_powershell(ip_address, output_path)

    local ps_written = false
    local vbs_written = false

    if type(io) == "table" and type(io.open) == "function" then
        local ps_ok, ps_file = pcall(io.open, ps_path, "wb")
        if ps_ok and ps_file then
            ps_written = pcall(function() ps_file:write(ps_command) end) == true
            pcall(function() ps_file:close() end)
        end

        local safe_ps = ps_path:gsub('"', '""')
        local vbs_command =
            'Set sh = CreateObject("WScript.Shell")\r\n' ..
            'sh.Run "powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File ""' ..
            safe_ps ..
            '""", 0, False\r\n'

        local vbs_ok, vbs_file = pcall(io.open, vbs_path, "wb")
        if vbs_ok and vbs_file then
            vbs_written = pcall(function() vbs_file:write(vbs_command) end) == true
            pcall(function() vbs_file:close() end)
        end
    end

    if ps_written ~= true then
        ui.network.server_region_online_lookup_status = "Lookup script write failed."
        return false
    end

    local shell_command
    if vbs_written == true then
        shell_command = 'cmd.exe /C wscript.exe "' .. vbs_path:gsub('"', '') .. '"'
    else
        shell_command = 'powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "' .. ps_path:gsub('"', '') .. '"'
    end

    local ok = pcall(os.execute, shell_command)
    if ok then
        ui.network.server_region_online_lookup_last_start = now
        ui.network.server_region_online_lookup_active_ip = ip_address
        ui.network.server_region_online_lookup_active_path = output_path
        ui.network.server_region_online_lookup_started_at = now
        ui.network.server_region_online_lookup_status = "GeoIP lookup started for " .. ip_address .. "."
        return true
    end

    ui.network.server_region_online_lookup_status = "GeoIP lookup start failed."
    return false
end

function ui.network.read_geoip_online_lookup_result(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)

    if ip_address == "" or type(io) ~= "table" or type(io.open) ~= "function" then
        return ""
    end

    local active_ip = tostring(ui.network.server_region_online_lookup_active_ip or "")
    if active_ip ~= ip_address then
        return ""
    end

    local path = tostring(ui.network.server_region_online_lookup_active_path or "")
    if path == "" then
        path = ui.network.get_geoip_online_result_path(ip_address)
    end

    local file_ok, file = pcall(io.open, path, "rb")

    if not file_ok or not file then
        local age = os.clock() - (tonumber(ui.network.server_region_online_lookup_started_at) or 0.0)
        local timeout = math.max(8.0, tonumber(ui.network.server_region_online_lookup_timeout) or 20.0)

        if age >= timeout then
            ui.network.server_region_online_lookup_active_ip = ""
            ui.network.server_region_online_lookup_active_path = ""
            ui.network.server_region_online_lookup_status = "GeoIP lookup timed out."

            if type(ui.network.server_region_online_lookup_next_retry) ~= "table" then
                ui.network.server_region_online_lookup_next_retry = {}
            end

            ui.network.server_region_online_lookup_next_retry[ip_address] =
                os.clock() + math.max(120.0, tonumber(ui.network.server_region_online_lookup_retry_interval) or 600.0)
        end

        return ""
    end

    local read_ok, content = pcall(function() return file:read("*a") end)
    pcall(function() file:close() end)

    if not read_ok then
        return ""
    end

    content = tostring(content or "")
        :gsub("^\239\187\191", "")
        :gsub("[\r\n]+", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")

    if content == "" then
        return ""
    end

    ui.network.server_region_online_lookup_active_ip = ""
    ui.network.server_region_online_lookup_active_path = ""

    local status = content:match("^([^|]+)") or ""

    if status == "OK" then
        local details = dst_geo_parse_kv_line(content)
        details = ui.network.normalize_geoip_detail(details, ip_address)

        if ui.network.cache_geoip_online_details(ip_address, details) then
            return tostring(details.country or "")
        end
    end

    local error_message = content:match("message=([^|]+)") or "Unknown error"
    ui.network.server_region_online_lookup_status = "GeoIP lookup failed: " .. tostring(error_message)

    if type(ui.network.server_region_online_lookup_next_retry) ~= "table" then
        ui.network.server_region_online_lookup_next_retry = {}
    end

    ui.network.server_region_online_lookup_next_retry[ip_address] =
        os.clock() + math.max(120.0, tonumber(ui.network.server_region_online_lookup_retry_interval) or 600.0)

    return ""
end

function ui.network.get_geoip_details_from_online_lookup(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)

    if ip_address == "" then
        return nil
    end

    local cached = ui.network.get_geoip_details_from_online_cache(ip_address)
    if cached ~= nil then
        return cached
    end

    local active_country = ui.network.read_geoip_online_lookup_result(ip_address)
    if active_country ~= "" then
        return ui.network.get_geoip_details_from_online_cache(ip_address)
    end

    ui.network.start_geoip_online_lookup(ip_address)
    return nil
end

function ui.network.get_geoip_country_from_online_lookup(ip_address)
    local details = ui.network.get_geoip_details_from_online_lookup(ip_address)
    return details and tostring(details.country or "") or ""
end

function ui.network.get_server_geoip_details(address)
    address = tostring(address or "")
    local ip, port = ui.network.extract_server_ip_port(address)

    local details = nil
    local known = false
    local detecting = false

    if address == "" or address == "Unknown" or address == "CONNECTED SERVER" then
        return {
            ip = "",
            port = "",
            country = "",
            display = "-"
        }, false, false
    end

    if ui.network.is_local_server_address(address) then
        return {
            ip = ip,
            port = port,
            country = "",
            city = "",
            display = "-"
        }, false, false
    end

    if ip ~= "" and ui.network.is_private_ipv4_address(ip) then
        return {
            ip = ip,
            port = port,
            country = "",
            city = "",
            display = "-"
        }, false, false
    end

    local manual = ui.network.get_manual_server_region(address, ip)
    if manual ~= "" then
        details = ui.network.normalize_geoip_detail({
            query = ip,
            country = manual,
            source = "manual"
        }, ip)
        known = true
    end

    if details == nil and ip ~= "" then
        details = ui.network.get_geoip_details_from_online_lookup(ip)
        if ui.network.geoip_detail_has_country(details) then
            known = true
        else
            details = nil
            detecting = ui.network.is_geoip_online_lookup_pending(ip)
        end
    end

    if details == nil and ip ~= "" then
        local file_country = ui.network.get_geoip_country_from_file(ip)
        if file_country ~= "" then
            details = ui.network.normalize_geoip_detail({
                query = ip,
                country = file_country,
                source = "offline-file"
            }, ip)
            known = true
        end
    end

    if details == nil and ip ~= "" then
        local builtin_country = ui.network.get_builtin_ip_region(ip)
        if builtin_country ~= "" then
            details = ui.network.normalize_geoip_detail({
                query = ip,
                country = builtin_country,
                source = "builtin"
            }, ip)
            known = true
        end
    end

    if details == nil then
        local hostname = ui.network.get_cached_server_hostname(address)
        local hostname_region, hostname_known = ui.network.extract_region_from_hostname(hostname)
        if hostname_known == true and tostring(hostname_region or "") ~= "" then
            details = ui.network.normalize_geoip_detail({
                query = ip,
                country = hostname_region,
                source = "hostname"
            }, ip)
            known = true
        end
    end

    if details == nil then
        details = {
            query = ip,
            country = detecting and "Detecting..." or "Unknown",
            source = detecting and "pending" or "unknown"
        }
        known = false
    end

    details = ui.network.normalize_geoip_detail(details, ip)
    details.ip = ip
    details.port = port
    details.display =
        known == true
        and ui.network.format_geoip_country_value(details)
        or (detecting and "Detecting..." or "Unknown")

    return details, known == true, detecting == true
end

