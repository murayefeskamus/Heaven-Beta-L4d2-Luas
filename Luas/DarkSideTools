end

function ui.favourites.is_pinned(
    entry
)
    local target_key =
        ui.favourites.entry_key(
            entry
        )

    for _, existing in ipairs(
        ui.favourites.normalize_entries()
    ) do
        if ui.favourites.entry_key(
            existing
        ) == target_key then

            return true
        end
    end

    return false
end

function ui.favourites.is_effectively_pinned(
