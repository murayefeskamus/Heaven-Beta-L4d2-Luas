    ui.lobby.special_infected_announce_cycle_position = 1
    ui.lobby.special_infected_announce_cycle_signature = ""
end

function ui.lobby.normalize_special_infected_announcement_templates()
    local default_template =
        tostring(
            ui.lobby.special_infected_announce_default_template
            or "{player} spawned as {class}."
        )

    if type(ui.lobby.special_infected_announce_templates) ~= "table" then
        ui.lobby.special_infected_announce_templates = {}
    end

    if #ui.lobby.special_infected_announce_templates == 0 then
        local legacy_template =
            ui.lobby.sanitize_special_infected_announcement_template(
                ui.lobby.special_infected_announce_template
            )

        table.insert(
            ui.lobby.special_infected_announce_templates,
            legacy_template ~= ""
                and legacy_template
                or default_template
        )
    end

    if type(ui.lobby.special_infected_announce_preferred) ~= "table" then
        ui.lobby.special_infected_announce_preferred = {}
    end

    local maximum_templates =
        math.max(
            1,
            math.floor(
                tonumber(
                    DARKSIDE_CONFIG.MAX_SPECIAL_INFECTED_ANNOUNCEMENT_TEMPLATES
                ) or 10
            )
        )

    while #ui.lobby.special_infected_announce_templates >
        maximum_templates do

        table.remove(
            ui.lobby.special_infected_announce_templates
        )

        table.remove(
            ui.lobby.special_infected_announce_preferred
        )
    end

    local preferred_found = false

    for index = 1,
        #ui.lobby.special_infected_announce_templates do

        ui.lobby.special_infected_announce_templates[index] =
            ui.lobby.sanitize_special_infected_announcement_template(
                ui.lobby.special_infected_announce_templates[index]
            )

        local preferred =
            ui.lobby.special_infected_announce_preferred[index] == true
            and ui.lobby.special_infected_announce_templates[index] ~= ""

        if preferred and not preferred_found then
            preferred_found = true
            ui.lobby.special_infected_announce_preferred[index] = true
        else
            ui.lobby.special_infected_announce_preferred[index] = false
        end
    end

    while #ui.lobby.special_infected_announce_preferred <
        #ui.lobby.special_infected_announce_templates do

        table.insert(
            ui.lobby.special_infected_announce_preferred,
            false
        )
    end

    while #ui.lobby.special_infected_announce_preferred >
        #ui.lobby.special_infected_announce_templates do

        table.remove(
            ui.lobby.special_infected_announce_preferred
        )
    end

    if type(ui.lobby.special_infected_removed_templates) ~= "table" then
        ui.lobby.special_infected_removed_templates = {}
    end

    if type(ui.lobby.special_infected_removed_preferred) ~= "table" then
        ui.lobby.special_infected_removed_preferred = {}
    end

    for index = #ui.lobby.special_infected_removed_templates,
        1,
        -1 do

        ui.lobby.special_infected_removed_templates[index] =
            ui.lobby.sanitize_special_infected_announcement_template(
                ui.lobby.special_infected_removed_templates[index]
            )

        ui.lobby.special_infected_removed_preferred[index] =
            ui.lobby.special_infected_removed_preferred[index] == true
    end

    while #ui.lobby.special_infected_removed_preferred <
        #ui.lobby.special_infected_removed_templates do

        table.insert(
            ui.lobby.special_infected_removed_preferred,
            false
        )
    end

    while #ui.lobby.special_infected_removed_preferred >
        #ui.lobby.special_infected_removed_templates do

        table.remove(
            ui.lobby.special_infected_removed_preferred
        )
    end

    ui.lobby.special_infected_announce_template =
        tostring(
            ui.lobby.special_infected_announce_templates[1]
            or default_template
        )
end

function ui.lobby.get_preferred_special_infected_announcement_index()
    ui.lobby.normalize_special_infected_announcement_templates()

    for index, preferred in ipairs(
        ui.lobby.special_infected_announce_preferred
    ) do
        if preferred == true
            and tostring(
                ui.lobby.special_infected_announce_templates[index]
                or ""
            ) ~= "" then

            return index
        end
    end

    return nil
end

function ui.lobby.get_special_infected_announcement_templates()
    ui.lobby.normalize_special_infected_announcement_templates()

    local active_templates = {}

    for _, template_text in ipairs(
        ui.lobby.special_infected_announce_templates
    ) do
        template_text =
            ui.lobby.sanitize_special_infected_announcement_template(
                template_text
            )

        if template_text ~= "" then
            table.insert(
                active_templates,
                template_text
            )
        end
    end

    if #active_templates == 0 then
        table.insert(
            active_templates,
            tostring(
                ui.lobby.special_infected_announce_default_template
                or "{player} spawned as {class}."
            )
        )
    end

    return active_templates
end

function ui.lobby.get_special_infected_preview_template()
    ui.lobby.normalize_special_infected_announcement_templates()

    local preferred_index =
        ui.lobby.get_preferred_special_infected_announcement_index()

    if preferred_index then
        return tostring(
            ui.lobby.special_infected_announce_templates[preferred_index]
        )
    end

    local active_templates =
        ui.lobby.get_special_infected_announcement_templates()

    return tostring(
        active_templates[1]
        or ui.lobby.special_infected_announce_default_template
        or "{player} spawned as {class}."
    )
end


function ui.lobby.get_special_infected_announcement_template()
    return ui.lobby.get_special_infected_preview_template()
end

function ui.lobby.get_next_special_infected_announcement_template()
    ui.lobby.normalize_special_infected_announcement_templates()

    local preferred_index =
        ui.lobby.get_preferred_special_infected_announcement_index()

    if preferred_index then
        return tostring(
            ui.lobby.special_infected_announce_templates[preferred_index]
        )
    end

    local active_templates =
        ui.lobby.get_special_infected_announcement_templates()

    local signature =
        table.concat(
            active_templates,
            "\31"
        )

    local cycle =
        type(ui.lobby.special_infected_announce_cycle) == "table"
        and ui.lobby.special_infected_announce_cycle
        or {}

    local cycle_position =
        math.max(
            1,
            math.floor(
                tonumber(
                    ui.lobby.special_infected_announce_cycle_position
                ) or 1
            )
        )

    if signature ~= tostring(
        ui.lobby.special_infected_announce_cycle_signature or ""
    )
        or cycle_position > #cycle
        or #cycle ~= #active_templates then

        cycle = {}

        for index = 1, #active_templates do
            cycle[index] = index
        end

        for index = #cycle, 2, -1 do
            local swap_index = math.random(1, index)

            cycle[index], cycle[swap_index] =
                cycle[swap_index], cycle[index]
        end

        cycle_position = 1
        ui.lobby.special_infected_announce_cycle_signature = signature
    end

    local template_index =
        tonumber(cycle[cycle_position]) or 1

    ui.lobby.special_infected_announce_cycle = cycle
    ui.lobby.special_infected_announce_cycle_position =
        cycle_position + 1

    return tostring(
        active_templates[template_index]
        or active_templates[1]
    )
end

function ui.lobby.build_special_infected_announcement(
    player_name,
    class_name,
    template_override
)
    local template_text =
        template_override ~= nil
        and ui.lobby.sanitize_special_infected_announcement_template(
            template_override
        )
        or ui.lobby.get_next_special_infected_announcement_template()

    if template_text == "" then
        template_text =
            tostring(
                ui.lobby.special_infected_announce_default_template
                or "{player} spawned as {class}."
            )
    end

    local safe_player_name =
        tostring(player_name or "Infected player")
        :gsub("[\r\n]", " ")

    local safe_class_name =
        tostring(class_name or "Special Infected")
        :gsub("[\r\n]", " ")

    local message =
        template_text:gsub(
            "{player}",
            function()
                return safe_player_name
            end
        )

    message = message:gsub(
        "{class}",
        function()
            return safe_class_name
        end
    )

    return ui.lobby.sanitize_special_infected_announcement_template(
        message
    )
end

function ui.lobby.build_bot_special_infected_announcement(
    class_name
)
    local safe_class_name =
        tostring(class_name or "Special Infected")
        :gsub("[\r\n]", " ")

    return ui.lobby.sanitize_special_infected_announcement_template(
        safe_class_name .. " [BOT] detected."
    )
end

function ui.lobby.get_infected_prediction_class_limit(
    class_id
)
    class_id = math.floor(
        tonumber(class_id) or 0
    )

    local cvar_name =
        ui.lobby.infected_prediction_limit_cvars[class_id]

    local configured_limit = nil

    if cvar_name then
        configured_limit = tonumber(
            ui.lobby.read_cvar(
                cvar_name
            )
        )
    end

    if configured_limit == nil then
        configured_limit = 1
    end

    return math.max(
        0,
        math.floor(
            configured_limit
        )
    )
end


function ui.lobby.format_infected_player_prediction_line(
    prediction_row
)
    if type(prediction_row) ~= "table" then
        return "Class prediction unavailable."
    end

    local player_name =
        tostring(prediction_row.name or "Player")

    local class_name =
        tostring(prediction_row.class_name or "Unavailable")

    if prediction_row.exact == true then
        return player_name ..
            " - " ..
            (
                prediction_row.state == "Ghost"
                and "assigned ghost class"
                or "current class"
            ) ..
            ": " ..
            class_name
    end

    return player_name ..
        " - predicted next class: " ..
        class_name ..
        " (" ..
        ui.lobby.format_prediction_percentage(
            prediction_row.chance
        ) ..
        ")"
end

function ui.lobby.format_next_infected_class_prediction()
    local prediction =
        ui.lobby.get_next_infected_class_prediction()

    local parts = {}

    for _, row in ipairs(
        prediction.rows or {}
    ) do
        if tonumber(row.chance) > 0 then
            table.insert(
                parts,
                tostring(row.name) ..
                    " " ..
                    ui.lobby.format_prediction_percentage(
                        row.chance
                    )
            )
        end
    end

    if #parts == 0 then
        return "unavailable"
    end

    return table.concat(
        parts,
        " | "
    )
end


function ui.lobby.draw_next_infected_class_prediction_table()
    local prediction =
