function ui.setting_search.prepare_exact_scroll(result)
    result = type(result) == "table" and result or nil

    if not result then
        ui.setting_search.reset_exact_scroll()
        return
    end

    ui.setting_search.exact_scroll_pending = true
    ui.setting_search.exact_scroll_found = false
    ui.setting_search.exact_scroll_attempts = 0
    ui.setting_search.exact_scroll_tab = tostring(result.tab_key or "")
    ui.setting_search.exact_scroll_section = tostring(result.section_key or "")
    ui.setting_search.exact_scroll_term = tostring(result.term or "")
    ui.setting_search.exact_scroll_query = tostring(ui.setting_search.query or "")
    ui.setting_search.exact_target_content_y = nil
    ui.setting_search.exact_scroll_success_frames = 0
    ui.setting_search.exact_capture_consumed = false
    ui.setting_search.setting_search_scroll_jump_frames = math.max(
        3,
        math.floor(tonumber(ui.setting_search.setting_search_scroll_max_jump_frames) or 8)
    )
    ui.setting_search.setting_search_scroll_section_target_y = nil
    ui.setting_search.setting_search_scroll_best_score = 0
    ui.setting_search.setting_search_scroll_overlay_drawn = false
end

function ui.setting_search.setting_search_scroll_item_score(label)
    local candidate = ui.setting_search.normalize(
        ui.setting_search.visible_item_label(label)
    )
    local target = ui.setting_search.normalize(
        ui.setting_search.exact_scroll_term
    )

    if candidate == "" or target == "" then
        return 0
    end

    if candidate == target then
        return 1000
    end

    if candidate:find(target .. " ", 1, true) == 1 then
        return 920 - math.min(120, #candidate - #target)
    end

    if target:find(candidate .. " ", 1, true) == 1 then
        return 860 - math.min(120, #target - #candidate)
    end

    local target_tokens = ui.setting_search.meaningful_tokens(target)
    local candidate_tokens = ui.setting_search.meaningful_tokens(candidate)

    if #target_tokens == 0 or #candidate_tokens == 0 then
        return 0
    end

    local candidate_lookup = {}
    for _, token in ipairs(candidate_tokens) do
        candidate_lookup[token] = true
    end

    local matched = 0
    for _, token in ipairs(target_tokens) do
        if candidate_lookup[token] then
            matched = matched + 1
        end
    end

    if matched == #target_tokens then
        local extra_tokens = math.max(0, #candidate_tokens - matched)
        return 760 - math.min(180, extra_tokens * 24)
    end

    if matched >= 2 and matched / #target_tokens >= 0.70 then
        return 620 + matched * 10
    end

    return 0
end

function ui.setting_search.setting_search_match_is_exact_rendered_label(label)
    if ui.setting_search.exact_observer_guard == true
        or ui.setting_search.rendering_exact_target_section ~= true then
        return false
    end

    return ui.setting_search.setting_search_scroll_item_score(label) > 0
end

function ui.setting_search.setting_search_match_make_temporary_wrapper(raw_method, label_index)
    return function(...)
        local label = select(label_index, ...)
        local score = ui.setting_search.setting_search_scroll_item_score(label)
        local target_y = nil

        if score > 0
            and ui.setting_search.rendering_exact_target_section == true then

            target_y = math.max(
                0.0,
                tonumber(ui.lobby.get_cursor_y()) or 0.0
            )
        end

        local packed_results = ui.setting_search.exact_pack(raw_method(...))

        if score > (tonumber(ui.setting_search.setting_search_scroll_best_score) or 0) then
            ui.setting_search.setting_search_scroll_best_score = score
            ui.setting_search.exact_target_content_y = target_y
            ui.setting_search.exact_scroll_found = target_y ~= nil

            if score >= 900 then
                ui.setting_search.setting_search_match_draw_exact_item_overlay()
                ui.setting_search.setting_search_scroll_overlay_drawn = true
            end
        end

        return ui.setting_search.exact_unpack(
            packed_results,
            1,
            packed_results.n
        )
    end
end

ui.setting_search.performance_tab_wrapper_cache = {}

function ui.setting_search.apply_exact_scroll()
    local target_y = tonumber(
        ui.setting_search.exact_target_content_y
        or ui.setting_search.setting_search_scroll_section_target_y
    )

    if target_y == nil then
        return false
    end

    local requested_scroll = math.max(0.0, target_y - 4.0)
    local applied = false

    if type(imgui.set_scroll_y) == "function" then
        local ok = pcall(imgui.set_scroll_y, requested_scroll)
        applied = ok == true
    end

    if not applied and type(imgui.set_scroll_from_pos_y) == "function" then
        local ok = pcall(imgui.set_scroll_from_pos_y, target_y, 0.0)
        applied = ok == true
    end

    if not applied then
        local restore_y = ui.lobby.get_cursor_y()
        ui.lobby.set_cursor_y(target_y)

        if type(imgui.set_scroll_here_y) == "function" then
            local ok = pcall(imgui.set_scroll_here_y, 0.0)
            applied = ok == true
        elseif type(imgui.set_scroll_here) == "function" then
            local ok = pcall(imgui.set_scroll_here, 0.0)
            applied = ok == true
        end

        ui.lobby.set_cursor_y(restore_y)
    end

    if applied then
        ui.setting_search.exact_scroll_success_frames =
            (tonumber(ui.setting_search.exact_scroll_success_frames) or 0) + 1
        ui.setting_search.setting_search_scroll_jump_frames = math.max(
            0,
            math.floor(tonumber(ui.setting_search.setting_search_scroll_jump_frames) or 0) - 1
        )

        if ui.setting_search.setting_search_scroll_jump_frames <= 0 then
            ui.setting_search.exact_scroll_pending = false
            ui.setting_search.exact_scroll_found = true
        end
    end

    return applied
end

function ui.setting_search.get_temporary_scroll_padding()
    local padding = math.max(
        900.0,
        tonumber(ui.setting_search.exact_padding_pixels) or 1200.0
    )

    if type(imgui.get_window_height) == "function" then
        local ok, height = pcall(imgui.get_window_height)
        if ok then
            height = tonumber(height)
            if height and height > 0.0 then
                padding = math.max(padding, height * 1.35 + 180.0)
            end
        end
    elseif type(imgui.get_window_size) == "function" then
        local ok, first, second = pcall(imgui.get_window_size)
        if ok then
            local _, height = ui.setting_search.setting_search_match_read_vec2(first, second)
            if height and height > 0.0 then
                padding = math.max(padding, height * 1.35 + 180.0)
            end
        end
    end

    return math.min(2400.0, padding)
end

function ui.section_layout.draw_sections(tab_key, renderers)
    renderers = type(renderers) == "table" and renderers or {}

    local rendered_count = 0
    local exact_tab_active =
        ui.setting_search.exact_scroll_pending == true
        and tostring(ui.setting_search.exact_scroll_tab) == tostring(tab_key)

    ui.setting_search.exact_target_content_y = nil
    ui.setting_search.setting_search_scroll_section_target_y = nil
    ui.setting_search.setting_search_scroll_best_score = 0
    ui.setting_search.setting_search_scroll_overlay_drawn = false

    for _, section_key in ipairs(ui.section_layout.normalize_order(tab_key)) do
        local renderer = renderers[section_key]

        if type(renderer) == "function" then
            if rendered_count > 0 then
                draw_compact_gap()
            end

            local section_start_y = math.max(
                0.0,
                tonumber(ui.lobby.get_cursor_y()) or 0.0
            )
            local is_section_jump_target =
                tostring(ui.setting_search.exact_scroll_tab) == tostring(tab_key)
                and tostring(ui.setting_search.exact_scroll_section) == tostring(section_key)
                and ui.setting_search.exact_scroll_pending == true

            if is_section_jump_target then
                ui.setting_search.expand_section(tab_key, section_key)
                ui.setting_search.setting_search_scroll_section_target_y = section_start_y

                ui.setting_search.pending_frames = 0
                ui.setting_search.pending_tab = ""
                ui.setting_search.pending_section = ""
            end

            local is_active_result_section =
                tostring(ui.setting_search.active_highlight_term or "") ~= ""
                and tostring(ui.setting_search.active_highlight_tab) == tostring(tab_key)
                and tostring(ui.setting_search.active_highlight_section) == tostring(section_key)

            ui.setting_search.rendering_highlight_active = is_active_result_section
            ui.setting_search.rendering_highlight_consumed = false
            ui.setting_search.rendering_exact_target_section =
                is_active_result_section and is_section_jump_target and exact_tab_active

            if ui.setting_search.rendering_exact_target_section then
                ui.setting_search.setting_search_match_install_temporary_observers()
            end

            renderer()

            if ui.setting_search.rendering_exact_target_section then
                ui.setting_search.setting_search_match_restore_temporary_observers()
            end

            ui.setting_search.rendering_exact_target_section = false
            ui.setting_search.rendering_highlight_active = false
            ui.setting_search.rendering_highlight_consumed = false
            rendered_count = rendered_count + 1
        end
    end

    if ui.setting_search.should_add_temporary_padding(tab_key) then
        local current_y = ui.lobby.get_cursor_y()
        ui.lobby.set_cursor_y(
            current_y + ui.setting_search.get_temporary_scroll_padding()
        )
    end

    if exact_tab_active then
        if ui.setting_search.exact_target_content_y == nil then
            ui.setting_search.exact_target_content_y =
                ui.setting_search.setting_search_scroll_section_target_y
        end

        if ui.setting_search.exact_target_content_y ~= nil then
            ui.setting_search.apply_exact_scroll()
        else
            ui.setting_search.exact_scroll_attempts =
                (tonumber(ui.setting_search.exact_scroll_attempts) or 0) + 1

            if ui.setting_search.exact_scroll_attempts >= 12 then
                ui.setting_search.exact_scroll_pending = false
                ui.setting_search.set_status(
                    "The selected search destination is unavailable in the current layout.",
                    true
                )
            end
        end
    end

    ui.setting_search.setting_search_match_restore_temporary_observers()
end



