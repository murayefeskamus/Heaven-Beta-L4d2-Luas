function chat_spammer.parrot_message_is_allowed(
    author_name,
    spoken_text
)
    author_name =
        tostring(
            author_name or ""
        )

    spoken_text =
        tostring(
            spoken_text or ""
        )

    local selected_author = false

    for _, selected_name in ipairs(
        chat_spammer.parrot_filter_selected_names
    ) do
        if selected_name == author_name then
            selected_author = true
            break
        end
    end

    if chat_spammer.parrot_filter_mode == 1
        and not selected_author then

        return false
    elseif chat_spammer.parrot_filter_mode == 2
        and selected_author then

        return false
    end

    local keyword_filter =
        tostring(
            chat_spammer.parrot_keyword_filter or ""
        )

    keyword_filter =
        keyword_filter:gsub(
            "^%s+",
            ""
        ):gsub(
            "%s+$",
            ""
        )

    if keyword_filter == "" then
        return true
    end

    local spoken_lower =
        spoken_text:lower()

    local has_keyword = false
    local saw_keyword = false

    for keyword in keyword_filter:gmatch(
        "[^,;]+"
    ) do
        keyword =
            keyword:gsub(
                "^%s+",
                ""
            ):gsub(
                "%s+$",
                ""
            )

        if keyword ~= "" then
            saw_keyword = true

            if spoken_lower:find(
                keyword:lower(),
                1,
                true
            ) then

                has_keyword = true
                break
            end
        end
    end

    return not saw_keyword
        or has_keyword
end

