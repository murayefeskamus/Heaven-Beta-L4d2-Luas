function ui.kill_tools.build_context(
    event
)
    if not event
        or not engine.is_in_game()
        or not engine.is_connected() then

        return nil
    end

    local local_player =
        client.get_local_player()

    if not local_player then
        return nil
    end

    local local_index_success,
        local_index =
            pcall(
                function()
                    return local_player:get_index()
                end
            )

    local_index =
        local_index_success
        and tonumber(local_index)
        or 0

    if local_index <= 0 then
        return nil
    end

    local attacker_userid =
        ui.kill_tools.safe_event_int(
            event,
            "attacker"
        )

    local victim_userid =
        ui.kill_tools.safe_event_int(
            event,
            "userid"
        )

    local attacker_index =
        ui.kill_tools.player_index_from_userid(
            attacker_userid
        )

    local victim_index =
        ui.kill_tools.player_index_from_userid(
            victim_userid
        )

    if attacker_index <= 0
        or victim_index <= 0
        or victim_index == attacker_index then

        return nil
    end

    local attacker_info =
        ui.kill_tools.get_player_info(
            attacker_index
        )

    local victim_info =
        ui.kill_tools.get_player_info(
            victim_index
        )

    local attacker_entity =
        ui.kill_tools.get_player_entity(
            attacker_index
        )

    local victim_entity =
        ui.kill_tools.get_player_entity(
            victim_index
        )

    local attacker_team =
        ui.kill_tools.get_player_team(
            attacker_entity
        )

    local victim_team =
        ui.kill_tools.get_player_team(
            victim_entity
        )

    local same_team =
        attacker_team > 1
        and victim_team > 1
        and attacker_team == victim_team

    local raw_weapon =
        ui.kill_tools.safe_event_string(
            event,
            "weapon"
        )

    local context = {
        attacker_userid = attacker_userid,
        victim_userid = victim_userid,
        attacker_index = attacker_index,
        victim_index = victim_index,
        local_kill = attacker_index == local_index,
        killer_name =
            ui.kill_tools.get_player_name(
                attacker_index,
                attacker_info,
                attacker_entity
            ),
        victim_name =
            ui.kill_tools.get_player_name(
                victim_index,
                victim_info,
                victim_entity
            ),
        attacker_team = attacker_team,
        victim_team = victim_team,
        same_team = same_team,
        enemy_kill = not same_team,
        victim_is_bot =
            ui.kill_tools.is_bot_victim(
                victim_index,
                victim_entity
            ),
        infected_class =
            ui.kill_tools.get_infected_class(
                victim_entity,
                victim_team
            ),
        raw_weapon = raw_weapon,
        weapon_name =
            ui.kill_tools.get_weapon_name(
                raw_weapon
            ),
        headshot =
            ui.kill_tools.safe_event_bool(
                event,
                "headshot"
            )
    }

    context.signature =
        tostring(attacker_userid) ..
        ":" ..
        tostring(victim_userid) ..
        ":" ..
        tostring(raw_weapon) ..
        ":" ..
        tostring(context.headshot)

    return context
end

function ui.kill_tools.context_allowed(
    context,
    settings
)
    if not context
        or type(settings) ~= "table" then

        return false
    end

    if settings.enemy_kills_only == true
        and context.enemy_kill ~= true then

        return false
    end

    if settings.include_bot_victims ~= true
        and context.victim_is_bot == true then

        return false
    end

    return true
end

function ui.kill_tools.build_feed_message(
    context
)
    local settings =
        ui.kill_tools.kill_feed

    local message =
        tostring(context.killer_name) ..
        " killed " ..
        tostring(context.victim_name)

    if settings.show_infected_class == true
        and context.infected_class ~= "" then

        message =
            message ..
            " (" ..
            tostring(context.infected_class) ..
            ")"
    end

    if settings.show_weapon == true
        and context.raw_weapon ~= "" then

        message =
            message ..
            " with " ..
            tostring(context.weapon_name)
    end

    if settings.show_headshots == true
        and context.headshot == true then

        message =
            message ..
            " [HEADSHOT]"
    end

    return message
end

function ui.kill_tools.emit_feed(
    context,
    suppress_chat_output
)
    local settings =
        ui.kill_tools.kill_feed

    if settings.enabled ~= true
        or not ui.kill_tools.context_allowed(
            context,
            settings
        ) then

        return false
    end

    local message = ""

    local template =
        ui.kill_tools.next_feed_template(
            context
        )

    if template then
        message =
            ui.kill_tools.format_message(
                template,
                context
            )
    else
        message =
            ui.kill_tools.build_feed_message(
                context
            )
    end

    if message == "" then
        return false
    end

    local posted_to_chat = false

    if settings.all_chat_output == true
        and suppress_chat_output ~= true then

        local safe_message =
            sanitize_chat_message(
                message,
                true
            )

        if safe_message ~= "" then
            if ui.lobby
                and type(
                    ui.lobby.append_chat_message
                ) == "function" then

                local feed_initial_delay = 0.05

                if ui.kill_tools
                    and type(
                        ui.kill_tools.get_hidden_name_chat_delay
                    ) == "function" then

                    feed_initial_delay =
                        ui.kill_tools.get_hidden_name_chat_delay(
                            feed_initial_delay
                        )
                end

                posted_to_chat =
                    ui.lobby.append_chat_message(
                        safe_message,
                        false,
                        feed_initial_delay
                    ) == true
            end

            if posted_to_chat ~= true then
                posted_to_chat =
                    pcall(
                        client.execnormal,
                        'say "' ..
                            safe_message ..
                            '"'
                    ) == true

                if posted_to_chat == true
                    and chat_spammer then

                    chat_spammer.automatic_chat_lane_used_this_frame = true
                end
            end
        end
    end

    settings.notification_count =
        (tonumber(settings.notification_count) or 0) + 1

    settings.last_message =
        message

    return true
end

