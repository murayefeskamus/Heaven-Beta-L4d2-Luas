function ui.favourites.ensure_renderer(
    tab_key,
    section_key
)
    tab_key =
        tostring(tab_key or "")

    section_key =
        tostring(section_key or "")

    local cached =
        type(
            ui.favourites.renderer_cache[
                tab_key
            ]
        ) == "table"
        and ui.favourites.renderer_cache[
            tab_key
        ][
            section_key
        ]
        or nil

    if type(cached) == "function" then
        return cached
    end

    if ui.favourites.capture_in_progress == true then
        return nil
    end

    local source_drawer =
        ui.favourites.get_source_drawer(
            tab_key
        )

    if type(source_drawer) ~= "function" then
        return nil
    end

    local previous_capture_only =
        ui.favourites.capture_only

    local previous_capture_in_progress =
        ui.favourites.capture_in_progress

    local previous_rendering_tab =
        ui.favourites.rendering_tab

    local previous_selected_tool =
        ui.selected_tool

    ui.favourites.capture_only = true
    ui.favourites.capture_in_progress = true
    ui.favourites.rendering_tab = false

    local tool_index =
        ui.favourites.tool_indices[
            tab_key
        ]

    if tool_index ~= nil then
        ui.selected_tool =
            tool_index
    end

    local capture_ok,
        capture_error =
            pcall(
                source_drawer
            )

    ui.selected_tool =
        previous_selected_tool

    ui.favourites.rendering_tab =
        previous_rendering_tab

    ui.favourites.capture_only =
        previous_capture_only

    ui.favourites.capture_in_progress =
        previous_capture_in_progress

    if not capture_ok then
        ui.favourites.set_status(
            "Favourite could not be prepared: " ..
            tostring(capture_error),
            true
        )

        return nil
    end

    return
        type(
            ui.favourites.renderer_cache[
                tab_key
            ]
        ) == "table"
        and ui.favourites.renderer_cache[
            tab_key
        ][
            section_key
        ]
        or nil
end

