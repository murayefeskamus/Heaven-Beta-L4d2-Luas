function ui.network.write_geoip_country_template(path)
    path = tostring(path or "")

    if path == ""
        or type(io) ~= "table"
        or type(io.open) ~= "function" then

        return false
    end

    local file_ok, file = pcall(io.open, path, "wb")

    if not file_ok or not file then
        return false
    end

    local template = table.concat(
        {
            "# Optional DarkSideTools offline GeoIP fallback.",
            "# The script can do async online country lookup when this file is empty/missing.",
            "# Add manual offline ranges here only if you want instant local lookup.",
            "# Supported examples:",
            "# 164.132.0.0/16=France",
            "# 45.67.85.0-45.67.85.255=United Kingdom",
            "# 155.133.181.0,155.133.181.255,Sweden",
            ""
        },
        "\n"
    )

    local write_ok = pcall(
        function()
            file:write(template)
        end
    )

    pcall(function() file:close() end)

    return write_ok == true
end

function ui.network.parse_geoip_country_line(line)
    line =
        tostring(line or "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

    if line == ""
        or line:sub(1, 1) == "#"
        or line:sub(1, 2) == "--" then

        return nil
    end

    line = line:gsub("%s+#.*$", "")

    local lower_line = line:lower()
    if lower_line:find("network", 1, true)
        and lower_line:find("country", 1, true) then

        return nil
    end

    local range_text = nil
    local country = nil
    local first_value = nil
    local last_value = nil

    local start_ip, end_ip, country_value =
        line:match(
            "^(%d+%.%d+%.%d+%.%d+)%s*,%s*(%d+%.%d+%.%d+%.%d+)%s*,%s*(.+)$"
        )

    if start_ip ~= nil and end_ip ~= nil and country_value ~= nil then
        range_text = start_ip .. "-" .. end_ip
        country = country_value
    end

    if range_text == nil then
        local number_first, number_last, number_country =
            line:match("^(%d+)%s*,%s*(%d+)%s*,%s*(.+)$")

        if number_first ~= nil
            and number_last ~= nil
            and number_country ~= nil then

            first_value = tonumber(number_first)
            last_value = tonumber(number_last)
            country = number_country

            if first_value ~= nil
                and last_value ~= nil
                and first_value > last_value then

                first_value, last_value = last_value, first_value
            end
        end
    end

    if range_text == nil and first_value == nil then
        range_text,
            country =
                line:match("^([^=,;|]+)%s*[=,;|]%s*(.+)$")
    end

    if country == nil then
        return nil
    end

    country = ui.network.normalize_geoip_country_label(country)

    if country == "" then
        return nil
    end

    if first_value == nil or last_value == nil then
        if range_text == nil then
            return nil
        end

        first_value, last_value =
            ui.network.parse_geoip_country_range(range_text)
    end

    if first_value == nil or last_value == nil then
        return nil
    end

    return {
        first = first_value,
        last = last_value,
        country = country
    }
end

function ui.network.load_geoip_country_database()
    if ui.network.server_region_geoip_loaded == true then
        return
    end

    ui.network.server_region_geoip_loaded = true
    ui.network.server_region_geoip_ranges = {}

    if type(io) ~= "table" or type(io.open) ~= "function" then
        ui.network.server_region_geoip_status = "Lua file IO unavailable."
        return
    end

    local path = ui.network.get_geoip_country_path()
    local file_ok, file = pcall(io.open, path, "rb")

    if not file_ok or not file then
        if ui.network.write_geoip_country_template(path) then
            ui.network.server_region_geoip_status =
                "Created optional GeoIP template."
        else
            ui.network.server_region_geoip_status =
                "No GeoIP country file."
        end

        return
    end

    local ranges = {}
    local line_count = 0
    local max_lines =
        math.max(
            1000,
            math.floor(
                tonumber(ui.network.server_region_geoip_max_lines) or 200000
            )
        )

    for line in file:lines() do
        line_count = line_count + 1

        if line_count > max_lines then
            break
        end

        local parsed = ui.network.parse_geoip_country_line(line)

        if type(parsed) == "table" then
            ranges[#ranges + 1] = parsed
        end
    end

    pcall(function() file:close() end)

    table.sort(
        ranges,
        function(a, b)
            return (tonumber(a.first) or 0) <
                (tonumber(b.first) or 0)
        end
    )

    ui.network.server_region_geoip_ranges = ranges
    ui.network.server_region_geoip_status =
        "Loaded " .. tostring(#ranges) .. " GeoIP ranges."
end

function ui.network.get_geoip_country_from_file(ip_address)
    ip_address = tostring(ip_address or "")

    local ip_value = ui.network.ipv4_to_number(ip_address)

    if ip_value == nil then
        return ""
    end

    ui.network.load_geoip_country_database()

    local ranges =
        type(ui.network.server_region_geoip_ranges) == "table"
        and ui.network.server_region_geoip_ranges
        or {}

    local left = 1
    local right = #ranges

    while left <= right do
        local middle = math.floor((left + right) / 2)
        local entry = ranges[middle]
        local first = tonumber(entry.first) or 0
        local last = tonumber(entry.last) or 0

        if ip_value < first then
            right = middle - 1
        elseif ip_value > last then
            left = middle + 1
        else
            return tostring(entry.country or "")
        end
    end

    return ""
end


