    remembered_yes,
    remembered_no
)
    local palette =
        ui.enhancements.theme_palette()

    local rows = {}

    if remembered_vote then
        local result_color =
            remembered_state == "Passed"
            and { 0.38, 0.86, 0.46, 1.0 }
            or remembered_state == "Failed"
            and { 0.94, 0.38, 0.38, 1.0 }
            or remembered_state == "Active"
            and { 0.52, 0.78, 0.92, 1.0 }
            or { 0.90, 0.68, 0.30, 1.0 }

        rows = {
            {
                label = "Date & time",
                value = tostring(
                    remembered_vote.recorded_at_text
                    or "Unknown"
                )
            },
            {
                label = "Map",
                value = chat_spammer.truncate_vote_text(
                    tostring(
                        remembered_vote.map_name
                        or remembered_vote.map_code
                        or "Unknown"
                    ),
                    42
                )
            },
            {
                label = "Vote",
                value = chat_spammer.truncate_vote_text(
                    chat_spammer.vote_action_label(
                        remembered_vote
                    ),
                    48
                )
            },
            {
                label = "Caller",
                value = chat_spammer.truncate_vote_text(
                    tostring(
                        remembered_vote.caller
                        or "Unknown player"
                    ),
                    36
                )
            },
            {
                label = "Scope",
                value = chat_spammer.vote_scope_label(
                    remembered_vote
                )
            },
            {
                label = "Mode",
                value = chat_spammer.truncate_vote_text(
                    tostring(
                        remembered_vote.game_mode
                        or "Unknown"
                    ),
                    28
                )
            },
            {
                label = "Result",
                value = tostring(
                    remembered_state or "Unknown"
                ),
                color = result_color
            },
            {
                label = "Votes",
                value =
                    tostring(
                        math.max(
                            0,
                            tonumber(remembered_yes) or 0
                        )
                    ) ..
                    " yes  /  " ..
                    tostring(
                        math.max(
                            0,
                            tonumber(remembered_no) or 0
                        )
                    ) ..
                    " no"
            }
        }
    end

    local label_width = 96
    local value_width = 190

    for _, row in ipairs(rows) do
        label_width =
            math.max(
                label_width,
                ui.lobby.measure_text_width(
                    tostring(row.label or "")
                ) + 14
            )

        value_width =
            math.max(
                value_width,
                ui.lobby.measure_text_width(
                    tostring(row.value or "")
                ) + 16
            )
    end

    label_width =
        math.max(
            92,
            math.min(124, label_width)
        )

    value_width =
        math.max(
            220,
            math.min(430, value_width)
        )

    local card_width =
        math.max(
            390,
            math.min(
                580,
                label_width + value_width + 34
            )
        )

    local card_height =
        remembered_vote
        and (#rows * 20 + 28)
        or 58

    local card_open =
        imgui.begin_child(
            "DarkSideRememberedVoteSummary",
            card_width,
            card_height,
            true,
            0
        )

    if card_open then
        ui.draw_theme_table_header_text(
            "VOTE DETAILS"
        )

        imgui.separator()

        if remembered_vote then
            local start_x =
                ui.lobby.get_cursor_x()

            local divider_color =
                palette.border
                or palette.separator
                or palette.text_disabled

            for row_index, row in ipairs(rows) do
                ui.lobby.set_cursor_x(
                    start_x + 6
                )

                theme_text_colored(
                    palette.text_disabled[1],
                    palette.text_disabled[2],
                    palette.text_disabled[3],
                    1.0,
                    tostring(row.label or "")
                )

                imgui.same_line()
                ui.lobby.set_cursor_x(
                    start_x + label_width
                )

                theme_text_colored(
                    divider_color[1],
                    divider_color[2],
                    divider_color[3],
                    1.0,
                    "|"
                )

                imgui.same_line()
                ui.lobby.set_cursor_x(
                    start_x + label_width + 12
                )

                local row_color =
                    type(row.color) == "table"
                    and row.color
                    or palette.text

                theme_text_colored(
                    row_color[1] or 1.0,
                    row_color[2] or 1.0,
                    row_color[3] or 1.0,
                    row_color[4] or 1.0,
                    tostring(row.value or "")
                )

                if row_index < #rows then
                    imgui.separator()
                end
            end
        else
            theme_text_colored(
                palette.text_disabled[1],
                palette.text_disabled[2],
                palette.text_disabled[3],
                1.0,
                "No vote has been recorded yet."
            )
        end
    end

    imgui.end_child()
end

function chat_spammer.draw_manual_vote_voters_card(
    remembered_vote,
    remembered_records,
    remembered_row_count
)
    remembered_records =
        type(remembered_records) == "table"
        and remembered_records
        or {}

    remembered_row_count =
        math.max(
            0,
            math.floor(
                tonumber(remembered_row_count) or 0
            )
        )

    local palette =
        ui.enhancements.theme_palette()

    local id_width = 48
    local player_width = 150
    local team_width = 84
    local choice_width = 68

    for _, vote_record in ipairs(remembered_records) do
        id_width =
            math.max(
                id_width,
                ui.lobby.measure_text_width(
                    chat_spammer.vote_record_uid_text(
                        vote_record
                    )
                ) + 16
            )

        player_width =
            math.max(
                player_width,
                ui.lobby.measure_text_width(
                    tostring(
                        vote_record.name
                        or "Unknown player"
                    )
                ) + 18
            )

        team_width =
            math.max(
                team_width,
                ui.lobby.measure_text_width(
                    chat_spammer.vote_record_team_label(
                        vote_record
                    )
                ) + 18
            )
    end

    id_width = math.min(72, id_width)
    player_width = math.min(240, player_width)
    team_width = math.min(112, team_width)

    local left_padding = 6
    local divider_gap = 14
    local id_x = left_padding
    local first_divider_x = id_x + id_width
    local player_x = first_divider_x + divider_gap
    local second_divider_x = player_x + player_width
    local team_x = second_divider_x + divider_gap
    local third_divider_x = team_x + team_width
    local choice_x = third_divider_x + divider_gap

    local card_width =
        math.max(
            420,
            math.min(
                620,
                choice_x + choice_width + 14
            )
        )

    local visible_rows =
        math.max(
            1,
            #remembered_records
        )

    local card_height =
        remembered_vote
        and math.min(
            286,
            62 + visible_rows * 21
        )
        or 58

    local card_open =
        imgui.begin_child(
            "DarkSideRememberedVoteVoters",
            card_width,
            card_height,
            true,
            0
        )

    if card_open then
        ui.draw_theme_table_header_text(
            "VOTERS"
        )

        if remembered_vote then
            imgui.same_line()

            theme_text_colored(
                palette.text_disabled[1],
                palette.text_disabled[2],
                palette.text_disabled[3],
                1.0,
                tostring(#remembered_records) ..
                " shown / " ..
                tostring(remembered_row_count) ..
                " captured"
            )

            imgui.separator()

            local start_x =
                ui.lobby.get_cursor_x()

            local divider_color =
                palette.border
                or palette.separator
                or palette.text_disabled

            local function draw_divider(x_position)
                imgui.same_line()
                ui.lobby.set_cursor_x(
                    start_x + x_position
                )

                theme_text_colored(
                    divider_color[1],
                    divider_color[2],
                    divider_color[3],
                    1.0,
                    "|"
                )
            end

            ui.lobby.set_cursor_x(start_x + id_x)
            ui.draw_theme_table_header_text("ID")
            draw_divider(first_divider_x)

            imgui.same_line()
            ui.lobby.set_cursor_x(start_x + player_x)
            ui.draw_theme_table_header_text("PLAYER")
            draw_divider(second_divider_x)

            imgui.same_line()
            ui.lobby.set_cursor_x(start_x + team_x)
            ui.draw_theme_table_header_text("TEAM")
            draw_divider(third_divider_x)

            imgui.same_line()
            ui.lobby.set_cursor_x(start_x + choice_x)
            ui.draw_theme_table_header_text("CHOICE")

            imgui.separator()

            if #remembered_records > 0 then
                for record_index, vote_record in ipairs(
                    remembered_records
                ) do
                    ui.lobby.set_cursor_x(start_x + id_x)
                    theme_text_colored(
                        palette.text_disabled[1],
                        palette.text_disabled[2],
                        palette.text_disabled[3],
                        1.0,
                        chat_spammer.vote_record_uid_text(
                            vote_record
                        )
                    )

                    draw_divider(first_divider_x)

                    imgui.same_line()
                    ui.lobby.set_cursor_x(start_x + player_x)
                    theme_text_colored(
                        palette.text[1],
                        palette.text[2],
                        palette.text[3],
                        1.0,
                        chat_spammer.truncate_vote_text(
                            tostring(
                                vote_record.name
                                or "Unknown player"
                            ),
                            30
                        )
                    )

                    draw_divider(second_divider_x)

                    imgui.same_line()
                    ui.lobby.set_cursor_x(start_x + team_x)
                    theme_text_colored(
                        palette.text_disabled[1],
                        palette.text_disabled[2],
                        palette.text_disabled[3],
                        1.0,
                        chat_spammer.vote_record_team_label(
                            vote_record
                        )
                    )

                    draw_divider(third_divider_x)

                    imgui.same_line()
                    ui.lobby.set_cursor_x(start_x + choice_x)

                    local choice =
                        tostring(
                            vote_record.choice
                            or "UNKNOWN"
                        )

                    if choice == "YES" then
                        theme_text_colored(
                            0.38, 0.86, 0.46, 1.0,
                            "Yes"
                        )
                    elseif choice == "NO" then
                        theme_text_colored(
                            0.94, 0.38, 0.38, 1.0,
                            "No"
                        )
                    else
                        theme_text_colored(
                            palette.text_disabled[1],
                            palette.text_disabled[2],
                            palette.text_disabled[3],
                            1.0,
                            chat_spammer.format_status_label(
                                choice
                            )
                        )
                    end

                    if record_index < #remembered_records then
                        imgui.separator()
                    end
                end
            elseif remembered_row_count > 0 then
                theme_text_colored(
                    palette.text_disabled[1],
                    palette.text_disabled[2],
                    palette.text_disabled[3],
                    1.0,
                    "No voters match the selected filter."
                )
            else
                theme_text_colored(
                    palette.text_disabled[1],
                    palette.text_disabled[2],
                    palette.text_disabled[3],
                    1.0,
                    "No individual voter choices captured yet."
                )
            end
        else
            theme_text_colored(
                palette.text_disabled[1],
                palette.text_disabled[2],
                palette.text_disabled[3],
                1.0,
                "No vote selected."
            )
        end
    end

    imgui.end_child()
end

function chat_spammer.draw_chat_spammer_gui()
    local chat_controls_x =
        ui.lobby.get_aligned_control_x(
            {
                "Spam speed (msg/sec):",
                "Chat mode:",
                "Newline message:",
                "Message 10:",
                "Repeat style:",
                "Vote delivery:",
                "Lobby-wide Votes:",
                "Unresolved Team Chat:",
                "Filter mode:",
                "Player from lobby:",
                "Selected player:",
                "Keywords:"
            },
            10
        )

    local section_renderers = {
        automation = function()
            ui.chat_automation_expanded =
                draw_collapsible_section(
                    "AUTOMATION",
                    ui.chat_automation_expanded,
                    "ChatAutomation"
                )

            if ui.chat_automation_expanded then
                if chat_spammer.enabled then
                    if colored_button(
                        "Stop Chat Spammer",
                        1.0, 1.0, 1.0,
                        0.55, 0.08, 0.08
                    ) then
                        set_chat_spammer_enabled(false)
                    end
                else
                    if colored_button(
                        "Start Chat Spammer",
                        1.0, 1.0, 1.0,
                        0.08, 0.42, 0.12
                    ) then
                        local started =
                            set_chat_spammer_enabled(
                                true
                            )

                        if not started
                            and get_chat_cycle_message_count()
                                <= 0 then

                            chat_spammer.start_warning_until =
                                get_time() + 2.0
                        else
                            chat_spammer.start_warning_until =
                                0.0
                        end
                    end
                end

                if not chat_spammer.enabled
                    and get_time()
                        < chat_spammer.start_warning_until then

                    imgui.same_line()
                    theme_text_colored(
                        1.0, 0.2, 0.2, 1.0,
                        "Select at least one message or preset."
                    )
                end

                draw_compact_gap()

                if chat_spammer.enabled then
                    theme_text_colored(
                        0.2, 1.0, 0.2, 1.0,
                        "Chat spammer is running."
                    )
                else
                    theme_text_colored(
                        0.7, 0.7, 0.7, 1.0,
                        "Chat spammer is stopped."
                    )
                end

                imgui.text("Chat mode:")
                imgui.same_line()
                ui.lobby.set_cursor_x(
                    chat_controls_x
                )
                imgui.push_item_width(190)

                local neutral_chat_mode_colors =
                    push_neutral_combo_colors()

                local changed_mode,
                    mode_value =
                        imgui.combo(
                            "##ChatMode",
                            chat_spammer.mode,
                            CHAT_MODES
                        )

                pop_neutral_combo_colors(
                    neutral_chat_mode_colors
                )

                imgui.pop_item_width()

                if changed_mode then
                    chat_spammer.mode =
                        mode_value
                end

                draw_compact_gap()

                imgui.text("Spam speed (msg/sec):")
                imgui.same_line()
                ui.lobby.set_cursor_x(
                    chat_controls_x
                )
                imgui.push_item_width(190)

                local changed_speed,
                    speed_value =
                        imgui.slider_int(
                            "##ChatSpamSpeed",
                            math.floor(
                                tonumber(
                                    chat_spammer.speed
                                ) or DARKSIDE_CONFIG.MIN_CHAT_SPEED
                            ),
                            math.floor(
                                DARKSIDE_CONFIG.MIN_CHAT_SPEED
                            ),
                            math.floor(
                                DARKSIDE_CONFIG.MAX_CHAT_SPEED
                            )
                        )

                imgui.pop_item_width()

                if changed_speed then
                    chat_spammer.speed =
                        math.floor(
                            tonumber(
                                speed_value
                            ) or DARKSIDE_CONFIG.MIN_CHAT_SPEED
                        )

                    update_chat_delay_from_speed()

                    if chat_spammer.elapsed
                        > chat_spammer.delay then

                        chat_spammer.elapsed =
                            chat_spammer.delay
                    end
                end

                imgui.text("Send interval:")
                imgui.same_line()
                imgui.text(
                    string.format(
                        "%.3fs",
                        chat_spammer.delay
                    )
                )
            end
        end,
        messages = function()
            ui.chat_messages_expanded =
                draw_collapsible_section(
                    "MESSAGES SELECTOR",
                    ui.chat_messages_expanded,
                    "ChatMessages",
                    get_enabled_chat_message_count()
                )

            if ui.chat_messages_expanded then
                local all_messages_enabled =
                    are_all_chat_items_enabled()

                if all_messages_enabled then
                    if colored_button(
                        "Deselect All##ChatMessages",
                        1.0, 1.0, 1.0,
                        0.55, 0.08, 0.08
                    ) then
                        set_all_chat_items_enabled(
                            false
                        )
                        stop_chat_spammer_if_no_messages_enabled()
                    end
                else
                    if colored_button(
                        "Select All##ChatMessages",
                        1.0, 1.0, 1.0,
                        0.08, 0.42, 0.12
                    ) then
                        set_all_chat_items_enabled(
                            true
                        )
                    end
                end

                for index = 1,
                    get_chat_message_count() do

                    local message =
                        tostring(
                            get_chat_message(
                                index
                            ) or ""
                        )

                    local changed_enabled,
                        enabled_value =
                            imgui.checkbox(
                                "##EditableChatMessageEnabled" ..
                                tostring(index),
                                is_chat_message_enabled(
                                    index
                                )
                            )

                    if changed_enabled then
                        set_chat_message_enabled(
                            index,
                            enabled_value
                        )

                        stop_chat_spammer_if_no_messages_enabled()
                    end

                    imgui.same_line()
                    imgui.text(
                        "Message " ..
                        tostring(index) ..
                        ":"
                    )
                    imgui.same_line()
                    ui.lobby.set_cursor_x(
                        chat_controls_x
                    )
                    imgui.push_item_width(220)

                    local changed_message,
                        message_value =
                            draw_custom_message_input(
                                "##ChatMessage" ..
                                tostring(index),
                                message,
                                DARKSIDE_CONFIG.MAX_CHAT_MESSAGE_LENGTH
                            )

                    imgui.pop_item_width()

                    if changed_message then
                        set_chat_message(
                            index,
                            message_value
                        )

                        message =
                            tostring(
                                message_value or ""
                            )

                        if chat_spammer.is_chat_name_selected_for(
                            "editable",
                            index
                        ) then
                            clear_chat_applied_name_state()
                        end
                    end

                    local editable_vertical_active =
                        chat_spammer.is_chat_name_vertical_for(
                            "editable",
                            index
                        )

                    local editable_horizontal_active =
                        chat_spammer.is_chat_name_horizontal_for(
                            "editable",
                            index
                        )

                    imgui.same_line()

                    if editable_vertical_active then
                        if colored_button(
                            "Horizontal##EditableMessageName" ..
                            tostring(index),
                            0.15, 1.0, 1.0,
                            0.05, 0.30, 0.34
                        ) then
                            chat_spammer.apply_chat_message_as_name(
                                message,
                                "Message " ..
                                tostring(index),
                                false,
                                "editable",
                                index
                            )
                        end
                    elseif editable_horizontal_active then
                        if colored_button(
                            "Vertical##EditableMessageVertical" ..
                            tostring(index),
                            1.0, 1.0, 1.0,
                            0.30, 0.20, 0.48
                        ) then
                            chat_spammer.apply_chat_message_as_name(
                                message,
                                "Message " ..
                                tostring(index),
                                true,
                                "editable",
                                index
                            )
                        end
                    else
                        if colored_button(
                            "Use as Name##EditableMessageName" ..
                            tostring(index),
                            0.15, 1.0, 1.0,
                            0.05, 0.30, 0.34
                        ) then
                            chat_spammer.apply_chat_message_as_name(
                                message,
                                "Message " ..
                                tostring(index),
                                false,
                                "editable",
                                index
                            )
                        end

                        imgui.same_line()

                        if colored_button(
                            "Vertical##EditableMessageVertical" ..
                            tostring(index),
                            1.0, 1.0, 1.0,
                            0.30, 0.20, 0.48
                        ) then
                            chat_spammer.apply_chat_message_as_name(
                                message,
                                "Message " ..
                                tostring(index),
                                true,
                                "editable",
                                index
                            )
                        end
                    end
                end

                theme_text_colored(
                    0.65, 0.65, 0.65, 1.0,
                    "Type {newline} inside a message to create a new chat line. Empty fields are allowed."
                )

                if colored_button(
                    "Add Message Field",
                    0.15, 1.0, 1.0,
                    0.05, 0.30, 0.34
                ) then
                    add_chat_message_field()
                end

                if get_chat_message_count() > 1 then
                    imgui.same_line()

                    if colored_button(
                        "Remove Last Message Field",
                        1.0, 1.0, 1.0,
                        0.55, 0.08, 0.08
                    ) then
                        if remove_last_chat_message_field() then
                            stop_chat_spammer_if_no_messages_enabled()
                        end
                    end
                end
            end
        end,
        newline = function()
            ui.chat_newline_spam_expanded =
                draw_collapsible_section(
                    "NEWLINE SPAM",
                    ui.chat_newline_spam_expanded,
                    "ChatNewlineSpam"
                )

            if ui.chat_newline_spam_expanded then
                local changed_newline_enabled,
                    newline_enabled_value =
                        imgui.checkbox(
                            "Enable Newline Spam",
                            chat_spammer.newline_spam_enabled == true
                        )

                if changed_newline_enabled then
                    chat_spammer.set_newline_spam_enabled(
                        newline_enabled_value
                    )
                end


                imgui.same_line()

                local inline_newline_status =
                    tostring(
                        chat_spammer.newline_spam_status or "IDLE"
                    )

                local confirmed_newline_count =
                    math.max(
                        0,
                        math.floor(
                            tonumber(
                                chat_spammer.newline_spam_sent
                            ) or 0
                        )
                    )

                local inline_newline_status_text =
                    "Status: " ..
                    chat_spammer.format_status_label(
                        inline_newline_status
                    ) ..
                    " | Sent: " ..
                    tostring(
                        confirmed_newline_count
                    )

                if chat_spammer.newline_spam_enabled == true
                    and inline_newline_status == "RUNNING" then

                    theme_text_colored(
                        0.20, 1.00, 0.20, 1.0,
                        inline_newline_status_text
                    )
                elseif inline_newline_status == "EMPTY MESSAGE" then
                    theme_text_colored(
                        1.00, 0.35, 0.20, 1.0,
                        inline_newline_status_text
                    )
                elseif inline_newline_status == "WAITING FOR GAME" then
                    theme_text_colored(
                        1.00, 0.80, 0.25, 1.0,
                        inline_newline_status_text
                    )
                else
                    theme_text_colored(
                        0.70, 0.70, 0.70, 1.0,
                        inline_newline_status_text
                    )
                end

                local previous_newline_invisible =
                    chat_spammer.newline_spam_use_invisible_symbol == true

                local changed_newline_invisible,
                    newline_invisible_value =
                        imgui.checkbox(
                            "Use invisible symbol instead of text##ChatNewlineSpamInvisible",
                            previous_newline_invisible
                        )

                if changed_newline_invisible then
                    chat_spammer.newline_spam_use_invisible_symbol =
                        newline_invisible_value == true

                    chat_spammer.reset_newline_spam_counters()
                end

                local previous_newline_vertical =
                    chat_spammer.newline_spam_vertical_text == true

                local changed_newline_vertical,
                    newline_vertical_value =
                        imgui.checkbox(
                            "Use vertical text##ChatNewlineSpamVertical",
                            previous_newline_vertical
                        )

