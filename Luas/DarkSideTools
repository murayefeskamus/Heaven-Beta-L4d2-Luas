        for section_key, renderer in pairs(renderers) do
            if type(renderer) == "function" then
                guarded_renderers[section_key] = function()
                    local ok, error_message = pcall(renderer)

                    if not ok then
                        ui.section_layout.command_permission_report_renderer_error(
                            tab_key,
