function ui.kill_tools.begin_hidden_name_sequence(
    now
)
    local settings =
        ui.kill_tools.message_on_kill

    if type(settings) ~= "table" then
        return false
    end

    now = tonumber(now) or get_time()

    if settings.hidden_name_sequence_active ~= true then
        local original_name =
            ui.kill_tools.get_raw_local_name_for_restore()

        settings.hidden_name_original_name =
            original_name
    end

    local invisible_name =
        DARKSIDE_CONFIG.INVISIBLE_NAME

    local current_original =
        tostring(
            settings.hidden_name_original_name or ""
        )

    if current_original == invisible_name then
        settings.hidden_name_original_name = ""
    end

    local applied =
        ui.kill_tools.set_raw_local_name(
            invisible_name,
            "Message On Kill hidden name"
        )

    if applied ~= true then
        settings.hidden_name_last_error =
            "Could not apply invisible name."

        return false
    end

    settings.hidden_name_sequence_active = true
    settings.hidden_name_last_error = ""
    settings.hidden_name_chat_ready_at =
        now + 0.55
    settings.hidden_name_restore_due_at = 0.0

    if spammer_runtime
        and type(spammer_runtime.set_current_name_metadata) == "function" then

        spammer_runtime.set_current_name_metadata(
            invisible_name,
            {
                style = "Invisible",
                case_label = "N/A",
                shape_label = "N/A",
                decoration_label = "None",
                source = "Message On Kill"
            }
        )
    end

    return true
end

function ui.kill_tools.get_hidden_name_chat_delay(
    fallback_delay
)
    local settings =
        ui.kill_tools.message_on_kill

    local delay =
        math.max(
            0.0,
            tonumber(fallback_delay) or 0.0
        )

    if type(settings) ~= "table"
        or settings.hidden_name_sequence_active ~= true then

        return delay
    end

    local remaining =
        (tonumber(settings.hidden_name_chat_ready_at) or 0.0) -
        get_time()

    if remaining > delay then
        return remaining
    end

    return delay
end

function ui.kill_tools.schedule_hidden_name_restore(
    restore_at
)
    local settings =
        ui.kill_tools.message_on_kill

    if type(settings) ~= "table"
        or settings.hidden_name_sequence_active ~= true then

        return false
    end

    settings.hidden_name_restore_due_at =
        math.max(
            tonumber(restore_at) or get_time(),
            get_time() + 0.35
        )

    return true
end

function ui.kill_tools.restore_hidden_name_sequence(
    force_restore
)
    local settings =
        ui.kill_tools.message_on_kill

    if type(settings) ~= "table"
        or settings.hidden_name_sequence_active ~= true then

        return false
    end

    local now = get_time()

    if force_restore ~= true then
        local restore_due =
            tonumber(
                settings.hidden_name_restore_due_at
            ) or 0.0

        if restore_due <= 0.0
            or now < restore_due then

            return false
        end
    end

    local original_name =
        sanitize_name(
            settings.hidden_name_original_name
        )

    local restored = true

    if original_name ~= "" then
        restored =
            ui.kill_tools.set_raw_local_name(
                original_name,
                "Message On Kill restored name"
            )

        if restored == true
            and spammer_runtime
            and type(spammer_runtime.set_current_name_metadata) == "function" then

            spammer_runtime.set_current_name_metadata(
                original_name,
                {
                    style = "Horizontal",
                    case_label = "Original",
                    shape_label = "Original",
                    decoration_label = nil,
                    source = "Message On Kill restore"
                }
            )
        end
    end

    if restored == true
        or force_restore == true then

        settings.hidden_name_sequence_active = false
        settings.hidden_name_original_name = ""
        settings.hidden_name_chat_ready_at = 0.0
        settings.hidden_name_restore_due_at = 0.0

        return restored == true
    end

    settings.hidden_name_last_error =
        "Could not restore previous name."

    return false
end

function ui.kill_tools.update_hidden_name_sequence(
    now
)
    local settings =
        ui.kill_tools.message_on_kill

    if type(settings) ~= "table"
        or settings.hidden_name_sequence_active ~= true then

        return false
    end

    now = tonumber(now) or get_time()

    if settings.enabled ~= true
        or not engine.is_in_game()
        or not engine.is_connected() then

        return ui.kill_tools.restore_hidden_name_sequence(
            true
        )
    end

    local pending_count = 0

    if type(settings.pending) == "table" then
        pending_count = #settings.pending
    end

    if pending_count == 0
        and (tonumber(settings.hidden_name_restore_due_at) or 0.0) <= 0.0 then

        ui.kill_tools.schedule_hidden_name_restore(
            now + 0.45
        )
    end

    return ui.kill_tools.restore_hidden_name_sequence(
        false
    )
end

function ui.kill_tools.queue_kill_message(
    context
)
    local settings =
        ui.kill_tools.message_on_kill

    if settings.enabled ~= true
        or not context
        or context.local_kill ~= true
        or not ui.kill_tools.context_allowed(
            context,
            settings
        ) then

        return false
    end

    local messages_to_queue = {}
    local enabled_catalog =
        ui.kill_tools.get_message_catalog(
            true
        )

    if settings.send_all_custom_messages == true then
        for catalog_index,
            entry in ipairs(
                enabled_catalog
            ) do

            local message =
                ui.kill_tools.format_message(
                    entry.text,
                    context
                )

            if message ~= "" then
                messages_to_queue[#messages_to_queue + 1] = {
                    text = message,
                    template_index = catalog_index
                }
            end
        end
    else
        local requested_count = 1

        for _ = 1,
            requested_count do

            local template,
                template_index =
                ui.kill_tools.next_message_template()

            if not template then
                break
            end

            local message =
                ui.kill_tools.format_message(
                    template,
                    context
                )

            if message ~= "" then
                messages_to_queue[#messages_to_queue + 1] = {
                    text = message,
                    template_index = template_index
                }
            end
        end
    end

    if #messages_to_queue == 0 then
        settings.status =
            "NO ENABLED MESSAGES"

        settings.skipped_count =
            (tonumber(settings.skipped_count) or 0) + 1

        return false
    end

    local now =
        get_time()

    local hide_name_for_sequence =
        settings.hide_name_during_sequence == true
        and settings.send_all_custom_messages == true
        and #messages_to_queue > 1

    local hidden_name_ready_delay = 0.0

    if hide_name_for_sequence == true
        and ui.kill_tools.begin_hidden_name_sequence(
            now
        ) == true then

        hidden_name_ready_delay =
            ui.kill_tools.get_hidden_name_chat_delay(
                0.55
            )
    end

    local feed =
        ui.kill_tools.kill_feed

    local feed_will_chat =
        type(feed) == "table"
        and feed.enabled == true
        and feed.all_chat_output == true
        and ui.kill_tools.context_allowed(
            context,
            feed
        ) == true

    local base_delay =
        feed_will_chat
        and math.max(
            0.35,
            (tonumber(ui.lobby.chat_send_interval) or 0.70) + 0.10
        )
        or 0.0

    if hidden_name_ready_delay > base_delay then
        base_delay = hidden_name_ready_delay
    end

    local pair_delay =
        settings.send_all_custom_messages == true
        and math.max(
            0.85,
            tonumber(ui.lobby.chat_send_interval) or 0.70
        )
        or math.max(
            0.25,
            tonumber(ui.lobby.chat_send_interval) or 0.70
        )

    for index,
        queued in ipairs(
            messages_to_queue
        ) do

        table.insert(
            settings.pending,
            {
                text = queued.text,
                queued_at = now,
                available_at = now + base_delay + ((index - 1) * pair_delay),
                victim = context.victim_name,
                weapon = context.weapon_name,
                template_index = queued.template_index,
                fast_next = index < #messages_to_queue
            }
        )
    end

    settings.queued_count =
        (tonumber(settings.queued_count) or 0) + #messages_to_queue

    settings.last_victim =
        context.victim_name

    settings.last_weapon =
        context.weapon_name

    if #messages_to_queue > 1 then
        settings.status =
            "QUEUED SEQUENCE"
    else
        settings.status =
            "QUEUED"
    end

    return true
end

function ui.kill_tools.other_chat_tool_is_busy()
    if chat_spammer
        and chat_spammer.enabled == true then

        return true
    end

    if chat_spammer
        and chat_spammer.automatic_chat_lane_used_this_frame == true then

        return true
    end

    return false
end

function ui.kill_tools.send_kill_message(
    message
)
    local settings =
        ui.kill_tools.message_on_kill

    if not engine.is_in_game()
        or not engine.is_connected() then

        return false
    end

    local safe_message =
        sanitize_chat_message(
            message,
            true
        )

    if safe_message == "" then
        return false
    end

    local command =
        settings.team_chat == true
        and "say_team"
        or "say"

    local success =
        pcall(
            client.execnormal,
            command ..
            ' "' ..
            safe_message ..
            '"'
        )

    if not success then
        return false
    end

    settings.last_message =
        safe_message

    settings.sent_count =
        (tonumber(settings.sent_count) or 0) + 1

    settings.status =
        "SENT"

    return true
end

function ui.kill_tools.reset_message_runtime(
    clear_counters
)
    local settings =
        ui.kill_tools.message_on_kill

    ui.kill_tools.restore_hidden_name_sequence(
        true
    )

    settings.pool = {}
    ui.kill_tools.clear_feed_preset_pool()
    settings.pending = {}
    settings.next_allowed_time = 0.0
    settings.last_template_index = 0
    settings.status =
        settings.enabled == true
        and "READY"
        or "IDLE"

    if clear_counters == true then
        settings.last_message = "None"
        settings.last_victim = "None"
        settings.last_weapon = "None"
        settings.sent_count = 0
        settings.queued_count = 0
        settings.skipped_count = 0
        settings.dropped_count = 0

        ui.kill_tools.kill_feed.notification_count = 0
        ui.kill_tools.kill_feed.last_message = "None"
    end
end

function ui.kill_tools.update()
    local settings =
        ui.kill_tools.message_on_kill

    local now =
        get_time()

    ui.kill_tools.update_hidden_name_sequence(
        now
    )

    if now -
        (tonumber(settings.last_map_check_time) or 0.0)
        >= 1.0 then

        settings.last_map_check_time =
            now

        local current_map =
            ui.kill_tools.get_current_map()

        if current_map ~= settings.last_map then
            settings.last_map =
                current_map

            ui.kill_tools.reset_message_runtime(
                false
            )
        end
    end

    if settings.enabled ~= true then
        if #settings.pending > 0 then
            settings.pending = {}
        end

        settings.status = "IDLE"
        return
    end

    if not engine.is_in_game()
        or not engine.is_connected() then

        settings.pending = {}
        settings.status = "WAITING FOR GAME"
        return
    end

    if #settings.pending == 0 then
        settings.status = "READY"
        return
    end

    local first_pending =
        settings.pending[1]

    local available_at =
        type(first_pending) == "table"
        and tonumber(first_pending.available_at)
        or 0.0

    if available_at
        and available_at > now then

        settings.status = "WAITING FOR CHAT"
        return
    end

    if settings.respect_other_chat_tools == true
        and ui.kill_tools.other_chat_tool_is_busy() then

        local queued_at =
            tonumber(
                settings.pending[1].queued_at
            ) or now


        if now - queued_at < 2.0 then
            settings.status =
                "WAITING FOR CHAT"

            return
        end
    end

    if now < settings.next_allowed_time then
        settings.status = "COOLDOWN"
        return
    end

    local queued_message =
        table.remove(
            settings.pending,
            1
        )

    if ui.kill_tools.send_kill_message(
        queued_message.text
    ) then
        if queued_message.fast_next == true then
            settings.next_allowed_time =
                now + 0.05
        else
            settings.next_allowed_time =
                now +
                settings.cooldown
        end

        if #settings.pending == 0 then
            ui.kill_tools.schedule_hidden_name_restore(
                now + 0.55
            )
        end
    else
        settings.skipped_count =
            (tonumber(settings.skipped_count) or 0) + 1

        settings.status =
            "SEND FAILED"
    end
end

function ui.kill_tools.handle_player_death(
    event
)
    local context =
        ui.kill_tools.build_context(
            event
        )

    if not context then
        return
    end

    local now =
        get_time()

    if context.signature ==
        ui.kill_tools.recent_event_signature
        and now -
            ui.kill_tools.recent_event_time < 0.25 then

        return
    end

    ui.kill_tools.recent_event_signature =
        context.signature

    ui.kill_tools.recent_event_time =
        now

    ui.kill_tools.queue_kill_message(
        context
    )

    ui.kill_tools.emit_feed(
        context,
        false
    )
end

function ui.kill_tools.handle_event(
    event_name,
    event
)
    if event_name == "player_death" then
        ui.kill_tools.handle_player_death(
            event
        )
    elseif event_name == "round_start" then
        ui.kill_tools.reset_message_runtime(
            false
        )
    end
end

function ui.kill_tools.normalize_settings()
    local feed =
        ui.kill_tools.kill_feed

    local settings =
        ui.kill_tools.message_on_kill

    feed.enabled =
        feed.enabled == true

    if feed.include_bot_victims == nil then
        feed.include_bot_victims = true
    else
        feed.include_bot_victims =
            feed.include_bot_victims == true
    end

    if feed.all_chat_output == nil then
        feed.all_chat_output =
            feed.local_chat_output ~= false
    else
        feed.all_chat_output =
            feed.all_chat_output == true
    end


    feed.local_chat_output = nil
    feed.console_output = nil

    settings.team_chat =
        settings.team_chat == true

    settings.hide_name_during_sequence =
        settings.hide_name_during_sequence == true

    local legacy_send_two_custom_messages =
        settings.send_two_custom_messages == true

    settings.send_all_custom_messages =
        settings.send_all_custom_messages == true
        or legacy_send_two_custom_messages == true

    settings.send_two_custom_messages = false

    settings.cooldown =
        math.max(
            0.0,
            math.min(
                2.0,
                tonumber(settings.cooldown)
                or 1.0
            )
        )

    local presets =
        ui.kill_tools.default_messages()

    local legacy_preset_enabled =
        type(settings.preset_enabled) == "table"
        and settings.preset_enabled
        or nil

    local feed_has_selected_preset = false

    if type(feed.preset_enabled) == "table" then
        for index = 1,
            #presets do

            if feed.preset_enabled[index] == true then
                feed_has_selected_preset = true
                break
            end
        end
    end

    if type(feed.preset_enabled) ~= "table"
        or (
            legacy_preset_enabled ~= nil
            and feed_has_selected_preset ~= true
        ) then

        feed.preset_enabled =
            legacy_preset_enabled
            or {}
    end

    local normalized_preset_enabled = {}

    for index = 1,
        #presets do

        normalized_preset_enabled[index] =
            feed.preset_enabled[index] == true
    end

    feed.preset_enabled =
        normalized_preset_enabled

    local legacy_preset_messages =
        type(settings.preset_messages) == "table"
        and settings.preset_messages
        or nil

    if type(feed.preset_messages) ~= "table"
        or legacy_preset_messages ~= nil then

        feed.preset_messages =
            legacy_preset_messages
            or feed.preset_messages
            or {}
    end

    local previous_preset_defaults = {
        "{killer} eliminated {victim}.",
        "{victim} was playing as {class}.",
        "{killer} used {weapon}.",
        "{headshot} - {victim} eliminated.",
        "{killer} defeated {victim} with {weapon}.",
        "{killer} eliminated {victim} ({class}) with {weapon} {headshot}."
    }

    local preset_text_is_previous_default =
        #feed.preset_messages ==
        #previous_preset_defaults

    if preset_text_is_previous_default then
        for index = 1,
            #previous_preset_defaults do

            if ui.kill_tools.clean_template_text(
                feed.preset_messages[index]
                or ""
            ) ~= previous_preset_defaults[index] then

                preset_text_is_previous_default = false
                break
            end
        end
    end

    local normalized_preset_messages = {}

    for index = 1,
        #presets do

        normalized_preset_messages[index] =
            ui.kill_tools.clean_template_text(
                preset_text_is_previous_default
                and presets[index]
                or feed.preset_messages[index]
                or presets[index]
            ):sub(
                1,
                DARKSIDE_CONFIG.MAX_KILL_MESSAGE_TEMPLATE_LENGTH
            )
    end

    feed.preset_messages =
        normalized_preset_messages

    settings.preset_enabled = nil
    settings.preset_messages = nil
    settings.respect_other_chat_tools = true

    if type(settings.messages) ~= "table" then
        settings.messages = {
            ""
        }
    end

    if type(settings.message_enabled) ~= "table" then
        settings.message_enabled = {}
    end

    local known_default_sets = {
        presets,
        {
            "{killer} eliminated {victim}.",
            "{victim} was playing as {class}.",
            "{killer} used {weapon}.",
            "{headshot} - {victim} eliminated.",
            "{killer} defeated {victim}.",
            "{killer} eliminated {victim} ({class}) with {weapon} {headshot}."
        },
        {
            "{killer} eliminated {victim}.",
            "Target class: {class}.",
            "Weapon used: {weapon}.",
            "{headshot} on {victim}.",
            "Kill registered.",
            "{killer} eliminated {victim} ({class}) with {weapon} {headshot}."
        },
        {
            "{killer} eliminated {victim}.",
            "Target class: {class}.",
            "Weapon used: {weapon}.",
            "{headshot} on {victim}.",
            "Kill registered."
        },
        {
            "{killer} secured the kill.",
            "Target down: {victim}.",
            "Eliminated a {class}.",
            "Weapon used: {weapon}.",
            "Result: {headshot} kill.",
            "Kill registered."
        }
    }

    local uses_old_defaults = false

    for _,
        default_set in ipairs(
            known_default_sets
        ) do

        if #settings.messages ==
            #default_set then

            local matches = true

            for index = 1,
                #default_set do

                if ui.kill_tools.clean_template_text(
                    settings.messages[index]
                    or ""
                ) ~= tostring(
                    default_set[index]
                ) then

                    matches = false
                    break
                end
            end

            if matches then
                uses_old_defaults = true
                break
            end
        end
    end


    if uses_old_defaults then
        settings.messages = {
            ""
        }

        settings.message_enabled = {
            false
        }
    end

    local maximum_custom_messages =
        math.max(
            1,
            DARKSIDE_CONFIG.MAX_KILL_MESSAGE_TEMPLATES
        )

    local normalized_messages = {}
    local normalized_enabled = {}

    for index = 1,
        math.min(
            #settings.messages,
            maximum_custom_messages
        ) do

        normalized_messages[index] =
            ui.kill_tools.clean_template_text(
                settings.messages[index]
                or ""
            ):sub(
                1,
                DARKSIDE_CONFIG.MAX_KILL_MESSAGE_TEMPLATE_LENGTH
            )

        normalized_enabled[index] =
            settings.message_enabled[index] == true
    end

    if #normalized_messages == 0 then
        normalized_messages[1] = ""
        normalized_enabled[1] = false
    end

    settings.messages =
        normalized_messages

    settings.message_enabled =
        normalized_enabled

    if type(settings.removed_messages) ~= "table" then
        settings.removed_messages = {}
    end

    if type(settings.removed_message_enabled) ~= "table" then
        settings.removed_message_enabled = {}
    end

    local normalized_removed_messages = {}
    local normalized_removed_enabled = {}

    for index = 1,
        math.min(
            #settings.removed_messages,
            maximum_custom_messages
        ) do

        normalized_removed_messages[index] =
            ui.kill_tools.clean_template_text(
                settings.removed_messages[index]
                or ""
            ):sub(
                1,
                DARKSIDE_CONFIG.MAX_KILL_MESSAGE_TEMPLATE_LENGTH
            )

        normalized_removed_enabled[index] =
            settings.removed_message_enabled[index] == true
    end

    settings.removed_messages =
        normalized_removed_messages

    settings.removed_message_enabled =
        normalized_removed_enabled


    settings.max_queue_size = nil

    feed.pool =
        type(feed.pool) == "table"
        and feed.pool
