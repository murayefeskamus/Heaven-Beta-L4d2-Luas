function spammer_cfg.clamp_max_width_input(text)
    local clean_name =
        spammer_cfg.normalize_max_width_name(
            text
        )

    local prefix =
        spammer_cfg.use_color_char
        and DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR
        or ""

    local available_bytes =
        DARKSIDE_CONFIG.MAX_NAME_LENGTH -
        #prefix

    local fitted = {}
    local used_character_bytes = 0

    for _, character in ipairs(
        spammer_cfg.smart_vertical_split_utf8(
            clean_name
        )
    ) do
        local next_count =
            #fitted + 1

        local minimum_gap_bytes =
            math.max(
                0,
                next_count - 1
            )

        if used_character_bytes +
            #character +
            minimum_gap_bytes <= available_bytes then

            table.insert(
                fitted,
                character
            )

            used_character_bytes =
                used_character_bytes +
                #character
        else
            break
        end
    end

    local fitted_text =
        table.concat(
            fitted
        )

    return fitted_text,
        fitted_text ~= clean_name
end

