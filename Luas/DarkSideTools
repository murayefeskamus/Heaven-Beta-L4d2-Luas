function ui.section_layout.get_tab(tab_key)
    tab_key = tostring(tab_key or "")

    for _, tab in ipairs(ui.section_layout.tabs) do
        if tostring(tab.key) == tab_key then
            return tab
        end
    end

    return nil
end

function ui.section_layout.get_default_order(tab_key)
    local tab = ui.section_layout.get_tab(tab_key)
    local order = {}

    if not tab then
        return order
    end

    for _, section in ipairs(tab.sections or {}) do
        order[#order + 1] = tostring(section.key or "")
    end

    return order
end

function ui.section_layout.normalize_order(tab_key)
    tab_key = tostring(tab_key or "")

    local default_order =
        ui.section_layout.get_default_order(tab_key)
    local saved_order =
        type(ui.section_layout.orders[tab_key]) == "table"
        and ui.section_layout.orders[tab_key]
        or {}

    local valid = {}
    for _, section_key in ipairs(default_order) do
        valid[section_key] = true
    end

    local normalized = {}
    local seen = {}

    for _, section_key in ipairs(saved_order) do
        section_key = tostring(section_key or "")
        if valid[section_key] and not seen[section_key] then
            normalized[#normalized + 1] = section_key
            seen[section_key] = true
        end
    end

    for _, section_key in ipairs(default_order) do
        if not seen[section_key] then
            normalized[#normalized + 1] = section_key
            seen[section_key] = true
        end
    end

    ui.section_layout.orders[tab_key] = normalized
    return normalized
end

function ui.section_layout.normalize_all()
    for _, tab in ipairs(ui.section_layout.tabs) do
        ui.section_layout.normalize_order(tab.key)
    end

    ui.section_layout.selected_tab =
        math.max(
            0,
            math.min(
                #ui.section_layout.tabs - 1,
                math.floor(
                    tonumber(ui.section_layout.selected_tab) or 0
                )
            )
        )
end

function ui.section_layout.get_section_label(tab_key, section_key)
    local tab = ui.section_layout.get_tab(tab_key)

    if tab then
        for _, section in ipairs(tab.sections or {}) do
            if tostring(section.key) == tostring(section_key) then
                return tostring(section.label or section_key)
            end
        end
    end

    return tostring(section_key or "Unknown")
end

function ui.section_layout.draw_sections(tab_key, renderers)
    renderers = type(renderers) == "table" and renderers or {}

    local rendered_count = 0
    for _, section_key in ipairs(
        ui.section_layout.normalize_order(tab_key)
    ) do
        local renderer = renderers[section_key]

        if type(renderer) == "function" then
            if rendered_count > 0 then
                draw_compact_gap()
            end

            renderer()
            rendered_count = rendered_count + 1
        end
    end
end

function ui.section_layout.move(tab_key, from_index, to_index)
    local order = ui.section_layout.normalize_order(tab_key)
    from_index = math.floor(tonumber(from_index) or 0)
    to_index = math.floor(tonumber(to_index) or 0)

    if from_index < 1 or from_index > #order then
        return false
    end

    to_index = math.max(1, math.min(#order, to_index))

    if from_index == to_index then
        return false
    end

    local section_key = table.remove(order, from_index)
    table.insert(order, to_index, section_key)
    ui.section_layout.orders[tostring(tab_key)] = order

    ui.section_layout.last_status =
        ui.section_layout.get_section_label(tab_key, section_key) ..
        " moved to position " .. tostring(to_index) .. "."
    ui.section_layout.last_status_until = get_time() + 2.5
    return true
end

function ui.section_layout.reset(tab_key)
    tab_key = tostring(tab_key or "")
    ui.section_layout.orders[tab_key] =
        ui.section_layout.get_default_order(tab_key)
    ui.section_layout.last_status =
        "Default section order restored for " ..
        tostring((ui.section_layout.get_tab(tab_key) or {}).label or tab_key) ..
        "."
    ui.section_layout.last_status_until = get_time() + 2.5
end

function ui.section_layout.is_default(tab_key)
    local current =
        ui.section_layout.normalize_order(tab_key)
    local default =
        ui.section_layout.get_default_order(tab_key)

    if #current ~= #default then
        return false
    end

    for index = 1, #default do
        if tostring(current[index]) ~= tostring(default[index]) then
            return false
        end
    end

    return true
end

function ui.section_layout.all_tabs_are_default()
    for _, tab in ipairs(ui.section_layout.tabs) do
        if not ui.section_layout.is_default(tab.key) then
            return false
        end
    end

    return true
end

function ui.section_layout.draw_settings()
    ui.section_layout.expanded =
        draw_collapsible_section(
            "SECTION ORDER",
            ui.section_layout.expanded,
            "GlobalSectionOrderSettings"
        )

    if not ui.section_layout.expanded then
        return
    end

    ui.section_layout.normalize_all()

    local tab_labels = {}
    for _, tab in ipairs(ui.section_layout.tabs) do
        tab_labels[#tab_labels + 1] = tostring(tab.label or tab.key)
    end

    imgui.text("Customize tab:")
    imgui.same_line()
    ui.lobby.set_cursor_x(150)
    imgui.push_item_width(220)

    local changed_tab, selected_tab =
        imgui.combo(
            "##SectionOrderTabSelector",
            ui.section_layout.selected_tab,
            tab_labels
        )

    imgui.pop_item_width()

    if changed_tab then
        ui.section_layout.selected_tab =
            math.max(
                0,
                math.min(
                    #ui.section_layout.tabs - 1,
                    math.floor(tonumber(selected_tab) or 0)
                )
            )
    end

    theme_text_colored(
        0.65, 0.65, 0.65, 1.0,
        "Use UP and DOWN to rearrange the sections in the selected tab."
    )

    draw_compact_gap()

    local selected =
        ui.section_layout.tabs[
            ui.section_layout.selected_tab + 1
        ]

    if not selected then
        return
    end

    local order =
        ui.section_layout.normalize_order(selected.key)
    local pending_from = 0
    local pending_to = 0

    local columns = {
        { offset = 0,   width = 54,  label = "#" },
        { offset = 54,  width = 326, label = "SECTION NAME" },
        { offset = 380, width = 194, label = "ACTION" }
    }

    local table_width = 574

    local row_height = 24
    local table_height =
        math.min(
            380,
            28 + (#order * row_height)
        )

    local table_open =
        imgui.begin_child(
            "SectionOrderTable##" .. tostring(selected.key),
            table_width + 8,
            table_height,
            true,
            0
        )

    if table_open then
        local start_x = ui.lobby.get_cursor_x()
        local header_r, header_g, header_b =
            ui.get_theme_table_header_color()
        local palette = ui.enhancements.theme_palette()
        local divider = palette.border or palette.separator or { 0.42, 0.42, 0.44 }

        local function draw_divider(next_column)
            imgui.same_line()
            ui.lobby.set_cursor_x(start_x + next_column.offset - 3)
            theme_text_colored(
                divider[1] or 0.42,
                divider[2] or 0.42,
                divider[3] or 0.44,
                1.0,
                "|"
            )
        end

        for column_index, column in ipairs(columns) do
            ui.lobby.draw_table_text(
                start_x,
                column.offset,
                column.width,
                column.label,
                header_r,
                header_g,
                header_b,
                column_index == 1
            )

            local next_column = columns[column_index + 1]
            if next_column then
                draw_divider(next_column)
            end
        end

        imgui.separator()

        local action_button_width = 62
        local action_button_gap = 8
        local action_group_width =
            action_button_width * 2 + action_button_gap

        local function draw_section_action_button(
            label,
            unique_id,
            enabled
        )
            local button_palette =
                ui.enhancements.theme_palette()

            local text_color = enabled
                and { 1.0, 1.0, 1.0 }
                or (button_palette.text_disabled or { 0.55, 0.55, 0.55 })

            local button_color = enabled
                and { 0.18, 0.18, 0.18 }
                or (button_palette.inactive_tab or { 0.16, 0.16, 0.16 })

            local color_count = push_button_colors(
                text_color[1],
                text_color[2],
                text_color[3],
                button_color[1],
                button_color[2],
                button_color[3]
            )

            local clicked =
                ui.heaven_configs.draw_sized_button(
                    label .. "##" .. unique_id,
                    action_button_width
                )

            pop_button_colors(color_count)
            return enabled and clicked == true
        end

        for index, section_key in ipairs(order) do
            ui.lobby.draw_table_text(
                start_x,
                columns[1].offset,
                columns[1].width,
                tostring(index),
                palette.text[1],
                palette.text[2],
                palette.text[3],
                true
            )
            draw_divider(columns[2])

            ui.lobby.draw_table_text(
                start_x,
                columns[2].offset,
                columns[2].width,
                ui.section_layout.get_section_label(
                    selected.key,
                    section_key
                ),
                palette.text[1],
                palette.text[2],
                palette.text[3],
                false
            )
            draw_divider(columns[3])

            imgui.same_line()
            ui.lobby.set_cursor_x(
                start_x +
                columns[3].offset +
                math.max(
                    0,
                    (columns[3].width - action_group_width) * 0.5
                )
            )

            if draw_section_action_button(
                "UP",
                "SectionOrderUp" .. tostring(selected.key) .. tostring(index),
                index > 1
            ) then
                pending_from = index
                pending_to = index - 1
            end

            imgui.same_line()
            ui.lobby.set_cursor_x(
                start_x +
                columns[3].offset +
                math.max(
                    0,
                    (columns[3].width - action_group_width) * 0.5
                ) +
                action_button_width +
                action_button_gap
            )

            if draw_section_action_button(
                "DOWN",
                "SectionOrderDown" .. tostring(selected.key) .. tostring(index),
                index < #order
            ) then
                pending_from = index
                pending_to = index + 1
            end

            imgui.separator()
        end
    end

    imgui.end_child()

    if pending_from > 0 then
        ui.section_layout.move(
            selected.key,
            pending_from,
            pending_to
        )
    end

    local selected_is_default =
        ui.section_layout.is_default(selected.key)

    if selected_is_default then
        disabled_button(
            "Restore Selected Tab Default##SectionOrderResetSelected"
        )
    elseif colored_button(
        "Restore Selected Tab Default##SectionOrderResetSelected",
        1.0, 1.0, 1.0,
        0.18, 0.18, 0.18
    ) then
        ui.section_layout.reset(selected.key)
    end

    imgui.same_line()

    local all_are_default =
        ui.section_layout.all_tabs_are_default()

    if all_are_default then
        disabled_button(
            "Restore All Defaults##SectionOrderResetAll"
        )
    elseif colored_button(
        "Restore All Defaults##SectionOrderResetAll",
        1.0, 1.0, 1.0,
        0.18, 0.18, 0.18
    ) then
        for _, tab in ipairs(ui.section_layout.tabs) do
            ui.section_layout.orders[tab.key] =
                ui.section_layout.get_default_order(tab.key)
        end

        ui.section_layout.last_status =
            "Default section order restored for every tab."
        ui.section_layout.last_status_until = get_time() + 2.5
    end

    if get_time() < ui.section_layout.last_status_until
        and ui.section_layout.last_status ~= "" then
        draw_compact_gap()
        theme_text_colored(
            0.35, 0.90, 0.45, 1.0,
            ui.section_layout.last_status
        )
    end
end

