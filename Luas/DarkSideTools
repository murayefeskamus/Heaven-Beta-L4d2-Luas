function ui.kill_tools.draw_feed_presets()
    local feed =
        ui.kill_tools.kill_feed

    local defaults =
        ui.kill_tools.default_messages()

    local presets =
        feed.preset_messages

    if type(presets) ~= "table" then
        presets = {}
        feed.preset_messages = presets
    end

    local selected_preset_count = 0

    for index = 1,
        #defaults do

        if feed.preset_enabled[index] == true then
            selected_preset_count =
                selected_preset_count + 1
        end
    end

    ui.kill_tools.ui_state.presets_expanded =
        draw_collapsible_section(
            "PRESETS",
            ui.kill_tools.ui_state.presets_expanded,
            "KillToolsFeedPresets",
            selected_preset_count
        )

    if ui.kill_tools.ui_state.presets_expanded then
        theme_text_colored(
            0.70,
            0.70,
            0.70,
            1.0,
            "Kill Feed presets. Placeholders: {killer}, {victim}, {class}, {weapon}, {headshot}, {newline}. Class presets need an infected victim; headshot presets need a headshot event."
        )

        local all_presets_selected =
            #defaults > 0
            and selected_preset_count == #defaults

        if all_presets_selected then
            if colored_button(
                "Deselect All##KillFeedPresets",
                1.0, 1.0, 1.0,
                0.45, 0.10, 0.10
            ) then
                for index = 1,
                    #defaults do

                    feed.preset_enabled[index] = false
                end

                ui.kill_tools.clear_feed_preset_pool()
            end
        else
            if colored_button(
                "Select All##KillFeedPresets",
                1.0, 1.0, 1.0,
                0.08, 0.42, 0.12
            ) then
                for index = 1,
                    #defaults do

                    feed.preset_enabled[index] = true
                end

                ui.kill_tools.clear_feed_preset_pool()
            end
        end

        local preset_input_offset =
            ui.lobby.measure_text_width(
                "Preset 99:"
            ) + 34

        for index = 1,
            #defaults do

            local preset_row_start_x =
                ui.lobby.get_cursor_x()

            local changed_enabled,
                enabled_value =
                    imgui.checkbox(
                        "##KillFeedPresetEnabled" ..
                        tostring(index),
                        feed.preset_enabled[index] == true
                    )

            if changed_enabled then
                feed.preset_enabled[index] =
                    enabled_value == true

                ui.kill_tools.clear_feed_preset_pool()
            end

            imgui.same_line()

            ui.lobby.set_cursor_x(
                preset_row_start_x + 24
            )

            theme_text_colored(
                0.75, 0.85, 1.0, 1.0,
                "Preset " ..
                    tostring(index) ..
                    ":"
            )

            imgui.same_line()

            ui.lobby.set_cursor_x(
                preset_row_start_x +
                preset_input_offset
            )

            imgui.push_item_width(300)

            local changed_preset,
                preset_value =
                    imgui.input_text(
                        "##KillFeedPresetText" ..
                        tostring(index),
                        tostring(
                            presets[index]
                            or defaults[index]
                            or ""
                        ),
                        DARKSIDE_CONFIG.MAX_KILL_MESSAGE_TEMPLATE_LENGTH + 1
                    )

            imgui.pop_item_width()

            if changed_preset then
                ui.kill_tools.ui_state.reset_confirmation = false

                presets[index] =
                    ui.kill_tools.clean_template_text(
                        preset_value or ""
                    ):sub(
                        1,
                        DARKSIDE_CONFIG.MAX_KILL_MESSAGE_TEMPLATE_LENGTH
                    )

                ui.kill_tools.clear_feed_preset_pool()
            end
        end

        local presets_are_default = true

        for index = 1,
            #defaults do

            if tostring(
                presets[index] or ""
            ) ~= tostring(
                defaults[index] or ""
            ) then

                presets_are_default = false
                break
            end
        end

        if presets_are_default then
            ui.kill_tools.ui_state.reset_confirmation = false

            disabled_button(
                "Reset Defaults"
            )
        elseif ui.kill_tools.ui_state.reset_confirmation then
            if colored_button(
                "Confirm Reset Defaults##KillFeedPresetConfirmReset",
                1.0, 1.0, 1.0,
                0.52, 0.08, 0.08
            ) then
                for index = 1,
                    #defaults do

                    presets[index] =
                        tostring(
                            defaults[index] or ""
