function ui.network.extract_valve_datacenter_code(text_value)
    text_value =
        tostring(text_value or ""):lower()

    local patterns = {
        "srcds%d+%-([a-z][a-z][a-z])%d*[%._%-]",
        "%-([a-z][a-z][a-z])%d*[%._%-]%d+",
        "%(([a-z][a-z][a-z])%d*[%._%-]"
    }

    for _, pattern in ipairs(patterns) do
        local code =
            text_value:match(pattern)

        if code ~= nil then
            return code
        end
    end

    return ""
end


