        return false
    end

    local state_text =
        player_record.alive == true
        and "Alive"
        or (
            player_record.alive == false
            and "Dead"
            or "Unknown"
        )

    local userid_text =
        player_record.userid > 0
        and ("#" .. tostring(player_record.userid))
        or "N/A"

    local joined_age =
        ui.lobby.format_age(
            get_time() -
                (
                    player_record.first_seen
                    or get_time()
                )
        )

