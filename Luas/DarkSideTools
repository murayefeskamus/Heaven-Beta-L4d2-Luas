        spammer_runtime.status =
            "WAITING FOR GAME"

        return false, nil
    end

    vertical = vertical ~= false

    local clean_target_name =
        sanitize_name(
            target_name_str
        )

    local character_count =
        spammer_cfg.get_name_character_count(
            clean_target_name
        )

    local character_limit =
        vertical
        and DARKSIDE_CONFIG.MAX_VERTICAL_NAME_CHARACTERS
        or DARKSIDE_CONFIG.MAX_NAME_CHARACTERS

    if clean_target_name == "" then
        spammer_runtime.status =
            "INVALID EMPTY NAME"

        if not silent then
            ui.console.print(
                "[Name Spammer] Name is empty."
            )
        end

        return false, nil
    end

    if character_count > character_limit then
        spammer_runtime.status =
            vertical
            and "VERTICAL NAME LIMIT EXCEEDED"
            or "HORIZONTAL NAME LIMIT EXCEEDED"

        if not silent then
            ui.console.print(
                string.format(
                    "[Name Spammer] %s is too long for %s mode: %d/%d characters.",
                    tostring(
                        label or "Name"
                    ),
                    vertical
                    and "vertical"
                    or "horizontal",
                    character_count,
                    character_limit
                )
            )
        end

        return false, nil
    end

    local final_message = nil
    local truncated = false
    local final_length = 0

    if vertical then
        final_message,
            truncated,
            final_length =
                build_vertical_name(
                    target_name_str
                )
    else
        final_message,
            truncated,
            final_length =
                spammer_cfg.build_horizontal_name(
                    target_name_str
                )
    end

    if not final_message then
        spammer_runtime.status =
            "NAME COULD NOT BE BUILT"

        if not silent then
            ui.console.print(
                "[Name Spammer] The selected name could not be built."
            )
        end

        return false, nil
    end

    spammer_runtime.remember_requested_name(
        target_name_str,
        final_message
    )

    client.execnormal(
        'setinfo name "' ..
        final_message ..
        '"'
    )

    spammer_runtime.commands_sent =
        spammer_runtime.commands_sent + 1

    spammer_runtime.last_applied =
        label or target_name_str

    local applied_label =
        tostring(
            label or ""
        )

    spammer_runtime.original_name_vertical_active =
        vertical
        and applied_label == "Original name"

    spammer_runtime.custom_name_vertical_active =
        vertical
        and applied_label == "One-time name"

    spammer_runtime.mark_preview_applied(
        target_name_str,
        vertical
    )

    if not silent then
        local suffix =
            truncated
            and (
                " (shortened to fit the 31-byte name limit)"
            )
            or ""

        ui.console.print(
            string.format(
                "[Name Spammer] Sent %s as %s: %s [%d/%d]%s",
                tostring(
                    label or "name"
                ),
                vertical
                and "vertical"
                or "horizontal",
                tostring(target_name_str),
                final_length,
                DARKSIDE_CONFIG.MAX_NAME_LENGTH,
                suffix
            )
        )
    end

    return true, final_message
end

