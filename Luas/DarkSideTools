function ui.setting_search.setting_search_match_is_exact_rendered_label(label)
    if ui.setting_search.exact_observer_guard == true
        or ui.setting_search.rendering_highlight_active ~= true then
        return false
    end

    local candidate = ui.setting_search.normalize(
        ui.setting_search.visible_item_label(label)
    )
    local target = ui.setting_search.normalize(
        ui.setting_search.active_highlight_term
    )

    return candidate ~= "" and target ~= "" and candidate == target
end

