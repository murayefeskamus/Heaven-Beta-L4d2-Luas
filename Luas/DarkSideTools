function chat_spammer.apply_parrot_case_shape(
    message
)
    local source_message =
        sanitize_chat_message(
            message
        )

    local case_index =
        math.max(
            0,
            math.min(
                #chat_spammer.parrot_case_modes - 1,
                math.floor(
                    tonumber(
                        chat_spammer.parrot_case_selection
                    ) or 0
                )
            )
        )

    local shape_index =
        math.max(
            0,
            math.min(
                #chat_spammer.parrot_shape_modes - 1,
                math.floor(
                    tonumber(
                        chat_spammer.parrot_shape_selection
                    ) or 0
                )
            )
        )

    chat_spammer.parrot_case_selection =
        case_index

    chat_spammer.parrot_shape_selection =
        shape_index

    local case_result =
        source_message

    if case_index == 1 then
        case_result =
            source_message:upper()
    elseif case_index == 2 then
        case_result =
            source_message:lower()
    elseif case_index == 3 then
        case_result =
            alternating_case_text(
                source_message,
                true
            )
    elseif case_index == 4 then
        case_result =
            alternating_case_text(
                source_message,
                false
            )
    end

    local shape_result =
        case_result

    if shape_index == 1 then
        shape_result =
            reverse_utf8_text(
                case_result
            )
    elseif shape_index == 2 then
        shape_result =
            chat_spammer.reverse_parrot_words(
                case_result
            )
    elseif shape_index == 3 then
        shape_result =
            chat_spammer.shuffle_parrot_text(
                case_result
            )
    elseif shape_index == 4 then
        shape_result =
            case_result ..
            reverse_utf8_text(
                case_result
            )
    elseif shape_index == 5 then
        shape_result =
            twist_chat_message(
                case_result
            )
    end

    return sanitize_chat_message(
        shape_result
    )
end

