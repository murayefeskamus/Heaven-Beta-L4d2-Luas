function ui.control.filter_prediction_velocity(player, raw_velocity, settings)
    if not raw_velocity or settings.prediction_stabilizer ~= true then
        return raw_velocity, 1.0
    end

    local index = tonumber(ui.lobby.call_method(player, "get_index")) or 0
    if index <= 0 then
        return raw_velocity, 1.0
    end

    local cache_table = ui.control.runtime.prediction_velocity_cache
    if type(cache_table) ~= "table" then
        cache_table = {}
        ui.control.runtime.prediction_velocity_cache = cache_table
    end

    local now = ui.control.aim_v2_now()
    local raw_x = tonumber(raw_velocity.x) or 0.0
    local raw_y = tonumber(raw_velocity.y) or 0.0
    local raw_z = tonumber(raw_velocity.z) or 0.0
    local cache = cache_table[index]

    if type(cache) ~= "table" then
        cache = {
            x = raw_x,
            y = raw_y,
            z = raw_z,
            raw_x = raw_x,
            raw_y = raw_y,
            raw_z = raw_z,
            updated_at = now
        }
        cache_table[index] = cache
        return vector.new(raw_x, raw_y, raw_z), 1.0
    end

    local dt = ui.control.clamp(now - (tonumber(cache.updated_at) or now), 1.0 / 300.0, 0.10)
    local delta_x = raw_x - (tonumber(cache.raw_x) or raw_x)
    local delta_y = raw_y - (tonumber(cache.raw_y) or raw_y)
    local delta_z = raw_z - (tonumber(cache.raw_z) or raw_z)
    local delta_length = math.sqrt(delta_x * delta_x + delta_y * delta_y + delta_z * delta_z)

    local allowed_delta = ui.control.clamp(
        tonumber(settings.prediction_spike_limit) or 420.0,
        80.0,
        1200.0
    ) * 60.0 * dt

    local confidence = 1.0
    if delta_length > allowed_delta and delta_length > 0.0001 then
        local scale = allowed_delta / delta_length
        delta_x = delta_x * scale
        delta_y = delta_y * scale
        delta_z = delta_z * scale
        confidence = ui.control.clamp(scale, 0.15, 1.0)
    end

    local accepted_x = (tonumber(cache.raw_x) or raw_x) + delta_x
    local accepted_y = (tonumber(cache.raw_y) or raw_y) + delta_y
    local accepted_z = (tonumber(cache.raw_z) or raw_z) + delta_z

    local retention = ui.control.clamp(
        tonumber(settings.prediction_velocity_smoothing) or 0.50,
        0.0,
        0.92
    )

    local response_hz = 4.0 + (1.0 - retention) * 26.0
    local alpha = 1.0 - math.exp(-response_hz * dt)

    cache.x = (tonumber(cache.x) or accepted_x) + (accepted_x - (tonumber(cache.x) or accepted_x)) * alpha
    cache.y = (tonumber(cache.y) or accepted_y) + (accepted_y - (tonumber(cache.y) or accepted_y)) * alpha
    cache.z = (tonumber(cache.z) or accepted_z) + (accepted_z - (tonumber(cache.z) or accepted_z)) * alpha
    cache.raw_x = accepted_x
    cache.raw_y = accepted_y
    cache.raw_z = accepted_z
    cache.updated_at = now

    return vector.new(cache.x, cache.y, cache.z), confidence
end

function ui.control.stabilize_aim_v2_angles(current_angles, target, settings)
    local raw_target = target and target.aim_angle
    if not current_angles or not raw_target then
        return raw_target or current_angles
    end

    local runtime = ui.control.runtime
    local now = ui.control.aim_v2_now()
    local previous_step_at = tonumber(runtime.aim_v2_last_step_at) or 0.0
    local dt = previous_step_at > 0.0 and (now - previous_step_at) or (1.0 / 60.0)
    dt = ui.control.clamp(dt, 1.0 / 300.0, 1.0 / 20.0)
    runtime.aim_v2_last_step_at = now

    local target_index = tonumber(target.index) or 0
    local filtered = runtime.filtered_target_angle

    if target_index ~= (tonumber(runtime.filtered_target_index) or 0) or not filtered then
        filtered = vector.new(raw_target.x, raw_target.y, 0.0)
        runtime.filtered_target_index = target_index
        runtime.deadzone_holding = false
    else
        local raw_pitch_error = ui.control.normalize_angle(raw_target.x - filtered.x)
        local raw_yaw_error = ui.control.normalize_angle(raw_target.y - filtered.y)
        local raw_error = math.sqrt(raw_pitch_error * raw_pitch_error + raw_yaw_error * raw_yaw_error)
        local stability = settings.tracking_stabilizer == true
            and ui.control.clamp(tonumber(settings.tracking_stability) or 0.58, 0.0, 0.95)
            or 0.0

        local release = ui.control.clamp(raw_error / 35.0, 0.0, 1.0)
        local filter_hz = 32.0 - stability * 24.0
        filter_hz = filter_hz + release * 18.0

        if target.grace == true then
            filter_hz = math.min(filter_hz, 8.0)
        end

        local filter_alpha = 1.0 - math.exp(-filter_hz * dt)
        filtered = vector.new(
            ui.control.clamp(filtered.x + raw_pitch_error * filter_alpha, -89.0, 89.0),
            ui.control.normalize_angle(filtered.y + raw_yaw_error * filter_alpha),
            0.0
        )
    end

    runtime.filtered_target_angle = filtered

    local pitch_delta = ui.control.normalize_angle(filtered.x - current_angles.x)
    local yaw_delta = ui.control.normalize_angle(filtered.y - current_angles.y)
    local angular_error = math.sqrt(pitch_delta * pitch_delta + yaw_delta * yaw_delta)

    local deadzone = ui.control.clamp(tonumber(settings.aim_deadzone) or 0.06, 0.0, 1.0)
    local release_zone = deadzone + ui.control.clamp(
        tonumber(settings.deadzone_hysteresis) or 0.08,
        0.0,
        0.50
    )

    if runtime.deadzone_holding == true then
        if angular_error <= release_zone then
            runtime.last_tracking_step = 0.0
            return current_angles
        end
        runtime.deadzone_holding = false
    elseif angular_error <= deadzone then
        runtime.deadzone_holding = true
        runtime.last_tracking_step = 0.0
        return current_angles
    end

    local effective_smoothing = ui.control.get_effective_smoothing(settings, target)
    local response_hz = 28.0 / math.max(effective_smoothing, 1.0)
    local correction = 1.0 - math.exp(-response_hz * dt)

    local micro_zone = ui.control.clamp(tonumber(settings.micro_correction_zone) or 0.85, 0.10, 5.0)
    if angular_error < micro_zone then
        local ratio = ui.control.clamp(angular_error / micro_zone, 0.0, 1.0)
        local minimum = ui.control.clamp(
            tonumber(settings.micro_correction_strength) or 0.28,
            0.05,
            1.0
        )
        correction = correction * (minimum + (1.0 - minimum) * ratio * ratio)
    end

    local step_pitch = pitch_delta * correction
    local step_yaw = yaw_delta * correction
    local step_length = math.sqrt(step_pitch * step_pitch + step_yaw * step_yaw)

    local maximum_rate = ui.control.clamp(
        tonumber(settings.maximum_angular_step) or 32.0,
        2.0,
        90.0
    ) * 60.0
    local maximum_step = maximum_rate * dt

    if step_length > maximum_step and step_length > 0.0001 then
        local scale = maximum_step / step_length
        step_pitch = step_pitch * scale
        step_yaw = step_yaw * scale
        step_length = maximum_step
    end

    runtime.last_tracking_step = step_length
    runtime.last_tracking_retention = 1.0 - correction

    return vector.new(
        ui.control.clamp(current_angles.x + step_pitch, -89.0, 89.0),
        ui.control.normalize_angle(current_angles.y + step_yaw),
        0.0
    )
end

function ui.control.get_best_target_v2(local_player, settings, view_angles)
    local runtime = ui.control.runtime
    local eye_position = ui.lobby.call_method(local_player, "get_eye_position")

    if not eye_position then
        local origin = ui.lobby.call_method(local_player, "get_origin")
            or ui.lobby.call_method(local_player, "get_abs_origin")

        if origin then
            eye_position = vector.new(
                tonumber(origin.x) or 0.0,
                tonumber(origin.y) or 0.0,
                (tonumber(origin.z) or 0.0) + 56.0
            )
        end
    end

    if not eye_position then
        runtime.status = "Local view position unavailable"
        return nil
    end

    local smart_context = ui.control.get_aim_v2_smart_context(local_player, settings)
    runtime.smart_class = tostring(smart_context.class_name or "Neutral")
    runtime.smart_profile = tostring(smart_context.profile_name or "Off")

    local held_index = math.floor(tonumber(runtime.lock_session_target_index) or 0)

    if runtime.lock_session_active == true and held_index > 0 then
        local live = ui.control.build_v2_candidate(
            local_player,
            held_index,
            settings,
            eye_position,
            view_angles,
            999.0,
            smart_context,
            true
        )

        if live then
            runtime.lock_session_status = "Locked until key release"
            runtime.lock_session_lost_since = 0.0
            return live
        end

        local snapshot = runtime.last_valid_target
        if type(snapshot) == "table" and tonumber(snapshot.index) == held_index then
            local world_position = snapshot.aim_position or snapshot.world_position
            if world_position then
                local recomputed_angle = ui.control.calculate_angle(eye_position, world_position)
                if recomputed_angle then
                    local distance = vector.distance(eye_position, world_position)
                    local fov = ui.control.get_fov(view_angles, recomputed_angle)
                    runtime.lock_session_status = "Locked - using last target position"
                    return {
                        player = snapshot.player,
                        index = held_index,
                        aim_position = world_position,
                        aim_angle = recomputed_angle,
                        distance = distance,
                        fov = fov,
                        score = snapshot.score or fov,
                        prediction_time = snapshot.prediction_time or 0.0,
                        prediction_confidence = snapshot.prediction_confidence or 0.5,
                        confidence = snapshot.confidence or 0.5,
                        effective_fov = snapshot.effective_fov or settings.fov,
                        effective_max_distance = snapshot.effective_max_distance or settings.max_distance,
                        smart_smoothing_multiplier = snapshot.smart_smoothing_multiplier or 1.0,
                        smart_prediction_multiplier = snapshot.smart_prediction_multiplier or 1.0,
                        smart_class = snapshot.smart_class or smart_context.class_name,
                        smart_profile = snapshot.smart_profile or smart_context.profile_name,
                        incapacitated = snapshot.incapacitated == true,
                        hanging = snapshot.hanging == true,
                        grace = true,
                        held = true
                    }
                end
            end
        end

        runtime.lock_session_status = "Locked - waiting for target data"
        return nil
    end

    local best = nil
    local maximum_clients = tonumber(engine.get_max_clients()) or 0

    for index = 1, maximum_clients do
        local candidate = ui.control.build_v2_candidate(
            local_player,
            index,
            settings,
            eye_position,
            view_angles,
            1.0,
            smart_context,
            false
        )

        if candidate and (not best or candidate.score < best.score) then
            best = candidate
        end
    end

    return best
end

ui.control.aim_v2_legacy_apply = ui.control.apply_aim_infected

function ui.control.apply_aim_infected(command, local_player)
    if tonumber(ui.control.aim.mode) ~= 1 then
        return ui.control.aim_v2_legacy_apply(command, local_player)
    end

    local settings = ui.control.aim.v2
    local runtime = ui.control.runtime
    ui.control.normalize_aim_v2_rebuilt_settings()

    if ui.control.aim.enabled ~= true then
        return false
    end

    local hold_active = ui.control.is_aim_v2_session_hold_active(settings)
    if not hold_active then
        if runtime.lock_session_active == true then
            ui.control.finish_aim_v2_lock_session()
        end
        runtime.status = "Ready - hold " .. ui.control.get_key_name(ui.control.action_key)
        return false
    end

    ui.control.begin_aim_v2_lock_session()

    local supported, class_id, class_name = ui.control.get_special_infected_identity(local_player)
    runtime.smart_class = class_name

    if not supported then
        runtime.status = class_id > 0
            and "Special Infected only - unsupported class"
            or "Special Infected only"
        runtime.lock_session_status = "Unavailable"
        return false
    end

    local current_ok, current_angles = pcall(function()
        return command:get_viewangles()
    end)

    if not current_ok or not current_angles then
        runtime.status = "View angles unavailable"
        return false
    end

    local target_ok, target = pcall(
        ui.control.get_best_target_v2,
        local_player,
        settings,
        current_angles
    )

    if not target_ok then
        runtime.status = "Aim V2 target evaluation failed"
        return false
    end

    if not target then
        if tonumber(runtime.lock_session_target_index) > 0 then
            runtime.locked_target_index = runtime.lock_session_target_index
            runtime.target_name = runtime.lock_session_target_name ~= "None"
                and runtime.lock_session_target_name
                or ui.control.get_target_name(runtime.lock_session_target_index)
            runtime.target_state = "Held"
            runtime.status = "Target held - waiting for live data"
        else
            runtime.status = "Searching target"
            runtime.target_name = "None"
            runtime.target_state = "None"
        end
        return false
    end

    if tonumber(runtime.lock_session_target_index) <= 0 then
        runtime.lock_session_target_index = target.index
        runtime.lock_session_target_name = ui.control.get_target_name(target.index)
        runtime.lock_session_started_at = ui.control.aim_v2_now()
        runtime.lock_session_status = "Locked until key release"
        ui.control.reset_aim_v2_tracking(false)
    elseif tonumber(runtime.lock_session_target_index) ~= tonumber(target.index) then
        runtime.status = "Lock invariant protected"
        return false
    end

    runtime.locked_target_index = target.index

    local final_angles = ui.control.stabilize_aim_v2_angles(
        current_angles,
        target,
        settings
    )

    local set_ok = pcall(function()
        command:set_viewangles(final_angles)
    end)

    if not set_ok then
        runtime.status = "Command angle write failed"
        return false
    end

    if settings.silent_aim ~= true then
        pcall(engine.set_view_angles, final_angles)
    end

    local target_name = runtime.lock_session_target_name
    if target_name == "None" or target_name == "" then
        target_name = ui.control.get_target_name(target.index)
        runtime.lock_session_target_name = target_name
    end

    runtime.target_name = target_name
    runtime.target_fov = tonumber(target.fov) or 0.0
    runtime.target_distance = tonumber(target.distance) or 0.0
    runtime.prediction_time_used = tonumber(target.prediction_time) or 0.0
    runtime.prediction_confidence = tonumber(target.prediction_confidence) or 1.0
    runtime.target_confidence = tonumber(target.confidence) or 1.0
    runtime.effective_fov = tonumber(target.effective_fov) or settings.fov
    runtime.effective_max_distance = tonumber(target.effective_max_distance) or settings.max_distance
    runtime.smart_class = tostring(target.smart_class or class_name)
    runtime.smart_profile = tostring(target.smart_profile or "Balanced")

    if target.hanging then
        runtime.target_state = "Hanging"
    elseif target.incapacitated then
        runtime.target_state = "Incapacitated"
    elseif target.grace == true then
        runtime.target_state = "Cached"
    else
        runtime.target_state = "Standing"
    end

    if target.grace ~= true then
        runtime.last_valid_target = {
            player = target.player,
            index = target.index,
            world_position = target.aim_position,
            aim_position = target.aim_position,
            distance = target.distance,
            fov = target.fov,
            score = target.score,
            prediction_time = target.prediction_time,
            prediction_confidence = target.prediction_confidence,
            confidence = target.confidence,
            effective_fov = target.effective_fov,
            effective_max_distance = target.effective_max_distance,
            smart_smoothing_multiplier = target.smart_smoothing_multiplier,
            smart_prediction_multiplier = target.smart_prediction_multiplier,
            smart_class = target.smart_class,
            smart_profile = target.smart_profile,
            incapacitated = target.incapacitated,
            hanging = target.hanging
        }
        runtime.last_valid_target_time = ui.control.aim_v2_now()
        runtime.lock_session_last_live_at = runtime.last_valid_target_time
    end

    ui.control.mark_engaged(string.format(
        "Locked: %s | %s | %.1f deg | %.0f u",
        target_name,
        tostring(runtime.smart_class),
        runtime.target_fov,
        runtime.target_distance
    ))

    return true
end

ui.control.aim_v2_legacy_update = ui.control.update

function ui.control.update()
    if ui.control.resolve_active_mode() ~= 1
        or ui.control.aim.enabled ~= true
        or tonumber(ui.control.aim.mode) ~= 1 then
        return ui.control.aim_v2_legacy_update()
    end

    ui.control.handle_toggle_key()
    ui.control.normalize_settings()
    ui.control.normalize_aim_v2_rebuilt_settings()

    local runtime = ui.control.runtime

    if not engine.is_in_game() or not engine.is_connected() then
        runtime.status = "Waiting for game"
        runtime.aim_v2_spawn_state = "Not in game"
        ui.control.finish_aim_v2_lock_session()
        return
    end

    local local_player = client.get_local_player()
    if not local_player then
        runtime.status = "Waiting for player"
        runtime.aim_v2_spawn_state = "Unavailable"
        return
    end

    local supported, class_id, class_name, spawn_state =
        ui.control.get_special_infected_identity(local_player)

    runtime.smart_class = class_name
    runtime.aim_v2_spawn_state = spawn_state

    if not supported then
        runtime.status = class_id == 7
            and "Unsupported infected class"
            or "Special Infected only"
        runtime.lock_session_status = "Unavailable"
        ui.control.finish_aim_v2_lock_session()
        return
    end

    if ui.control.is_aim_v2_session_hold_active(ui.control.aim.v2) then
        ui.control.begin_aim_v2_lock_session()
        if tonumber(runtime.lock_session_target_index) > 0 then
            runtime.status = string.format(
                "%s | Locked: %s",
                spawn_state,
                tostring(runtime.lock_session_target_name or "Survivor")
            )
        else
            runtime.status = spawn_state .. " | Searching target"
        end
    else
        if runtime.lock_session_active == true then
            ui.control.finish_aim_v2_lock_session()
        end
        runtime.status = string.format(
            "%s | Ready - hold %s",
            spawn_state,
            ui.control.get_key_name(ui.control.action_key)
        )
    end
end

