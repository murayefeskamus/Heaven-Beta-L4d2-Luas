function ui.lobby.sync_sort_index()
    for index, definition in ipairs(
        ui.lobby.sort_definitions
    ) do
        if definition.key == ui.lobby.sort_key
            and definition.desc ==
                (ui.lobby.sort_desc == true) then

            ui.lobby.sort_index = index - 1
            return
        end
    end

    ui.lobby.sort_index = 0
end

function ui.lobby.normalize_sort_state()
    if ui.lobby.sort_key == nil then

        local legacy_index =
            math.floor(
                tonumber(ui.lobby.sort_index) or 0
            )

        local legacy_sorts = {
            [0] = { key = "userid", desc = false },
            [1] = { key = "name", desc = false },
            [2] = { key = "team_name", desc = false },
            [3] = { key = "health", desc = true },
            [4] = { key = "health", desc = false },
            [5] = { key = "session_time", desc = true },
            [6] = { key = "name", desc = true },
            [7] = { key = "alive", desc = true },
            [8] = { key = "kills", desc = true },
            [9] = { key = "deaths", desc = true }
        }

        local legacy =
            legacy_sorts[legacy_index]
            or legacy_sorts[0]

        ui.lobby.sort_key = legacy.key
        ui.lobby.sort_desc = legacy.desc == true
    end

    ui.lobby.sort_key =
        tostring(ui.lobby.sort_key or "userid")

    ui.lobby.sort_desc =
        ui.lobby.sort_desc == true

    ui.lobby.sync_sort_index()
end

function ui.lobby.set_sort(key, force_desc)
    key = tostring(key or "")

    if key == "" then
        return
    end

    if ui.lobby.sort_key == key
        and force_desc == nil then

        ui.lobby.sort_desc =
            not ui.lobby.sort_desc
    else
        ui.lobby.sort_key = key

        if force_desc ~= nil then
            ui.lobby.sort_desc = force_desc == true
        else
            ui.lobby.sort_desc =
                key == "alive"
                or key == "health"
                or key == "kills"
                or key == "deaths"
                or key == "kd"
                or key == "special_kills"
                or key == "common_kills"
                or key == "si_damage_total"
                or key == "session_time"
        end
    end

    ui.lobby.sync_sort_index()
end

function ui.lobby.set_sort_from_index(index)
    local definition =
        ui.lobby.sort_definitions[
            math.floor(tonumber(index) or 0) + 1
        ]

    if definition then
        ui.lobby.sort_key = definition.key
        ui.lobby.sort_desc = definition.desc == true
        ui.lobby.sync_sort_index()
    end
end

function ui.lobby.get_filtered_players()
    local displayed_players = {}

    for _, player_record in ipairs(
        ui.lobby.players
    ) do
        if ui.lobby.player_matches_filter(
            player_record
        ) then
            table.insert(
                displayed_players,
                player_record
            )
        end
    end

    ui.lobby.normalize_sort_state()

    local sort_key =
        tostring(ui.lobby.sort_key or "userid")

    local descending =
        ui.lobby.sort_desc == true

    local pin_local_player_first =
        math.floor(
            tonumber(ui.lobby.filter_index) or 0
        ) == 8

    local function get_value(record)
        if sort_key == "userid" then
            local value = tonumber(record.userid) or 0
            return value > 0 and value or math.huge
        elseif sort_key == "entity_index" then
            return tonumber(record.entity_index) or math.huge
        elseif sort_key == "name" then
            return tostring(record.name or ""):lower()
        elseif sort_key == "class_name" then
            return tostring(record.class_name or ""):lower()
        elseif sort_key == "team_name" then
            return tostring(record.team_name or ""):lower()
        elseif sort_key == "alive" then
            return record.alive == true and 1 or 0
        elseif sort_key == "health" then
            return tonumber(record.health) or -1
        elseif sort_key == "kills" then
            return tonumber(record.kills) or 0
        elseif sort_key == "deaths" then
            return tonumber(record.deaths) or 0
        elseif sort_key == "kd" then
            local kills = tonumber(record.kills) or 0
            local deaths = tonumber(record.deaths) or 0
            return kills / (deaths > 0 and deaths or 1)
        elseif sort_key == "special_kills" then
            return tonumber(record.special_kills) or 0
        elseif sort_key == "common_kills" then
            return tonumber(record.common_kills) or 0
        elseif sort_key == "si_damage_total" then
            return tonumber(record.si_damage_total) or 0
        elseif sort_key == "session_time" then
            return math.max(
                0,
                get_time() -
                    (tonumber(record.first_seen) or get_time())
            )
        end

        return tonumber(record.entity_index) or math.huge
    end

    table.sort(
        displayed_players,
        function(a, b)
            if pin_local_player_first
                and (a.is_local == true) ~=
                    (b.is_local == true) then

                return a.is_local == true
            end

            local a_value = get_value(a)
            local b_value = get_value(b)

            if a_value == b_value then
                local a_index =
                    tonumber(a.entity_index) or math.huge

                local b_index =
                    tonumber(b.entity_index) or math.huge

                return a_index < b_index
            end

            if descending then
                return a_value > b_value
            end

            return a_value < b_value
        end
    )

    return displayed_players
end


function ui.lobby.send_all_chat(
