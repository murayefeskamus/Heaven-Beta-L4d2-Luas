            weapon_display_name
            and (
                " with " ..
                weapon_display_name
            )
            or ""

        local victim_is_tank =
            victim
            and tostring(victim.class_name) == "Tank"

        local victim_is_special =
            victim
            and victim.team == 3
            and tostring(
                victim.class_name or ""
            ) ~= "Witch"

        if attacker.team == 2
            and victim
            and victim.team == 3 then

