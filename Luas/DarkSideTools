    local attacker_userid =
        ui.lobby.get_event_int(
            event,
            "attacker"
        )

    local victim =
        ui.lobby.find_player_by_userid(
            victim_userid
        )

    local attacker =
        ui.lobby.find_player_by_userid(
            attacker_userid
        )

    if victim_userid > 0 then
        ui.lobby.recent_deaths[
            victim_userid
        ] = get_time()
    end

    if victim then
        victim.deaths =
            (victim.deaths or 0) + 1

        victim.alive = false
        victim.health = 0

        ui.lobby.update_activity_cache(
            victim
        )

        if tonumber(victim.team) == 3
            and victim.is_bot ~= true
            and type(ui.lobby.mark_infected_prediction_waiting) == "function" then

            ui.lobby.mark_infected_prediction_waiting(
                victim,
                get_time()
            )
        end
    end

    local victim_name =
        victim
        and tostring(victim.name)
        or get_player_name_from_userid(
            victim_userid
        )
        or "Unknown victim"

    ui.lobby.add_history(
        "DEAD",
        victim_name ..
            " died"
    )

    if attacker
        and attacker_userid > 0
        and attacker_userid ~= victim_userid then

        attacker.kills =
            (attacker.kills or 0) + 1

        ui.lobby.update_activity_cache(
            attacker
        )

        local weapon =
            ui.lobby.resolve_kill_weapon_identifier(
                event,
                attacker
            )

        local weapon_display_name =
            ui.lobby.get_kill_log_weapon_name(
                weapon
            )

