                    }
                elseif key == "requester" then
                    return {
                        label = "Requester",
                        value = ui.quotes.get_requester_display()
                    }
                elseif key == "search_mode" then
                    return {
                        label = "Mode",
                        value = tostring(
                            status.last_search_mode or "None"
                        )
                    }
                elseif key == "search_matches" then
                    return {
                        label = "Matches",
                        value = tostring(status.last_search_matches)
                    }
                end

                return nil
            end

            local function draw_random_quote_button(unique_id)
                if colored_button(
                    "Random Quote##" .. tostring(unique_id),
                    1.0, 1.0, 1.0,
                    0.08, 0.42, 0.12
