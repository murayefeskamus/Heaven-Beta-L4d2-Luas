function ui.settings_io.apply_snapshot(
    settings
)
    if type(settings) ~= "table" then
        return false
    end

    local stored_ui =
        settings.ui

    if type(stored_ui) == "table" then
        local settings_version =
            math.floor(
                tonumber(
                    settings.version
                ) or 0
            )

        if settings_version < 6 then
            stored_ui =
                ui.settings_io.copy_value(
                    stored_ui
                )
        end

        if stored_ui.spammer_workshop_expanded == nil
            and stored_ui.stealer_workshop_expanded ~= nil then

            stored_ui.spammer_workshop_expanded =
                stored_ui.stealer_workshop_expanded
        end

        stored_ui.stealer_workshop_expanded = nil

        local old_selected =
            tonumber(
                stored_ui.selected_tool
            )

        if settings_version < 5 then
            if old_selected == 3 then
                old_selected = 4
            elseif old_selected == 4 then
                old_selected = 5
            end
        end


        if settings_version < 6
            and old_selected == 5 then

            old_selected = 6
        end

        stored_ui.selected_tool =
            old_selected
    end

    ui.settings_io.merge(
        ui,
        stored_ui
    )

    if type(settings.section_layout) == "table" then
        if settings.section_layout.expanded ~= nil then
            ui.section_layout.expanded =
                settings.section_layout.expanded == true
        end

        ui.section_layout.selected_tab =
            tonumber(settings.section_layout.selected_tab)
            or ui.section_layout.selected_tab

        if type(settings.section_layout.orders) == "table" then
            ui.section_layout.orders =
                ui.settings_io.copy_value(
                    settings.section_layout.orders
                )
        end
    end

    ui.section_layout.normalize_all()

    if type(settings.tab_layout) == "table" then
        ui.tab_layout.expanded = true

        if type(settings.tab_layout.order) == "table" then
            ui.tab_layout.order =
                ui.settings_io.copy_value(
                    settings.tab_layout.order
                )
        end
    end

    ui.tab_layout.normalize_order()

    if type(settings.favourites) == "table"
        and type(settings.favourites.entries) == "table" then

        ui.favourites.entries =
            ui.settings_io.copy_value(
                settings.favourites.entries
            )
    end

    ui.favourites.normalize_entries()

    ui.settings_io.merge(
        ui.lobby,
        settings.lobby
    )

    if type(settings.lobby) == "table"
        and type(
            settings.lobby.special_infected_announce_templates
        ) ~= "table"
        and type(
            settings.lobby.special_infected_announce_template
        ) == "string" then

        ui.lobby.special_infected_announce_templates = {
            settings.lobby.special_infected_announce_template
        }
    end

    ui.lobby.normalize_special_infected_announcement_templates()
    ui.lobby.reset_special_infected_announcement_cycle()

    ui.lobby.normalize_sort_state()

    ui.settings_io.merge(
        ui.heaven_configs,
        settings.heaven_configs
    )

    ui.heaven_configs.normalize_settings()

    ui.settings_io.merge(
        ui.network,
        settings.network
    )

    ui.settings_io.merge(
        ui.quotes.settings,
        settings.quotes
    )

    ui.settings_io.merge(
        ui.window_master,
        settings.window_master
    )

    ui.window_master.normalize_settings()

    ui.network.normalize_settings()
    ui.quotes.normalize_settings()

    ui.settings_io.merge(
        ui.quotes.ui_state,
        settings.quotes_ui
    )

    ui.settings_io.merge(
        spammer_cfg,
        settings.name_spammer
    )

    local stored_name_stealer_settings =
        settings.name_stealer

    ui.settings_io.merge(
        name_stealer,
        stored_name_stealer_settings
