            0.42,
            0.42,
            0.44
        }

        if ui.enhancements
            and type(ui.enhancements.theme_palette) == "function" then

            local palette_ok,
                palette =
                    pcall(
                        ui.enhancements.theme_palette
                    )

            if palette_ok
                and type(palette) == "table" then

                divider =
                    palette.border
                    or palette.separator
                    or divider
            end
        end

        local function draw_divider(
            next_column
        )
            if type(next_column) ~= "table" then
                return
            end

            imgui.same_line()

            ui.lobby.set_cursor_x(
                start_x + next_column.offset - 3
            )

            theme_text_colored(
                divider[1] or 0.42,
                divider[2] or 0.42,
                divider[3] or 0.44,
                1.0,
                "|"
            )
        end

        for index, column in ipairs(columns) do
