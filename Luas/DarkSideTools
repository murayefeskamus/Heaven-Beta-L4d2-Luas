)
    entry =
        type(entry) == "table"
        and entry
        or {}

    if ui.favourites.is_pinned(
        entry
    ) then
        return true
    end

    if tostring(entry.kind) == "setting" then
        return ui.favourites.is_pinned({
            kind = "section",
            tab_key = entry.tab_key,
            section_key = entry.section_key,
            term = ""
        })
    end

    return false
end

function ui.favourites.pin_entry(
    entry
)
    entry =
        type(entry) == "table"
        and entry
        or {}

    local clean_entry = {
        kind =
            tostring(
                entry.kind
                or "section"
            ),
        tab_key =
            tostring(
                entry.tab_key
                or ""
            ),
        section_key =
            tostring(
                entry.section_key
                or ""
            ),
        term =
            ui.favourites.clean_label(
                entry.term
            )
    }

    local original_entries =
        ui.favourites.entries

    ui.favourites.entries = {
        clean_entry
    }

    local valid_entries =
        ui.favourites.normalize_entries()

    ui.favourites.entries =
        original_entries

    if #valid_entries ~= 1 then
        ui.favourites.set_status(
            "This item cannot be pinned.",
            true
        )

        return false
    end

    clean_entry =
        valid_entries[1]

    if ui.favourites.is_effectively_pinned(
        clean_entry
    ) then
        return false
    end

    if clean_entry.kind == "section" then
        local retained = {}

        for _, existing in ipairs(
            ui.favourites.normalize_entries()
        ) do
            if tostring(existing.tab_key) ~=
                tostring(clean_entry.tab_key)
                or tostring(existing.section_key) ~=
                    tostring(clean_entry.section_key) then

                retained[
                    #retained + 1
                ] = existing
            end
        end

        ui.favourites.entries = retained
    end

    ui.favourites.entries[
        #ui.favourites.entries + 1
    ] = clean_entry

    ui.favourites.normalize_entries()
    return true
end

