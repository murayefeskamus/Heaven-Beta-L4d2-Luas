function spammer_cfg.get_name_field_stats()
    local stats = {
        added_horizontal = 0,
        added_vertical = 0,
        enabled_horizontal = 0,
        enabled_vertical = 0,
        active_horizontal = 0,
        active_vertical = 0,
        empty_enabled_horizontal = 0,
        empty_enabled_vertical = 0
    }

    spammer_cfg.ensure_name_enabled_states()
    spammer_cfg.ensure_name_vertical_modes()

    for index = 1,
        get_spammer_name_count() do

        local vertical =
            spammer_cfg.is_name_vertical(
                index
            )

        local enabled =
            spammer_cfg.is_name_enabled(
                index
            )

        local empty =
            spammer_cfg.is_name_field_empty(
                index
            )

        if vertical then
            stats.added_vertical =
                stats.added_vertical + 1

            if enabled then
                stats.enabled_vertical =
                    stats.enabled_vertical + 1

                if empty then
                    stats.empty_enabled_vertical =
                        stats.empty_enabled_vertical + 1
                else
                    stats.active_vertical =
                        stats.active_vertical + 1
                end
            end
        else
            stats.added_horizontal =
                stats.added_horizontal + 1

            if enabled then
                stats.enabled_horizontal =
                    stats.enabled_horizontal + 1

                if empty then
                    stats.empty_enabled_horizontal =
                        stats.empty_enabled_horizontal + 1
                else
                    stats.active_horizontal =
                        stats.active_horizontal + 1
                end
            end
        end
    end

    stats.added_total =
        stats.added_horizontal +
        stats.added_vertical

    stats.enabled_total =
        stats.enabled_horizontal +
        stats.enabled_vertical

    stats.active_total =
        stats.active_horizontal +
        stats.active_vertical

    local mode =
        spammer_cfg.normalize_automation_order_mode()

    if mode == 0 then
        stats.selected_active =
            stats.active_horizontal
    elseif mode == 1 then
        stats.selected_active =
            stats.active_vertical
    else
        stats.selected_active =
            stats.active_total
    end

    return stats
end

