function name_stealer.delete_saved_name(
    selected_name
)
    selected_name =
        sanitize_name(
            selected_name
        )

    local selected_key =
        normalize_candidate_name_for_filter(
            selected_name
        )

    if selected_key == "" then
        return false
    end

    local updated_names = {}
    local removed = false

    for _, saved_name in ipairs(
        name_stealer.saved_names or {}
    ) do
        local saved_key =
            normalize_candidate_name_for_filter(
                saved_name
            )

        if not removed
            and saved_key == selected_key then

            removed = true
        else
            updated_names[#updated_names + 1] =
                saved_name
        end
    end

    if not removed then
        name_stealer.save_status =
            "Selected saved name was not found."

        return false
    end

    if not name_stealer.rewrite_saved_names_file(
        updated_names
    ) then
        name_stealer.save_status =
            "Could not delete the selected saved name."

        return false
    end

    name_stealer.saved_names =
        updated_names

    if type(name_stealer.saved_name_metadata) == "table" then
        name_stealer.saved_name_metadata[
            selected_key
        ] = nil
    end

    if type(name_stealer.session_saved_name_keys) == "table"
        and name_stealer.session_saved_name_keys[
            selected_key
        ] == true then

        name_stealer.session_saved_name_keys[
            selected_key
        ] = nil

        name_stealer.session_saved_count =
            math.max(
                0,
                math.floor(
                    tonumber(
                        name_stealer.session_saved_count
                    ) or 0
                ) - 1
            )
    end

    name_stealer.saved_names_count =
        #name_stealer.saved_names

    save_saved_name_metadata()

    if type(name_stealer.invalidate_saved_names_gui_cache) == "function" then
        name_stealer.invalidate_saved_names_gui_cache()
    end

    if #name_stealer.saved_names == 0
        and name_stealer.saved_randomizer_enabled == true
        and type(set_saved_name_randomizer_enabled) == "function" then

        set_saved_name_randomizer_enabled(
            false
        )
    end

    name_stealer.save_status =
        "Deleted saved name: " ..
        selected_name

    return true
end

