function ui.settings_io.save()
    if type(io) ~= "table"
        or type(io.open) ~= "function" then

        ui.settings_io.save_failed = true
        return false
    end

    local serialized =
        "return " ..
        ui.settings_io.serialize(
            ui.settings_io.snapshot(),
            0
        ) ..
        "\n"

    local open_ok,
        file =
            pcall(
                io.open,
                ui.settings_io.path,
                "w"
            )

    if not open_ok
        or not file then

        ui.settings_io.save_failed = true
        return false
    end

    local write_ok =
        pcall(
            function()
                file:write(
                    serialized
                )

                file:flush()
                file:close()
            end
        )

    if not write_ok then
        pcall(
            function()
                file:close()
            end
        )

        ui.settings_io.save_failed = true
        return false
    end

    ui.settings_io.last_serialized =
        serialized

    ui.settings_io.save_failed = false

    return true
end

function ui.settings_io.load()
    if type(loadfile) ~= "function" then
        return false
    end

    local load_ok,
        chunk_or_error =
            pcall(
                loadfile,
                ui.settings_io.path
            )

    if not load_ok
        or type(chunk_or_error) ~= "function" then

        return false
    end

    local run_ok,
        settings =
            pcall(
                chunk_or_error
            )

    if not run_ok
        or type(settings) ~= "table" then

        return false
    end

    if not ui.settings_io.apply_snapshot(
        settings
    ) then
        return false
    end

    ui.settings_io.loaded = true

    return true
end

function ui.settings_io.update()
    if not ui.settings_io.loaded then
        return
    end

    local now =
        get_time()

    if now <
        (tonumber(ui.settings_io.next_check_time) or 0.0) then

        return
    end

    ui.settings_io.next_check_time =
        now +
        math.max(
            1.0,
            tonumber(ui.settings_io.check_interval) or 4.0
        )

    local serialized =
        "return " ..
        ui.settings_io.serialize(
            ui.settings_io.snapshot(),
            0
        ) ..
        "\n"

    if serialized ~=
        ui.settings_io.last_serialized then

        ui.settings_io.save()
    end
end


if not ui.settings_io.load() then
    ui.settings_io.loaded = true
    ui.settings_io.save()
else
    ui.settings_io.last_serialized =
        "return " ..
        ui.settings_io.serialize(
            ui.settings_io.snapshot(),
            0
        ) ..
        "\n"
end



