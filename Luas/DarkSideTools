            end
        end

        imgui.separator()

        if #rows == 0 then
            for index, column in ipairs(columns) do
                ui.lobby.draw_table_text(
                    start_x,
                    column.offset,
                    column.width,
                    index == 1 and "No Infected players" or "-",
                    0.68, 0.68, 0.68,
                    index == 1
                )

                local next_column = columns[index + 1]
                if next_column then
                    draw_divider(next_column)
                end
            end
        else
            for row_index, row in ipairs(rows) do
                local neutral_r, neutral_g, neutral_b =
                    0.70, 0.70, 0.72

                local display_state =
                    row.exact == true
                    and (row.state == "Ghost" and "Unspawned" or "Spawned")
                    or "Guess"

                local class_r, class_g, class_b =
                    0.72, 0.36, 1.00

                if row.exact == true then
                    if row.state == "Ghost" then
                        class_r, class_g, class_b =
                            0.70, 0.70, 0.72
                    else
                        class_r, class_g, class_b =
                            1.0, 0.30, 0.30
                    end
