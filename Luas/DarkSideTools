function ui.control.get_tool_cycle_capture_keys()
    local capture =
        ui.control.tool_cycle_capture

    if type(capture.candidates) == "table" then
        return capture.candidates
    end

    local candidates = {}
    local seen = {}

    local function add_key(key_value)
        key_value =
            math.floor(
                tonumber(key_value) or 0
            )

        if key_value > 0
            and key_value <= 4096
            and not seen[key_value] then

            seen[key_value] = true
            candidates[#candidates + 1] =
                key_value
        end
    end

    for key_value = 1, 255 do
        add_key(key_value)
    end

    if type(keys) == "table" then
        for _, key_value in pairs(keys) do
            add_key(key_value)
        end
    end

    table.sort(candidates)
    capture.candidates = candidates

    return candidates
end

