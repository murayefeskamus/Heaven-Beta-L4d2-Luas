function ui.control.set_nofall_enabled(
    enabled,
    source_label
)
    local new_state =
        enabled == true

    if ui.control.nofall.enabled == new_state then
        return false
    end

    ui.control.nofall.enabled =
        new_state

    ui.control.runtime.nofall_status =
        new_state
        and "Monitoring"
        or "Disabled"

    ui.control.runtime.nofall_last_error = ""

    ui.console.print(
        "[Gameplay Tools] No Fall Damage " ..
        (
            new_state
            and "enabled"
            or "disabled"
        ) ..
        (
            tostring(source_label or "") ~= ""
            and (" from " .. tostring(source_label))
            or ""
        ) ..
        "."
    )

    return true
end

function ui.control.toggle_nofall(
    source_label
)
    return ui.control.set_nofall_enabled(
        ui.control.nofall.enabled ~= true,
        source_label
    )
