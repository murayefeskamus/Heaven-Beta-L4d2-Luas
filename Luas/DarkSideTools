                    post_random_quote()
                end

                draw_compact_gap()
                draw_compact_gap()
            end

            if not settings.details_expanded then
                local compact =
                    settings.compact_display

                local pending_rows = {}
                local table_index = 0
                local anything_drawn = false

                local function flush_compact_rows()
                    if #pending_rows <= 0 then
                        return
                    end

                    table_index = table_index + 1

                    draw_overlay_table(
                        "QuotesStandaloneCompactTable_" ..
                            tostring(table_index),
                        pending_rows
                    )

                    pending_rows = {}
                    anything_drawn = true
                end

                for _, key in ipairs(
                    settings.compact_order
                ) do
                    if compact[key] == true then
                        local row = make_quote_row(key)

                        if row then
                            pending_rows[#pending_rows + 1] = row
                        elseif key == "detected_players" then
                            flush_compact_rows()
                            draw_detected_quotes(
                                overlay_detected_players
                            )
                            anything_drawn = true
                        elseif key == "random_button" then
                            flush_compact_rows()
                            draw_random_quote_button(
                                "QuotesStandaloneCompactOrdered"
                            )
                            anything_drawn = true
                        end
                    end
                end

                flush_compact_rows()

                if not anything_drawn then
                    imgui.text(
                        "All compact-view fields are hidden in Settings."
                    )
                end
            end

            if settings.details_expanded then
                local detailed =
                    settings.detailed_display

                local definition_lookup =
                    ui.reorderable_fields.definition_lookup(
                        ui.quotes.detailed_field_definitions
                    )

                local pending_rows = {}
                local current_section = ""
                local table_index = 0
                local anything_drawn = false

                local function flush_detailed_rows()
                    if #pending_rows <= 0 then
                        return
                    end

                    table_index = table_index + 1

                    draw_overlay_table(
                        "QuotesStandaloneDetailedTable_" ..
                            tostring(table_index),
                        pending_rows
                    )

                    pending_rows = {}
                    anything_drawn = true
                end

                for _, key in ipairs(
                    settings.detailed_order
                ) do
                    if detailed[key] == true then
                        local definition =
                            definition_lookup[key]

                        local section =
                            definition
                            and tostring(
                                definition.section or "DETAILS"
                            )
                            or "DETAILS"

                        local row = make_quote_row(key)

                        if key == "detected_players" then
                            flush_detailed_rows()
                            draw_detected_quotes(
                                overlay_detected_players
                            )
                            current_section = "DETECTION"
                            anything_drawn = true
                        else
                            if section ~= current_section then
                                flush_detailed_rows()
                                ui.quotes.draw_overlay_section(
                                    section
                                )
                                current_section = section
                            end

                            if row then
                                pending_rows[#pending_rows + 1] = row
                            elseif key == "random_button" then
                                flush_detailed_rows()
                                draw_random_quote_button(
                                    "QuotesStandaloneDetailedOrdered"
                                )
                                anything_drawn = true
                            end
                        end
                    end
                end

                flush_detailed_rows()

                if not anything_drawn then
                    imgui.text(
                        "All detailed-view fields are hidden in Settings."
                    )
                end
            end

            if overlay_resize_frames > 0 then
                overlay_resize_frames =
                    overlay_resize_frames - 1
            end
        end

        imgui["end"]()

        ui.performance.pop_style_colors(
            opacity_fallback_colors
        )

        ui.quotes.rendering_overlay = false
        ui.quotes.manual_opacity_fallback = false

    end

    function ui.quotes.start()
        if ui.quotes.started then
            return
        end

        ui.quotes.started = true
        ui.quotes.normalize_settings()

        load_quotes()

        ui.console.print(
            "[DST Quotes] Integrated Quotes module loaded. " ..
            "Press [" ..
            ui.control.get_key_name(
