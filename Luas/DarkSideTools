function sanitize_chat_message(
    message,
    preserve_newlines
)
    message = tostring(message or "")

    message = expand_custom_newline_placeholders(
        message
    )

    message = message:gsub('"', "'")

    if preserve_newlines == true then
        message = message:gsub("\r\n", "\r")
        message = message:gsub("\n", "\r")
        message = message:gsub("\r+", "\r")
    else
        message = message:gsub("[\r\n]", " ")
    end

    if #message > DARKSIDE_CONFIG.MAX_CHAT_MESSAGE_LENGTH then
        message = message:sub(
            1,
            DARKSIDE_CONFIG.MAX_CHAT_MESSAGE_LENGTH
        )
    end

    return message
end

function normalize_chat_for_compare(message)
    local normalized =
        sanitize_chat_message(
            message
        )

    normalized =
        normalized:gsub(
            "^%s+",
            ""
        )

    normalized =
        normalized:gsub(
            "%s+$",
            ""
        )


    normalized =
        normalized:gsub(
            chat_spammer.parrot_loop_marker,
            ""
        )

    return normalized
end

function chat_spammer.normalize_parrot_loop_text(
    message
)
    local normalized =
        tostring(
            message or ""
        )

    normalized =
        normalized:gsub(
            chat_spammer.parrot_loop_marker,
            ""
        )

    normalized =
        normalized:gsub(
            "[\r\n]",
            " "
        )

    normalized =
        normalized:gsub(
            "%s+",
            " "
        )

    normalized =
        normalized:gsub(
            "^%s+",
            ""
        )

    normalized =
        normalized:gsub(
            "%s+$",
            ""
        )

    return normalized:lower()
end

function chat_spammer.prune_parrot_loop_cache()
    local now =
        get_time()

    local expire_before =
        now -
        (
            tonumber(
                chat_spammer.parrot_loop_window
            ) or 8.0
        )

    for index =
        #chat_spammer.parrot_loop_recent,
        1,
        -1 do

        local entry =
            chat_spammer.parrot_loop_recent[
                index
            ]

        if not entry
            or not entry.time
            or entry.time < expire_before then

            table.remove(
                chat_spammer.parrot_loop_recent,
                index
            )
        end
    end

    while #chat_spammer.parrot_loop_recent
        > 64 do

        table.remove(
            chat_spammer.parrot_loop_recent,
            1
        )
    end
end

function chat_spammer.remember_parrot_exchange(
    source_message,
    output_message
)
    chat_spammer.prune_parrot_loop_cache()

    local normalized_source =
        chat_spammer.normalize_parrot_loop_text(
            source_message
        )

    local normalized_output =
        chat_spammer.normalize_parrot_loop_text(
            output_message
        )

    if normalized_source == ""
        and normalized_output == "" then

        return
    end

    table.insert(
        chat_spammer.parrot_loop_recent,
        {
            source = normalized_source,
            output = normalized_output,
            time = get_time()
        }
    )

    chat_spammer.prune_parrot_loop_cache()
end

function chat_spammer.is_parrot_loop_message(
    message
)
    local raw_message =
        tostring(
            message or ""
        )


    if raw_message:find(
        chat_spammer.parrot_loop_marker,
        1,
        true
    ) then

        chat_spammer.parrot_loop_blocked =
            chat_spammer.parrot_loop_blocked + 1

        return true
    end

    local normalized =
        chat_spammer.normalize_parrot_loop_text(
            raw_message
        )

    if normalized == "" then
        return false
    end

    chat_spammer.prune_parrot_loop_cache()

    for _, entry in ipairs(
        chat_spammer.parrot_loop_recent
    ) do
        local source =
            tostring(
                entry.source or ""
            )

        local output =
            tostring(
                entry.output or ""
            )


        if (
            source ~= ""
            and normalized == source
        ) or (
            output ~= ""
            and normalized == output
        ) then

            chat_spammer.parrot_loop_blocked =
                chat_spammer.parrot_loop_blocked + 1

            return true
        end


        if output ~= ""
            and #normalized > #output
            and normalized:sub(
                -#output
            ) == output then

            local prefix =
                normalized:sub(
                    1,
                    #normalized - #output
                )

            if prefix:match(
                "^.-:%s*$"
            ) then

                chat_spammer.parrot_loop_blocked =
                    chat_spammer.parrot_loop_blocked + 1

                return true
            end
        end
    end

    return false
end

function chat_spammer.build_loop_safe_parrot_message(
    message
)
    local safe_message =
        sanitize_chat_message(
            message
        )

    local marker =
        chat_spammer.parrot_loop_marker

    local available_length =
        math.max(
            0,
            DARKSIDE_CONFIG.MAX_CHAT_MESSAGE_LENGTH -
            #marker
        )

    if #safe_message > available_length then
        safe_message =
            safe_message:sub(
                1,
                available_length
            )
    end

    return safe_message ..
        marker
end

function shuffle_chat_word(
    word
)
    local characters =
        split_utf8_characters(
            tostring(
                word or ""
            )
        )

    if #characters <= 1 then
        return table.concat(
            characters
        )
    end

    local original =
        table.concat(
            characters
        )

    for index = #characters,
        2,
        -1 do

        local swap_index =
            math.random(
                1,
                index
            )

        characters[index],
        characters[swap_index] =
            characters[swap_index],
            characters[index]
    end

    local shuffled =
        table.concat(
            characters
        )

    if shuffled == original then
        local different_index = nil

        for index = 2,
            #characters do

            if characters[index]
                ~= characters[1] then

                different_index = index
                break
            end
        end

        if different_index then
            characters[1],
            characters[different_index] =
                characters[different_index],
                characters[1]

            shuffled =
                table.concat(
                    characters
                )
        end
    end

    return shuffled
end

function twist_chat_message(
    message
)
    local safe_message =
        sanitize_chat_message(
            message
        )

    local words = {}

    for word in safe_message:gmatch(
        "%S+"
    ) do
        table.insert(
            words,
            shuffle_chat_word(
                word
            )
        )
    end

    local left = 1
    local right = #words

    while left < right do
        words[left],
        words[right] =
            words[right],
            words[left]

        left = left + 1
        right = right - 1
    end

    return sanitize_chat_message(
        table.concat(
            words,
            " "
        )
    )
end

