local function extract_quoted_person(quote_text)
    quote_text = tostring(quote_text or "")

    if quote_text == "" then
        return nil
    end

    quote_text = quote_text:gsub("\239\187\191", "")
    quote_text = quote_text:gsub("\226\128\139", "")
    quote_text = quote_text:gsub("\226\128\140", "")
    quote_text = quote_text:gsub("\226\128\141", "")
    quote_text = quote_text:gsub("\226\128\142", "")
    quote_text = quote_text:gsub("\226\128\143", "")
    quote_text = quote_text:gsub("%c", "")
    quote_text = trim(quote_text)

    if quote_text == "" then
        return nil
    end

    quote_text = quote_text:gsub(
        "^%s*%[#%d+%]%s*",
        ""
    )

    quote_text = quote_text:gsub(
        "^%s*%b()%s*",
        ""
    )

    local person =
        quote_text:match("^%s*(.-)%s*:%s*%S.+$")
        or quote_text:match("^%s*(.-)%s*\239\188\154%s*%S.+$")
        or quote_text:match("^%s*(.-)%s+%-%s+%S.+$")
        or quote_text:match("^%s*(.-)%s+%-%-%s+%S.+$")
        or quote_text:match("^%s*(.-)%s+\226\128\148%s+%S.+$")
        or quote_text:match("^%s*(.-)%s+\226\128\147%s+%S.+$")
        or quote_text:match("^%s*%[([^%]]+)%]%s*:%s*%S.+$")
        or quote_text:match("^%s*%[([^%]]+)%]%s+%S.+$")
        or quote_text:match("^%s*<([^>]+)>%s*:%s*%S.+$")
        or quote_text:match("^%s*<([^>]+)>%s+%S.+$")

    if not person then
        return nil
    end

    person = trim(person)
    person = person:gsub("^%b()%s*", "")
    person = person:gsub("^%[", ""):gsub("%]$", "")
    person = person:gsub("^<", ""):gsub(">$", "")
    person = trim(person)

    if person == "" then
        return nil
    end

    return person
end

local normalize_player_name_for_detection

local function quote_belongs_to_person(
    quote_text,
    target_person
)
    local quote_person =
        extract_quoted_person(
            quote_text
        )

    if not quote_person then
        return false
    end


    return normalize_player_name_for_detection(
        quote_person
    ) == normalize_player_name_for_detection(
        target_person
    )
end

local function find_quotes_by_person(
    person,
    excluded_line_number
)
    local matches = {}

    for index, quote in ipairs(quotes) do
        if quote.line_number
                ~= excluded_line_number
            and quote_belongs_to_person(
                quote.text,
                person
            ) then

            table.insert(
                matches,
                index
            )
        end
    end

    return matches
end


local function post_random_quote()
    if not engine.is_in_game() then
        status.message = "Not in game"

        ui.console.print(
            "[L4D2 Quotes] You are not in a game."
        )

        return
    end

    if not engine.is_connected() then
        status.message = "Not connected"

        ui.console.print(
            "[L4D2 Quotes] Not connected to a server."
        )

        return
    end

    local current_time =
        os.clock()

    if current_time - last_post_time
        < settings.cooldown_seconds then

        return
    end

    if not load_quotes()
        or #quotes == 0 then

        status.message =
            "No quote available"

        ui.console.print(
            "[L4D2 Quotes] No quotes available."
        )

        return
    end

    local selected_quote =
        select_next_quote()

    if not selected_quote then
        status.message =
            "No quote available"

        ui.console.print(
            "[L4D2 Quotes] No quotes available."
        )

        return
    end

    local chat_message =
        format_quote_message(
            selected_quote
        )

    local sent =
        post_to_all_chat_immediately(
            chat_message
        )

    if not sent then
        status.message = "Post failed"
        return
    end

    last_post_time =
        current_time

    status.last_number =
        selected_quote.line_number

    mark_quote_displayed(
        selected_quote
    )

    remember_posted_quote(
        nil,
        selected_quote
    )

    set_quote_status(
        "Post a random quote posted"
    )

    ui.console.print(
        "[L4D2 Quotes] Posted: " ..
        chat_message
    )
end

local function handle_quote_key()
    local key_down =
        input.is_key_down(settings.key)

    if ui.quotes.suppress_random_hotkey_until_release == true then
        if not key_down then
            ui.quotes.suppress_random_hotkey_until_release = false
            key_was_down = false
        end

        return
    end

    if key_down and not key_was_down then
        post_random_quote()
    end

    key_was_down = key_down
end


