function ui.enhancements.capture_chat_output(
    callback
)
    local captured = {}

    local original_queue =
        ui.lobby.queue_chat_messages

    ui.lobby.queue_chat_messages =
        function(messages)
            for _, message in ipairs(
                messages or {}
            ) do
                table.insert(
                    captured,
                    tostring(message)
                )
            end

            return #captured > 0
        end

    local ok,
        error_message =
            pcall(
                callback
            )

    ui.lobby.queue_chat_messages =
        original_queue

    if not ok then

        captured = {
            "Preview error: " ..
            tostring(error_message)
        }
    end

    return captured
end

function ui.enhancements.preview_infected_class_line(
    player_record
)
    if not player_record then
        return "No Infected player selected."
    end

    local assignment = nil

    if tonumber(player_record.entity_index)
        and tonumber(player_record.entity_index) > 0 then

        assignment =
            ui.lobby.get_verified_infected_assignment_by_index(
                player_record.entity_index,
                false
            )
    end

    if not assignment
        and tonumber(player_record.userid)
        and tonumber(player_record.userid) > 0 then

        assignment =
            ui.lobby.get_verified_infected_assignment(
                player_record.userid,
                false
            )
    end

    if assignment then
        return tostring(player_record.name or "Player") ..
            " - " ..
            (
                assignment.is_ghost
                and "assigned ghost class"
                or "current class"
            ) ..
            ": " ..
            tostring(assignment.name)
    end

    local prediction_row =
        ui.lobby.get_infected_player_prediction(
            player_record,
            true
        )

    if prediction_row then
        return ui.lobby.format_infected_player_prediction_line(
            prediction_row
        )
    end

    return tostring(player_record.name or "Player") ..
        " - class prediction unavailable."
end

function ui.enhancements.build_zombieclass_preview(
    include_all
)
    local infected_players = {}

    for _, player_record in ipairs(
        ui.lobby.players or {}
    ) do
        if tonumber(player_record.team) == 3 then
            table.insert(
                infected_players,
                player_record
            )
        end
    end

    table.sort(
        infected_players,
        function(left, right)
            if left.is_bot ~= right.is_bot then
                return left.is_bot ~= true
            end

            return tostring(left.name or ""):lower() <
                tostring(right.name or ""):lower()
        end
    )

    if #infected_players == 0 then
        return {
            "No Infected players are currently available."
        }
    end

    if include_all ~= true then
        local selected =
            ui.lobby.get_selected_player()

        if not selected
            or tonumber(selected.team) ~= 3 then

            selected = nil

            for _, player_record in ipairs(
                infected_players
            ) do
                if player_record.is_local then
                    selected = player_record
                    break
                end
            end

            selected = selected or infected_players[1]
        end

        return {
            ui.enhancements.preview_infected_class_line(
                selected
            )
        }
    end

    local messages = {
        "Infected classes and predictions:"
    }

    for _, player_record in ipairs(
        infected_players
    ) do
        table.insert(
            messages,
            ui.enhancements.preview_infected_class_line(
                player_record
            )
        )
    end

    return messages
end

