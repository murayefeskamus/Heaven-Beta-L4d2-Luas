function ui.control.get_color_lut_candidate_paths(profile_name)
    profile_name = tostring(profile_name or "infected.raw")

    local relative = {
        "left4dead2\\materials\\correction\\" .. profile_name,
        "materials\\correction\\" .. profile_name,
        "..\\left4dead2\\materials\\correction\\" .. profile_name
    }

    local program_files_x86 = ui.control.safe_environment_value("ProgramFiles(x86)")
    local program_files = ui.control.safe_environment_value("ProgramFiles")
    local candidates = {}

    local function add(path)
        path = tostring(path or "")
        if path ~= "" then
            candidates[#candidates + 1] = path
        end
    end

    for _, path in ipairs(relative) do
        add(path)
    end

    if program_files_x86 ~= "" then
        add(program_files_x86 .. "\\Left 4 Dead 2\\left4dead2\\materials\\correction\\" .. profile_name)
    end

    if program_files ~= "" then
        add(program_files .. "\\Left 4 Dead 2\\left4dead2\\materials\\correction\\" .. profile_name)
    end

    for _, drive in ipairs({ "C", "D", "E", "F", "G" }) do
        add(drive .. ":\\Games\\Left 4 Dead 2\\left4dead2\\materials\\correction\\" .. profile_name)
        add(drive .. ":\\Left 4 Dead 2\\left4dead2\\materials\\correction\\" .. profile_name)
    end

    return candidates
end

function ui.control.load_color_lut_profile(profile_name, force_reload)
    profile_name = tostring(profile_name or "infected.raw")
    local cache = ui.control.fov_color_lut_cache

    if force_reload == true then
        cache.profiles[profile_name] = nil
        cache.attempted[profile_name] = nil
        cache.inverse = {}
    end

    if cache.profiles[profile_name] then
        return cache.profiles[profile_name]
    end

    if cache.attempted[profile_name] then
        return nil
    end

    cache.attempted[profile_name] = true

    if type(io) ~= "table" or type(io.open) ~= "function" then
        ui.control.runtime.fov_circle_color_profile_status = "Lua file I/O unavailable"
        return nil
    end

    for _, path in ipairs(ui.control.get_color_lut_candidate_paths(profile_name)) do
        local file = io.open(path, "rb")

        if file then
            local data = file:read("*a")
            file:close()

            local byte_count = type(data) == "string" and #data or 0
            local entry_count = math.floor(byte_count / 3)
            local dimension = math.floor(entry_count ^ (1.0 / 3.0) + 0.5)

            if byte_count > 0
                and byte_count % 3 == 0
                and dimension >= 2
                and dimension * dimension * dimension == entry_count then

                local profile = {
                    name = profile_name,
                    path = path,
                    data = data,
                    dimension = dimension,
                    entry_count = entry_count
                }

                cache.profiles[profile_name] = profile
                ui.control.runtime.fov_circle_color_profile_status = "Loaded"
                ui.control.runtime.fov_circle_color_profile_path = path
                ui.control.runtime.fov_circle_color_profile_dimension = dimension
                return profile
            end
        end
    end

    ui.control.runtime.fov_circle_color_profile_status = "Profile not found; using Direct RGB"
    ui.control.runtime.fov_circle_color_profile_path = ""
    ui.control.runtime.fov_circle_color_profile_dimension = 0
    return nil
end

function ui.control.read_color_lut_entry(profile, red_index, green_index, blue_index)
    if type(profile) ~= "table" or type(profile.data) ~= "string" then
        return 0.0, 0.0, 0.0
    end

    local dimension = math.max(2, math.floor(tonumber(profile.dimension) or 32))
    red_index = math.max(0, math.min(dimension - 1, math.floor(tonumber(red_index) or 0)))
    green_index = math.max(0, math.min(dimension - 1, math.floor(tonumber(green_index) or 0)))
    blue_index = math.max(0, math.min(dimension - 1, math.floor(tonumber(blue_index) or 0)))

    local entry_index = red_index + (green_index + blue_index * dimension) * dimension
    local offset = entry_index * 3 + 1
    local red, green, blue = string.byte(profile.data, offset, offset + 2)

    return (tonumber(red) or 0) / 255.0,
        (tonumber(green) or 0) / 255.0,
        (tonumber(blue) or 0) / 255.0
end

function ui.control.sample_color_lut(profile, input_color)
    input_color = ui.control.normalize_rgba_color(input_color, { 1.0, 1.0, 1.0, 1.0 })

    local dimension = math.max(2, math.floor(tonumber(profile and profile.dimension) or 32))
    local maximum_index = dimension - 1
    local x = input_color[1] * maximum_index
    local y = input_color[2] * maximum_index
    local z = input_color[3] * maximum_index
    local x0, y0, z0 = math.floor(x), math.floor(y), math.floor(z)
    local x1, y1, z1 = math.min(maximum_index, x0 + 1), math.min(maximum_index, y0 + 1), math.min(maximum_index, z0 + 1)
    local tx, ty, tz = x - x0, y - y0, z - z0

    local function entry(ix, iy, iz)
        local r, g, b = ui.control.read_color_lut_entry(profile, ix, iy, iz)
        return { r, g, b }
    end

    local c000, c100 = entry(x0, y0, z0), entry(x1, y0, z0)
    local c010, c110 = entry(x0, y1, z0), entry(x1, y1, z0)
    local c001, c101 = entry(x0, y0, z1), entry(x1, y0, z1)
    local c011, c111 = entry(x0, y1, z1), entry(x1, y1, z1)

    local output = { 0.0, 0.0, 0.0, input_color[4] }

    for channel = 1, 3 do
        local c00 = c000[channel] + (c100[channel] - c000[channel]) * tx
        local c10 = c010[channel] + (c110[channel] - c010[channel]) * tx
        local c01 = c001[channel] + (c101[channel] - c001[channel]) * tx
        local c11 = c011[channel] + (c111[channel] - c011[channel]) * tx
        local c0 = c00 + (c10 - c00) * ty
        local c1 = c01 + (c11 - c01) * ty
        output[channel] = c0 + (c1 - c0) * tz
    end

    return output
end

function ui.control.color_match_error(first, second)
    first = ui.control.normalize_rgba_color(first, { 0.0, 0.0, 0.0, 1.0 })
    second = ui.control.normalize_rgba_color(second, { 0.0, 0.0, 0.0, 1.0 })

    local dr = first[1] - second[1]
    local dg = first[2] - second[2]
    local db = first[3] - second[3]

    return dr * dr * 0.299 + dg * dg * 0.587 + db * db * 0.114
end

function ui.control.solve_color_lut_inverse(profile, desired_color)
    desired_color = ui.control.normalize_rgba_color(desired_color, { 1.0, 1.0, 1.0, 1.0 })

    if type(profile) ~= "table" then
        return desired_color, desired_color, 0.0
    end

    local profile_key = tostring(profile.path or profile.name or "profile")
    local quantized_key = string.format(
        "%s|%02X%02X%02X",
        profile_key,
        math.floor(desired_color[1] * 31 + 0.5),
        math.floor(desired_color[2] * 31 + 0.5),
        math.floor(desired_color[3] * 31 + 0.5)
    )

    local cache = ui.control.fov_color_lut_cache
    local cached = cache.inverse[quantized_key]

    if cached then
        return { cached.input[1], cached.input[2], cached.input[3], desired_color[4] },
            { cached.output[1], cached.output[2], cached.output[3], desired_color[4] },
            cached.error
    end

    local dimension = profile.dimension
    local maximum_index = dimension - 1
    local best_error = math.huge
    local best_r, best_g, best_b = 0, 0, 0

    for blue_index = 0, maximum_index do
        for green_index = 0, maximum_index do
            for red_index = 0, maximum_index do
                local out_r, out_g, out_b = ui.control.read_color_lut_entry(
                    profile,
                    red_index,
                    green_index,
                    blue_index
                )

                local dr = out_r - desired_color[1]
                local dg = out_g - desired_color[2]
                local db = out_b - desired_color[3]
                local error = dr * dr * 0.299 + dg * dg * 0.587 + db * db * 0.114

                if error < best_error then
                    best_error = error
                    best_r, best_g, best_b = red_index, green_index, blue_index
                end
            end
        end
    end

    local best_input = {
        best_r / maximum_index,
        best_g / maximum_index,
        best_b / maximum_index,
        desired_color[4]
    }
    local best_output = ui.control.sample_color_lut(profile, best_input)
    best_error = ui.control.color_match_error(best_output, desired_color)

    local step = 1.0 / maximum_index

    for _ = 1, 5 do
        local improved = true

        while improved do
            improved = false

            for _, delta in ipairs({
                { step, 0, 0 }, { -step, 0, 0 },
                { 0, step, 0 }, { 0, -step, 0 },
                { 0, 0, step }, { 0, 0, -step }
            }) do
                local candidate = {
                    ui.control.clamp(best_input[1] + delta[1], 0.0, 1.0),
                    ui.control.clamp(best_input[2] + delta[2], 0.0, 1.0),
                    ui.control.clamp(best_input[3] + delta[3], 0.0, 1.0),
                    desired_color[4]
                }
                local output = ui.control.sample_color_lut(profile, candidate)
                local error = ui.control.color_match_error(output, desired_color)

                if error + 0.0000001 < best_error then
                    best_input, best_output, best_error = candidate, output, error
                    improved = true
                end
            end
        end

        step = step * 0.5
    end

    cache.inverse[quantized_key] = {
        input = { best_input[1], best_input[2], best_input[3] },
        output = { best_output[1], best_output[2], best_output[3] },
        error = best_error
    }

    return best_input, best_output, best_error
end

function ui.control.get_color_pipeline_profile_name(settings)
    settings = settings or ui.control.aim.v2
    local mode = math.max(0, math.min(5, math.floor(tonumber(settings.fov_circle_color_pipeline) or 1)))

    if mode == 2 then return "infected.raw" end
    if mode == 3 then return "infected.pwl.raw" end
    if mode == 4 then return "ghost.raw" end
    if mode == 5 then return "ghost.pwl.raw" end
    if mode == 0 then return nil end

    local alive = false
    local local_player = type(client) == "table" and type(client.get_local_player) == "function"
        and client.get_local_player()
        or nil

    if local_player then
        local ok, value = pcall(function()
            return type(local_player.is_alive) == "function" and local_player:is_alive() or false
        end)
        alive = ok and (value == true or value == 1 or tostring(value):lower() == "true")
    end

    local base = alive and "infected" or "ghost"

    local pwl_name = base .. ".pwl.raw"
    local pwl = ui.control.load_color_lut_profile(pwl_name, false)
    if pwl then return pwl_name end
    return base .. ".raw"
end

