            aim_settings.fov_circle_opacity = opacity_value
        end

        draw_hint("Controls main-guide transparency.")
        draw_scenario("Troubleshooting/blatant: 0.90-1.00; normal: 0.60-0.85; subtle: 0.25-0.50.")

