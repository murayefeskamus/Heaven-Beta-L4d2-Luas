function ui.lobby.queue_infected_class_query(
    requester_userid,
    target_records,
    query_mode,
    response_team_only
)
    if type(target_records) ~= "table" then
        return false
    end

    local targets = {}

    for _, player_record in ipairs(
        target_records
    ) do
        if type(player_record) == "table"
            and tonumber(player_record.team) == 3 then

            local userid =
                math.floor(
                    tonumber(player_record.userid) or 0
                )

            local entity_index =
                math.floor(
                    tonumber(player_record.entity_index) or 0
                )

            if userid > 0
                or entity_index > 0 then

                table.insert(
                    targets,
                    {
                        userid = userid,
                        entity_index = entity_index,
                        name = tostring(
                            player_record.name or "Player"
                        ),
                        is_bot = player_record.is_bot == true,
                        last_class_id = nil,
                        stable_reads = 0,
                        resolved = false,
                        result = nil
                    }
                )
            end
        end
    end

    if #targets == 0 then
        return false
    end

    local requester_key =
        tostring(
            math.floor(
                tonumber(requester_userid) or 0
            )
        )

    ui.lobby.pending_infected_class_queries[
        requester_key
    ] = {
        requester_userid =
            math.floor(
                tonumber(requester_userid) or 0
            ),
        owner_request =
            is_local_player_userid(
                requester_userid
            ),
        response_team_only =
            response_team_only == true,
        mode = tostring(query_mode or "single"),
        targets = targets,
        started_at = get_time(),
        next_poll = get_time()
    }

    return true
end

function ui.lobby.get_verified_infected_assignment_by_index(
    player_index,
    require_spawned
)
    player_index = math.floor(
        tonumber(player_index) or 0
    )

    if player_index <= 0 then
        return nil, "invalid player"
    end

    local player_entity =
        entity.get_by_index(
            player_index
        )

    if not player_entity then
        return nil, "entity unavailable"
    end

    local team_number = tonumber(
        ui.lobby.call_method(
            player_entity,
            "get_team"
        )
    ) or 0

    if team_number ~= 3 then
        return nil, "not infected"
    end


    local zombie_class = tonumber(
        ui.lobby.call_method(
            player_entity,
            "get_prop",
            "m_zombieClass"
        )
    )

    if zombie_class == nil then
        zombie_class = tonumber(
            ui.lobby.call_method(
                player_entity,
                "get_zombie_class"
            )
        )
    end

    local class_name =
        ui.lobby.verified_infected_class_names[
            zombie_class
        ]

    if not class_name then
        return nil, "class not assigned"
    end


    local life_state = tonumber(
        ui.lobby.call_method(
            player_entity,
            "get_prop",
            "m_lifeState"
        )
    )

    local alive = nil

    if life_state ~= nil then
        alive = life_state == 0
    else
        local alive_value =
            ui.lobby.call_method(
                player_entity,
                "is_alive"
            )

        if alive_value ~= nil then
            alive = alive_value == true
                or alive_value == 1
                or tostring(alive_value):lower() == "true"
        else
            local health_value = tonumber(
                ui.lobby.call_method(
                    player_entity,
                    "get_prop",
                    "m_iHealth"
                )
            )

            if health_value == nil then
                health_value = tonumber(
                    ui.lobby.call_method(
                        player_entity,
                        "get_health"
                    )
                )
            end

            if health_value ~= nil then
                alive = health_value > 0
            end
        end
    end

    if alive == nil then
        return nil, "state unavailable"
    end

    local record = nil

    if type(ui.lobby.find_player_by_entity_index) == "function" then
        record =
            ui.lobby.find_player_by_entity_index(
                player_index
            )
    end

    local is_bot =
        record
        and record.is_bot == true
        or name_stealer.is_player_bot(
            player_index,
            player_entity
        ) == true

    local ghost_value =
        ui.lobby.call_method(
            player_entity,
            "get_prop",
            "m_isGhost"
        )

    if ghost_value == nil then
        ghost_value =
            ui.lobby.call_method(
                player_entity,
                "is_ghost"
            )
    end

    local is_ghost = false

    if ghost_value ~= nil then
        is_ghost = ghost_value == true
            or ghost_value == 1
            or tostring(ghost_value):lower() == "true"
    elseif is_bot and alive == true then


        is_ghost = false
    else


        return nil, "state unavailable"
    end

    local spawned =
        alive == true
        and is_ghost ~= true

    if require_spawned == true then
        if not spawned then
            return nil, "spawn not confirmed"
        end
    elseif not spawned
        and is_ghost ~= true then


        return nil, "class not assigned"
    end

    return {
        id = zombie_class,
        name = class_name,
        player_index = player_index,
        alive = alive == true,
        is_ghost = is_ghost == true,
        spawned = spawned == true,
        is_bot = is_bot == true
    }, nil
end

function ui.lobby.get_verified_infected_assignment(
    userid,
    require_spawned
)
    userid = math.floor(
        tonumber(userid) or 0
    )

    if userid <= 0 then
        return nil, "invalid user id"
    end

    local success,
        player_index =
            pcall(
                engine.get_player_for_userid,
                userid
            )

    if not success
        or not player_index
        or tonumber(player_index) <= 0 then

        return nil, "entity unavailable"
    end

    return ui.lobby.get_verified_infected_assignment_by_index(
        player_index,
        require_spawned
    )
end

function ui.lobby.team_name(
    team_number
)
    team_number =
        tonumber(team_number) or 0

    if team_number == 1 then
        return "Spectator"
    elseif team_number == 2 then
        return "Survivors"
    elseif team_number == 3 then
        return "Infected"
    elseif team_number == 0 then
