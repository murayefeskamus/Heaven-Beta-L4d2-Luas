function spammer_cfg.ensure_name_enabled_states()
    if type(
        spammer_cfg.name_enabled
    ) ~= "table" then

        spammer_cfg.name_enabled = {}
    end

    if type(
        spammer_cfg.removed_name_enabled
    ) ~= "table" then

        spammer_cfg.removed_name_enabled = {}
    end

    local name_count =
        get_spammer_name_count()

    for index = 1,
        name_count do

        if spammer_cfg.name_enabled[
            index
        ] == nil then

            spammer_cfg.name_enabled[
                index
            ] = true
        else
            spammer_cfg.name_enabled[
                index
            ] =
                spammer_cfg.name_enabled[
                    index
                ] == true
        end
    end

    for index =
        #spammer_cfg.name_enabled,
        name_count + 1,
        -1 do

        table.remove(
            spammer_cfg.name_enabled,
            index
        )
    end
end

function spammer_cfg.is_name_enabled(index)
    spammer_cfg.ensure_name_enabled_states()

    index =
