function ui.lobby.get_weapon_entity_identifier(
    weapon_entity
)
    if not weapon_entity then
        return nil
    end

    local script_name =
        ui.lobby.call_method(
            weapon_entity,
            "get_prop",
            "m_strMapSetScriptName"
        )

    if script_name
        and tostring(script_name) ~= "" then

        local normalized_script =
            ui.lobby.normalize_weapon_identifier(
                script_name
            )

        if ui.lobby.get_weapon_display_name(
            normalized_script
        ) then
            return normalized_script
        end
    end

    local method_names = {
        "get_classname",
        "get_class_name",
        "get_network_name",
        "get_name"
    }

    for _, method_name in ipairs(
        method_names
    ) do
        local value =
            ui.lobby.call_method(
                weapon_entity,
                method_name
            )

        if value
            and tostring(value) ~= "" then

            local normalized =
                ui.lobby.normalize_weapon_identifier(
                    value
                )

            if normalized == "melee"
                and script_name
                and tostring(script_name) ~= "" then

                normalized =
                    ui.lobby.normalize_weapon_identifier(
                        script_name
                    )
            end

            if ui.lobby.get_weapon_display_name(
                normalized
            ) then
                return normalized
            end
        end
    end

    return nil
end

function ui.lobby.get_active_weapon_identifier(
    player_record
)
    if not player_record then
        return nil
    end

    local player_entity =
        entity.get_by_index(
            tonumber(
                player_record.entity_index
            ) or 0
        )

    if not player_entity then
        return nil
    end

    local weapon_entity =
        ui.lobby.call_method(
            player_entity,
            "get_active_weapon"
        )

    if type(weapon_entity) == "number" then
        local weapon_index =
            math.floor(weapon_entity) % 4096

        weapon_entity =
            weapon_index > 0
            and entity.get_by_index(
                weapon_index
            )
            or nil
    end

    if not weapon_entity then
        local active_handle =
            tonumber(
                ui.lobby.call_method(
                    player_entity,
                    "get_prop",
                    "m_hActiveWeapon"
                )
            )

        if active_handle
            and active_handle > 0 then

            local weapon_index =
                math.floor(active_handle) % 4096

            if weapon_index > 0 then
                weapon_entity =
                    entity.get_by_index(
                        weapon_index
                    )
            end
        end
    end

    local identifier =
        ui.lobby.get_weapon_entity_identifier(
            weapon_entity
        )

    if identifier == "pistol" then
        local has_dual =
            ui.lobby.call_method(
                player_entity,
                "get_prop",
                "m_hasDualWeapons"
            )

        if has_dual == true
            or has_dual == 1
            or tostring(has_dual):lower() == "true" then

            identifier = "dual_pistols"
        end
    end

    return identifier
end

function ui.lobby.remember_player_weapon(
    player_record,
    weapon_identifier
)
    if not player_record
        or not player_record.key then

        return nil
    end

    local normalized =
        ui.lobby.normalize_weapon_identifier(
            weapon_identifier
        )

    if normalized == ""
        or not ui.lobby.get_weapon_display_name(
            normalized
        ) then

        return nil
    end

    if normalized == "melee" then
        normalized =
            ui.lobby.get_active_weapon_identifier(
                player_record
            ) or normalized
    elseif normalized == "pistol" then
        local active_identifier =
            ui.lobby.get_active_weapon_identifier(
                player_record
            )

        if active_identifier == "dual_pistols" then
            normalized =
                active_identifier
        end
    end

    ui.lobby.last_weapon_by_player[
        player_record.key
    ] = {
        identifier = normalized,
        observed_at = get_time()
    }

    return normalized
end

function ui.lobby.record_weapon_observation(
    event,
    explicit_field
)
    local player_record =
        ui.lobby.resolve_event_player(
            event,
            {
                "userid",
                "attacker"
            },
            {
                "attackerentid",
                "entityid"
            }
        )

    if not player_record then
        return
    end

    local weapon_name = ""

    if explicit_field then
        weapon_name =
            ui.lobby.get_event_string(
                event,
                explicit_field
            )
    end

    if weapon_name == "" then
        local fields = {
            "weapon",
            "weapon_name",
            "weaponname",
            "item"
        }

        for _, field_name in ipairs(
            fields
        ) do
            weapon_name =
                ui.lobby.get_event_string(
                    event,
                    field_name
                )

            if weapon_name ~= "" then
                break
            end
        end
    end

    if weapon_name == "" then
        weapon_name =
            ui.lobby.get_active_weapon_identifier(
                player_record
            ) or ""
    end

    ui.lobby.remember_player_weapon(
        player_record,
        weapon_name
    )
end

function ui.lobby.resolve_kill_weapon_identifier(
    event,
    player_record
)
    local event_fields = {
        "weapon",
        "weapon_name",
        "weaponname",
        "melee_weapon",
        "item"
    }

    local explicit_identifier = nil

    for _, field_name in ipairs(
        event_fields
    ) do
        local event_value =
            ui.lobby.get_event_string(
                event,
                field_name
            )

        if event_value ~= "" then
            local normalized =
                ui.lobby.normalize_weapon_identifier(
                    event_value
                )

            if ui.lobby.get_weapon_display_name(
                normalized
            ) then
                explicit_identifier =
                    normalized

                break
            end
        end
    end

    local weapon_id =
        ui.lobby.get_event_int(
            event,
            "weapon_id"
        )

    if weapon_id <= 0 then
        weapon_id =
            ui.lobby.get_event_int(
                event,
                "weaponid"
            )
    end

    local id_identifier =
        ui.lobby.weapon_id_names[
            weapon_id
        ]

    local remembered =
        player_record
        and ui.lobby.last_weapon_by_player[
            player_record.key
        ]
        or nil

    local remembered_identifier =
        remembered
        and remembered.identifier
        or nil

    local active_identifier =
        ui.lobby.get_active_weapon_identifier(
            player_record
        )

    local resolved =
        explicit_identifier

    if not resolved
        and id_identifier then

        resolved =
            ui.lobby.normalize_weapon_identifier(
                id_identifier
            )
    end


    if resolved == "melee" then
        if active_identifier
            and ui.lobby.is_melee_weapon_identifier(
                active_identifier
            ) then

            resolved =
                active_identifier
        elseif remembered_identifier
            and ui.lobby.is_melee_weapon_identifier(
                remembered_identifier
            ) then

            resolved =
                remembered_identifier
        end
    elseif resolved == "pistol" then
        if remembered_identifier == "dual_pistols"
            or active_identifier == "dual_pistols" then

            resolved = "dual_pistols"
        end
    end

    if not resolved then
        resolved =
            remembered_identifier
            or active_identifier
    end

    if resolved then
        resolved =
            ui.lobby.remember_player_weapon(
                player_record,
                resolved
            ) or resolved
    end

    return resolved
end

function ui.lobby.merge_counter_totals(
    target,
    source
)
    target =
        type(target) == "table"
        and target
        or {}

    for counter_name, counter_value in pairs(
        source or {}
    ) do
        local incoming =
            math.max(
                0,
                tonumber(counter_value) or 0
            )

        local current =
            math.max(
                0,
                tonumber(
                    target[counter_name]
                ) or 0
            )

        if incoming > current then
            target[counter_name] =
                incoming
        end
    end

    return target
end

function ui.lobby.record_weapon_kill(
    player_record,
    weapon_identifier
)
    if not player_record
        or player_record.team ~= 2 then

        return false
    end

    local normalized =
        ui.lobby.normalize_weapon_identifier(
            weapon_identifier
        )

    local display_name =
        ui.lobby.get_weapon_display_name(
            normalized
        )

    if not display_name then
        return false
    end

    player_record.weapon_kills =
        ui.lobby.merge_counter_totals(
            player_record.weapon_kills,
            (
                ui.lobby.activity_cache[
                    player_record.key
                ] or {}
            ).weapon_kills
        )

    local cached =
        ui.lobby.activity_cache[
            player_record.key
        ] or {}

    cached.weapon_kills =
        ui.lobby.merge_counter_totals(
            cached.weapon_kills,
            player_record.weapon_kills
        )

    local next_total =
        math.max(
            tonumber(
                player_record.weapon_kills[
                    display_name
                ]
            ) or 0,
            tonumber(
                cached.weapon_kills[
                    display_name
                ]
            ) or 0
        ) + 1

    player_record.weapon_kills[
        display_name
    ] =
        next_total

    cached.weapon_kills[
        display_name
    ] =
        next_total

    ui.lobby.activity_cache[
        player_record.key
    ] = cached

    ui.lobby.update_activity_cache(
        player_record
    )

    return true
end

