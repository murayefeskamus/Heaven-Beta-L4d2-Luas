)
    local vertical =
        spammer_cfg.is_name_vertical(
            configured_index
        )

    local layout_position =
        spammer_cfg.get_layout_position_for_name_index(
            configured_index,
            vertical
        )

    local label =
        "Name " ..
        tostring(
            layout_position
        )

    if include_layout == true then
        label =
            label ..
            " - " ..
            (
                vertical
                and "Vertical"
                or "Horizontal"
            )
    end

    return label
end

function spammer_cfg.are_all_layout_names_enabled(
    vertical
)
    local indices =
        spammer_cfg.get_name_indices_for_layout(
            vertical
        )

    if #indices <= 0 then
        return false
    end

    for _, index in ipairs(indices) do
        if not spammer_cfg.is_name_enabled(
            index
        ) then

