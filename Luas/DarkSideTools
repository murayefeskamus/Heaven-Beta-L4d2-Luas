function ui.keybinds.binding_entries()
    local entries = {}

    local function add(binding_id, key_value, display_name)
        key_value = math.floor(tonumber(key_value) or 0)
        if key_value > 0 then
            entries[#entries + 1] = {
                id = tostring(binding_id),
                key = key_value,
                name = tostring(display_name)
            }
        end
    end

    add("control.action", ui.control.action_key, "Shared hold key")
    add("control.tool_cycle", ui.control.toggle_key, "Tool cycle key")
    add(
        "control.target_cycle",
        ui.control.aim and ui.control.aim.v2 and ui.control.aim.v2.target_cycle_key,
        "Cycle target key"
    )

    if ui.control.aim
        and ui.control.aim.v2
        and ui.control.aim.v2.pursuit_use_shared_key == false then

        add("control.pursuit", ui.control.aim.v2.pursuit_key, "Pursuit key")
    end

    add("window.network", ui.network.toggle_key, "Game & Net toggle key")

    if type(ui.quotes) == "table"
        and type(ui.quotes.settings) == "table" then

        add(
            "window.quotes",
            ui.quotes.settings.layout_toggle_key,
            "Quotes toggle key"
        )

        if ui.quotes.settings.hotkey_enabled == true then
            add(
                "quotes.random",
                ui.quotes.settings.key,
                "Random quote hotkey"
            )
        end
    end

    if type(ui.heaven_configs) == "table" then
        if ui.heaven_configs.use_cycle_key == true then
            add(
                "heaven.cycle",
                ui.heaven_configs.cycle_key,
                "Heaven config cycle key"
            )
        else
            for index = 1, math.floor(tonumber(ui.heaven_configs.max_slots) or 0) do
                local slot = ui.heaven_configs.slots[index]
                if slot then
                    add(
                        "heaven.slot." .. tostring(index),
                        slot.key,
                        "Heaven config hotkey " .. tostring(index)
                    )
                end
            end
        end
    end

    return entries
end

function ui.keybinds.conflict_reason(binding_id, key_value)
    binding_id = tostring(binding_id or "")
    key_value = math.floor(tonumber(key_value) or 0)

    if key_value <= 0 then
        return "Invalid key."
    end

    for _, entry in ipairs(ui.keybinds.binding_entries()) do
        if entry.id ~= binding_id and entry.key == key_value then
            return "Already bound to " .. tostring(entry.name) .. "."
        end
    end

    return nil
end

