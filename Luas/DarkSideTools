    return palindrome
end

function build_decorated_name(
    text,
    decoration_index
)


    local source_name =
        strip_known_name_decorations(
            text
        )

    local decoration =
        NAME_DECORATIONS[
            tonumber(decoration_index) or 1
        ] or NAME_DECORATIONS[1]

    local left =
        tostring(
            decoration.left or ""
        )

    local right =
        tostring(
            decoration.right or ""
        )

    local byte_limit =
        get_visible_name_byte_limit()

    local available_for_name =
        math.max(
            0,
            byte_limit -
            #left -
            #right
        )

    local fitted_source =
        truncate_name_utf8(
            source_name,
            available_for_name
        )

    local decorated =
        left ..
        fitted_source ..
        right

    return truncate_name_utf8(
        decorated,
        byte_limit
    )
end

