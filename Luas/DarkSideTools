local function geo84_trim(value)
    return tostring(value or "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
end

local function geo84_clean(value)
    value = geo84_trim(value)
    value = value:gsub("[\r\n|]", " ")
        :gsub("%s+", " ")
    return geo84_trim(value)
end

local function geo84_field(value)
    value = geo84_clean(value)
    if value == "" or value:lower() == "unknown" then
        return "-"
    end
    return value
end

local function geo84_escape_cache(value)
    return geo84_clean(value):gsub("|", "/")
end

local function geo84_parse_kv_line(line)
    local details = {}
    line = tostring(line or "")
        :gsub("^\239\187\191", "")
        :gsub("[\r\n]+", " ")

    for key, value in line:gmatch("([^|=]+)=([^|]*)") do
        key = geo84_trim(key)
        value = geo84_clean(value)
        if key ~= "" then
            details[key] = value
        end
    end

    return details
end

local function geo84_quote_cmd_path(path)
    return '"' .. tostring(path or ""):gsub('"', '') .. '"'
end

local function geo84_get_env(name)
    if type(os) == "table" and type(os.getenv) == "function" then
        local ok, value = pcall(os.getenv, name)
