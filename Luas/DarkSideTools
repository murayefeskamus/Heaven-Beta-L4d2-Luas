function ui.lobby.process_infected_class_queries()
    local pending_queries =
        ui.lobby.pending_infected_class_queries

    if type(pending_queries) ~= "table" then
        ui.lobby.pending_infected_class_queries = {}
        return
    end

    local now = get_time()
    local local_record = nil

    for _, player_record in ipairs(
        ui.lobby.players
    ) do
        if player_record.is_local then
            local_record = player_record
            break
        end
    end

    for query_key, query in pairs(
        pending_queries
    ) do
        if now >= (tonumber(query.next_poll) or 0) then
            query.next_poll =
                now +
                ui.lobby.infected_detection_poll_interval

            local requester =
                ui.lobby.find_player_by_userid(
                    query.requester_userid
                )

            local owner_request =
                query.owner_request == true
                and is_local_player_userid(
                    query.requester_userid
                )

            local request_still_allowed =
                owner_request
                or (
                    requester
                    and tonumber(requester.team) == 3
                    and local_record
                    and tonumber(local_record.team) == 3
                )

            if not request_still_allowed then
                pending_queries[query_key] = nil
            else
                local all_resolved = true

                for _, target in ipairs(
                    query.targets or {}
                ) do
                    if target.resolved ~= true then
                        all_resolved = false

                        local current_record = nil


                        if tonumber(target.entity_index)
                            and tonumber(target.entity_index) > 0 then

                            current_record =
                                ui.lobby.find_player_by_entity_index(
                                    target.entity_index
                                )
                        end

                        if not current_record
                            and tonumber(target.userid)
                            and tonumber(target.userid) > 0 then

                            current_record =
                                ui.lobby.find_player_by_userid(
                                    target.userid
                                )
                        end

                        if current_record then
                            target.name = tostring(
                                current_record.name
                                or target.name
                                or "Player"
                            )

                            target.entity_index =
                                math.floor(
                                    tonumber(
                                        current_record.entity_index
                                    ) or tonumber(target.entity_index) or 0
                                )

                            target.is_bot =
                                current_record.is_bot == true

                            local refreshed_userid =
                                math.floor(
                                    tonumber(
                                        current_record.userid
                                    ) or 0
                                )

                            if refreshed_userid > 0 then
                                target.userid = refreshed_userid
                            end
                        end

                        if current_record
                            and tonumber(current_record.team) ~= 3 then

                            target.result =
                                tostring(target.name) ..
                                " is no longer on the Infected team."

                            target.resolved = true
                        else
                            local assignment = nil
                            local assignment_error =
                                "entity unavailable"


                            if tonumber(target.entity_index)
                                and tonumber(target.entity_index) > 0 then

                                assignment,
                                    assignment_error =
                                        ui.lobby.get_verified_infected_assignment_by_index(
                                            target.entity_index,
                                            false
                                        )
                            end

                            if not assignment
                                and tonumber(target.userid)
                                and tonumber(target.userid) > 0 then

                                local userid_assignment,
                                    userid_error =
                                        ui.lobby.get_verified_infected_assignment(
                                            target.userid,
                                            false
                                        )

                                if userid_assignment then
                                    assignment = userid_assignment
                                    assignment_error = nil
                                elseif assignment_error ==
                                    "entity unavailable" then

                                    assignment_error = userid_error
                                end
                            end

                            target.last_error =
                                tostring(
                                    assignment_error or ""
                                )

                            if assignment then
                                if target.last_class_id ==
                                    assignment.id then

                                    target.stable_reads =
                                        (tonumber(target.stable_reads) or 0) + 1
                                else
                                    target.last_class_id =
                                        assignment.id

                                    target.stable_reads = 1
                                end


                                if target.stable_reads >= 3 then
                                    local state_label =
                                        assignment.is_ghost
                                        and "assigned ghost class"
                                        or "current class"

                                    target.result =
                                        tostring(target.name) ..
                                        " - " ..
                                        state_label ..
                                        ": " ..
                                        tostring(assignment.name)

                                    target.resolved = true
                                end
                            elseif now -
                                (tonumber(query.started_at) or now) >=
                                ui.lobby.infected_detection_max_wait then


                                if target.last_error ==
                                    "not infected" then

                                    target.result =
                                        tostring(target.name) ..
                                        " - no longer on the Infected team."
                                else
                                    local prediction_row =
                                        ui.lobby.get_infected_player_prediction(
                                            current_record or target,
                                            true
                                        )

                                    if prediction_row then
                                        target.result =
                                            ui.lobby.format_infected_player_prediction_line(
                                                prediction_row
                                            )

                                        target.predicted = true
                                    else
                                        target.result =
                                            tostring(target.name) ..
                                            " - class prediction unavailable."
                                    end
                                end

                                target.resolved = true
                            end
                        end

                        if target.resolved == true then
                            all_resolved = true

                            for _, other_target in ipairs(
                                query.targets or {}
                            ) do
                                if other_target.resolved ~= true then
                                    all_resolved = false
                                    break
                                end
                            end
                        end
                    end
                end

                if all_resolved then
                    local messages = {}

                    if tostring(query.mode) == "all" then
                        table.insert(
                            messages,
                            "Infected classes and predictions:"
                        )
                    end

                    local has_prediction = false

                    for _, target in ipairs(
                        query.targets or {}
                    ) do
                        table.insert(
                            messages,
                            tostring(
                                target.result
                                or (
                                    ui.lobby.format_infected_player_prediction_line(
                                        ui.lobby.get_infected_player_prediction(
                                            target,
                                            true
                                        )
                                    )
                                )
                            )
                        )

                        if target.predicted == true then
                            has_prediction = true
                        end
                    end

                    if has_prediction then
                        table.insert(
                            messages,
                            "Predictions use open class slots; the Director may differ."
                        )
                    end

                    ui.lobby.queue_zombieclass_messages(
                        messages,
                        query.response_team_only == true
                    )

                    pending_queries[query_key] = nil
                end
            end
        end
    end
end

function ui.lobby.update()
    ui.lobby.process_chat_queue()

    if ui.enhancements then
        ui.enhancements.process_verified_infected_spawns()
        ui.enhancements.scan_verified_infected_spawns()
    end

    ui.lobby.process_infected_class_queries()

    if not is_game_ready() then
        if ui.lobby.connected then
            ui.lobby.refresh(
                true
            )
        else
            ui.lobby.history = {}
            ui.lobby.clear_logs_confirmation = false
        end

        return
    end

    local current_server =
        get_server_address()

    if current_server == "" then
        current_server =
            "CONNECTED SERVER"
    end

    if not ui.lobby.connected
        or current_server
            ~= ui.lobby.last_server_address then

        ui.lobby.refresh(
            true
        )

        return
    end

    if ui.lobby.force_refresh then
        ui.lobby.refresh(
            true
        )

        return
    end

    if ui.lobby.auto_refresh
        and get_time() -
            ui.lobby.last_refresh_time
            >= ui.lobby.refresh_interval then

        ui.lobby.refresh(
            true
        )
    end
end

function ui.lobby.record_chat(
