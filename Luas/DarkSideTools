function ui.control.get_special_infected_identity(local_player)
    if not local_player then
        return false, 0, "Unavailable", "No player", false, false
    end

    local team = tonumber(
        ui.lobby.call_method(local_player, "get_team")
        or ui.lobby.call_method(local_player, "get_prop", "m_iTeamNum")
        or 0
    ) or 0

    local class_id = ui.control.get_local_infected_class(local_player)
    local class_name = (ui.control.aim_v2_engine.special_classes or {})[class_id]
        or (class_id == 0 and "Unspawned" or "Infected")

    local alive_value = ui.lobby.call_method(local_player, "is_alive")
    local alive = alive_value == true
        or alive_value == 1
        or tostring(alive_value):lower() == "true"

    local ghost_value = ui.lobby.call_method(local_player, "get_prop", "m_isGhost")
    local ghost = ghost_value == true
        or ghost_value == 1
        or tostring(ghost_value):lower() == "true"

    local spawn_state = alive and "Spawned"
        or ghost and "Ghost / unspawned"
        or "Unspawned"

    return team == 3, class_id, class_name, spawn_state, alive, ghost
end

function ui.control.aim_v2_simple_frame_delta()
    local now = get_time()
    local previous = tonumber(ui.control.aim_v2_engine.last_frame_at) or 0.0
    local delta = previous > 0.0 and (now - previous) or (1.0 / 60.0)
    ui.control.aim_v2_engine.last_frame_at = now
    return ui.control.clamp(delta, 1.0 / 300.0, 1.0 / 20.0)
end

