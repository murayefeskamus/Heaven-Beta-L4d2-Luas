function ui.enhancements.command_allowed(
    command_key,
    userid,
    response_team_only
)
    local control =
        ui.enhancements.command_control

    local permission =
        control.permissions[
            command_key
        ]

    if not permission then
        return true
    end

    local function queue_permission_response(
        messages
    )
        return ui.lobby.queue_command_messages(
            ui.lobby.get_command_response_label(
                command_key
            ),
            messages,
            response_team_only == true
        )
    end


    if is_local_player_userid(
        userid
    ) then
        return true
    end

    if not permission.enabled then
        queue_permission_response({
            tostring(permission.label) ..
            " is currently disabled."
        })

        return false
    end

    local requester =
        ui.enhancements.command_requester(
            userid
        )

    local local_record =
        ui.enhancements.get_local_lobby_record()

    local access = false

    if permission.lua_only then
        access = false
    elseif permission.everyone then
        access = true
    elseif permission.same_team
        and requester
        and local_record then

        access =
            requester.team ==
            local_record.team
    end

    if not access then
        queue_permission_response({
            "You are not allowed to use " ..
            tostring(permission.label) ..
            "."
        })

        return false
    end

    local cooldown =
        math.max(
            0,
            tonumber(
                permission.cooldown
            ) or 0
        )

    if cooldown > 0 then
        local cooldown_key =
            tostring(command_key) ..
            ":" ..
            tostring(userid)

        local now =
            get_time()

        local last_used =
            control.cooldowns[
                cooldown_key
            ] or 0

        local remaining =
            cooldown -
            (
                now -
                last_used
            )

        if remaining > 0 then
            queue_permission_response({
                tostring(permission.label) ..
                " cooldown: " ..
                tostring(
                    math.max(
                        1,
                        math.ceil(remaining)
                    )
                ) ..
                "s"
            })

            return false
        end

        control.cooldowns[
            cooldown_key
        ] =
            now
    end

    return true
end

function ui.enhancements.command_permissions_are_default()
    local defaults =
        ui.enhancements.command_permission_defaults

    local permissions =
        ui.enhancements.command_control.permissions

    for command_key, default_values in pairs(
        defaults
    ) do
        local permission =
            permissions[
                command_key
            ]

        if not permission then
            return false
        end

        for field_name, default_value in pairs(
            default_values
        ) do
            if permission[
                field_name
            ] ~= default_value then

                return false
            end
        end
    end

    return true
end

