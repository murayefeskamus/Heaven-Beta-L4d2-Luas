function ui.lobby.build_saved_name_match_messages()
    local matches =
        type(ui.network) == "table"
        and type(ui.network.get_stolen_lobby_name_matches) == "function"
        and ui.network.get_stolen_lobby_name_matches()
        or {}

    local messages = {}

    if type(matches) ~= "table"
        or #matches == 0 then

        messages = {
            "No names from your saved list were found in the current lobby."
        }
    else
        local match_count = #matches

        messages[1] =
            match_count == 1
            and "Found 1 lobby player whose name is in your saved list:"
            or (
                "Found " ..
                tostring(match_count) ..
                " lobby players whose names are in your saved list:"
            )

        for index, player_name in ipairs(
            matches
        ) do
            messages[#messages + 1] =
                tostring(index) ..
                ". " ..
                tostring(player_name)
        end

        messages = ui.lobby.pack_chat_fields(
            messages,
            100
        )
    end

    return ui.lobby.prefix_command_messages(
        "Name Stealer",
        messages
    )
end

function ui.lobby.get_chat_commands_table_dimensions()
    local rows =
        ui.lobby.get_chat_command_rows()

    local command_width =
        ui.lobby.measure_text_width(
            "COMMAND"
        )

    local description_width =
        ui.lobby.measure_text_width(
            "DESCRIPTION"
        )

    for _, row in ipairs(
        rows
    ) do
        command_width =
            math.max(
                command_width,
                ui.lobby.measure_text_width(
                    row[1]
                )
            )

        description_width =
            math.max(
                description_width,
                ui.lobby.measure_text_width(
                    row[2]
                )
            )
    end

    command_width =
        command_width + 18

    description_width =
        description_width + 18

    return
        command_width +
        description_width +
        24,
        command_width,
        description_width,
        24 + #rows * 21
end

