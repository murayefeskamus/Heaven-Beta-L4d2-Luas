                    theme_text_colored(
                        0.25,
                        1.0,
                        0.35,
                        1.0,
                        tostring(index)
                    )
                else
                    imgui.text(
                        tostring(index)
                    )
                end

                draw_divider(config_x)

                imgui.same_line()
                ui.lobby.set_cursor_x(
                    config_x + 6
                )
                imgui.push_item_width(
                    config_width - 12
                )

                local combo_items,
                    combo_index =
                        ui.heaven_configs.combo_items_for_slot(slot)

