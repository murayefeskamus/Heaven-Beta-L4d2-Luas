function ui.kill_tools.clean_template_text(
    text_value
)
    text_value =
        tostring(
            text_value or ""
        )

    local retired_map_token =
        string.char(123) ..
        "map" ..
        string.char(125)

    text_value =
        text_value:gsub(
            "Kill on " ..
                retired_map_token ..
                ":%s*",
            ""
        )

    text_value =
        text_value:gsub(
            "%s+on%s+" ..
                retired_map_token,
            ""
        )

    text_value =
        text_value:gsub(
            retired_map_token,
            ""
        )

    return text_value
end

