                    settings.removed_messages,
                    tostring(
                        removed_message or ""
                    )
                )

                table.insert(
                    settings.removed_message_enabled,
                    removed_enabled == true
                )

                ui.kill_tools.clear_message_pool()
            end
        end

        local custom_fields_have_text = false

        for _,
            custom_message in ipairs(
                settings.messages
            ) do

            if tostring(custom_message or "") ~= "" then
                custom_fields_have_text = true
