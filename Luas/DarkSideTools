    if binding_id == "control.action" then
        ui.control.action_key = key_value
    elseif binding_id == "control.pursuit" then
        ui.control.aim.v2.pursuit_key = key_value
    elseif binding_id == "control.tool_cycle" then
        ui.control.toggle_key = key_value
        ui.control.toggle_key_was_down = key_is_down == true
    elseif binding_id == "control.target_cycle" then
        ui.control.aim.v2.target_cycle_key = key_value
        ui.control.runtime.target_cycle_key_was_down = key_is_down == true
    elseif binding_id == "window.network" then
        ui.network.toggle_key = key_value
        ui.network.toggle_key_was_down = key_is_down == true
    elseif binding_id == "window.quotes"
        and type(ui.quotes) == "table"
        and type(ui.quotes.settings) == "table" then

        ui.quotes.settings.layout_toggle_key = key_value
        ui.quotes.settings.layout_toggle_key_name = ui.control.get_key_name(key_value)
        ui.quotes.suppress_layout_toggle_until_release = true
    elseif binding_id == "heaven.cycle" then
        ui.heaven_configs.cycle_key = key_value
        ui.heaven_configs.cycle_key_was_down = key_is_down == true
    else
        local slot_index = tonumber(binding_id:match("^heaven%.slot%.(%d+)$"))
        if slot_index then
            slot_index = math.floor(slot_index)
            local slot = ui.heaven_configs.slots[slot_index]
            if not slot then
                return false
            end

            slot.key = key_value
            ui.heaven_configs.hotkey_was_down[slot_index] = key_is_down == true
        else
            return false
        end
    end

    ui.keybinds.save_settings()
    ui.keybinds.set_status(
        binding_id,
        "Set to " .. ui.control.get_key_name(key_value) .. ".",
        false
    )
    ui.keybinds.finish_capture()
    return true
end

function ui.keybinds.poll_capture()
    local capture = ui.keybinds.capture
    local binding_id = tostring(capture.id or "")

    if binding_id == "" then
        return false
    end

    if ui.input_safety.block_runtime_hotkeys() then
        return true
    end

    if type(input) ~= "table" then
        ui.keybinds.cancel_capture("Heaven input API is unavailable.", true)
        return true
    end

    local can_read_down = type(input.is_key_down) == "function"
    local can_read_pressed = type(input.is_key_pressed) == "function"

    if not can_read_down and not can_read_pressed then
        ui.keybinds.cancel_capture("Heaven key input functions are unavailable.", true)
        return true
    end

    local now = get_time()
    if now - (tonumber(capture.started_at) or now)
        >= (tonumber(capture.timeout) or 12.0) then

        ui.keybinds.cancel_capture("Key capture timed out.", true)
        return true
    end

    local candidates = ui.keybinds.get_candidates()

    if capture.waiting_for_release == true then
        if can_read_down then
            for _, key_value in ipairs(candidates) do
                if ui.keybinds.is_down(key_value) then
                    return true
                end
            end
        elseif now < (tonumber(capture.ready_at) or 0.0) then
            return true
        end

        capture.waiting_for_release = false
        capture.ready_at = now + 0.05
        capture.previous_down = {}
        return true
    end

    if now < (tonumber(capture.ready_at) or 0.0) then
        return true
    end

    for _, key_value in ipairs(candidates) do
        local is_down = false
        local pressed = false

        if can_read_down then
            is_down = ui.keybinds.is_down(key_value)
            pressed = is_down and capture.previous_down[key_value] ~= true
            capture.previous_down[key_value] = is_down
        end

        if not pressed and can_read_pressed then
            local ok, pressed_value = pcall(input.is_key_pressed, key_value)
            pressed = ok and pressed_value == true
        end

        if pressed then
            if key_value == ui.keybinds.escape_key() then
                ui.keybinds.cancel_capture("Cancelled.", false)
                return true
            end

            local conflict = ui.keybinds.conflict_reason(binding_id, key_value)
            if conflict then
                ui.keybinds.set_status(binding_id, conflict, true)
                capture.previous_down[key_value] = true
                capture.ready_at = now + 0.08
                return true
            end

            ui.keybinds.apply_binding(binding_id, key_value, is_down)
            return true
        end
    end

    return true
end

