function format_quote_command_response(
    message,
    include_tag
)
    message = tostring(message or "")

    if message == "" then
        return message
    end

    local no_prefix_marker =
        "\226\128\139"

    local suppress_quotes_prefix = false

    if message:sub(1, #no_prefix_marker) ==
        no_prefix_marker then

        suppress_quotes_prefix = true
        message = message:sub(#no_prefix_marker + 1)
    end

    if message:match("^%[#%d+%]%s") then
        return message
    end

    if message:match("^%[QUOTES? COMMANDS? HELP%]:?") then
        suppress_quotes_prefix = true
    end

    local tagged_body =
        message:match(
            "^%[[Qq][Uu][Oo][Tt][Ee][Ss]%]%s*(.*)$"
        )

    if tagged_body ~= nil then
        message = "[QUOTES] " .. tagged_body
    end

    local outgoing = message

    if include_tag ~= false
        and tagged_body == nil
        and suppress_quotes_prefix ~= true then

        outgoing = "[QUOTES] " .. outgoing
    end

    if type(ui.lobby) == "table"
        and type(ui.lobby.truncate_utf8_chat_message) == "function" then

        local truncate_limit =
            message:match("^%[QUOTES? COMMANDS? HELP%]:?")
            and 240
            or 118

        return ui.lobby.truncate_utf8_chat_message(
            outgoing,
            truncate_limit
        )
    end

    return outgoing
end

function queue_chat_messages(
    messages,
    delay,
    minimum_send_interval,
    bypass_capacity
)
    if not messages or #messages == 0 then
        return false
    end

    local valid_messages = {}
    local command_tag_used = false

    for _, message in ipairs(messages) do
        if message and message ~= "" then
            local raw_message = tostring(message)
            local is_quote_output =
                raw_message:match("^%[#%d+%]%s") ~= nil
            local already_tagged =
                raw_message:match(
                    "^%[[Qq][Uu][Oo][Tt][Ee][Ss]%]%s"
                ) ~= nil
            local include_tag =
                not command_tag_used
                and not is_quote_output
                and not already_tagged

            table.insert(
                valid_messages,
                format_quote_command_response(
                    raw_message,
                    include_tag
                )
            )

            if include_tag or already_tagged then
                command_tag_used = true
            end
        end
    end

    if #valid_messages == 0 then
        return false
    end

    if bypass_capacity ~= true
        and not queue_has_space(#valid_messages) then

        report_queue_full()
        return false
    end

    local send_after =
        os.time() +
        (delay or settings.command_response_delay)

    local queued_interval =
        tonumber(minimum_send_interval)

    for _, message in ipairs(valid_messages) do
        table.insert(chat_queue, {
            text = message,
            send_after = send_after,
            minimum_send_interval = queued_interval
        })

        ui.console.print(
            "[L4D2 Quotes] Queued chat response: " ..
            message
        )
    end

    return true
end

function queue_all_chat_message(message, delay)
    return queue_chat_messages(
        { message },
        delay
    )
end

function announce_quote_change(
    message,
    delay,
    allow_duplicate,
    preserve_double_quotes,
    fast_mode,
    include_tag
)
    message = tostring(message or "")

    if message == "" then
        return false
    end

    message = format_quote_command_response(
        message,
        include_tag
    )


    if allow_duplicate ~= true
        and quote_change_pending[message] then

        return true
    end

    local current_time = get_time()
    local response_delay =
        math.max(
            0.0,
            tonumber(delay) or 0.0
        )

    if allow_duplicate ~= true then
        quote_change_pending[message] = true
    end

    table.insert(
        quote_change_queue,
        {
            text = message,
            echo_text =
                preserve_double_quotes == true
                and tostring(message):gsub("[\r\n;]", " ")
                or prepare_for_chat(message),
            send_after = current_time + response_delay,
            queued_at = current_time,
            attempts = 0,
            waiting_for_echo = false,
            next_retry_at = 0.0,
            deduplicated = allow_duplicate ~= true,
            preserve_double_quotes =
                preserve_double_quotes == true,
            fast_mode = fast_mode == true,
            minimum_send_interval =
                fast_mode == true
                and quote_help_send_interval
                or 0.55,
            retry_delay =
                fast_mode == true
                and quote_help_retry_delay
                or quote_change_retry_delay
        }
    )

    ui.console.print(
        "[L4D2 Quotes] Queued reliable confirmation: " ..
        message
    )

    return true
end

function ui.quotes.queue_reliable_messages(
    messages,
    delay,
    preserve_double_quotes,
    fast_mode,
    include_tag
)
    if type(messages) ~= "table"
        or #messages == 0 then

        return false
    end

    local queued_any = false

    for _, message in ipairs(messages) do
        message = tostring(message or "")

        if message ~= "" then
            announce_quote_change(
                message,
                queued_any
                    and 0.0
                    or (tonumber(delay) or 0.0),
                true,
                preserve_double_quotes == true,
                fast_mode == true,
                include_tag
            )

            queued_any = true
        end
    end

    return queued_any
end

local function acknowledge_quote_change_message(message)
    message = tostring(message or "")

    if message == "" then
        return false
    end

    for index,
        queued_message in ipairs(
            quote_change_queue
        ) do

        if tostring(
            queued_message.echo_text
            or queued_message.text
            or ""
        ) == message then

            table.remove(
