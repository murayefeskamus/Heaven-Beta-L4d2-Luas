function strip_known_name_decorations(name)
    local clean_name =
        clean_name_for_reverse(
            name
        )

    local removed_any = true

    while removed_any
        and clean_name ~= "" do

        removed_any = false

        for decoration_index = 2,
            #NAME_DECORATIONS do

            local decoration =
                NAME_DECORATIONS[
                    decoration_index
                ]

            local left =
                tostring(
                    decoration.left or ""
                )

            local right =
                tostring(
                    decoration.right or ""
                )

            local has_visible_frame =
                left ~= ""
                or right ~= ""

            local left_matches =
                left == ""
                or clean_name:sub(
                    1,
                    #left
                ) == left

            local right_matches =
                right == ""
                or clean_name:sub(
                    -#right
                ) == right

            if has_visible_frame
                and #clean_name >=
                    #left + #right
                and left_matches
                and right_matches then

                local first_index =
                    #left + 1

                local last_index =
                    right == ""
                    and #clean_name
                    or #clean_name - #right

                clean_name =
                    clean_name:sub(
                        first_index,
                        last_index
                    )

                removed_any = true
                break
            end
        end
    end

    return clean_name
end


function name_reverser.get_known_name_decoration_label(name)
