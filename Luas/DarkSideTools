            ui.network.cidr_to_ipv4_range(entry.cidr)

        if first_value ~= nil
            and last_value ~= nil
            and ip_value >= first_value
            and ip_value <= last_value then

            return tostring(entry.region or "")
        end
    end

    return ""
end

function ui.network.is_broad_server_region_label(value)
    value =
        tostring(value or "")
            :lower()
            :gsub("^%s+", "")
            :gsub("%s+$", "")

    if value == "" then
        return true
    end

    local broad_labels = {
        ["eu"] = true,
        ["eur"] = true,
        ["europe"] = true,
        ["european"] = true,
        ["eu north"] = true,
        ["eu south"] = true,
        ["eu east"] = true,
        ["eu west"] = true,
        ["eu central"] = true,
        ["north europe"] = true,
        ["south europe"] = true,
        ["east europe"] = true,
        ["west europe"] = true,
        ["central europe"] = true,
        ["unknown"] = true,
        ["detecting..."] = true
    }

    return broad_labels[value] == true
end

function ui.network.merge_ip_country_and_hostname_region(ip_region, hostname_region)
    ip_region = tostring(ip_region or "")
    hostname_region = tostring(hostname_region or "")

    if ip_region == "" then
        return hostname_region
    end

    if hostname_region == "" then
        return ip_region
    end

    if ip_region == hostname_region then
        return ip_region
    end

    if ui.network.is_broad_server_region_label(hostname_region) then
        if hostname_region ~= "Europe"
            and not ip_region:find(hostname_region, 1, true) then

            return ip_region .. " / " .. hostname_region
        end

        return ip_region
    end

    return hostname_region
end

function ui.network.get_ip_country_region(ip_address)
    ip_address = tostring(ip_address or "")

    if ip_address == "" then
        return ""
    end

    local geoip_country = ui.network.get_geoip_country_from_file(ip_address)

    if geoip_country ~= "" then
        return geoip_country
    end

    local builtin_region = ui.network.get_builtin_ip_region(ip_address)

    if builtin_region ~= "" then
        return builtin_region
    end

    local online_country =
        ui.network.get_geoip_country_from_online_lookup(ip_address)

    if online_country ~= "" then
        return online_country
    end

    return ""
end

function ui.network.get_manual_server_region(address, ip_address)
    local overrides =
        type(ui.network.server_region_overrides) == "table"
        and ui.network.server_region_overrides
        or {}

    address =
        tostring(address or "")

    ip_address =
        tostring(ip_address or "")

    local candidates = {
        address,
        address:gsub(":%d+$", ""),
        ip_address
    }

    for _, candidate in ipairs(candidates) do
        if candidate ~= ""
            and overrides[candidate] ~= nil then

            local value =
                tostring(overrides[candidate] or "")

            if value ~= "" then
                return value
            end
        end
    end

    if ip_address ~= "" then
        local a, b, c =
            ip_address:match(
                "^(%d+)%.(%d+)%.(%d+)%.%d+$"
            )

        local prefixes = {
            a and b and c and
                (a .. "." .. b .. "." .. c .. ".")
                or "",
            a and b and
                (a .. "." .. b .. ".")
                or "",
            a and
                (a .. ".")
                or ""
        }

        for _, prefix in ipairs(prefixes) do
            if prefix ~= ""
                and overrides[prefix] ~= nil then

                local value =
                    tostring(overrides[prefix] or "")

                if value ~= "" then
                    return value
                end
            end
        end
    end

    return ""
end

function ui.network.get_server_region_display(address)
    address =
        tostring(address or "")

    if address == ""
        or address == "Unknown"
        or address == "CONNECTED SERVER" then

        return "-", false
    end

    local hostname =
        ui.network.get_cached_server_hostname(
            address
        )

    local cache_key =
        address .. "|" .. hostname

    if ui.network.server_region_cache_key == cache_key then
        local cached_known =
            ui.network.server_region_cache_known == true

        if cached_known == true then
            return tostring(
                ui.network.server_region_cache_value or "-"
            ),
            true
        end
    end

    local region_text = "Unknown"
    local known = false

    local ip_address =
        ui.network.extract_ipv4_address(
            address
        )

    if ip_address ~= ""
        and tostring(ui.network.server_region_online_lookup_active_ip or "") ~= ""
        and tostring(ui.network.server_region_online_lookup_active_ip or "") ~= ip_address then

        ui.network.server_region_online_lookup_active_ip = ""
        ui.network.server_region_online_lookup_active_path = ""
    end

    if ui.network.is_local_server_address(
        address
    ) then
        region_text = "Local server"
        known = true
    elseif ip_address ~= ""
        and ui.network.is_private_ipv4_address(
            ip_address
        ) then

        region_text = "Local / LAN"
        known = true
    else
        local manual_region =
            ui.network.get_manual_server_region(
                address,
                ip_address
            )

        if manual_region ~= "" then
            region_text = manual_region
            known = true
        else
            local hostname_region,
                hostname_known =
                    ui.network.extract_region_from_hostname(
                        hostname
                    )

            local ip_region =
                ui.network.get_ip_country_region(
                    ip_address
                )

            if ip_region ~= ""
                and hostname_known == true
                and tostring(hostname_region or "") ~= "" then

                region_text =
                    ui.network.merge_ip_country_and_hostname_region(
                        ip_region,
                        hostname_region
                    )

                known = true
            elseif ip_region ~= "" then
                region_text = ip_region
                known = true
            elseif hostname_known == true
                and tostring(hostname_region or "") ~= "" then

                region_text = hostname_region

                if ip_address ~= ""
                    and ui.network.server_region_online_lookup_enabled == true then

                    known = false
                else
                    known = true
                end
            end
        end
    end

    if known ~= true then
        local now =
            os.clock()

        local probe_active =
            ui.network.server_region_status_probe_active == true

        local next_probe =
            tonumber(
                ui.network.server_region_status_next_probe
            ) or 0.0

        local online_pending =
            ip_address ~= ""
            and ui.network.is_geoip_online_lookup_pending(
                ip_address
            )

        if online_pending == true
            or (
                tostring(hostname or "") == ""
                and (
                    probe_active
                    or next_probe == 0.0
                )
            ) then

            region_text = "Detecting..."
        elseif tostring(region_text or "") ~= ""
            and tostring(region_text or "") ~= "Unknown" then

            region_text = tostring(region_text or "")
        else
            region_text = "Unknown"
        end
    end

    ui.network.server_region_cache_key = cache_key
    ui.network.server_region_cache_value = region_text
    ui.network.server_region_cache_known = known == true

    return region_text,
        known == true
end

function ui.network.is_copyable_server_address(address)
    address =
        tostring(address or "")

    if address == ""
        or address == "Unknown"
        or ui.network.is_local_server_address(
            address
        ) then

        return false
    end

    return address:match(
        "^[%w%.:%-%[%]]+$"
    ) ~= nil
end

function ui.network.get_copy_state_text()
    local address =
        tostring(
            ui.network.current_server_raw or ""
        )

    if address == "" then
        return "Waiting"
    end

    if ui.network.is_local_server_address(
        address
    ) then
        return "Local server"
    end

    if ui.network.copied_server_raw ==
        address then

        if ui.network.copy_source == "automatic" then
            return "Copied automatically"
        elseif ui.network.copy_source == "manual" then
            return "Copied manually"
        end

        return "Copied"
    end

    if ui.network.copy_error ~= "" then
        return "Copy failed"
    end

    if ui.network.auto_copy_on_connect then
        return "Not copied"
    end

    return "Manual copy"
end

function ui.network.get_server_line()
    local address =
        tostring(
            ui.network.current_server_raw or ""
        )

    if address == "" then
        return "Not connected to a server"
    end

    local display_address =
        ui.network.get_server_display_address(
            address
        )

    if ui.network.is_local_server_address(
        address
    ) then
        return display_address
    end

    local copied =
        ui.network.copied_server_raw ==
        address

    return display_address ..
        (
            copied
            and " (copied)"
            or " (not copied)"
        )
end

function ui.network.set_clipboard_text_process_free(
    text_value
)
    text_value =
        tostring(text_value or "")

    local direct_setters = {
        rawget(_G, "set_clipboard_text"),
        rawget(_G, "set_clipboard")
    }

    for _, setter in ipairs(
        direct_setters
    ) do
        if type(setter) == "function" then
            local set_ok,
                set_result =
                    pcall(
                        setter,
                        text_value
                    )

            if set_ok
                and set_result ~= false then

                return true, "Heaven native API"
            end
        end
    end

    local candidates = {
        {
            table_value = imgui,
            names = {
                "set_clipboard_text",
                "set_clipboard"
            }
        },
        {
            table_value = client,
            names = {
                "set_clipboard_text",
                "set_clipboard"
            }
        },
        {
            table_value = rawget(
                _G,
                "clipboard"
            ),
            names = {
                "set_text",
                "set"
            }
        },
        {
            table_value = rawget(
                _G,
                "utils"
            ),
            names = {
                "set_clipboard_text",
                "set_clipboard"
            }
        }
    }

    for _, candidate in ipairs(
        candidates
    ) do
        local table_value =
            candidate.table_value

        if type(table_value) == "table" then
            for _, function_name in ipairs(
                candidate.names
            ) do
                local setter =
                    table_value[
                        function_name
                    ]

                if type(setter) == "function" then
                    local set_ok,
                        set_result =
                            pcall(
                                setter,
                                text_value
                            )

                    if set_ok
                        and set_result ~= false then

                        return true, "Heaven native API"
                    end
                end
            end
        end
    end

    return false,
        "Heaven's native clipboard API is unavailable; copy was skipped safely."
end

function ui.network.copy_server_address(
    address,
    source
)
    address =
        tostring(address or "")

    if not ui.network.is_copyable_server_address(
        address
    ) then
        ui.network.copy_error =
            ui.network.is_local_server_address(
                address
            )
            and "Local server addresses are not copied."
            or "No valid server IP is available."

        ui.network.copy_status = "UNAVAILABLE"
        return false
    end

    if ui.network.copied_server_raw ==
        address then

        ui.network.copy_status = "ALREADY COPIED"
        ui.network.copy_error = ""
        return true
    end

    local copied,
        backend_or_error =
            ui.network.set_clipboard_text_process_free(
                address
            )

    if copied then
        ui.network.copied_server_raw =
            address

        ui.network.copy_status = "COPIED"
        ui.network.copy_error = ""
        ui.network.copy_source =
            tostring(source or "manual")

        ui.console.print(
            "[Lobby & Network] Server IP copied: " ..
            address ..
            " [" ..
            tostring(backend_or_error) ..
            "]"
        )

        return true
    end

    ui.network.copy_status = "FAILED"
    ui.network.copy_error =
        tostring(
            backend_or_error
            or "In-process clipboard operation failed."
        )

    ui.console.print(
        "[Lobby & Network] Server IP copy failed: " ..
        address
    )

    return false
end

function ui.network.copy_current_server(
    source
)
    return ui.network.copy_server_address(
        ui.network.current_server_raw,
        source or "manual"
    )
end

function ui.network.reset_ping_history()
    ui.network.ping_history = {}
    ui.network.peak_ping = 0.0
end

function ui.network.update_ping_history(
    ping_ms
)
    ping_ms =
        math.max(
            0.0,
            tonumber(ping_ms) or 0.0
        )

    table.insert(
        ui.network.ping_history,
        ping_ms
    )

    while #ui.network.ping_history >
        ui.network.ping_history_size do

        table.remove(
            ui.network.ping_history,
            1
        )
    end

    ui.network.peak_ping =
        math.max(
            ui.network.peak_ping,
            ping_ms
        )

    local total = 0.0

    for _, sample in ipairs(
        ui.network.ping_history
    ) do
        total = total + sample
    end

    local average = 0.0

    if #ui.network.ping_history > 0 then
        average =
            total /
            #ui.network.ping_history
    end

    local jitter_total = 0.0

    for index = 2,
        #ui.network.ping_history do

        jitter_total =
            jitter_total +
            math.abs(
                ui.network.ping_history[index] -
                ui.network.ping_history[index - 1]
            )
    end

    local jitter = 0.0

    if #ui.network.ping_history > 1 then
        jitter =
            jitter_total /
            (#ui.network.ping_history - 1)
    end

    return average,
        jitter
end

function ui.network.get_connection_quality(
    ping_ms,
    loss_percent,
    choke_percent,
    is_timing_out
)
    if is_timing_out then
        return "TIMING OUT"
    end

    if ping_ms >= 250
        or loss_percent >= 8
        or choke_percent >= 8 then

        return "UNSTABLE"
    end

    if ping_ms >= 150
        or loss_percent >= 4
        or choke_percent >= 4 then

        return "POOR"
    end

    if ping_ms >= 80
        or loss_percent >= 1
        or choke_percent >= 1 then

        return "FAIR"
    end

    return "GOOD"
end

function ui.network.get_quality_color(
    quality
)
    quality =
        tostring(quality or ""):upper()

    if quality == "GOOD" then
        return 0.25, 1.0, 0.35
    elseif quality == "FAIR" then
        return 1.0, 0.86, 0.25
    elseif quality == "POOR" then
        return 1.0, 0.56, 0.18
    elseif quality == "UNSTABLE"
        or quality == "TIMING OUT" then

        return 1.0, 0.25, 0.25
    end

    return 0.70, 0.70, 0.72
end

function ui.network.get_latency_color(
