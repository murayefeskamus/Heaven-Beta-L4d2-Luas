                    "Refresh Now",
                    0.15, 1.0, 1.0,
                    0.05, 0.30, 0.34
                ) then
                    ui.lobby.force_refresh = true
                    ui.lobby.refresh(true)
                end

                imgui.same_line()

                if ui.lobby.connected then
                    theme_text_colored(
                        0.65, 0.65, 0.65, 1.0,
                        "Last refresh:"
