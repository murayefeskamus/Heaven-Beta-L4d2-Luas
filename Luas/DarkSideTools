function chat_spammer.get_event_string_any(
    event,
    field_names
)
    if not event
        or type(field_names) ~= "table" then

        return ""
    end

    for _, field_name in ipairs(
        field_names
    ) do
        local value_ok,
            value =
                pcall(
                    function()
                        return event:get_string(
                            field_name
                        )
                    end
                )

        value =
            value_ok
            and value ~= nil
            and tostring(value)
            or ""

        value =
            value:gsub(
                "^%s+",
                ""
            ):gsub(
                "%s+$",
                ""
            )

        if value ~= "" then
            return value
        end
    end

    return ""
end

