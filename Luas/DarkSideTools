function ui.kill_tools.clear_feed_preset_pool()
    local feed =
        ui.kill_tools.kill_feed

    feed.pool = {}
    feed.pool_context_signature = ""
end

function ui.kill_tools.feed_template_context_signature(
    context
)
    if type(context) ~= "table" then
        return "any"
    end

    local has_class =
        tostring(context.infected_class or "") ~= ""

    local has_weapon =
        tostring(context.raw_weapon or "") ~= ""
        or tostring(context.weapon_name or "") ~= ""

    local has_headshot =
        context.headshot == true

    return
        (has_class and "class" or "noclass") ..
        "|" ..
        (has_weapon and "weapon" or "noweapon") ..
        "|" ..
        (has_headshot and "headshot" or "noheadshot")
end

function ui.kill_tools.feed_template_is_eligible(
    template,
    context
)
    template =
        tostring(template or "")

    if type(context) ~= "table" then
        return true
    end

    if template:find("{class}", 1, true)
        and tostring(context.infected_class or "") == "" then

        return false
    end

    if template:find("{headshot}", 1, true)
        and context.headshot ~= true then

        return false
    end

    if template:find("{weapon}", 1, true)
        and tostring(context.raw_weapon or "") == ""
        and tostring(context.weapon_name or "") == "" then

        return false
    end

    return true
end

function ui.kill_tools.get_feed_preset_catalog(
    enabled_only,
    context
)
    local feed =
        ui.kill_tools.kill_feed

    local defaults =
        ui.kill_tools.default_messages()

    local presets =
        type(feed.preset_messages) == "table"
        and feed.preset_messages
        or defaults

    local catalog = {}

    for index = 1,
        #defaults do

        local preset_text =
            tostring(
                presets[index]
                or defaults[index]
                or ""
            )

        local trimmed =
            preset_text:gsub(
                "^%s+",
                ""
            ):gsub(
                "%s+$",
                ""
            )

        if (
                not enabled_only
                or (
                    feed.preset_enabled[index] == true
                    and trimmed ~= ""
                )
            )
            and ui.kill_tools.feed_template_is_eligible(
                preset_text,
                context
            ) then

            catalog[#catalog + 1] = {
                source_index = index,
                text = preset_text
            }
        end
    end

    return catalog
end

function ui.kill_tools.refill_feed_preset_pool(
    context
)
    local feed =
        ui.kill_tools.kill_feed

    local catalog =
        ui.kill_tools.get_feed_preset_catalog(
            true,
            context
        )

    local pool = {}

    for index = 1,
        #catalog do

        pool[index] = index
    end

    ui.kill_tools.shuffle_table(
        pool
    )

    if #pool > 1
        and pool[#pool] ==
            feed.last_template_index then

        pool[1],
            pool[#pool] =
                pool[#pool],
                pool[1]
    end

    feed.pool =
        pool

    feed.pool_context_signature =
        ui.kill_tools.feed_template_context_signature(
            context
        )

    return #pool > 0
end

function ui.kill_tools.next_feed_template(
    context
)
    local feed =
        ui.kill_tools.kill_feed

    if type(feed.pool) ~= "table" then
        feed.pool = {}
    end

    local context_signature =
        ui.kill_tools.feed_template_context_signature(
            context
        )

    if tostring(feed.pool_context_signature or "") ~=
        context_signature then

        feed.pool = {}
        feed.pool_context_signature = context_signature
    end

    if #feed.pool == 0
        and not ui.kill_tools.refill_feed_preset_pool(
            context
        ) then

        return nil,
            0
    end

    local template_index =
        tonumber(
            table.remove(
                feed.pool
            )
        ) or 0

    local catalog =
        ui.kill_tools.get_feed_preset_catalog(
            true,
            context
        )

    local entry =
        catalog[template_index]

    if not entry
        or tostring(entry.text or "") == "" then

        ui.kill_tools.clear_feed_preset_pool()
        return nil,
            0
    end

    feed.last_template_index =
        template_index

    return tostring(entry.text),
        template_index
end

function ui.kill_tools.peek_feed_template()
    local catalog =
        ui.kill_tools.get_feed_preset_catalog(
            true
        )

    if #catalog == 0 then
        return nil,
            0
    end

    local feed =
        ui.kill_tools.kill_feed

    if type(feed.pool) ~= "table"
        or #feed.pool == 0 then

        return tostring(catalog[1].text or ""),
            1
    end

    local template_index =
        tonumber(
            feed.pool[
                #feed.pool
            ]
        ) or 0

    local entry =
        catalog[template_index]

    if not entry then
        return tostring(catalog[1].text or ""),
            1
    end

    return tostring(entry.text),
        template_index
end

function ui.kill_tools.replace_placeholder(
    source,
    placeholder,
    value
)
    source =
        tostring(source or "")

    value =
        tostring(value or "")

    return (
        source:gsub(
            placeholder,
            function()
                return value
            end
        )
    )
end

function ui.kill_tools.format_message(
    template,
    context
)
    local class_name = ""

    if tonumber(context.attacker_team) == 2
        and tostring(
            context.infected_class
            or ""
        ) ~= "" then

        class_name =
            tostring(
                context.infected_class
            )
    end

    local headshot_text =
        context.headshot == true
        and "[HEADSHOT]"
        or ""

    local message =
        ui.kill_tools.clean_template_text(
            template
        )

    local replacements = {
        ["{killer}"] = context.killer_name,
        ["{victim}"] = context.victim_name,
        ["{class}"] = class_name,
        ["{weapon}"] = context.weapon_name,
        ["{headshot}"] = headshot_text
    }

    for placeholder,
        replacement in pairs(
            replacements
        ) do

        message =
            ui.kill_tools.replace_placeholder(
                message,
                placeholder,
                replacement
            )
    end

    message =
        expand_custom_newline_placeholders(
            message
        )

    local custom_message_has_newlines =
        tostring(message or ""):find("\n", 1, true) ~= nil
        or tostring(message or ""):find("\r", 1, true) ~= nil

    message =
        message:gsub(
            "\r\n",
            "\n"
        ):gsub(
            "\r",
            "\n"
        ):gsub(
            "%(%s*%)",
            ""
        ):gsub(
            "%[%s*%]",
            ""
        ):gsub(
            "[ \t]+([,.!?;:])",
            "%1"
        ):gsub(
            "[ \t]+%)",
            ")"
        ):gsub(
            "[ \t]+%]",
            "]"
        ):gsub(
            "\n+",
            "\n"
        )

    if custom_message_has_newlines ~= true then
        message =
            message:gsub(
                "[ \t]+",
                " "
            ):gsub(
                "^[ \t]+",
                ""
            ):gsub(
                "[ \t]+$",
                ""
            )
    end

    return sanitize_chat_message(
        message,
        true
    )
end

function ui.kill_tools.get_raw_local_name_for_restore()
    local raw_name = nil

    if spammer_runtime
        and type(
            spammer_runtime.get_raw_name_cvar
        ) == "function" then

        raw_name =
            spammer_runtime.get_raw_name_cvar()
    end

    if raw_name == nil
        or tostring(raw_name) == "" then

        raw_name = get_current_player_name()
    end

    if raw_name == nil
        or tostring(raw_name) == "" then

        raw_name = initial_in_game_name
    end

    raw_name =
        sanitize_name(
            raw_name
        )

    return tostring(raw_name or "")
end

function ui.kill_tools.set_raw_local_name(
    raw_name,
    status_label
)
    if not engine.is_in_game()
        or not engine.is_connected() then

        return false
    end

    local safe_name =
