    ui.network.order.detailed =
        ui.reorderable_fields.normalize(
            ui.network.order.detailed,
            ui.network.detailed_field_definitions
        )

    local function keep_field_after(order_table, field_key, after_key)
        if type(order_table) ~= "table" then
            return order_table
        end

        local cleaned = {}
        local found_field = false

        for _, order_key in ipairs(order_table) do
            order_key = tostring(order_key or "")

            if order_key == field_key then
                found_field = true
            elseif order_key ~= "" then
                cleaned[#cleaned + 1] = order_key
            end
        end

        if not found_field then
            found_field = true
        end

        local insert_index = #cleaned + 1

        for index, order_key in ipairs(cleaned) do
            if order_key == after_key then
                insert_index = index + 1
                break
            end
        end

        table.insert(
            cleaned,
            insert_index,
            field_key
        )

        return cleaned
    end

    ui.network.order.compact =
        keep_field_after(
            ui.network.order.compact,
            "server_region",
            "server"
        )

    ui.network.order.detailed =
        keep_field_after(
            ui.network.order.detailed,
            "server_region",
            "server"
        )
end

function ui.network.update(
    force
)
    local now =
        os.clock()

    if force ~= true
        and now - ui.network.last_update <
            ui.network.network_update_interval then

        return false
    end

    ui.network.normalize_settings()
    ui.network.last_update = now

    if not engine.is_connected() then
        if ui.network.connected
            or ui.network.current_server_raw ~= "" then

            ui.network.reset_ping_history()
        end

        ui.network.connected = false
        ui.network.network_available = false
        ui.network.current_server_raw = ""
        ui.network.server_region_hostname = ""
        ui.network.server_region_hostname_address = ""
        ui.network.server_region_status_hostname = ""
        ui.network.server_region_status_address = ""
        ui.network.server_region_status_probe_active = false
        ui.network.server_region_cache_key = ""
        ui.network.server_region_cache_value = "-"
        ui.network.server_region_cache_known = false


        ui.network.copy_status = "WAITING"
        ui.network.copy_error = ""

        ui.network.stats = {
            connected = false,
            network_available = false,
            status = "Not connected to a server."
        }

        return true
    end

    local net =
        engine.get_net_channel_info()

    if not net then
        ui.network.connected = true
        ui.network.network_available = false

        ui.network.stats = {
            connected = true,
            network_available = false,
            status = "Network information unavailable."
        }

        return true
    end

    local server_address =
        tostring(
            net.address or "Unknown"
        )

    local joined_new_server =
        not ui.network.connected
        or ui.network.current_server_raw ~=
            server_address

    if joined_new_server then
        ui.network.connected = true
        ui.network.current_server_raw =
            server_address
        ui.network.server_region_hostname = ""
        ui.network.server_region_hostname_address = ""
        ui.network.server_region_hostname_next_probe = 0.0
        ui.network.server_region_status_hostname = ""
        ui.network.server_region_status_address = ""
        ui.network.server_region_status_probe_active = false
        ui.network.server_region_status_next_probe = 0.0
        ui.network.server_region_cache_key = ""
        ui.network.server_region_cache_value = "-"
        ui.network.server_region_cache_known = false

        if ui.network.copied_server_raw ~=
            server_address then

            ui.network.copied_server_raw = ""
            ui.network.auto_copy_attempted_server_raw = ""
            ui.network.copy_status = "WAITING"
            ui.network.copy_error = ""
            ui.network.copy_source = ""
        else
            ui.network.copy_status = "ALREADY COPIED"
            ui.network.copy_error = ""
        end

        ui.network.reset_ping_history()
    end

    ui.network.network_available = true

    local ping_out_ms =
        ui.network.safe_number(
            net.latency_out
        ) * 1000

    local ping_in_ms =
        ui.network.safe_number(
            net.latency_in
        ) * 1000

    local current_average_ping =
        (ping_out_ms + ping_in_ms) /
        2

    local average_ping,
        jitter =
            ui.network.update_ping_history(
                current_average_ping
            )

    local loss_percent =
        ui.network.safe_number(
            net.loss_out
        ) * 100

    local choke_percent =
        ui.network.safe_number(
            net.choke_out
        ) * 100

    local is_timing_out =
        net.is_timing_out == true

    local quality =
        ui.network.get_connection_quality(
            math.max(
                ping_out_ms,
                ping_in_ms
            ),
            loss_percent,
            choke_percent,
            is_timing_out
        )

    ui.network.stats = {
        connected = true,
        network_available = true,
        server_address = server_address,
        server_display =
            ui.network.get_server_display_address(
                server_address
            ),
        server_region =
            ui.network.get_server_region_display(
                server_address
            ),
        connected_time =
            ui.network.format_duration(
                ui.network.safe_number(
                    net.time_connected
                )
            ),
        timeout_seconds =
            ui.network.safe_number(
                net.timeout_seconds
            ),
        quality = quality,
        is_timing_out = is_timing_out,
        ping_out_ms = ping_out_ms,
        ping_in_ms = ping_in_ms,
        average_ping_ms = average_ping,
        jitter_ms = jitter,
        peak_ping_ms = ui.network.peak_ping,
        loss_percent = loss_percent,
        choke_percent = choke_percent,
        packets_out =
            ui.network.safe_number(
                net.packets_out
            ),
        packets_in =
            ui.network.safe_number(
                net.packets_in
            ),
        rate_out_kb =
            ui.network.safe_number(
                net.data_out
            ) / 1024,
        rate_in_kb =
            ui.network.safe_number(
                net.data_in
            ) / 1024,
        total_data_out_mb =
            ui.network.safe_number(
                net.total_data_out
            ) / 1024 / 1024,
        total_data_in_mb =
            ui.network.safe_number(
                net.total_data_in
            ) / 1024 / 1024
    }

    if ui.network.auto_copy_on_connect
        and ui.network.is_copyable_server_address(
            server_address
        )
        and ui.network.copied_server_raw ~=
            server_address
        and ui.network.auto_copy_attempted_server_raw ~=
            server_address then

        ui.network.auto_copy_attempted_server_raw =
            server_address

        ui.network.copy_server_address(
            server_address,
            "automatic"
        )
    elseif ui.network.is_local_server_address(
        server_address
    ) then
        ui.network.copy_status = "LOCAL SERVER"
        ui.network.copy_error = ""
    elseif not ui.network.auto_copy_on_connect
        and ui.network.copied_server_raw ~=
            server_address
        and ui.network.copy_error == "" then

        ui.network.copy_status = "MANUAL"
    end

    return true
end

function ui.network.handle_toggle_key()
    if ui.input_safety.block_runtime_hotkeys() then
        ui.network.toggle_key_was_down = false
        return
    end

    if type(ui.window_hotkeys) == "table"
        and tostring(
            ui.window_hotkeys.waiting_target
            or ""
        ) ~= "" then

        ui.network.toggle_key_was_down = false
        return
    end

    if type(input) ~= "table"
        or type(input.is_key_down) ~= "function" then

        return
    end

    local key_ok,
        key_down =
            pcall(
                input.is_key_down,
                ui.network.toggle_key
            )

    key_down =
        key_ok
        and key_down == true

    if ui.network.f5_toggle_enabled
        and key_down
        and not ui.network.toggle_key_was_down then

        ui.network.details_expanded =
            not ui.network.details_expanded

        ui.network.position_restore_pending = true

        ui.console.print(
            "[Lobby & Network] Standalone view: " ..
            (
                ui.network.details_expanded
                and "Detailed"
                or "Compact"
            )
        )
    end

    ui.network.toggle_key_was_down =
        key_down
end

function ui.network.get_game_snapshot()
    local now =
        get_time()

    ui.network.cached_game_snapshot =
        type(ui.network.cached_game_snapshot) == "table"
        and ui.network.cached_game_snapshot
        or nil

    if ui.network.cached_game_snapshot
        and now <
            (tonumber(
                ui.network.next_game_snapshot_update
            ) or 0.0) then

        return ui.network.cached_game_snapshot
    end

    local in_game =
        engine.is_in_game()

    local map_code =
        in_game
        and ui.lobby.get_map_code()
        or nil

    local full_map_name =
        in_game
        and ui.lobby.get_map_name(
            map_code
        )
        or "-"

    full_map_name =
        tostring(full_map_name or "Unknown map")

    local campaign = "-"
    local map_name = "-"

    if in_game then
        local parsed_campaign,
            parsed_map =
                full_map_name:match(
                    "^(.-)%s+%-%s+(.+)$"
                )

        if parsed_campaign
            and parsed_map then

            campaign = parsed_campaign
            map_name = parsed_map
        else
            campaign = "Custom / Workshop"
            map_name = full_map_name
        end
    end

    local mode =
        in_game
        and ui.lobby.get_game_mode()
        or nil

    local current_time =
        os.date("%H:%M:%S")

    ui.network.cached_game_snapshot = {
        in_game = in_game == true,
        campaign = tostring(campaign or "-"),
        map = tostring(map_name or "-"),
        full_map = full_map_name,
        map_code = tostring(map_code or "None"),
        mode = tostring(mode or "None"),
        clock = tostring(current_time or "--:--:--")
    }

    ui.network.next_game_snapshot_update =
        now + 0.25

    return ui.network.cached_game_snapshot
end

function ui.network.get_stolen_lobby_name_matches()
    if not name_stealer.saved_names_loaded then
        pcall(
            load_saved_names_from_file,
            true
        )
    end

    local lobby_players =
        type(ui.lobby.players) == "table"
        and ui.lobby.players
        or {}

    local saved_names =
        type(name_stealer.saved_names) == "table"
        and name_stealer.saved_names
        or {}

    local cache_key =
        tostring(
            ui.lobby.last_refresh_time or 0
        ) .. ":" ..
        tostring(
            #lobby_players
        ) .. ":" ..
        tostring(
            name_stealer.saved_names_count or 0
        ) .. ":" ..
        tostring(
            #saved_names
        ) .. ":" ..
        tostring(
            name_stealer.save_status or ""
        )

    if ui.network.stolen_lobby_name_cache_key ==
        cache_key
        and type(
            ui.network.stolen_lobby_name_cache
        ) == "table" then

        return ui.network.stolen_lobby_name_cache
    end

    local saved_lookup = {}

    for _, saved_name in ipairs(
        saved_names
    ) do
        local normalized_key =
            normalize_candidate_name_for_filter(
                saved_name
            )

        if normalized_key ~= "" then
            saved_lookup[
                normalized_key
            ] = true
        end
    end

    local matches = {}
    local seen_matches = {}

    for _, player_record in ipairs(
        lobby_players
    ) do
        if type(player_record) == "table"
            and player_record.connected ~= false
            and player_record.is_bot ~= true
            and player_record.is_local ~= true then

            local player_name =
                sanitize_name(
                    player_record.name
                )

            local normalized_key =
                normalize_candidate_name_for_filter(
                    player_name
                )

            if normalized_key ~= ""
                and saved_lookup[
                    normalized_key
                ] == true
                and not seen_matches[
                    normalized_key
                ] then

                seen_matches[
                    normalized_key
                ] = true

                matches[
                    #matches + 1
                ] = player_name
            end
        end
    end

    table.sort(
        matches,
        function(first, second)
            return tostring(first):lower() <
                tostring(second):lower()
        end
    )

    ui.network.stolen_lobby_name_cache_key =
        cache_key

    ui.network.stolen_lobby_name_cache =
        matches

    return matches
end

function ui.network.get_stolen_lobby_name_display(
    detailed
)
    local matches =
        ui.network.get_stolen_lobby_name_matches()

    local match_count =
        #matches

    if match_count <= 0 then
        return "-",
            false
    end

    if detailed ~= true then
        return match_count == 1
            and tostring(matches[1])
            or (
                tostring(match_count) ..
                " matches"
            ),
            true
    end

    local names_text =
        table.concat(
            matches,
            ", "
        )

    if #names_text > 72 then
        names_text =
            names_text:sub(
                1,
                69
            ) ..
            "..."
    end

    return tostring(match_count) ..
        ": " ..
        names_text,
        true
end

function ui.network.fit_overlay_text(
    value,
    maximum_width
)
    value = tostring(value or "")

    maximum_width =
        math.max(
            24,
            tonumber(maximum_width) or 112
        )

    if ui.lobby.measure_text_width(
        value
    ) <= maximum_width then

        return value
    end

    local characters =
        split_utf8_characters(
            value
        )

    while #characters > 0 do
        table.remove(
            characters
        )

        local candidate =
            table.concat(
                characters
            ) ..
            "..."

        if ui.lobby.measure_text_width(
            candidate
        ) <= maximum_width then

            return candidate
        end
    end

    return "..."
end

