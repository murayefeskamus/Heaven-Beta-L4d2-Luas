function ui.heaven_configs.get_current_config_hotkey()
    if ui.heaven_configs.use_cycle_key == true then
        local key_value = math.floor(
            tonumber(ui.heaven_configs.cycle_key) or 0
        )

        if key_value > 0 then
            return key_value
        end

        return 0
    end

    local current_name = ui.heaven_configs.clean_config_name(
        ui.heaven_configs.last_loaded_config
    )

    if current_name == "" then
        return 0
    end

    for index = 1, ui.heaven_configs.max_slots do
        local slot = ui.heaven_configs.slots[index]
        local slot_name = ui.heaven_configs.clean_config_name(
            slot and slot.config_name or ""
        )

        if slot
            and slot.enabled == true
            and slot_name ~= ""
            and slot_name:lower() == current_name:lower() then

            return math.max(
                0,
                math.floor(tonumber(slot.key) or 0)
            )
        end
    end

    return 0
end

