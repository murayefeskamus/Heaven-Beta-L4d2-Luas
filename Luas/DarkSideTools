function ui.network.draw_compact_overlay()
    ui.network.overlay_section_started = false

    local game =
        ui.network.get_game_snapshot()

    local display =
        ui.network.display.compact

    local last_section = ""
    local drawn_count = 0

    for _, key in ipairs(
        ui.network.order.compact
    ) do
        if display[key] == true then
            local can_attempt =
                key ~= "copy_button"
                or (
                    not ui.network.auto_copy_on_connect
                    and ui.network.is_copyable_server_address(
                        ui.network.current_server_raw
                    )
                )

            if can_attempt then
                local self_titled_section =
                    key == "player_ids"

                if self_titled_section then
                    last_section = ""
                else
                    local section =
                        ui.network.get_compact_overlay_section(
                            key
                        )

                    if section ~= nil
                        and section ~= ""
                        and section ~= last_section then

                        ui.network.draw_section_title(
                            section
                        )

                        last_section = section
                    end
                end

                if ui.network.draw_overlay_field(
                    key,
                    false,
                    game,
                    ui.network.stats
                ) then
                    drawn_count = drawn_count + 1
                end

                if self_titled_section then
                    last_section = ""
                end
            end
        end
    end

    if drawn_count <= 0 then
        imgui.text(
            "All compact-view fields are hidden in Settings."
        )
    end
end

function ui.network.draw_detailed_overlay()
    ui.network.overlay_section_started = false

    local game =
        ui.network.get_game_snapshot()

    local display =
        ui.network.display.detailed

    local stats =
        ui.network.stats

    local last_section = ""
    local drawn_count = 0

    for _, key in ipairs(
        ui.network.order.detailed
    ) do
        if display[key] == true then
            local definition =
                ui.network.get_field_definition(
                    ui.network.detailed_field_definitions,
                    key
                )

            local section =
                definition
                and tostring(definition.section or "DETAILS")
                or "DETAILS"


            local can_attempt =
                key ~= "copy_button"
                or (
                    not ui.network.auto_copy_on_connect
                    and ui.network.is_copyable_server_address(
                        ui.network.current_server_raw
                    )
                )

            if can_attempt then
                if section ~= last_section then
                    ui.network.draw_section_title(
                        section
                    )
                    last_section = section
                end

                if ui.network.draw_overlay_field(
                    key,
                    true,
                    game,
                    stats
                ) then
                    drawn_count = drawn_count + 1
                end
            end
        end
    end

    if drawn_count <= 0 then
        imgui.text(
            "All detailed-view fields are hidden in Settings."
        )
    end
end

