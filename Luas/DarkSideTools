    local function native_picker_result_to_color(
        first_value,
        second_value,
        third_value,
        fourth_value,
        fallback
    )
        if type(first_value) == "table"
            or type(first_value) == "userdata" then

            return ui.control.normalize_rgba_color(
                first_value,
                fallback
            )
        end

        if tonumber(first_value) ~= nil
            and tonumber(second_value) ~= nil
            and tonumber(third_value) ~= nil then

            return ui.control.normalize_rgba_color(
                {
                    tonumber(first_value),
                    tonumber(second_value),
                    tonumber(third_value),
                    tonumber(fourth_value) or 1.0
                },
                fallback
            )
        end

        if tonumber(first_value) ~= nil then
            return ui.control.abgr_to_color(
                first_value,
                fallback
            )
        end

        return ui.control.normalize_rgba_color(
            fallback,
            fallback
        )
    end

    local function draw_native_color_picker(
        editor_key,
        current_color
    )
        current_color = ui.control.normalize_rgba_color(
            current_color,
            { 1.0, 1.0, 1.0, 1.0 }
        )

        local compact_picker_flags =
            2 + 8 + 16 + 32 + 64 + 128 + 256 + 512 +
            33554432 + 134217728

        local cached_backend = tostring(
            ui.control.runtime.color_picker_backend or ""
        )

        local backends = {}

        local function add_backend(name)
            if name ~= "" then
                table.insert(backends, name)
            end
        end

        add_backend(cached_backend)
        add_backend("color_picker4_table")
        add_backend("color_picker4_vector")
        add_backend("color_picker3_table")
        add_backend("color_picker3_vector")
        add_backend("color_picker_abgr")

        local seen = {}

        for _, backend in ipairs(backends) do
            if not seen[backend] then
                seen[backend] = true

                local picker = nil
                local input_value = nil
                local use_flags = true

                if backend == "color_picker4_table"
                    and type(imgui.color_picker4) == "function" then

                    picker = imgui.color_picker4
                    input_value = {
                        current_color[1],
                        current_color[2],
                        current_color[3],
                        current_color[4]
                    }
                elseif backend == "color_picker4_vector"
                    and type(imgui.color_picker4) == "function"
                    and type(vector) == "table"
                    and type(vector.new) == "function" then

                    local vector_ok, vector_value = pcall(
                        vector.new,
                        current_color[1],
                        current_color[2],
                        current_color[3],
                        current_color[4]
                    )

                    if vector_ok then
                        picker = imgui.color_picker4
                        input_value = vector_value
                    end
                elseif backend == "color_picker3_table"
                    and type(imgui.color_picker3) == "function" then

                    picker = imgui.color_picker3
                    input_value = {
                        current_color[1],
                        current_color[2],
                        current_color[3]
                    }
                elseif backend == "color_picker3_vector"
                    and type(imgui.color_picker3) == "function"
                    and type(vector) == "table"
                    and type(vector.new) == "function" then

                    local vector_ok, vector_value = pcall(
                        vector.new,
                        current_color[1],
                        current_color[2],
                        current_color[3]
                    )

                    if vector_ok then
                        picker = imgui.color_picker3
                        input_value = vector_value
                    end
                elseif backend == "color_picker_abgr"
                    and type(imgui.color_picker) == "function" then

                    picker = imgui.color_picker
                    input_value = ui.control.color_to_abgr(current_color)
                end

                if picker ~= nil and input_value ~= nil then
                    local call_ok,
                        changed,
                        value_one,
                        value_two,
                        value_three,
                        value_four = pcall(
                            picker,
                            "##" .. tostring(editor_key) .. "NativePicker",
                            input_value,
                            compact_picker_flags
                        )

                    if not call_ok then
                        call_ok,
                            changed,
                            value_one,
                            value_two,
                            value_three,
                            value_four = pcall(
                                picker,
                                "##" .. tostring(editor_key) .. "NativePicker",
                                input_value
                            )
                    end

                    if call_ok then
                        ui.control.runtime.color_picker_backend = backend

                        if changed == true then
                            local picked_color

                            if value_one ~= nil then
                                picked_color =
                                    native_picker_result_to_color(
                                        value_one,
                                        value_two,
                                        value_three,
                                        value_four,
                                        current_color
                                    )
                            else
                                picked_color =
                                    ui.control.normalize_rgba_color(
                                        input_value,
                                        current_color
                                    )
                            end

                            picked_color[4] = 1.0
                            return picked_color, true, backend
                        end

                        return current_color, false, backend
                    end

                    if cached_backend == backend then
                        ui.control.runtime.color_picker_backend = ""
                    end
                end
            end
        end

        return current_color, false, "fallback"
    end

