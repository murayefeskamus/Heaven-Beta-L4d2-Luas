    function ui.quotes.get_queue_state()
        local current =
            #chat_queue

        local maximum =
            math.max(
                1,
                tonumber(
                    settings.max_queue_size
                ) or 1
            )

        if current <= 0 then
            return "IDLE"
        end

        if current >= maximum then
            return "FULL"
        end

        local ratio =
            current /
            maximum

        if ratio <= 0.34 then
            return "LOW"
        elseif ratio <= 0.67 then
            return "MID"
        end

        return "HIGH"
    end

    function ui.quotes.get_queue_color()
        local queue_state =
            ui.quotes.get_queue_state()

        if queue_state == "FULL" then
            return 1.0, 0.25, 0.25
        elseif queue_state == "HIGH" then
            return 1.0, 0.56, 0.18
        elseif queue_state == "MID" then
            return 1.0, 0.86, 0.25
        elseif queue_state == "LOW" then
            return 0.25, 1.0, 0.35
        end

        local palette =
            ui.enhancements.theme_palette()

        return palette.text_disabled[1],
            palette.text_disabled[2],
            palette.text_disabled[3]
    end

    function ui.quotes.get_live_status()
        if not settings.enabled then
            return "Disabled"
        end

        if not engine.is_connected() then
            return "Idle"
        end

        if #chat_queue >=
            settings.max_queue_size then

            return "Queue full"
        end

        if #chat_queue > 0
            or #quote_change_queue > 0 then

            return "Sending"
        end

        if tostring(status.message or "") ==
            "Help displayed" then

            return "Ready"
        end

        if status.message ~=
                ui.quotes.ui_state.last_visible_status
            or (tonumber(status.message_revision) or 0) ~=
                (
                    tonumber(
                        ui.quotes.ui_state.last_visible_status_revision
                    ) or 0
                ) then

            ui.quotes.ui_state.last_visible_status =
                status.message

            ui.quotes.ui_state.last_visible_status_revision =
                tonumber(status.message_revision) or 0

            ui.quotes.ui_state.last_visible_status_time =
                os.clock()
        end

        if os.clock() -
            ui.quotes.ui_state.last_visible_status_time >= 3 then

            return "Ready"
        end

        local message =
            tostring(
                ui.quotes.ui_state.last_visible_status
                or "Ready"
            )

        local replacements = {
            ["Post a random quote posted"] = "Posted random quote",
            ["Post a random quote requested"] = "Random queued",
            ["Search result posted"] = "Result posted",
            ["Quote saved"] = "Saved",
            ["Quote deleted"] = "Deleted",
            ["Help displayed"] = "Help queued",
            ["Random cycle reshuffled"] = "Reshuffled",
            ["Quotes reloaded"] = "Reloaded",
            ["Saved, reload failed"] = "Reload failed",
            ["Deleted, reload failed"] = "Reload failed",
            ["Could not open quotes.txt"] = "File unavailable",
            ["File access unavailable."] = "File unavailable",
            ["No quotes found"] = "No quotes",
            ["No quote available"] = "No quote",
            ["Search selection failed"] = "Search failed",
            ["Invalid find input"] = "Invalid search",
            ["Invalid delete input"] = "Invalid ID",
            ["Delete target missing"] = "ID not found",
            ["Invalid findnext input"] = "Invalid command",
            ["Invalid random command"] = "Invalid command",
            ["Invalid save input"] = "Invalid quote",
            ["Help cooldown active"] = "Help cooldown"
        }

        message =
            replacements[
                message
            ] or message

        if #message > 20 then
            message =
                message:sub(
                    1,
                    17
                ) ..
                "..."
        end

        return message
    end


    function ui.quotes.get_status_color(
        status_value,
        palette
    )
        status_value =
            tostring(status_value or "")

        palette =
            type(palette) == "table"
            and palette
            or ui.enhancements.theme_palette()

        local lower_status =
            status_value:lower()

        if lower_status == "disabled"
            or lower_status == "offline"
            or lower_status == "idle" then

            local neutral =
                palette.text_disabled
                or { 0.60, 0.60, 0.62 }

            return neutral[1],
                neutral[2],
                neutral[3]
        end

        if lower_status == "sending"
            or lower_status:find("cooldown", 1, true)
            or lower_status:find("confirm", 1, true)
            or lower_status:find("queued", 1, true) then

            return 1.0, 0.86, 0.25
        end

        local negative_fragments = {
            "invalid",
            "failed",
            "failure",
            "unavailable",
            "not found",
            "no match",
            "no quote",
            "duplicate",
            "queue full",
            "error",
            "blocked",
            "missing"
        }

        for _, fragment in ipairs(
            negative_fragments
        ) do
            if lower_status:find(
                fragment,
                1,
                true
            ) then
                return 1.0, 0.25, 0.25
            end
        end

        return 0.25, 1.0, 0.35
    end

