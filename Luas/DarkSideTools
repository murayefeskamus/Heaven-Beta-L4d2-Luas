function ui.lobby.sanitize_special_infected_announcement_template(
    template_text
)
    template_text = tostring(template_text or "")
    template_text = template_text:gsub("[\r\n]", " ")
    template_text = template_text:gsub('"', "'")

    local maximum_characters =
        math.max(
            1,
            math.floor(
                tonumber(
                    DARKSIDE_CONFIG.SPECIAL_INFECTED_ANNOUNCEMENT_MAX_CHARACTERS
                ) or 120
            )
        )

    local characters =
        split_utf8_characters(
            template_text
        )

    if #characters > maximum_characters then
        local limited = {}

        for index = 1, maximum_characters do
            limited[index] = characters[index]
        end

        template_text = table.concat(limited)
    end

    return template_text
end

function ui.lobby.reset_special_infected_announcement_cycle()
