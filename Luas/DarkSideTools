                    is_active
                    and ui.heaven_configs.push_current_config_combo_colors()
                    or push_neutral_combo_colors()

                local changed_config,
                    selected_config_index =
                        imgui.combo(
                            "##HeavenConfigSelection" .. tostring(index),
                            combo_index,
                            combo_items
                        )

                pop_neutral_combo_colors(neutral_combo_colors)
                imgui.pop_item_width()

                if changed_config then
                    selected_config_index =
                        math.floor(
                            tonumber(selected_config_index) or 0
                        )

                    if selected_config_index >= 0
                        and selected_config_index < detected_count then

                        ui.heaven_configs.assign_config_to_slot(
                            index,
                            tostring(
                                ui.heaven_configs.detected_configs[
