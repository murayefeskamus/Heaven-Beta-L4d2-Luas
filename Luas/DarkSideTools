function ui.favourites.clean_label(
    value
)
    local label =
        tostring(value or "")

    label =
        label:gsub(
            "##.*$",
            ""
        )

    label =
        label:gsub(
            "^%s+",
            ""
        ):gsub(
            "%s+$",
            ""
        )

    label =
        label:gsub(
            "%s*:%s*$",
            ""
        )

    return label
end

function ui.favourites.normalize_label(
    value
)
    local label =
        ui.favourites.clean_label(
            value
        )

    if type(ui.setting_search) == "table"
        and type(
            ui.setting_search.normalize
        ) == "function" then

        return ui.setting_search.normalize(
            label
        )
    end

    return label:lower()
end

function ui.favourites.color_distance(
    first,
    second
)
    first =
        type(first) == "table"
        and first
        or { 0.0, 0.0, 0.0 }

    second =
        type(second) == "table"
        and second
        or { 0.0, 0.0, 0.0 }

    local red =
        (tonumber(first[1]) or 0.0) -
        (tonumber(second[1]) or 0.0)

    local green =
        (tonumber(first[2]) or 0.0) -
        (tonumber(second[2]) or 0.0)

    local blue =
        (tonumber(first[3]) or 0.0) -
        (tonumber(second[3]) or 0.0)

    return math.sqrt(
        red * red +
        green * green +
        blue * blue
    )
end

function ui.favourites.mix_color(
    first,
    second,
    amount
)
    first =
        type(first) == "table"
        and first
        or { 0.0, 0.0, 0.0 }

    second =
        type(second) == "table"
        and second
        or { 0.0, 0.0, 0.0 }

    amount =
        math.max(
            0.0,
            math.min(
                1.0,
                tonumber(amount) or 0.0
            )
        )

    return {
        (tonumber(first[1]) or 0.0) +
            (
                (tonumber(second[1]) or 0.0) -
                (tonumber(first[1]) or 0.0)
            ) * amount,
        (tonumber(first[2]) or 0.0) +
            (
                (tonumber(second[2]) or 0.0) -
                (tonumber(first[2]) or 0.0)
            ) * amount,
        (tonumber(first[3]) or 0.0) +
            (
                (tonumber(second[3]) or 0.0) -
                (tonumber(first[3]) or 0.0)
            ) * amount
    }
end

function ui.favourites.get_secondary_color(
    palette
)
    palette =
        type(palette) == "table"
        and palette
        or ui.enhancements.theme_palette()

    local accent =
        palette.accent
        or { 0.90, 0.65, 0.18 }

    local candidate =
        palette.section_text
        or palette.active_tab
        or palette.button
        or palette.text_disabled
        or { 0.35, 0.75, 1.0 }

    if ui.favourites.color_distance(
        candidate,
        accent
    ) < 0.12 then
        candidate =
            palette.active_tab
            or palette.button
            or palette.border
            or palette.text_disabled
            or { 0.35, 0.75, 1.0 }
    end

    if ui.favourites.color_distance(
        candidate,
        accent
    ) < 0.12 then
        candidate =
            ui.favourites.mix_color(
                palette.text
                or { 1.0, 1.0, 1.0 },
                palette.button
                or palette.child
                or { 0.15, 0.15, 0.17 },
                0.62
            )
    end

    return {
        math.max(
            0.0,
            math.min(
                1.0,
                tonumber(candidate[1]) or 0.35
            )
        ),
        math.max(
            0.0,
            math.min(
                1.0,
                tonumber(candidate[2]) or 0.75
            )
        ),
        math.max(
            0.0,
            math.min(
                1.0,
                tonumber(candidate[3]) or 1.0
            )
        )
    }
end

function ui.favourites.get_contrast_text_color(
    background
)
    background =
        type(background) == "table"
        and background
        or { 0.2, 0.2, 0.2 }

    local luminance =
        (tonumber(background[1]) or 0.0) * 0.299 +
        (tonumber(background[2]) or 0.0) * 0.587 +
        (tonumber(background[3]) or 0.0) * 0.114

    if luminance > 0.58 then
        return { 0.025, 0.030, 0.038 }
    end

    return { 1.0, 1.0, 1.0 }
end

function ui.favourites.get_tab_colors(
    palette,
    selected
)
    palette =
        type(palette) == "table"
        and palette
        or ui.enhancements.theme_palette()

    local accent =
        palette.accent
        or palette.active_tab
        or { 0.90, 0.65, 0.18 }

    if selected == true then
        return
            {
                tonumber(accent[1]) or 0.90,
                tonumber(accent[2]) or 0.65,
                tonumber(accent[3]) or 0.18
            },
            ui.favourites.get_contrast_text_color(
                accent
            )
    end

    local control_surface =
        palette.button_hover
        or palette.button
        or palette.inactive_tab
        or palette.child
        or { 0.18, 0.19, 0.21 }

    local theme_text =
        palette.text
        or { 0.92, 0.92, 0.94 }

    local base =
        ui.favourites.mix_color(
            control_surface,
            theme_text,
            0.24
        )

    if ui.favourites.color_distance(
        base,
        accent
    ) < 0.18 then
        base =
            ui.favourites.mix_color(
                palette.child
                or palette.background
                or control_surface,
                theme_text,
                0.34
            )
    end

    if ui.favourites.color_distance(
        base,
        palette.inactive_tab
        or control_surface
    ) < 0.08 then
        base =
            ui.favourites.mix_color(
                base,
                theme_text,
                0.18
            )
    end

    return
        base,
        ui.favourites.get_contrast_text_color(
            base
        )
end

