            end

            local function make_quote_row(key)
                if key == "status" then
                    return {
                        label = "Status",
                        value = ui.quotes.get_live_status(),
                        special = "status"
                    }
                elseif key == "quotes_shown" then
                    return {
                        label = "Quotes shown",
