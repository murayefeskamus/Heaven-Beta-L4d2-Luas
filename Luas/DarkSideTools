function ui.setting_search.get_attention_color(palette)
    palette = type(palette) == "table" and palette or {}

    local source =
        type(palette.section_text) == "table"
        and palette.section_text
        or (
            type(palette.accent) == "table"
            and palette.accent
            or { 0.20, 0.85, 1.00 }
        )

    local red = math.max(0.0, math.min(1.0, tonumber(source[1]) or 0.20))
    local green = math.max(0.0, math.min(1.0, tonumber(source[2]) or 0.85))
    local blue = math.max(0.0, math.min(1.0, tonumber(source[3]) or 1.00))
    local maximum = math.max(red, green, blue)
    local minimum = math.min(red, green, blue)
    local delta = maximum - minimum
    local hue = 0.0
    local saturation = maximum <= 0.0001 and 0.0 or delta / maximum

    if delta > 0.0001 then
        if maximum == red then
            hue = ((green - blue) / delta) % 6
        elseif maximum == green then
            hue = ((blue - red) / delta) + 2
        else
            hue = ((red - green) / delta) + 4
        end

        hue = hue / 6
    end

    if saturation < 0.24 then
        local family = tostring(palette.family or ""):lower()

        if family:find("gold", 1, true) then
            hue = 0.115
        elseif family:find("green", 1, true) then
            hue = 0.395
        elseif family:find("purple", 1, true) then
            hue = 0.775
        elseif family:find("red", 1, true) then
            hue = 0.985
        elseif family:find("pink", 1, true) then
            hue = 0.925
        else
            hue = 0.545
        end
    end

    saturation = math.max(saturation, 0.82)
    local value = palette.light == true and 0.72 or 1.00
    local chroma = value * saturation
    local hue_sector = (hue * 6) % 6
    local secondary = chroma * (1 - math.abs((hue_sector % 2) - 1))
    local match = value - chroma
    local out_red, out_green, out_blue = 0.0, 0.0, 0.0

    if hue_sector < 1 then
        out_red, out_green, out_blue = chroma, secondary, 0
    elseif hue_sector < 2 then
        out_red, out_green, out_blue = secondary, chroma, 0
    elseif hue_sector < 3 then
        out_red, out_green, out_blue = 0, chroma, secondary
    elseif hue_sector < 4 then
        out_red, out_green, out_blue = 0, secondary, chroma
    elseif hue_sector < 5 then
        out_red, out_green, out_blue = secondary, 0, chroma
    else
        out_red, out_green, out_blue = chroma, 0, secondary
    end

    return {
        math.max(0.0, math.min(1.0, out_red + match)),
        math.max(0.0, math.min(1.0, out_green + match)),
        math.max(0.0, math.min(1.0, out_blue + match))
    }
end

function ui.setting_search.draw_active_match_marker()
