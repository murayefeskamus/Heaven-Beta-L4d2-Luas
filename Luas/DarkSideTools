function ui.setting_search.setting_search_match_is_exact_rendered_label(label)
    if ui.setting_search.exact_observer_guard == true
        or ui.setting_search.rendering_highlight_active ~= true then
        return false
    end

    local target_source =
        tostring(ui.setting_search.active_highlight_term or "")

    if ui.setting_search.performance_tab_target_source ~= target_source then
        ui.setting_search.performance_tab_target_source = target_source
        ui.setting_search.performance_tab_target_normalized =
            ui.setting_search.normalize(target_source)
    end

    local raw_label = tostring(label or "")
    local candidate = ui.setting_search.performance_tab_label_cache[raw_label]

    if candidate == nil then
        candidate = ui.setting_search.normalize(
            ui.setting_search.visible_item_label(raw_label)
        )

        ui.setting_search.performance_tab_label_cache[raw_label] = candidate
        ui.setting_search.performance_tab_label_cache_count =
            ui.setting_search.performance_tab_label_cache_count + 1

        if ui.setting_search.performance_tab_label_cache_count > 1024 then
            ui.setting_search.performance_tab_label_cache = {
                [raw_label] = candidate
            }
            ui.setting_search.performance_tab_label_cache_count = 1
        end
    end

    return candidate ~= ""
        and ui.setting_search.performance_tab_target_normalized ~= ""
        and candidate == ui.setting_search.performance_tab_target_normalized
end

function ui.setting_search.setting_search_match_install_temporary_observers()
    if ui.setting_search.setting_search_match_temporary_observers_installed == true
        or type(imgui) ~= "table" then
        return
    end

    local originals = ui.setting_search.setting_search_match_temporary_originals

    if type(originals) ~= "table" then
        originals = {}
        ui.setting_search.setting_search_match_temporary_originals = originals
    else
        for method_name in pairs(originals) do
            originals[method_name] = nil
        end
    end

    for _, definition in ipairs(ui.setting_search.setting_search_match_observer_methods) do
        local method_name = tostring(definition.name or "")
        local label_index = math.max(
            1,
            math.floor(tonumber(definition.label_index) or 1)
        )
        local raw_method = imgui[method_name]

        if type(raw_method) == "function" then
            originals[method_name] = raw_method

            local cached =
                ui.setting_search.performance_tab_wrapper_cache[method_name]

            if type(cached) ~= "table"
                or cached.raw ~= raw_method
                or cached.label_index ~= label_index then

                cached = {
                    raw = raw_method,
                    label_index = label_index,
                    wrapper =
                        ui.setting_search.setting_search_match_make_temporary_wrapper(
                            raw_method,
                            label_index
                        )
                }

                ui.setting_search.performance_tab_wrapper_cache[method_name] = cached
            end

            imgui[method_name] = cached.wrapper
        end
    end

    ui.setting_search.setting_search_match_temporary_observers_installed = true
end

