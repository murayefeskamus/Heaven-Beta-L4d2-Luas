function ui.enhancements.get_chat_preview_message_lines(
    message,
    preview_width,
    badge_text
)
    preview_width =
        math.max(
            180,
            tonumber(preview_width) or 355
        )

    badge_text = tostring(badge_text or "1/1")

    local badge_width =
        ui.lobby.measure_text_width(
            badge_text
        ) + 18

    local text_width =
        math.max(
            90,
            preview_width -
                badge_width -
                34
        )

    return ui.enhancements.wrap_log_message_lines(
        tostring(message or ""),
        text_width
    )
end

function ui.enhancements.get_chat_preview_body_height(
    messages,
    preview_width
)
    messages =
        type(messages) == "table"
        and messages
        or {}

    local message_count = #messages
    local total_lines = 0

    for index, message in ipairs(messages) do
        local badge_text =
            tostring(index) ..
            "/" ..
            tostring(message_count)

        local lines =
            ui.enhancements.get_chat_preview_message_lines(
                message,
                preview_width,
                badge_text
            )

        total_lines =
            total_lines +
            math.max(
                1,
                #lines
            )
    end

    return math.max(
        36,
        total_lines * 18 +
            message_count * 6 +
            14
    )
end

