                    imgui.same_line()

                    theme_text_colored(
                        0.15, 1.0, 1.0, 1.0,
                        string.format(
                            "%.1fs ago",
                            math.max(
                                0,
                                get_time() -
                                    ui.lobby.last_refresh_time
                            )
                        )
                    )
