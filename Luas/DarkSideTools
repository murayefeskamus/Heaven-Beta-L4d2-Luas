    ui.network.load_geoip_online_cache()
    ui.network.server_geoip_details_cache[ip_address] = details
    ui.network.server_region_online_lookup_cache[ip_address] = details.country
    ui.network.server_region_online_lookup_status =
        "Resolved " .. ip_address .. " as " .. ui.network.format_geoip_country_value(details) .. "."
    ui.network.save_geoip_online_cache()
    return true
end

function ui.network.get_geoip_details_from_online_cache(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)
    if ip_address == "" then
        return nil
    end

    ui.network.load_geoip_online_cache()

    local cache =
        type(ui.network.server_geoip_details_cache) == "table"
        and ui.network.server_geoip_details_cache
        or {}

    local details = cache[ip_address]
    if ui.network.geoip_detail_has_country(details) then
        return ui.network.normalize_geoip_detail(details, ip_address)
    end

    return nil
end

function ui.network.build_geoip_online_lookup_powershell(ip_address, output_path)
    local ip = ui.network.escape_powershell_single_quoted(
        ui.network.extract_ipv4_address(ip_address)
    )
    local out = ui.network.escape_powershell_single_quoted(output_path)

    return table.concat({
        "$ErrorActionPreference='SilentlyContinue'",
        "$ProgressPreference='SilentlyContinue'",
        "$ip='" .. ip .. "'",
        "$out='" .. out .. "'",
        "New-Item -ItemType Directory -Force -Path (Split-Path -LiteralPath $out) | Out-Null",
        "$fields='status,message,country,countryCode,region,regionName,city,zip,lat,lon,timezone,offset,isp,org,as,query'",
        "$uri='http://ip-api.com/json/'+$ip+'?fields='+$fields",
        "function C($v){ if($null -eq $v){ return '' }; return ([string]$v).Replace('|','/').Replace(\"`r\",' ').Replace(\"`n\",' ').Trim() }",
        "try {",
        "  $r = Invoke-RestMethod -Method Get -Uri $uri -TimeoutSec 12 -Headers @{ 'User-Agent'='DarkSideTools GeoIP' }",
        "  if(($null -eq $r) -or ([string]$r.status).ToLower() -ne 'success') { throw ('lookup failed: ' + [string]$r.message) }",
        "  $local = ''",
        "  $culture = [System.Globalization.CultureInfo]::InvariantCulture",
        "  if($null -ne $r.offset -and ([string]$r.offset) -ne '') { $local = [DateTimeOffset]::FromUnixTimeSeconds(([DateTimeOffset]::UtcNow.ToUnixTimeSeconds() + [int]$r.offset)).ToString('HH:mm:ss dd-MM-yyyy (dddd)', $culture) }",
        "  $parts = @( 'OK', ('source=ip-api'), ('query='+(C $r.query)), ('country='+(C $r.country)), ('countryCode='+(C $r.countryCode)), ('region='+(C $r.region)), ('regionName='+(C $r.regionName)), ('city='+(C $r.city)), ('zip='+(C $r.zip)), ('lat='+(C $r.lat)), ('lon='+(C $r.lon)), ('timezone='+(C $r.timezone)), ('offset='+(C $r.offset)), ('isp='+(C $r.isp)), ('org='+(C $r.org)), ('as='+(C $r.as)), ('currentTime='+(C $local)) )",
        "  Set-Content -LiteralPath $out -Value ($parts -join '|') -Encoding UTF8",
        "} catch {",
        "  Set-Content -LiteralPath $out -Value ('ERR|message=' + (C $_.Exception.Message)) -Encoding UTF8",
        "}"
    }, "\r\n")
end

function ui.network.start_geoip_online_lookup(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)

    if ui.network.server_region_online_lookup_enabled ~= true
        or ip_address == ""
        or ui.network.ipv4_to_number(ip_address) == nil
        or ui.network.is_private_ipv4_address(ip_address) then
        return false
    end

    if ui.network.get_geoip_details_from_online_cache(ip_address) ~= nil then
        return true
    end

    local now = os.clock()
    local last_start = tonumber(ui.network.server_region_online_lookup_last_start) or 0.0
    local min_interval = math.max(1.5, tonumber(ui.network.server_region_online_lookup_min_interval) or 1.5)

    if now - last_start < min_interval then
        return false
    end

    local next_retry = 0.0
    if type(ui.network.server_region_online_lookup_next_retry) == "table" then
        next_retry = tonumber(ui.network.server_region_online_lookup_next_retry[ip_address]) or 0.0
    end

    if next_retry > 0.0 and now < next_retry then
        return false
    end

    local active_ip = tostring(ui.network.server_region_online_lookup_active_ip or "")
    if active_ip ~= "" then
        local active_age = now - (tonumber(ui.network.server_region_online_lookup_started_at) or 0.0)
        local timeout = math.max(8.0, tonumber(ui.network.server_region_online_lookup_timeout) or 20.0)

        if active_ip == ip_address and active_age < timeout then
            return true
        end

        if active_age < timeout then
            return false
        end

        ui.network.server_region_online_lookup_active_ip = ""
        ui.network.server_region_online_lookup_active_path = ""
    end

    if type(os) ~= "table" or type(os.execute) ~= "function" then
        ui.network.server_region_online_lookup_status = "OS execute unavailable."
        return false
    end

    local output_path = ui.network.get_geoip_online_result_path(ip_address)
    local ps_path = output_path:gsub("%.txt$", ".ps1")
    local vbs_path = output_path:gsub("%.txt$", ".vbs")

    if type(os.remove) == "function" then
        pcall(os.remove, output_path)
    end

    local ps_command = ui.network.build_geoip_online_lookup_powershell(ip_address, output_path)
    local ps_written = false
    local vbs_written = false

    if type(io) == "table" and type(io.open) == "function" then
        local ps_ok, ps_file = pcall(io.open, ps_path, "wb")
        if ps_ok and ps_file then
            ps_written = pcall(function() ps_file:write(ps_command) end) == true
            pcall(function() ps_file:close() end)
        end

        local safe_ps = ps_path:gsub('"', '""')
        local vbs_command =
            'Set sh = CreateObject("WScript.Shell")\r\n' ..
            'sh.Run "powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File ""' ..
            safe_ps ..
            '""", 0, False\r\n'

        local vbs_ok, vbs_file = pcall(io.open, vbs_path, "wb")
        if vbs_ok and vbs_file then
            vbs_written = pcall(function() vbs_file:write(vbs_command) end) == true
            pcall(function() vbs_file:close() end)
        end
    end

    if ps_written ~= true then
        ui.network.server_region_online_lookup_status =
            "Lookup script write failed: " .. tostring(ps_path)
        return false
    end

    local shell_command
    if vbs_written == true then
        shell_command = 'wscript.exe ' .. geo84_quote_cmd_path(vbs_path)
    else
        shell_command = 'powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File ' .. geo84_quote_cmd_path(ps_path)
    end

    local ok = pcall(os.execute, shell_command)
    if ok then
        ui.network.server_region_online_lookup_last_start = now
        ui.network.server_region_online_lookup_active_ip = ip_address
        ui.network.server_region_online_lookup_active_path = output_path
        ui.network.server_region_online_lookup_started_at = now
        ui.network.server_region_online_lookup_status =
            "GeoIP lookup started for " .. ip_address .. "."
        return true
    end

    ui.network.server_region_online_lookup_status = "GeoIP lookup start failed."
    return false
end

function ui.network.read_geoip_online_lookup_result(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)

    if ip_address == "" or type(io) ~= "table" or type(io.open) ~= "function" then
        return ""
    end

    local active_ip = tostring(ui.network.server_region_online_lookup_active_ip or "")
    if active_ip ~= ip_address then
        return ""
    end

    local path = tostring(ui.network.server_region_online_lookup_active_path or "")
    if path == "" then
        path = ui.network.get_geoip_online_result_path(ip_address)
    end

    local file_ok, file = pcall(io.open, path, "rb")
    if not file_ok or not file then
        local age = os.clock() - (tonumber(ui.network.server_region_online_lookup_started_at) or 0.0)
        local timeout = math.max(8.0, tonumber(ui.network.server_region_online_lookup_timeout) or 20.0)

        if age >= timeout then
            ui.network.server_region_online_lookup_active_ip = ""
            ui.network.server_region_online_lookup_active_path = ""
            ui.network.server_region_online_lookup_status =
                "GeoIP lookup timed out. Last output path: " .. tostring(path)

            if type(ui.network.server_region_online_lookup_next_retry) ~= "table" then
                ui.network.server_region_online_lookup_next_retry = {}
            end

            ui.network.server_region_online_lookup_next_retry[ip_address] =
                os.clock() + math.max(120.0, tonumber(ui.network.server_region_online_lookup_retry_interval) or 600.0)
        end

        return ""
    end

    local read_ok, content = pcall(function() return file:read("*a") end)
    pcall(function() file:close() end)

    if not read_ok then
        return ""
    end

    content = tostring(content or "")
        :gsub("^\239\187\191", "")
        :gsub("[\r\n]+", " ")
        :gsub("^%s+", "")
        :gsub("%s+$", "")

    if content == "" then
        return ""
    end

    ui.network.server_region_online_lookup_active_ip = ""
    ui.network.server_region_online_lookup_active_path = ""

    local status = content:match("^([^|]+)") or ""
    if status == "OK" then
        local details = geo84_parse_kv_line(content)
        details = ui.network.normalize_geoip_detail(details, ip_address)

        if ui.network.cache_geoip_online_details(ip_address, details) then
            return tostring(details.country or "")
        end
    end

    local error_message = content:match("message=([^|]+)") or "Unknown error"
    ui.network.server_region_online_lookup_status =
        "GeoIP lookup failed: " .. tostring(error_message)

    if type(ui.network.server_region_online_lookup_next_retry) ~= "table" then
        ui.network.server_region_online_lookup_next_retry = {}
    end

    ui.network.server_region_online_lookup_next_retry[ip_address] =
        os.clock() + math.max(120.0, tonumber(ui.network.server_region_online_lookup_retry_interval) or 600.0)

    return ""
end

function ui.network.get_geoip_details_from_online_lookup(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)
    if ip_address == "" then
        return nil
    end

    local cached = ui.network.get_geoip_details_from_online_cache(ip_address)
    if cached ~= nil then
        return cached
    end

    local active_country = ui.network.read_geoip_online_lookup_result(ip_address)
    if active_country ~= "" then
        return ui.network.get_geoip_details_from_online_cache(ip_address)
    end

    ui.network.start_geoip_online_lookup(ip_address)
    return nil
end

function ui.network.is_geoip_online_lookup_pending(ip_address)
    ip_address = ui.network.extract_ipv4_address(ip_address)
    if ip_address == "" then
        return false
    end

    if tostring(ui.network.server_region_online_lookup_active_ip or "") ~= ip_address then
        return false
    end

    local age = os.clock() - (tonumber(ui.network.server_region_online_lookup_started_at) or 0.0)
    local timeout = math.max(8.0, tonumber(ui.network.server_region_online_lookup_timeout) or 20.0)
    return age < timeout
end

function ui.network.get_server_geoip_details(address)
    address = tostring(address or "")
    local ip, port = ui.network.extract_server_ip_port(address)
    local details = nil
    local known = false
    local detecting = false

    if address == "" or address == "Unknown" or address == "CONNECTED SERVER" then
        return { ip = "", port = "", country = "", display = "-" }, false, false
    end

    if ui.network.is_local_server_address(address) then
        return {
            ip = ip,
            port = port,
            country = "",
            city = "",
            display = "-"
        }, false, false
    end

    if ip ~= "" and ui.network.is_private_ipv4_address(ip) then
        return {
            ip = ip,
            port = port,
            country = "",
            city = "",
            display = "-"
        }, false, false
    end

    if ip ~= "" then
        details = ui.network.get_geoip_details_from_online_lookup(ip)
        if ui.network.geoip_detail_has_country(details) then
            known = true
        else
            details = nil
            detecting = ui.network.is_geoip_online_lookup_pending(ip)
        end
    end

    if details == nil then
        local manual = ui.network.get_manual_server_region(address, ip)
        if manual ~= "" then
            details = ui.network.normalize_geoip_detail({
                query = ip,
                country = manual,
                source = "manual"
            }, ip)
            known = true
        end
    end

    if details == nil and ip ~= "" then
        local file_country = ui.network.get_geoip_country_from_file(ip)
        if file_country ~= "" then
            details = ui.network.normalize_geoip_detail({
                query = ip,
                country = file_country,
                source = "offline-file"
            }, ip)
            known = true
        end
    end

    if details == nil and ip ~= "" then
        local builtin_country = ui.network.get_builtin_ip_region(ip)
        if builtin_country ~= "" then
            details = ui.network.normalize_geoip_detail({
                query = ip,
                country = builtin_country,
                source = "builtin"
            }, ip)
            known = true
        end
    end

    if details == nil then
        local hostname = ui.network.get_cached_server_hostname(address)
        local hostname_region, hostname_known = ui.network.extract_region_from_hostname(hostname)
        if hostname_known == true and tostring(hostname_region or "") ~= "" then
            details = ui.network.normalize_geoip_detail({
                query = ip,
                country = hostname_region,
                source = "hostname"
            }, ip)
            known = true
        end
    end

    if details == nil then
        details = {
            query = ip,
            country = detecting and "Detecting..." or "Unknown",
            source = detecting and "pending" or "unknown"
        }
        known = false
    end

    details = ui.network.normalize_geoip_detail(details, ip)
    details.ip = ip
    details.port = port
    details.display =
        known == true
        and ui.network.format_geoip_country_value(details)
        or (detecting and "Detecting..." or "Unknown")

    return details, known == true, detecting == true
end

