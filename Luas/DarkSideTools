        controls_start_y +
        controls_row_height
    )

    if visible_slot_count > 0 then
        local enabled_width = 64
        local number_width = 30
        local config_width = 210
        local key_width = 132
        local actions_width = 136

        local table_width =
            enabled_width +
            number_width +
            config_width +
            key_width +
            actions_width

        local row_height = 24

        if type(imgui.get_frame_height_with_spacing) == "function" then
            local height_ok,
                measured_height =
                    pcall(
                        imgui.get_frame_height_with_spacing
                    )

            if height_ok
                and tonumber(measured_height) then

                row_height =
                    math.max(
                        22,
                        math.ceil(
                            tonumber(measured_height)
                        )
                    )
            end
        elseif type(imgui.get_text_line_height_with_spacing) == "function" then
            local height_ok,
                measured_height =
                    pcall(
                        imgui.get_text_line_height_with_spacing
                    )

            if height_ok
                and tonumber(measured_height) then

                row_height =
                    math.max(
                        22,
                        math.ceil(
                            tonumber(measured_height) + 2
                        )
                    )
            end
        end

        local dynamic_table_height =
            28 +
            visible_slot_count * 25

        local table_open =
            imgui.begin_child(
                "HeavenConfigHotkeysTable",
                table_width,
                dynamic_table_height,
                true,
                24
            )

        if table_open then
            local table_start_x =
                ui.lobby.get_cursor_x()

            local enabled_x = table_start_x
            local number_x = enabled_x + enabled_width
            local config_x = number_x + number_width
            local key_x = config_x + config_width
            local actions_x = key_x + key_width

            local divider_color =
                hint_palette.border
                or hint_palette.separator
                or { 0.42, 0.42, 0.44 }

            local function draw_divider(x_position)
                imgui.same_line()
                ui.lobby.set_cursor_x(x_position)

                theme_text_colored(
                    divider_color[1] or 0.42,
                    divider_color[2] or 0.42,
                    divider_color[3] or 0.44,
                    1.0,
                    "|"
                )
            end

            local function draw_centered_header(
                label,
                column_x,
                column_width,
                first_item
            )
                if not first_item then
                    imgui.same_line()
                end

                local text_width =
                    ui.lobby.measure_text_width(label)

                ui.lobby.set_cursor_x(
                    column_x +
                    math.max(
                        4,
                        (
                            column_width -
                            text_width
                        ) * 0.5
                    )
                )

                ui.draw_theme_table_header_text(label)
            end

            draw_centered_header(
                "ENABLED",
                enabled_x,
                enabled_width,
                true
            )

            draw_divider(number_x)

            draw_centered_header(
                "#",
                number_x,
                number_width,
                false
            )

            draw_divider(config_x)

            draw_centered_header(
                "CONFIG NAME",
                config_x,
                config_width,
                false
            )

            draw_divider(key_x)

            draw_centered_header(
                "KEY",
                key_x,
                key_width,
                false
            )

            draw_divider(actions_x)

            draw_centered_header(
                "ACTIONS",
                actions_x,
                actions_width,
                false
            )

