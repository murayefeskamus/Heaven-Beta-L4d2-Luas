ui.reorderable_fields = ui.reorderable_fields or {}

function ui.reorderable_fields.definition_lookup(definitions)
    local lookup = {}

    for _, definition in ipairs(
        type(definitions) == "table" and definitions or {}
    ) do
        local key = tostring(definition.key or "")

        if key ~= "" then
            lookup[key] = definition
        end
    end

    return lookup
end

function ui.reorderable_fields.normalize(order, definitions)
    local normalized = {}
    local seen = {}
    local lookup =
        ui.reorderable_fields.definition_lookup(
            definitions
        )

    for _, key in ipairs(
        type(order) == "table" and order or {}
    ) do
        key = tostring(key or "")

        if lookup[key]
            and not seen[key] then

            normalized[#normalized + 1] = key
            seen[key] = true
        end
    end

    for _, definition in ipairs(
        type(definitions) == "table" and definitions or {}
    ) do
        local key = tostring(definition.key or "")

        if key ~= ""
            and not seen[key] then

            normalized[#normalized + 1] = key
            seen[key] = true
        end
    end

    return normalized
end

function ui.reorderable_fields.move(order, index, direction)
    if type(order) ~= "table" then
        return false
    end

    index = math.floor(tonumber(index) or 0)
    direction = direction < 0 and -1 or 1

    local target_index = index + direction

    if index < 1
        or index > #order
        or target_index < 1
        or target_index > #order then

        return false
    end

    order[index], order[target_index] =
        order[target_index], order[index]

    return true
end

function ui.reorderable_fields.draw(
    display,
    order,
    definitions,
    unique_prefix,
    on_change
)
    display = type(display) == "table" and display or {}
    order = type(order) == "table" and order or {}

    local lookup =
        ui.reorderable_fields.definition_lookup(
            definitions
        )

    local row_start_x =
        ui.lobby.get_cursor_x()

    local controls_x = row_start_x + 255

    for index, key in ipairs(order) do
        local definition = lookup[key]

        if definition then
            local visible_label =
                tostring(definition.label or key)

            local auto_copy_status_text = ""

            if definition.show_auto_copy_status == true then
                auto_copy_status_text =
                    "Auto-copy: " ..
                    (
                        ui.network.auto_copy_on_connect
                        and "ON"
                        or "OFF"
                    )
            end

            local changed,
                enabled =
                    imgui.checkbox(
                        visible_label ..
                            "##" ..
                            tostring(unique_prefix) ..
                            "_Toggle_" ..
                            tostring(key),
                        display[key] == true
                    )

            if auto_copy_status_text ~= "" then
                imgui.same_line()

                theme_text_colored(
                    ui.network.auto_copy_on_connect and 0.25 or 0.65,
                    ui.network.auto_copy_on_connect and 1.00 or 0.65,
                    ui.network.auto_copy_on_connect and 0.35 or 0.67,
                    1.0,
                    auto_copy_status_text
                )
            end

            if changed then
                display[key] = enabled == true

                if type(on_change) == "function" then
                    pcall(
                        on_change,
                        key,
                        display[key]
                    )
                end
            end

            local row_controls_x = controls_x

            if auto_copy_status_text ~= "" then
                row_controls_x =
                    math.max(
                        row_controls_x,
                        row_start_x +
                        ui.lobby.measure_text_width(
                            visible_label
                        ) +
                        ui.lobby.measure_text_width(
                            auto_copy_status_text
                        ) +
                        48
                    )
            end

            imgui.same_line()
            ui.lobby.set_cursor_x(row_controls_x)

            if imgui.button(
                "Up##" ..
                    tostring(unique_prefix) ..
                    "_Up_" ..
                    tostring(key)
            ) then
                ui.reorderable_fields.move(
                    order,
                    index,
                    -1
                )
            end

            imgui.same_line()

            if imgui.button(
                "Down##" ..
                    tostring(unique_prefix) ..
                    "_Down_" ..
                    tostring(key)
            ) then
                ui.reorderable_fields.move(
                    order,
                    index,
                    1
                )
            end
        end
    end
end

function ui.window_hotkeys.get_target_key(
