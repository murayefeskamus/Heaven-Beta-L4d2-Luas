        )

        imgui.same_line()

        ui.lobby.set_cursor_x(
            start_x + label_width + 10
        )

        local value_start_offset = 10
        local value_reserved_width = 14

        if indicator_text ~= "" then
            theme_text_colored(
                indicator_r,
                indicator_g,
                indicator_b,
                1.0,
                indicator_text
            )

            imgui.same_line()
            value_start_offset = 22
            value_reserved_width = 26
        end

        ui.lobby.set_cursor_x(
            start_x + label_width + value_start_offset
        )

        local suffix_width =
