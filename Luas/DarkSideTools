function ui.enhancements.wrap_log_message_lines(
    message,
    max_width
)
    message =
        tostring(message or "")

    max_width =
        math.max(
            120,
            tonumber(max_width) or 120
        )

    local lines = {}
    local current_line = ""

    local function push_current()
        if current_line ~= "" then
            table.insert(
                lines,
                current_line
            )

            current_line = ""
        end
    end

    local function append_fragment(
        fragment
    )
        fragment =
            tostring(fragment or "")

        local candidate =
            current_line == ""
            and fragment
            or (
                current_line ..
                " " ..
                fragment
            )

        if ui.lobby.measure_text_width(
            candidate
        ) <= max_width then

            current_line = candidate
            return
        end

        push_current()

        if ui.lobby.measure_text_width(
            fragment
        ) <= max_width then

            current_line = fragment
            return
        end

        local fragment_line = ""

        for _, character in ipairs(
            split_utf8_characters(
                fragment
            )
        ) do
            local candidate_fragment =
                fragment_line ..
                character

            if fragment_line ~= ""
                and ui.lobby.measure_text_width(
                    candidate_fragment
                ) > max_width then

                table.insert(
                    lines,
                    fragment_line
                )

                fragment_line =
                    character
            else
                fragment_line =
                    candidate_fragment
            end
        end

        current_line =
            fragment_line
    end

    for word in message:gmatch(
        "%S+"
    ) do
        append_fragment(
            word
        )
    end

    push_current()

    if #lines == 0 then
        lines[1] = ""
    end

    return lines
end

