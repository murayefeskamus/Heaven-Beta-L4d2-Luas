function ui.setting_search.get_temporary_scroll_padding()
    local padding =
        math.max(
            220,
            tonumber(ui.setting_search.exact_padding_pixels) or 360
        )

    if type(imgui.get_window_height) == "function" then
        local ok, height = pcall(imgui.get_window_height)
        if ok and type(height) == "number" and height > 0 then
            padding = math.max(
                padding,
                math.min(620, height * 0.80)
            )
        end
    elseif type(imgui.get_window_size) == "function" then
        local ok, width, height = pcall(imgui.get_window_size)
        if ok then
            local resolved_height = tonumber(height)
            if resolved_height == nil and type(width) == "table" then
                resolved_height =
                    tonumber(width.y) or tonumber(width[2])
            end

            if resolved_height and resolved_height > 0 then
                padding = math.max(
                    padding,
                    math.min(620, resolved_height * 0.80)
                )
            end
        end
    end

    return padding
end

function ui.setting_search.should_add_temporary_padding(tab_key)
    return tostring(ui.setting_search.query or "") ~= ""
        and tostring(ui.setting_search.active_highlight_term or "") ~= ""
        and tostring(ui.setting_search.active_highlight_tab or "") ==
            tostring(tab_key or "")
end

function ui.section_layout.draw_sections(tab_key, renderers)
    renderers = type(renderers) == "table" and renderers or {}

    local rendered_count = 0
    for _, section_key in ipairs(ui.section_layout.normalize_order(tab_key)) do
        local renderer = renderers[section_key]

        if type(renderer) == "function" then
            if rendered_count > 0 then
                draw_compact_gap()
            end

            local is_section_jump_target =
                ui.setting_search.pending_frames > 0 and
                tostring(ui.setting_search.pending_tab) == tostring(tab_key) and
                tostring(ui.setting_search.pending_section) == tostring(section_key)

            if is_section_jump_target then
                ui.setting_search.expand_section(tab_key, section_key)

                if type(imgui.set_scroll_here_y) == "function" then
                    pcall(imgui.set_scroll_here_y, 0.0)
                elseif type(imgui.set_scroll_here) == "function" then
                    pcall(imgui.set_scroll_here, 0.0)
                end

                ui.setting_search.pending_frames = 0
                ui.setting_search.pending_tab = ""
                ui.setting_search.pending_section = ""
            end

            local is_active_result_section =
                tostring(ui.setting_search.active_highlight_term or "") ~= "" and
                tostring(ui.setting_search.active_highlight_tab) == tostring(tab_key) and
                tostring(ui.setting_search.active_highlight_section) == tostring(section_key)

            ui.setting_search.rendering_highlight_active =
                is_active_result_section
            ui.setting_search.rendering_highlight_consumed = false

            ui.setting_search.rendering_exact_target_section =
                is_active_result_section
                and ui.setting_search.exact_scroll_pending == true
                and tostring(ui.setting_search.exact_scroll_tab) == tostring(tab_key)
                and tostring(ui.setting_search.exact_scroll_section) == tostring(section_key)

            renderer()

            if ui.setting_search.rendering_exact_target_section == true
                and ui.setting_search.exact_scroll_pending == true then

                ui.setting_search.exact_scroll_attempts =
                    math.max(
                        0,
                        math.floor(
                            tonumber(
                                ui.setting_search.exact_scroll_attempts
                            ) or 0
                        )
                    ) + 1

                if ui.setting_search.exact_scroll_attempts >= 3 then
                    ui.setting_search.exact_scroll_pending = false
                end
            end

            ui.setting_search.rendering_exact_target_section = false
            ui.setting_search.rendering_highlight_active = false
            ui.setting_search.rendering_highlight_consumed = false
            rendered_count = rendered_count + 1
        end
    end

    if ui.setting_search.should_add_temporary_padding(tab_key) then
        local current_y = ui.lobby.get_cursor_y()
        ui.lobby.set_cursor_y(
            current_y +
            ui.setting_search.get_temporary_scroll_padding()
        )
    end
end



