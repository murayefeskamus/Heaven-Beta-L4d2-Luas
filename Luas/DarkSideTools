    function ui.quotes.draw_players_content(
        players_override
    )
        local gui =
            ui.quotes.ui_state

        local players =
            type(players_override) == "table"
            and players_override
            or ui.quotes.get_shared_current_players()

        local detected =
            ui.quotes.get_detected_players(
                players
            )

        local detected_by_userid = {}

        for _,
            player in ipairs(
                detected
            ) do

            detected_by_userid[
                tonumber(
                    player.userid
                ) or 0
            ] = player
        end

        local any_detected =
            #detected > 0

        local palette =
            ui.enhancements.theme_palette()

        local header_r,
            header_g,
            header_b =
                ui.get_theme_table_header_color()

        local id_width = 52
        local player_width = 108
        local count_width = 96
        local quote_id_width = 76
        local quote_width = 0
        local action_width = 96

        for _,
            player in ipairs(
                players
            ) do

            local player_display_width =
                ui.lobby.measure_text_width(
                    tostring(
                        player.name or ""
                    )
                )

            if player.is_local == true then
                player_display_width =
                    player_display_width +
                    ui.lobby.measure_text_width(
                        "YOU"
                    ) + 20
            end

            player_width =
                math.max(
                    player_width,
                    player_display_width + 22
                )
        end

        player_width =
            math.min(
                170,
                player_width
            )

        local function get_selected_quote(
            record
        )
            local indices =
                record
                and record.quote_indices
                or {}

            local userid =
                tonumber(
                    record
                    and record.userid
                ) or 0

            local selection =
                math.floor(
                    tonumber(
                        gui.detected_quote_selections[
                            userid
                        ]
                    ) or 0
                )

            selection =
                math.max(
                    0,
                    math.min(
                        math.max(
                            0,
                            #indices - 1
                        ),
                        selection
                    )
                )

            gui.detected_quote_selections[
                userid
            ] = selection

            local quote_index =
                indices[
                    selection + 1
                ]

            local quote =
                quote_index
                and quotes[
                    quote_index
                ]
                or nil

            return selection,
                quote,
                indices
        end

        for _,
            record in ipairs(
                detected
            ) do

            local _,
                quote =
                    get_selected_quote(
                        record
                    )

            if quote then
                quote_width =
                    math.max(
                        quote_width,
                        math.min(
                            500,
                            ui.lobby.measure_text_width(
                                tostring(
                                    quote.text or ""
                                )
                            ) + 24
                        )
                    )
            end
        end

        local detected_fixed_width =
            id_width +
            player_width +
            count_width +
            quote_id_width +
            action_width +
            28

        if any_detected then
            quote_width =
                math.min(
                    math.max(
                        200,
                        quote_width
                    ),
                    math.max(
                        200,
                        800 -
                        detected_fixed_width
                    )
                )
        end

        local row_infos = {}
        local total_row_height = 0

        for _,
            player in ipairs(
                players
            ) do

            local userid =
                tonumber(
                    player.userid
                ) or 0

            local record =
                detected_by_userid[
                    userid
                ]

            local selection,
                quote,
                indices =
                    get_selected_quote(
                        record
                    )

            local has_detection =
                record ~= nil
                and tonumber(
                    record.quote_count
                ) ~= nil
                and tonumber(
                    record.quote_count
                ) > 0
                and quote ~= nil

            local quote_lines = {
                "-"
            }

            if has_detection then
                quote_lines =
                    ui.quotes.get_hard_wrapped_lines(
                        tostring(
                            quote.text or ""
                        ),
                        math.max(
                            80,
                            quote_width - 18
                        )
                    )
            end

            local row_height = 22

            if any_detected
                and has_detection then

                if #indices > 1 then


                    row_height = 26
                else
                    row_height =
                        math.max(
                            row_height,
                            #quote_lines * 18 + 6
                        )
                end
            end

            row_infos[
                #row_infos + 1
            ] = {
                player = player,
                userid = userid,
                record = record,
                count =
                    record
                    and tonumber(
                        record.quote_count
                    ) or 0,
                selection = selection,
                quote = quote,
                has_detection = has_detection,
                indices = indices,
                quote_lines = quote_lines,
                row_height = row_height
            }

            total_row_height =
                total_row_height +
                row_height
        end

        if #row_infos == 0 then
            total_row_height = 22
        end

        local table_width =
            id_width +
            player_width +
            count_width +
            14

        if any_detected then
            table_width =
                detected_fixed_width +
                quote_width
        end

        local table_height =
            25 +
            total_row_height

        local table_open =
            imgui.begin_child(
                "QuotesPlayersDetectionTable",
                table_width,
                table_height,
                false,
                0
            )

        if table_open then
            local start_x =
                ui.lobby.get_cursor_x()

            local id_divider_x =
                start_x +
                id_width

            local player_x =
                id_divider_x + 8

            local player_divider_x =
                id_divider_x +
                player_width

            local count_x =
                player_divider_x + 8

            local count_divider_x =
                player_divider_x +
                count_width

            local quote_id_x =
                count_divider_x + 8

            local quote_id_divider_x =
                count_divider_x +
                quote_id_width

            local quote_x =
                quote_id_divider_x + 8

            local quote_divider_x =
                quote_id_divider_x +
                quote_width

            local action_x =
                quote_divider_x + 8

            local function draw_pipe(
                x
            )
                imgui.same_line()

                ui.lobby.set_cursor_x(
                    x
                )

                theme_text_colored(
                    palette.text_disabled[1],
                    palette.text_disabled[2],
                    palette.text_disabled[3],
                    1.0,
                    "|"
                )
            end

            local function draw_centered(
                x,
                width,
                value,
                r,
                g,
                b,
                first_item
            )
                if not first_item then
                    imgui.same_line()
                end

                local text_value =
                    tostring(
                        value or ""
                    )

                local text_width =
                    ui.lobby.measure_text_width(
                        text_value
                    )

                ui.lobby.set_cursor_x(
                    x +
                    math.max(
                        4,
                        (
                            width -
                            text_width
                        ) / 2
                    )
                )

                theme_text_colored(
                    r, g, b, 1.0,
                    text_value
                )
            end


            local function draw_player_name_cell(
                x,
                width,
                player
            )
                imgui.same_line()

                local player_name =
                    tostring(
                        player
                        and player.name
                        or ""
                    )

                local show_you_badge =
                    player
                    and player.is_local == true

                local badge_width =
                    show_you_badge
                    and (
                        ui.lobby.measure_text_width(
                            "YOU"
                        ) + 14
                    )
                    or 0

                local total_width =
                    ui.lobby.measure_text_width(
                        player_name
                    ) +
                    (
                        show_you_badge
                        and (6 + badge_width)
                        or 0
                    )

                ui.lobby.set_cursor_x(
                    x +
                    math.max(
                        4,
                        (
                            width -
                            total_width
                        ) / 2
                    )
                )

                theme_text_colored(
                    palette.text[1],
                    palette.text[2],
                    palette.text[3],
                    1.0,
                    player_name
                )

                if show_you_badge then
                    imgui.same_line()

                    colored_button(
                        "YOU##QuotesYouBadge_" ..
                            tostring(
                                player.userid
                                or player.name
                                or "Local"
                            ),
                        0.0, 0.0, 0.0,
                        1.0, 1.0, 1.0
                    )
                end
            end

            draw_centered(
                start_x,
                id_width,
                "ID",
                header_r,
                header_g,
                header_b,
                true
            )

            draw_pipe(
                id_divider_x
            )

            draw_centered(
                player_x,
                player_width - 8,
                "PLAYER",
                header_r,
                header_g,
                header_b,
                false
            )

            draw_pipe(
                player_divider_x
            )

            draw_centered(
                count_x,
                count_width - 8,
                "DETECTED",
                header_r,
                header_g,
                header_b,
                false
            )

            if any_detected then
                draw_pipe(
                    count_divider_x
                )

                draw_centered(
                    quote_id_x,
                    quote_id_width - 8,
                    "QUOTE ID",
                    header_r,
                    header_g,
                    header_b,
                    false
                )

                draw_pipe(
                    quote_id_divider_x
                )

                draw_centered(
                    quote_x,
                    quote_width - 8,
                    "QUOTE",
                    header_r,
                    header_g,
                    header_b,
                    false
                )

                draw_pipe(
                    quote_divider_x
                )

                draw_centered(
                    action_x,
                    action_width - 8,
                    "ACTION",
                    header_r,
                    header_g,
                    header_b,
                    false
                )
            end

            imgui.separator()

            if #row_infos == 0 then
                theme_text_colored(
                    palette.text_disabled[1],
                    palette.text_disabled[2],
                    palette.text_disabled[3],
                    1.0,
                    "No human players."
                )

                imgui.separator()
            else
                for _,
                    row in ipairs(
                        row_infos
                    ) do

                    local player =
                        row.player

                    draw_centered(
                        start_x,
                        id_width,
                        row.userid,
                        palette.text[1],
                        palette.text[2],
                        palette.text[3],
                        true
                    )

                    draw_pipe(
                        id_divider_x
                    )

                    draw_player_name_cell(
                        player_x,
                        player_width - 8,
                        player
                    )

                    draw_pipe(
                        player_divider_x
                    )

                    local detected_quote_count =
                        tonumber(
                            row.count
                        ) or 0

                    local detected_quote_text =
                        detected_quote_count <= 0
                        and "No quotes"
                        or (
                            tostring(
                                detected_quote_count
                            ) ..
                            " " ..
                            (
                                detected_quote_count == 1
                                and "quote"
                                or "quotes"
                            )
                        )

                    draw_centered(
                        count_x,
                        count_width - 8,
                        detected_quote_text,
                        detected_quote_count > 0
                        and 0.25
                        or palette.text_disabled[1],
                        detected_quote_count > 0
                        and 1.0
                        or palette.text_disabled[2],
                        detected_quote_count > 0
                        and 0.35
                        or palette.text_disabled[3],
                        false
                    )

                    if any_detected then
                        draw_pipe(
                            count_divider_x
                        )

                        draw_centered(
                            quote_id_x,
                            quote_id_width - 8,
                            row.has_detection
                            and row.quote
                            and (
                                "#" ..
                                tostring(
                                    row.quote.line_number
                                )
                            )
                            or "-",
                            row.has_detection
                            and row.quote
                            and palette.text[1]
                            or palette.text_disabled[1],
                            row.has_detection
                            and row.quote
                            and palette.text[2]
                            or palette.text_disabled[2],
                            row.has_detection
                            and row.quote
                            and palette.text[3]
                            or palette.text_disabled[3],
                            false
                        )

                        draw_pipe(
                            quote_id_divider_x
                        )

                        imgui.same_line()

                        ui.lobby.set_cursor_x(
                            quote_x
                        )

                        local quote_cell_open =
                            imgui.begin_child(
                                "QuotesDetectedQuoteCell" ..
                                    tostring(
                                        row.userid
                                    ),
                                math.max(
                                    80,
                                    quote_width - 6
                                ),
                                row.row_height - 2,
                                false,
                                0
                            )

                        if quote_cell_open then
                            if row.has_detection
                                and row.quote then
                                if #row.indices > 1 then
                                    local options = {}

                                    for option_index,
                                        quote_index in ipairs(
                                            row.indices
                                        ) do

                                        local option_quote =
                                            quotes[
                                                quote_index
                                            ]

                                        options[
                                            option_index
                                        ] =
                                            option_quote
                                            and truncate_preview(
                                                tostring(
                                                    option_quote.text or ""
                                                ),
                                                42
                                            )
                                            or "Unavailable"
                                    end

                                    imgui.push_item_width(
                                        math.max(
                                            80,
                                            quote_width - 18
                                        )
                                    )

                                    local combo_colors =
                                        push_neutral_combo_colors()

                                    local changed_quote,
                                        selected_value =
                                            imgui.combo(
                                                "##DetectedQuote" ..
                                                tostring(
                                                    row.userid
                                                ),
                                                row.selection,
                                                options
                                            )

                                    pop_neutral_combo_colors(
                                        combo_colors
                                    )

                                    imgui.pop_item_width()

                                    if changed_quote then
                                        gui.detected_quote_selections[
                                            row.userid
                                        ] =
                                            selected_value
                                    end
                                else


                                    for _,
                                        line in ipairs(
                                            row.quote_lines
                                        ) do

                                        theme_text_colored(
                                            palette.text[1],
                                            palette.text[2],
                                            palette.text[3],
                                            1.0,
                                            line
                                        )
                                    end
                                end
                            else
                                theme_text_colored(
                                    palette.text_disabled[1],
                                    palette.text_disabled[2],
                                    palette.text_disabled[3],
                                    1.0,
                                    "-"
                                )
                            end
                        end

                        imgui.end_child()

                        draw_pipe(
                            quote_divider_x
                        )

                        if row.has_detection
                            and row.quote then

                            imgui.same_line()

                            local action_button_width =
                                ui.lobby.measure_text_width(
                                    "Post Quote"
                                ) + 18

                            ui.lobby.set_cursor_x(
                                action_x +
                                math.max(
                                    4,
                                    (
                                        action_width -
                                        8 -
                                        action_button_width
                                    ) / 2
                                )
                            )

                            if colored_button(
                                "Post Quote##Detected" ..
                                tostring(
                                    row.userid
                                ),
                                1.0, 1.0, 1.0,
                                0.08, 0.42, 0.12
                            ) then
                                local message =
                                    format_quote_message(
                                        row.quote
                                    )

                                if post_to_all_chat_immediately(
                                    message
                                ) then
                                    mark_quote_displayed(
                                        row.quote
                                    )

                                    remember_posted_quote(
                                        ui.quotes.get_local_userid(),
                                        row.quote
                                    )

                                    status.last_number =
                                        row.quote.line_number

                                    status.last_search =
                                        "#" ..
                                        tostring(
                                            row.quote.line_number
                                        )

                                    status.last_search_mode =
                                        "Detected player"

                                    status.last_search_matches =
                                        #row.indices

                                    status.last_requester =
                                        ui.quotes.get_local_userid()

                                    status.last_requester_name =
                                        get_player_name_from_userid(
                                            status.last_requester
                                        )

                                    status.message =
                                        "Search result posted"
                                else
                                    status.message =
                                        "Post failed"
                                end
                            end
                        end
                    end

                    imgui.separator()
                end
            end
        end

        imgui.end_child()
    end

    function ui.quotes.draw_commands_content()
        local palette =
            ui.enhancements.theme_palette()

        local header_r,
            header_g,
            header_b =
                ui.get_theme_table_header_color()

        local rows = {
            {
                scope = "Owner",
                command = "[" .. ui.control.get_key_name(settings.key) .. "]",
                description = "Posts a random quote"
            },
            {
                scope = "Owner",
                command = "!save <quote>",
                description = "Saves a new quote"
            },
            {
                scope = "Owner",
                command = "!delete #ID",
                description = "Deletes a quote"
            }
        }

        for _,
            public_row in ipairs(
                ui.quotes.get_public_help_rows()
            ) do

            table.insert(
                rows,
                {
                    scope = public_row.scope,
                    command = public_row.command,
                    description = public_row.description
                }
            )
        end

        local scope_width =
            ui.lobby.measure_text_width(
                "Everyone"
            ) + 24

        local command_width = 150
        local description_width = 150

        for _,
            row in ipairs(
                rows
            ) do

            command_width =
                math.max(
                    command_width,
                    ui.lobby.measure_text_width(
                        row.command
                    ) + 24
                )

            description_width =
                math.max(
                    description_width,
                    ui.lobby.measure_text_width(
                        row.description
                    ) + 24
                )
        end

        local table_width =
            scope_width +
            command_width +
            description_width +
            14


        local table_height =
            22 +
            #rows * 20

        local table_open =
            imgui.begin_child(
                "QuotesCommandsInfoTable",
                table_width,
                table_height,
                false,
                0
            )

        if table_open then
            local start_x =
                ui.lobby.get_cursor_x()

            local scope_divider_x =
                start_x +
                scope_width

            local command_x =
                scope_divider_x + 8

            local command_divider_x =
                scope_divider_x +
                command_width

            local description_x =
                command_divider_x + 8

            local function draw_pipe(
                x
            )
                imgui.same_line()

                ui.lobby.set_cursor_x(
                    x
                )

                theme_text_colored(
                    palette.text_disabled[1],
                    palette.text_disabled[2],
                    palette.text_disabled[3],
                    1.0,
                    "|"
                )
            end

            local function draw_cell(
                x,
                value,
                r,
                g,
                b,
                first_item
            )
                if not first_item then
                    imgui.same_line()
                end

                ui.lobby.set_cursor_x(
                    x + 6
                )

                theme_text_colored(
                    r, g, b, 1.0,
                    tostring(
                        value or ""
                    )
                )
            end

            draw_cell(
                start_x,
                "ACCESS",
                header_r,
                header_g,
                header_b,
                true
            )

            draw_pipe(
                scope_divider_x
            )

            draw_cell(
                command_x,
                "COMMAND",
                header_r,
                header_g,
                header_b,
                false
            )

            draw_pipe(
                command_divider_x
            )

            draw_cell(
                description_x,
                "DESCRIPTION",
                header_r,
                header_g,
                header_b,
                false
            )

            imgui.separator()

            for _,
                row in ipairs(
                    rows
                ) do

                draw_cell(
                    start_x,
                    row.scope,
                    palette.text_disabled[1],
                    palette.text_disabled[2],
                    palette.text_disabled[3],
                    true
                )

                draw_pipe(
                    scope_divider_x
                )

                draw_cell(
                    command_x,
                    row.command,
                    palette.text[1],
                    palette.text[2],
                    palette.text[3],
                    false
                )

                draw_pipe(
                    command_divider_x
                )

                draw_cell(
                    description_x,
                    row.description,
                    palette.text[1],
                    palette.text[2],
                    palette.text[3],
                    false
                )

                imgui.separator()
            end
        end

        imgui.end_child()
        ui.lobby.compact_after_child(4)

        if colored_button(
            "Print Info in All Chat",
            1.0, 1.0, 1.0,
            0.10, 0.38, 0.70
        ) then
            ui.quotes.print_help_in_chat()
        end
    end

