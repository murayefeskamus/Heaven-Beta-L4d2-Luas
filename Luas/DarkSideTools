function spammer_cfg.get_duration_timing_state()
    local delay =
        math.max(
            0.1,
            tonumber(
                spammer_cfg.delay
            ) or 1.0
        )

    if not spammer_cfg.enabled
        or spammer_runtime.was_ready ~= true then


        return 0.0, 0.0, delay
    end

    local elapsed_run =
        math.max(
            0.0,
            tonumber(
                spammer_runtime.run_elapsed_seconds
            ) or 0.0
        )

    local interval_progress =
        math.max(
            0.0,
            math.min(
                delay,
                tonumber(
                    spammer_runtime.elapsed
                ) or 0.0
            )
        )

    local time_until_next_request =
        math.max(
            0.0,
            delay -
            interval_progress
        )

    return elapsed_run,
        time_until_next_request,
        delay
end

function spammer_cfg.get_duration_limit_minimum()
    local minimum =
        math.max(
            1,
            math.floor(
                tonumber(
                    DARKSIDE_CONFIG.NAME_SPAMMER_MIN_DURATION_SECONDS
                ) or 5
            )
        )

    if spammer_cfg.enabled then
        minimum =
            math.max(
                minimum,
                math.ceil(
                    math.max(
                        0.0,
                        tonumber(
                            spammer_runtime.run_elapsed_seconds
                        ) or 0.0
                    )
                )
            )
    end

    return minimum
end

function spammer_cfg.get_duration_limit_maximum()
    local total_budget,
        remaining_requests =
            spammer_cfg.get_duration_budget_state()

    local minimum =
        spammer_cfg.get_duration_limit_minimum()

    if total_budget <= 0 then
        return minimum
    end

    local elapsed_run,
        time_until_next_request,
        delay =
            spammer_cfg.get_duration_timing_state()


    local safe_total_seconds =
        elapsed_run +
        time_until_next_request +
        remaining_requests *
        delay

    local safe_seconds =
        math.floor(
            safe_total_seconds +
            0.000001
        )

    return math.max(
        minimum,
        math.min(
            DARKSIDE_CONFIG.NAME_SPAMMER_MAX_DURATION_SECONDS,
            safe_seconds
        )
    )
end

function spammer_cfg.get_duration_projected_changes(
    duration_seconds
)
    local duration =
        math.max(
            0.0,
            tonumber(duration_seconds) or 0.0
        )

    local elapsed_run,
        time_until_next_request,
        delay =
            spammer_cfg.get_duration_timing_state()

    local used_requests = 0

    if spammer_cfg.enabled then
        used_requests =
            spammer_cfg.get_run_request_count()
    end

    local remaining_time =
        duration -
        elapsed_run

    if remaining_time <=
        time_until_next_request +
        0.000001 then

        return used_requests
    end

    local active_window =
        remaining_time -
        time_until_next_request


    local future_requests =
        math.max(
            0,
            math.ceil(
                active_window /
                delay -
                0.000001
            )
        )

    return used_requests +
        future_requests
end

function spammer_cfg.get_request_cycle_breakdown(
    requests
)
    requests =
        math.max(
            0,
            math.floor(
                tonumber(requests) or 0
            )
        )

    local cycle_size =
        spammer_cfg.get_automation_cycle_size()

    if cycle_size <= 0 then
        return 0, requests
    end

    return math.floor(
        requests /
        cycle_size
    ),
        requests %
        cycle_size
end

function spammer_cfg.get_spam_delay_hint()
    local stats =
        spammer_cfg.get_name_field_stats()

    local cycle_size =
        spammer_cfg.get_automation_cycle_size()

    local delay =
        math.max(
            0.1,
            tonumber(
                spammer_cfg.delay
            ) or 1.0
        )

    if cycle_size <= 0 then
        return string.format(
            "Horizontal: %d fields, %d active | Vertical: %d fields, %d active | No active names for this order.",
            stats.added_horizontal,
            stats.active_horizontal,
            stats.added_vertical,
            stats.active_vertical
        )
    end

    return string.format(
        "Horizontal: %d fields, %d active | Vertical: %d fields, %d active | Selected cycle: %d name%s in %.2fs (%.1f changes/s).",
        stats.added_horizontal,
        stats.active_horizontal,
        stats.added_vertical,
        stats.active_vertical,
        cycle_size,
        cycle_size == 1 and "" or "s",
        cycle_size * delay,
        1.0 / delay
    )
end

function spammer_cfg.get_server_rate_limit_hint(
    mode
)
    mode =
        math.floor(
            tonumber(mode) or
            spammer_cfg.normalize_cycle_limit_settings()
        )

    local cycle_size =
        spammer_cfg.get_automation_cycle_size()

    if cycle_size <= 0 then
        return "Enable at least one filled name field used by the selected spam order."
    end

    local restore_reserve =
        spammer_cfg.get_restore_request_reserve()

    local reserve_text =
        restore_reserve > 0
        and " | 1 request reserved for restore."
        or ""

    if mode == 1 then
        local selected_cycles =
            spammer_cfg.cycle_limit_cycles

        local maximum_cycles =
            spammer_cfg.get_cycle_limit_maximum()

        return string.format(
            "Selected: %d cycle%s (%d changes) | Safe max: %d cycle%s (%d changes).%s",
            selected_cycles,
            selected_cycles == 1 and "" or "s",
            spammer_cfg.get_cycle_projected_changes(
                selected_cycles
            ),
            maximum_cycles,
            maximum_cycles == 1 and "" or "s",
            spammer_cfg.get_cycle_projected_changes(
                maximum_cycles
            ),
            reserve_text
        )
    elseif mode == 2 then
        local selected_changes =
            spammer_cfg.cycle_limit_changes

        local maximum_changes =
            spammer_cfg.get_change_limit_maximum()

        local full_cycles,
            partial_names =
                spammer_cfg.get_request_cycle_breakdown(
                    selected_changes
                )

        local cycle_text = ""

        if full_cycles > 0 then
            cycle_text =
                string.format(
                    " | About %d full cycle%s%s",
                    full_cycles,
                    full_cycles == 1 and "" or "s",
                    partial_names > 0
                    and (
                        " + " ..
                        tostring(partial_names) ..
                        " name" ..
                        (partial_names == 1 and "" or "s")
                    )
                    or ""
                )
        end

        return string.format(
            "Selected: %d confirmed change%s%s | Safe max: %d. Retries use the same budget.%s",
            selected_changes,
            selected_changes == 1 and "" or "s",
            cycle_text,
            maximum_changes,
            reserve_text
        )
    elseif mode == 3 then
        local maximum_seconds =
            spammer_cfg.get_duration_limit_maximum()

        local selected_requests =
            spammer_cfg.get_duration_projected_changes(
                spammer_cfg.cycle_limit_duration_seconds
            )

        local maximum_requests =
            spammer_cfg.get_duration_projected_changes(
                maximum_seconds
            )

        local _,
            remaining_requests,
            used_requests =
                spammer_cfg.get_duration_budget_state()

        local running_text = ""

        if spammer_cfg.enabled then
            running_text =
                string.format(
                    " | Used: %d, left: %d.",
                    used_requests,
                    remaining_requests
                )
        end

        return string.format(
            "Selected: %s (up to %d requests) | Safe max: %s (%d requests).%s%s",
            spammer_runtime.format_cycle_limit_duration(
                spammer_cfg.cycle_limit_duration_seconds
            ),
            selected_requests,
            spammer_runtime.format_cycle_limit_duration(
                maximum_seconds
            ),
            maximum_requests,
            reserve_text,
            running_text
        )
    end

    return string.format(
        "Safety stop: %d requests. Retries count toward the cap.",
        spammer_cfg.get_server_rate_limit()
    )
end

function spammer_cfg.normalize_cycle_limit_settings()
    if type(
        spammer_cfg.cycle_limit_modes
    ) ~= "table"
        or #spammer_cfg.cycle_limit_modes ~= 4 then

        spammer_cfg.cycle_limit_modes = {
            "Unlimited",
            "Complete cycles",
            "Name changes",
            "Duration"
        }
    end

    spammer_cfg.cycle_limit_mode =
        math.max(
            0,
            math.min(
                #spammer_cfg.cycle_limit_modes - 1,
                math.floor(
                    tonumber(
                        spammer_cfg.cycle_limit_mode
                    ) or 0
                )
            )
        )

    spammer_cfg.restore_initial_on_limit =
        spammer_cfg.restore_initial_on_limit ~= false


    local cycle_minimum = 1

    local cycle_maximum =
        math.max(
            cycle_minimum,
            spammer_cfg.get_cycle_limit_maximum()
        )

    spammer_cfg.cycle_limit_cycles =
        math.max(
            cycle_minimum,
            math.min(
                cycle_maximum,
                math.floor(
                    tonumber(
                        spammer_cfg.cycle_limit_cycles
                    ) or cycle_minimum
                )
            )
        )

    local change_minimum = 1

    local change_maximum =
        math.max(
            change_minimum,
            spammer_cfg.get_change_limit_maximum()
        )

    spammer_cfg.cycle_limit_changes =
        math.max(
            change_minimum,
            math.min(
                change_maximum,
                math.floor(
                    tonumber(
                        spammer_cfg.cycle_limit_changes
                    ) or 10
                )
            )
        )

    local duration_minimum =
        math.max(
            1,
            math.floor(
                tonumber(
                    DARKSIDE_CONFIG.NAME_SPAMMER_MIN_DURATION_SECONDS
                ) or 5
            )
        )

    local duration_maximum =
        math.max(
            duration_minimum,
            spammer_cfg.get_duration_limit_maximum()
        )

    spammer_cfg.cycle_limit_duration_seconds =
        math.max(
            duration_minimum,
            math.min(
                duration_maximum,
                math.floor(
                    tonumber(
                        spammer_cfg.cycle_limit_duration_seconds
                    ) or 60
                )
            )
        )

    return spammer_cfg.cycle_limit_mode
end

function spammer_cfg.recalculate_smart_limits(
    cycle_structure_changed
)
    if cycle_structure_changed == true then
        if type(
            spammer_runtime.reset_automation_cycle
        ) == "function" then

            spammer_runtime.reset_automation_cycle()
        end

        if spammer_cfg.enabled then

            spammer_runtime.pending_message = nil
            spammer_runtime.pending_label = "None"
            spammer_runtime.pending_attempts = 0
            spammer_runtime.rate_limited = false
            spammer_runtime.elapsed =
                math.max(
                    0.1,
                    tonumber(
                        spammer_cfg.delay
                    ) or 1.0
                )

            if spammer_cfg.cycle_limit_mode == 1 then


                spammer_runtime.run_completed_cycles = 0
            end
        end
    end

    return spammer_cfg.normalize_cycle_limit_settings()
end

function spammer_runtime.reset_cycle_limit_progress()
    spammer_runtime.run_confirmed_changes = 0
    spammer_runtime.run_command_attempts = 0
    spammer_runtime.run_completed_cycles = 0
    spammer_runtime.run_elapsed_seconds = 0.0
    spammer_runtime.run_limit_reached = false
    spammer_runtime.run_limit_reason = ""
    spammer_runtime.run_limit_restored = false
end

function spammer_runtime.format_cycle_limit_duration(
    seconds
)
    seconds =
        math.max(
            0,
            math.floor(
                tonumber(seconds) or 0
            )
        )

    local hours =
        math.floor(
            seconds / 3600
        )

    local minutes =
        math.floor(
            (
                seconds % 3600
            ) / 60
        )

    local remaining_seconds =
        seconds % 60

    if hours > 0 then
        return string.format(
            "%dh %02dm %02ds",
            hours,
            minutes,
            remaining_seconds
        )
    elseif minutes > 0 then
        return string.format(
            "%dm %02ds",
            minutes,
            remaining_seconds
        )
    end

    return string.format(
        "%ds",
        remaining_seconds
    )
end

function spammer_runtime.get_cycle_limit_progress_text()
    local mode =
        spammer_cfg.normalize_cycle_limit_settings()

    local requests =
        spammer_cfg.get_run_request_count()

    local finite_request_limit =
        spammer_cfg.get_automation_request_limit()

    if mode == 1
        or mode == 3 then

        finite_request_limit =
            spammer_cfg.get_mode_safe_change_budget()
    end

    if mode == 1 then
        return string.format(
            "%d / %d complete cycles | %d / %d safe requests",
            math.max(
                0,
                math.floor(
                    tonumber(
                        spammer_runtime.run_completed_cycles
                    ) or 0
                )
            ),
            spammer_cfg.cycle_limit_cycles,
            requests,
            finite_request_limit
        )
    elseif mode == 2 then
        return string.format(
            "%d / %d confirmed changes | %d / %d safe requests",
            math.max(
                0,
                math.floor(
                    tonumber(
                        spammer_runtime.run_confirmed_changes
                    ) or 0
                )
            ),
            spammer_cfg.cycle_limit_changes,
            requests,
            finite_request_limit
        )
    elseif mode == 3 then
        local duration_budget =
            spammer_cfg.get_mode_safe_change_budget()

        return (
            spammer_runtime.format_cycle_limit_duration(
                spammer_runtime.run_elapsed_seconds
            ) ..
            " / " ..
            spammer_runtime.format_cycle_limit_duration(
                spammer_cfg.cycle_limit_duration_seconds
            ) ..
            string.format(
                " | %d / %d safe requests",
                requests,
                duration_budget
            )
        )
    end

    return string.format(
        "Unlimited - %d / %d server-safe requests",
        requests,
        spammer_cfg.get_server_rate_limit()
    )
end

function spammer_runtime.get_cycle_limit_reached_reason()
    local mode =
        spammer_cfg.normalize_cycle_limit_settings()

    if mode == 1
        and spammer_runtime.run_completed_cycles >=
            spammer_cfg.cycle_limit_cycles then

        return string.format(
            "%d complete cycle%s",
            spammer_cfg.cycle_limit_cycles,
            spammer_cfg.cycle_limit_cycles == 1
            and ""
            or "s"
        )
    elseif mode == 2
        and spammer_runtime.run_confirmed_changes >=
            spammer_cfg.cycle_limit_changes then

        return string.format(
            "%d confirmed name change%s",
            spammer_cfg.cycle_limit_changes,
            spammer_cfg.cycle_limit_changes == 1
            and ""
            or "s"
        )
    elseif mode == 3
        and spammer_runtime.run_elapsed_seconds >=
            spammer_cfg.cycle_limit_duration_seconds then

        return (
            spammer_runtime.format_cycle_limit_duration(
                spammer_cfg.cycle_limit_duration_seconds
            ) ..
            " duration"
        )
    end

    local request_limit =
        spammer_cfg.get_server_rate_limit()

    if mode ~= 0 then
        request_limit =
            spammer_cfg.get_automation_request_limit()
    end

    if mode == 1
        or mode == 3 then

        local cycle_aligned_budget =
            spammer_cfg.get_mode_safe_change_budget()

        if cycle_aligned_budget > 0 then
            request_limit =
                math.min(
                    request_limit,
                    cycle_aligned_budget
                )
        end
    end


    if spammer_cfg.get_run_request_count() >=
        request_limit then

        return string.format(
            "Server rate-limit safety budget (%d automatic requests)",
            request_limit
        )
    end


    if spammer_runtime.run_confirmed_changes >=
        spammer_cfg.get_server_rate_limit() then

        return string.format(
            "Server rate-limit safety cap (%d confirmed name changes)",
            spammer_cfg.get_server_rate_limit()
        )
    end

    return nil
end

function spammer_cfg.get_selected_name_indices_for_layout(
    vertical,
    nonempty_only
)
    local indices = {}

    spammer_cfg.ensure_name_enabled_states()
    spammer_cfg.ensure_name_vertical_modes()

    for index = 1,
        get_spammer_name_count() do

        if spammer_cfg.is_name_enabled(
            index
        )
            and spammer_cfg.is_name_vertical(
                index
            ) == (vertical == true)
            and (
                nonempty_only ~= true
                or not spammer_cfg.is_name_field_empty(
                    index
                )
            ) then

            table.insert(
                indices,
                index
            )
        end
    end

    return indices
end

function spammer_cfg.append_automation_indices(
    target,
    source
)
    for _, index in ipairs(
        source
    ) do
        table.insert(
            target,
            index
        )
    end
end

function spammer_cfg.append_alternating_automation_indices(
    target,
    first_group,
    second_group
)
    local longest =
        math.max(
            #first_group,
            #second_group
        )

    for position = 1,
        longest do

        if first_group[position] ~= nil then
            table.insert(
                target,
                first_group[position]
            )
        end

        if second_group[position] ~= nil then
            table.insert(
                target,
                second_group[position]
            )
        end
    end
end

function spammer_cfg.get_automation_candidate_indices(
    nonempty_only
)
    local mode =
        spammer_cfg.normalize_automation_order_mode()

    local horizontal =
        spammer_cfg.get_selected_name_indices_for_layout(
            false,
            nonempty_only
        )

    local vertical =
        spammer_cfg.get_selected_name_indices_for_layout(
            true,
            nonempty_only
        )

    if mode == 0 then
        return horizontal
    elseif mode == 1 then
        return vertical
    end

    local combined = {}

    spammer_cfg.append_automation_indices(
        combined,
        horizontal
    )

    spammer_cfg.append_automation_indices(
        combined,
        vertical
    )

    return combined
end

function spammer_cfg.build_automation_cycle()
    local mode =
        spammer_cfg.normalize_automation_order_mode()

    local horizontal =
        spammer_cfg.get_selected_name_indices_for_layout(
            false,
            true
        )

    local vertical =
        spammer_cfg.get_selected_name_indices_for_layout(
            true,
            true
        )

    local cycle = {}

    if mode == 0 then
        spammer_cfg.append_automation_indices(
            cycle,
            horizontal
        )
    elseif mode == 1 then
        spammer_cfg.append_automation_indices(
            cycle,
            vertical
        )
    elseif mode == 2 then
        spammer_cfg.append_automation_indices(
            cycle,
            horizontal
        )

        spammer_cfg.append_automation_indices(
            cycle,
            vertical
        )
    elseif mode == 3 then
        spammer_cfg.append_automation_indices(
            cycle,
            vertical
        )

        spammer_cfg.append_automation_indices(
            cycle,
            horizontal
        )
    elseif mode == 4 then
        spammer_cfg.append_alternating_automation_indices(
            cycle,
            horizontal,
            vertical
        )
    elseif mode == 5 then
        spammer_cfg.append_alternating_automation_indices(
            cycle,
            vertical,
            horizontal
        )
    else
        spammer_cfg.append_automation_indices(
            cycle,
            horizontal
        )

        spammer_cfg.append_automation_indices(
            cycle,
            vertical
        )

        for index = #cycle,
            2,
            -1 do

            local swap_index =
                math.random(
                    1,
                    index
                )

            cycle[index],
                cycle[swap_index] =
                    cycle[swap_index],
                    cycle[index]
        end

        if #cycle > 1
            and cycle[1] ==
                spammer_runtime.last_automation_index then

            cycle[1],
                cycle[2] =
                    cycle[2],
                    cycle[1]
        end
    end

    return cycle
end

function spammer_cfg.get_automation_cycle_signature()
    local parts = {
        tostring(
            spammer_cfg.normalize_automation_order_mode()
        )
    }

    for _, index in ipairs(
        spammer_cfg.get_enabled_nonempty_name_indices()
    ) do
        table.insert(
            parts,
            tostring(index) ..
            ":" ..
            (
                spammer_cfg.is_name_vertical(
                    index
                )
                and "V"
                or "H"
            )
        )
    end

    return table.concat(
        parts,
        "|"
    )
end

function spammer_runtime.reset_automation_cycle()
    spammer_runtime.automation_cycle = {}
    spammer_runtime.automation_cycle_position = 1
    spammer_runtime.automation_cycle_signature = ""
    spammer_runtime.next_name_index = 1
end

function spammer_runtime.rebuild_automation_cycle()
    spammer_runtime.automation_cycle =
        spammer_cfg.build_automation_cycle()

    spammer_runtime.automation_cycle_position = 1
    spammer_runtime.automation_cycle_signature =
        spammer_cfg.get_automation_cycle_signature()

    spammer_runtime.next_name_index =
        spammer_runtime.automation_cycle[1]
        or 1

    return spammer_runtime.automation_cycle
end

function spammer_runtime.ensure_automation_cycle()
    local signature =
        spammer_cfg.get_automation_cycle_signature()

    local cycle =
        spammer_runtime.automation_cycle

    local position =
        math.floor(
            tonumber(
                spammer_runtime.automation_cycle_position
            ) or 1
        )

    if type(cycle) ~= "table"
        or #cycle <= 0
        or signature ~=
            spammer_runtime.automation_cycle_signature
        or position < 1
        or position > #cycle then

        cycle =
            spammer_runtime.rebuild_automation_cycle()
    end

    return cycle
end

function spammer_runtime.get_next_automation_name_index()
    local cycle =
        spammer_runtime.ensure_automation_cycle()

    local position =
        math.floor(
            tonumber(
                spammer_runtime.automation_cycle_position
            ) or 1
        )

    local target_index =
        cycle[position]

    spammer_runtime.next_name_index =
        target_index or 1

    return target_index
end

function spammer_runtime.advance_automation_cycle()
    local cycle =
        spammer_runtime.ensure_automation_cycle()

    if #cycle <= 0 then
        spammer_runtime.next_name_index = 1
        return nil, false
    end

    local position =
        math.floor(
            tonumber(
                spammer_runtime.automation_cycle_position
            ) or 1
        )

    local current_index =
        cycle[position]

    if current_index ~= nil then
        spammer_runtime.last_automation_index =
            current_index
    end

    position = position + 1

    local completed_cycle = false

    if position > #cycle then
        completed_cycle = true

        cycle =
            spammer_runtime.rebuild_automation_cycle()

        position = 1
    else
        spammer_runtime.automation_cycle_position =
            position
    end

    local next_index =
        cycle[position]

    spammer_runtime.next_name_index =
        next_index or 1

    return next_index,
        completed_cycle
end

function spammer_cfg.find_next_enabled_name_index(
    start_index
)
    local enabled_indices =
        spammer_cfg.get_enabled_nonempty_name_indices()

    if #enabled_indices <= 0 then
        return nil
    end

    start_index =
        math.max(
            1,
            math.floor(
                tonumber(start_index) or 1
            )
        )

    for _, configured_index in ipairs(
        enabled_indices
    ) do
        if configured_index >= start_index then
            return configured_index
        end
    end

    return enabled_indices[1]
end

function spammer_cfg.ensure_name_vertical_modes()
    if type(
        spammer_cfg.name_vertical_modes
    ) ~= "table" then

        spammer_cfg.name_vertical_modes = {}
    end

    if type(
        spammer_cfg.removed_name_vertical_modes
    ) ~= "table" then

        spammer_cfg.removed_name_vertical_modes = {}
    end

    local name_count =
        get_spammer_name_count()

    for index = 1,
        name_count do

        if spammer_cfg.name_vertical_modes[
            index
        ] == nil then

            spammer_cfg.name_vertical_modes[
                index
            ] = true
        else
            spammer_cfg.name_vertical_modes[
                index
            ] =
                spammer_cfg.name_vertical_modes[
                    index
                ] == true
        end
    end

    for index =
        #spammer_cfg.name_vertical_modes,
        name_count + 1,
        -1 do

        table.remove(
            spammer_cfg.name_vertical_modes,
            index
        )
    end
end

function spammer_cfg.is_name_vertical(index)
    spammer_cfg.ensure_name_vertical_modes()

    index =
        math.max(
            1,
            math.floor(
                tonumber(index) or 1
            )
        )

    return spammer_cfg.name_vertical_modes[
        index
    ] ~= false
end

function spammer_cfg.set_name_vertical(
    index,
    vertical
)
    spammer_cfg.ensure_name_vertical_modes()

    index =
        math.max(
            1,
            math.floor(
                tonumber(index) or 1
            )
        )

    if index > get_spammer_name_count() then
        return false
    end

    spammer_cfg.name_vertical_modes[
        index
    ] = vertical == true

    return true
end

function spammer_cfg.get_name_indices_for_layout(
    vertical
)
    spammer_cfg.ensure_name_vertical_modes()

    local name_count =
        get_spammer_name_count()

    local signature_parts = {
        vertical == true
        and "V"
        or "H",
        tostring(name_count)
    }

    for index = 1, name_count do
        signature_parts[#signature_parts + 1] =
            spammer_cfg.name_vertical_modes[index] ~= false
            and "1"
            or "0"
    end

    local signature =
        table.concat(
            signature_parts,
            ""
        )

    return ui.performance.memoize_values(
        "spammer_layout_indices",
        signature,
        function()
            local indices = {}

            for index = 1, name_count do
                local index_is_vertical =
                    spammer_cfg.name_vertical_modes[index] ~= false

                if index_is_vertical ==
                    (vertical == true) then

                    indices[#indices + 1] =
                        index
                end
            end

            return indices
        end,
        64
    )
end

function spammer_cfg.get_layout_position_for_name_index(
    configured_index,
    vertical
)
    configured_index =
        math.max(
            1,
            math.floor(
                tonumber(configured_index) or 1
            )
        )

    if vertical == nil then
        vertical =
            spammer_cfg.is_name_vertical(
                configured_index
            )
    else
        vertical = vertical == true
    end

    for layout_position, index in ipairs(
        spammer_cfg.get_name_indices_for_layout(
            vertical
        )
    ) do
        if index == configured_index then
            return layout_position
        end
    end

    return configured_index
end

function spammer_cfg.get_layout_field_label(
    configured_index,
