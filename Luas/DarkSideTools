    ui.draw_theme_accent_text(
        "NEXT CLASS PREDICTION"
    )

    local columns = {
        { offset = 0,   width = 132, label = "PLAYER" },
        { offset = 132, width = 76,  label = "STATE" },
        { offset = 208, width = 118, label = "CLASS" },
        { offset = 326, width = 98,  label = "CONFIDENCE" },
        { offset = 424, width = 62,  label = "RESULT" }
    }

    local table_width = 486
    local rows = prediction.rows or {}
    local visible_rows = math.max(1, #rows)
    local table_height =
        math.max(
            66,
            30 + (visible_rows * 22)
        )

    local table_open =
        imgui.begin_child(
            "NextClassPredictionTable",
            table_width + 8,
            table_height,
            false,
            0
        )

    if table_open then
        local start_x =
            ui.lobby.get_cursor_x()

