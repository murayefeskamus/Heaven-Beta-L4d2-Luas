    ["ghost"] = true
}

function normalize_candidate_name_for_filter(name)
    local normalized =
        sanitize_name(
            name
        )


    normalized =
        normalized:gsub(
            "[%z\1-\31\127]",
            ""
        )

    local invisible_sequences = {
        "\226\128\139",
        "\226\128\140",
        "\226\128\141",
        "\226\128\142",
        "\226\128\143",
        "\239\187\191"
    }

    for _, sequence in ipairs(
        invisible_sequences
    ) do
        normalized =
            normalized:gsub(
                sequence,
                ""
            )
    end

    normalized =
        normalized:gsub(
            DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR,
            ""
        )

    normalized =
        normalized:lower()


    local previous_value = nil

    repeat
        previous_value = normalized

        normalized =
            normalized:gsub(
                "^%s*%[bot%]%s*",
                ""
            )

        normalized =
            normalized:gsub(
                "^%s*%(bot%)%s*",
                ""
            )

        normalized =
            normalized:gsub(
                "^%s*bot%s*[:%-|]%s*",
                ""
            )
    until normalized == previous_value

    normalized =
        normalized:gsub(
            "^%s+",
            ""
        ):gsub(
            "%s+$",
            ""
        )

    return normalized
end

function name_stealer.is_protected_saved_name(
    name
)
    local normalized =
        normalize_candidate_name_for_filter(
            name
        )

    return PROTECTED_SAVED_NAMES[
        normalized
    ] == true
end

function name_stealer.get_excluded_bot_name_key(
    name
)
    local normalized =
        normalize_candidate_name_for_filter(
            name
        )


    normalized =
        normalized:gsub(
            "[^%a%d]",
            ""
        )

    return normalized
end

function is_excluded_bot_name(name)
    local bot_name_key =
        name_stealer.get_excluded_bot_name_key(
            name
        )

    if bot_name_key == "" then
        return false
    end


    for excluded_name in pairs(
        EXCLUDED_BOT_NAMES
    ) do
        if #bot_name_key >= #excluded_name
            and bot_name_key:sub(
                -#excluded_name
            ) == excluded_name then

            return true
        end
    end

    return false
end

function is_excluded_survivor_bot_name(name)
    local bot_name_key =
        name_stealer.get_excluded_bot_name_key(
