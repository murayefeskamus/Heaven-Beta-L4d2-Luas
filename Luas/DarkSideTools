        imgui.separator()
        return
    end

    local labels = {}
    for _, result in ipairs(ui.setting_search.matches) do
        labels[#labels + 1] = tostring(result.display)
    end

    local result_label_width =
        ui.lobby.measure_text_width("Search result:") + 8
    local combo_width = 430
