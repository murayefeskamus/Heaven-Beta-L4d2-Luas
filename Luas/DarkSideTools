    if event_lower == "vote_cast_yes" then
        return "YES"
    elseif event_lower == "vote_cast_no" then
        return "NO"
    end

    local option = 0
    local option_ok,
        option_value =
            pcall(
                function()
                    return event:get_int(
                        "vote_option"
                    )
                end
            )

    if option_ok then
        option =
            math.floor(
                tonumber(option_value) or 0
            )
    end

    if option == 0 then
        return "YES"
    elseif option == 1 then
        return "NO"
    end

    return "OPTION " ..
        tostring(option)
end

