    if event_lower == "vote_started" then
        return "Vote started - " ..
            chat_spammer.vote_action_label(
                session
            )
    elseif event_lower == "vote_passed" then
        return "Vote passed - " ..
            chat_spammer.vote_outcome_action(
                session,
                event_lower
            )
    elseif event_lower == "vote_failed"
        or event_lower == "callvote_failed" then

        return "Vote failed - " ..
            chat_spammer.vote_outcome_action(
                session,
                event_lower
            )
    elseif event_lower == "vote_ended" then
        return "Vote ended - " ..
            chat_spammer.vote_action_label(
                session
            )
    end

    return tostring(
        fallback_message or "Vote updated"
    )
end

function chat_spammer.normalize_vote_issue_key(
    issue
)
    return tostring(issue or "")
        :lower()
        :gsub("[^%w]", "")
end

function chat_spammer.infer_vote_scope(
    issue,
    event,
    caller_team
)
    local compact_issue =
        chat_spammer.normalize_vote_issue_key(
            issue
        )


    local lobby_tokens = {
        "changealltalk",
        "alltalk",
        "changemission",
        "changecampaign",
        "changechapter",
        "changemap",
        "changelevel",
        "newmap",
        "returntolobby"
    }

    for _, token in ipairs(
        lobby_tokens
    ) do
        if compact_issue:find(
            token,
            1,
            true
        ) then
            return "lobby",
                0,
                "recognized lobby-wide vote"
        end
    end

    local team_tokens = {
        "kick",
        "votekick",
        "removeplayer"
    }

    for _, token in ipairs(
        team_tokens
    ) do
        if compact_issue:find(
            token,
            1,
            true
        ) then
            return "team",
                math.floor(
                    tonumber(caller_team) or 0
                ),
                "recognized team vote"
        end
    end

    local explicit_team =
        chat_spammer.get_event_int_any(
            event,
            {
                "team",
                "teamid",
                "team_num",
                "teamnum",
                "team_index"
            }
        )

    if explicit_team > 1 then
        return "team",
            explicit_team,
            "event team field"
    end

    caller_team =
        math.floor(
            tonumber(caller_team) or 0
        )

    if caller_team > 1 then
        return "team",
            caller_team,
            "caller team fallback"
    end

    return "unknown",
        0,
        "insufficient team data"
end

function chat_spammer.vote_scope_label(
    session
)
    session =
        type(session) == "table"
        and session
        or chat_spammer.vote_session

    if session.scope == "lobby" then
        return "Lobby-wide"
    elseif session.scope == "team" then
        local team_class =
            chat_spammer.classify_team_number(
                session.scope_team
            )

        if team_class == "my_team" then
            return "My team"
        elseif team_class == "enemy_team" then
            return "Enemy team"
        end

        return "Team vote"
    end

    return "Unresolved"
end

function chat_spammer.get_vote_expected_count(
    session
)
    session =
        type(session) == "table"
        and session
        or chat_spammer.vote_session

    local expected = 0

    for _, record in ipairs(
        ui.lobby.players or {}
    ) do
        local team_number =
            math.floor(
                tonumber(record.team) or 0
            )

        if record.connected ~= false
            and record.is_bot ~= true
            and team_number > 1 then

            if session.scope == "lobby"
                or (
                    session.scope == "team"
                    and team_number ==
                        math.floor(
                            tonumber(
                                session.scope_team
                            ) or 0
                        )
                ) then

                expected = expected + 1
            end
        end
    end

    return expected
end

function chat_spammer.begin_vote_session(
    event,
    fallback_issue
)
    local previous =
        chat_spammer.vote_session

    local delivery_mode =
        chat_spammer.normalize_vote_delivery_mode(
            chat_spammer.vote_delivery_mode
        )

    if chat_spammer.vote_automatic_delivery_enabled == true
        and type(previous) == "table"
        and previous.active == true
        and previous.revision >
            previous.last_summary_revision then

        if delivery_mode == 1 then
            chat_spammer.flush_vote_summary(
                "new vote"
            )
        elseif delivery_mode == 2
            and previous.final_summary_sent ~= true then

            previous.final_status = "superseded"
            previous.finalized_at = get_time()

            chat_spammer.flush_vote_summary(
                "new vote",
                true
            )
        end
    end

    chat_spammer.reset_vote_session()

    local session =
        chat_spammer.vote_session

    local player_name,
        caller_team =
            chat_spammer.get_vote_actor(
                event
            )

    local issue =
        chat_spammer.get_vote_issue_from_event(
            event
        )

    if issue == "" then
        issue =
            tostring(
                fallback_issue or ""
            )

        issue =
            issue:gsub(
                "^[Vv]ote started:%s*",
                ""
            )

        issue =
            issue:gsub(
                "%s*|%s*Caller:.*$",
                ""
            )
    end

    if issue == "" then
        issue = "Current vote"
    end

    local scope,
        scope_team,
        scope_reason =
            chat_spammer.infer_vote_scope(
                issue,
                event,
                caller_team
            )

    local now = get_time()

    local reported_duration =
        chat_spammer.get_event_int_any(
            event,
            {
                "duration",
                "vote_duration",
                "timeout",
                "time_remaining",
                "remaining"
            }
        )

    local fallback_timeout =
        math.max(
            10.0,
            tonumber(
                chat_spammer.vote_final_timeout
            ) or 35.0
        )

    local expiry_delay =
        (
            reported_duration > 0
            and reported_duration <= 120
        )
        and (
            tonumber(reported_duration) + 1.0
        )
        or fallback_timeout

    session.active = true
    session.issue = issue
    session.caller =
        tostring(player_name or "Unknown player")
    session.caller_team =
        math.floor(
            tonumber(caller_team) or 0
        )
    session.scope = scope
    session.scope_team = scope_team
    session.scope_reason = scope_reason

    chat_spammer.update_vote_descriptor_from_event(
        session,
        event
    )

    session.started_at = now
    session.expires_at = now + expiry_delay


    chat_spammer.remember_vote_session(
        session
    )
    chat_spammer.vote_manual_player_selection = 0
    chat_spammer.vote_manual_clear_confirmation = false
    chat_spammer.vote_manual_last_status =
        "Remembering current vote."

    return session
end

function chat_spammer.ensure_vote_session(
    event
)
    local session =
        chat_spammer.vote_session

    if type(session) == "table"
        and session.active == true then

        return session
    end

    local fallback_issue = ""

    if ui.enhancements
        and ui.enhancements.vote_tracking then

        fallback_issue =
            tostring(
                ui.enhancements.vote_tracking.active_issue
                or ""
            )
    end

    return chat_spammer.begin_vote_session(
        event,
        fallback_issue
    )
end

function chat_spammer.get_vote_count_from_event(
    event,
    field_names
)
    local highest = nil

    for _, field_name in ipairs(
        field_names or {}
    ) do
        local value_ok,
            value =
                pcall(
                    function()
                        return event:get_int(
                            field_name
                        )
                    end
                )

        value =
            value_ok
            and tonumber(value)
            or nil

        if value
            and value >= 0 then

            value = math.floor(value)

            if highest == nil
                or value > highest then

                highest = value
            end
        end
    end

    return highest
end

function chat_spammer.update_vote_counts_from_event(
    event
)
    local session =
        chat_spammer.ensure_vote_session(
            event
        )

    local previous_yes =
        tonumber(session.server_yes) or 0

    local previous_no =
        tonumber(session.server_no) or 0

    local previous_total =
        tonumber(session.server_total) or 0

    local yes_count =
        chat_spammer.get_vote_count_from_event(
            event,
            {
                "yesVotes",
                "yes_votes",
                "yes"
            }
        )

    local no_count =
        chat_spammer.get_vote_count_from_event(
            event,
            {
                "noVotes",
                "no_votes",
            }
        )

    local total_count =
        chat_spammer.get_vote_count_from_event(
            event,
            {
                "potentialVotes",
                "potential_votes",
                "totalVotes",
                "total_votes"
            }
        )

    if yes_count ~= nil then
        session.server_yes =
            math.max(
                previous_yes,
                yes_count
            )
    end

    if no_count ~= nil then
        session.server_no =
            math.max(
                previous_no,
                no_count
            )
    end

    if total_count ~= nil then
        session.server_total =
            math.max(
                previous_total,
                total_count
            )
    end

    local counts_changed =
        (tonumber(session.server_yes) or 0) ~= previous_yes
        or (tonumber(session.server_no) or 0) ~= previous_no
        or (tonumber(session.server_total) or 0) ~= previous_total

    if counts_changed then
        session.revision =
            (session.revision or 0) + 1

        session.last_vote_at = get_time()

        if chat_spammer.normalize_vote_delivery_mode(
            chat_spammer.vote_delivery_mode
        ) == 1 then

            session.summary_due =
                session.last_vote_at +
                math.max(
                    0.50,
                    tonumber(
                        chat_spammer.vote_summary_delay
                    ) or 1.50
                )
        end
    end

    return session
end

function chat_spammer.vote_actor_key(
    player_name,
    userid,
    player_index
)
    userid =
        math.floor(
            tonumber(userid) or 0
        )

    player_index =
        math.floor(
            tonumber(player_index) or 0
        )

    if userid > 0 then
        return "userid:" ..
            tostring(userid)
    elseif player_index > 0 then
        return "index:" ..
            tostring(player_index)
    end

    return "name:" ..
        tostring(player_name or "unknown")
            :lower()
end

function chat_spammer.record_vote_cast(
    event_name,
    event
)
    local session =
        chat_spammer.ensure_vote_session(
            event
        )

    local player_name,
        team_number,
        userid,
        player_index =
            chat_spammer.get_vote_actor(
                event
            )

    local choice =
        chat_spammer.get_vote_choice(
            event_name,
            event
        )

    local actor_key =
        chat_spammer.vote_actor_key(
            player_name,
            userid,
            player_index
        )

    local existing =
        session.votes[
            actor_key
        ]

    if existing
        and existing.choice == choice then

        return existing,
            true
    end

    if not existing then
        table.insert(
            session.order,
            actor_key
        )
    end

    session.votes[actor_key] = {
        key = actor_key,
        name = tostring(player_name),
        choice = tostring(choice),
        team = math.floor(
            tonumber(team_number) or 0
        ),
        userid = math.floor(
            tonumber(userid) or 0
        ),
        player_index = math.floor(
            tonumber(player_index) or 0
        )
    }

    team_number =
        math.floor(
            tonumber(team_number) or 0
        )

    if team_number > 1 then
        session.observed_teams[
            team_number
        ] = true
    end

    local playable_teams = 0

    for observed_team, _ in pairs(
        session.observed_teams
    ) do
        if tonumber(observed_team)
            and tonumber(observed_team) > 1 then

            playable_teams = playable_teams + 1
        end
    end

    if playable_teams >= 2 then
        session.scope = "lobby"
        session.scope_team = 0
        session.scope_reason =
            "voters detected on both teams"
    elseif session.scope == "unknown"
        and team_number > 1 then

        session.scope = "team"
        session.scope_team = team_number
        session.scope_reason =
            "first resolved voter team"
    end

    local now = get_time()

    session.last_vote_at = now
    session.revision =
        (session.revision or 0) + 1

    if chat_spammer.normalize_vote_delivery_mode(
        chat_spammer.vote_delivery_mode
    ) == 1 then

        session.summary_due =
            now +
            math.max(
                0.50,
                tonumber(
                    chat_spammer.vote_summary_delay
                ) or 1.50
            )

        local recorded_count =
            #session.order

        local expected_count =
            chat_spammer.get_vote_expected_count(
                session
            )

        if expected_count > 0
            and recorded_count >= expected_count then

            session.summary_due =
                math.min(
                    session.summary_due,
                    now + 0.15
                )
        end
    else
        session.summary_due = 0.0
    end

    return session.votes[actor_key],
        false
end

function chat_spammer.vote_relay_is_duplicate(
    relay_key
)
    relay_key =
        tostring(relay_key or "")

    if relay_key == "" then
        return false
    end

    local now = get_time()
    local window =
        math.max(
            0.10,
            tonumber(
                chat_spammer.vote_relay_dedup_window
            ) or 0.65
        )

    for key, seen_at in pairs(
        chat_spammer.vote_relay_recent
    ) do
        if now -
            (
                tonumber(seen_at) or 0.0
            ) > window * 4.0 then

            chat_spammer.vote_relay_recent[
                key
            ] = nil
        end
    end

    local last_seen =
        tonumber(
            chat_spammer.vote_relay_recent[
                relay_key
            ]
        ) or 0.0

    chat_spammer.vote_relay_recent[
        relay_key
    ] = now

    return last_seen > 0.0
        and now - last_seen <= window
end

function chat_spammer.get_vote_route_for_team(
    team_number
)
    local team_class =
        chat_spammer.classify_team_number(
            team_number
        )

    if team_class == "my_team" then
        return chat_spammer.normalize_route_mode(
            chat_spammer.vote_my_team_route
        ),
            team_class
    elseif team_class == "enemy_team" then
        return chat_spammer.normalize_route_mode(
            chat_spammer.vote_enemy_team_route
        ),
            team_class
    end

    return chat_spammer.normalize_route_mode(
        chat_spammer.vote_unknown_team_route
    ),
        team_class
end

function chat_spammer.get_vote_route_for_session(
    session
)
    session =
        type(session) == "table"
        and session
        or chat_spammer.vote_session

    if session.scope == "lobby" then
        return chat_spammer.normalize_route_mode(
            chat_spammer.vote_lobby_route
        ),
            "lobby"
    elseif session.scope == "team" then
        return chat_spammer.get_vote_route_for_team(
            session.scope_team
        )
    end

    return chat_spammer.normalize_route_mode(
        chat_spammer.vote_unknown_team_route
    ),
        "unknown_team"
end

function chat_spammer.get_immediate_vote_route(
    session,
    vote_record
)
    if session.scope == "lobby" then
        return chat_spammer.normalize_route_mode(
            chat_spammer.vote_lobby_route
        )
    elseif session.scope == "team"
        and session.scope_team > 1 then

        return chat_spammer.get_vote_route_for_team(
            session.scope_team
        )
    end

    return chat_spammer.get_vote_route_for_team(
        vote_record
        and vote_record.team
        or 0
    )
end

function chat_spammer.truncate_vote_text(
    text,
    maximum_length
)
    text = tostring(text or "")
    maximum_length =
        math.max(
            1,
            math.floor(
                tonumber(maximum_length) or 40
            )
        )

    if #text <= maximum_length then
        return text
    end

    if maximum_length <= 3 then
        return text:sub(
            1,
            maximum_length
        )
    end

    return text:sub(
        1,
        maximum_length - 3
    ) .. "..."
end

function chat_spammer.collect_vote_groups(
    session
)
    local groups = {
        YES = {},
        NO = {}
    }

    local extra_order = {}

    for _, actor_key in ipairs(
        session.order or {}
    ) do
        local vote =
            session.votes[
                actor_key
            ]

        if vote then
            local choice =
                tostring(vote.choice or "OPTION")

            if not groups[choice] then
                groups[choice] = {}

                table.insert(
                    extra_order,
                    choice
                )
            end

            table.insert(
                groups[choice],
                tostring(vote.name or "Unknown player")
            )
        end
    end

    return groups,
        extra_order
end

function chat_spammer.format_vote_group(
    label,
    names,
    total_count
)
    names =
        type(names) == "table"
        and names
        or {}

    total_count =
        math.max(
            #names,
            math.floor(
                tonumber(total_count) or 0
            )
        )

    local text =
        tostring(label) ..
        " (" ..
        tostring(total_count) ..
        "): "

    if #names > 0 then
        text = text ..
            table.concat(
                names,
                ", "
            )
    else
        text = text .. "None"
    end

    local unlisted =
        total_count - #names

    if unlisted > 0 then
        text = text ..
            " (+" ..
            tostring(unlisted) ..
            " unlisted)"
    end

    return text
end

function chat_spammer.append_vote_group_lines(
    output,
    label,
    names,
    total_count
)
    local maximum =
        DARKSIDE_CONFIG.MAX_CHAT_MESSAGE_LENGTH

    names =
        type(names) == "table"
        and names
        or {}

    total_count =
        math.max(
            #names,
            math.floor(
                tonumber(total_count) or 0
            )
        )

    local prefix =
        tostring(label) ..
        " (" ..
        tostring(total_count) ..
        "): "

    if #names == 0 then
        table.insert(
            output,
            prefix ..
            (
                total_count > 0
                and (
                    tostring(total_count) ..
                    " vote(s) not individually identified"
                )
                or "None"
            )
        )

        return
    end

    local current = prefix

    for _, player_name in ipairs(
        names
    ) do
        local separator =
            current == prefix
            and ""
            or ", "

        local piece =
            separator ..
            tostring(player_name)

        if #current + #piece > maximum
            and current ~= prefix then

            table.insert(
                output,
                current
            )

            current =
                tostring(label) ..
                ": " ..
                tostring(player_name)
        else
            current = current .. piece
        end
    end

    local unlisted =
        total_count - #names

    if unlisted > 0 then
        local suffix =
            " (+" ..
            tostring(unlisted) ..
            " unlisted)"

        if #current + #suffix > maximum then
            table.insert(
                output,
                current
            )

            current =
                tostring(label) ..
                ": " ..
                suffix:gsub("^%s+", "")
        else
            current = current .. suffix
        end
    end

    table.insert(
        output,
        current
    )
end

function chat_spammer.build_vote_summary_lines(
    session,
    final_delivery
)
    local groups,
        extra_order =
            chat_spammer.collect_vote_groups(
                session
            )

    local yes_count =
        math.max(
            #(groups.YES or {}),
            tonumber(session.server_yes) or 0
        )

    local no_count =
        math.max(
            #(groups.NO or {}),
            tonumber(session.server_no) or 0
        )

    local yes_text =
        chat_spammer.format_vote_group(
            "YES",
            groups.YES,
            yes_count
        )

    local no_text =
        chat_spammer.format_vote_group(
            "NO",
            groups.NO,
            no_count
        )


    local action_text =
        chat_spammer.truncate_vote_text(
            chat_spammer.vote_action_label(
                session
            ),
            72
        )

    local status_label =
        chat_spammer.vote_final_status_label(
            session.final_status
        )

    local title =
        final_delivery == true
        and (
            "[VOTE " ..
            status_label ..
            " | " ..
            action_text ..
            "]"
        )
        or (
            "[VOTE SUMMARY | " ..
            action_text ..
            "]"
        )

    local lines = {
        chat_spammer.truncate_vote_text(
            title,
            DARKSIDE_CONFIG.MAX_CHAT_MESSAGE_LENGTH
        )
    }

    local grouped_votes =
        yes_text ..
        " | " ..
        no_text

    if #grouped_votes <=
        DARKSIDE_CONFIG.MAX_CHAT_MESSAGE_LENGTH
        and #extra_order == 0 then

        table.insert(
            lines,
            grouped_votes
        )

        return lines
    end


    chat_spammer.append_vote_group_lines(
        lines,
        "YES",
        groups.YES,
        yes_count
    )

    chat_spammer.append_vote_group_lines(
        lines,
        "NO",
        groups.NO,
        no_count
    )

    for _, extra_choice in ipairs(
        extra_order
    ) do
        chat_spammer.append_vote_group_lines(
            lines,
            extra_choice,
            groups[extra_choice],
            #(groups[extra_choice] or {})
        )
    end

    return lines
end

function chat_spammer.flush_vote_summary(
    reason,
    final_delivery
)
    local session =
        chat_spammer.vote_session

    final_delivery =
        final_delivery == true

    if type(session) ~= "table"
        or session.active ~= true then

        return false
    end

    if final_delivery then
        if session.final_summary_sent == true then
            return false
        end
    elseif session.revision <=
        session.last_summary_revision then

        return false
    end

    local route_mode =
        chat_spammer.get_vote_route_for_session(
            session
        )

    session.summary_due = 0.0
    session.last_summary_revision =
        session.revision

    if final_delivery then
        session.final_summary_sent = true
        session.final_summary_due = 0.0
    end

    if route_mode == 0 then
        return false
    end

    local summary_lines =
        chat_spammer.build_vote_summary_lines(
            session,
            final_delivery
        )

    local sent_count = 0

    for _, line in ipairs(
        summary_lines
    ) do
        if chat_spammer.send_to_route(
            line,
            route_mode,
            true
        ) then
            sent_count = sent_count + 1
        end
    end

    if sent_count > 0 then
        chat_spammer.vote_relay_sent =
            chat_spammer.vote_relay_sent +
            sent_count

        chat_spammer.last_vote_relay =
            table.concat(
                summary_lines,
                " / "
            )

        return true
    end

    return false
end

function chat_spammer.send_manual_vote_lines(
    lines,
    status_label
)
    if chat_spammer.vote_manual_publish_enabled ~= true then
        chat_spammer.vote_manual_last_status =
            "Manual publishing is disabled."
        return false
    end

    lines = type(lines) == "table"
        and lines
        or {}

    if #lines == 0 then
        chat_spammer.vote_manual_last_status =
            "Nothing is available to publish."
        return false
    end

    local now = get_time()
    local cooldown =
        math.max(
            0.20,
            tonumber(
                chat_spammer.vote_manual_publish_cooldown
            ) or 0.75
        )

    if now -
        (
            tonumber(
                chat_spammer.vote_manual_last_publish_at
            ) or 0.0
        ) < cooldown then

        chat_spammer.vote_manual_last_status =
            "Please wait before publishing again."
        return false
    end

    local route_mode =
        chat_spammer.get_manual_vote_route()

    route_mode =
        chat_spammer.normalize_route_mode(
            route_mode
        )

    if route_mode == 0 then
        chat_spammer.vote_manual_last_status =
            "Manual vote destination is disabled."
        return false
    end

    local team_only =
        route_mode == 2

    local queued_lines = {}
    local queued_count = 0

    for _, line in ipairs(lines) do
        local safe_line =
            tostring(line or "")
                :gsub("[\r\n]", " ")
                :gsub('"', "'")

        if safe_line ~= "" then
            if ui.lobby.append_chat_message(
                safe_line,
                team_only,
                queued_count == 0 and 0.05 or 0.0
            ) then
                queued_count = queued_count + 1
                table.insert(
                    queued_lines,
                    safe_line
                )
            end
        end
    end

    if queued_count <= 0 then
        chat_spammer.vote_manual_last_status =
            "The vote result could not be queued."
        return false
    end

    chat_spammer.vote_manual_last_publish_at = now
    chat_spammer.vote_manual_posts =
        (chat_spammer.vote_manual_posts or 0) + 1
    chat_spammer.vote_relay_sent =
        chat_spammer.vote_relay_sent + queued_count
    chat_spammer.last_vote_relay =
        table.concat(queued_lines, " / ")
    chat_spammer.vote_manual_last_status =
        tostring(status_label or "Vote result published.")

    return true
end

function chat_spammer.publish_remembered_individual_votes()
    local session =
        chat_spammer.get_remembered_vote_session()

    if not session then
        chat_spammer.vote_manual_last_status =
            "No vote has been remembered yet."
        return false
    end

    local records =
        chat_spammer.get_vote_records(
            session
        )

    if #records <= 0 then
        chat_spammer.vote_manual_last_status =
            "No individual voter names were captured."
        return false
    end

    local lines = {}

    for _, vote_record in ipairs(records) do
        local line =
            chat_spammer.build_manual_vote_record_line(
                session,
                vote_record
            )

        if line ~= "" then
            table.insert(
                lines,
                line
            )
        end
    end

    return chat_spammer.send_manual_vote_lines(
        lines,
        "Published " ..
        tostring(#lines) ..
        " captured voter choice(s)."
    )
end

