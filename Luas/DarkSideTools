        player_value_color,
        is_local_player,
        is_bot_player,
        prediction_row
    )
        if ui.network.rendering_overlay then
            ui.network.begin_overlay_value_cell(
                label
            )
        else
            imgui.text(
                tostring(label or "") .. ":"
            )
            imgui.same_line()
        end

        local value_start_x =
            ui.lobby.get_cursor_x()

        local name_text =
            tostring(player_name or "Unknown")

        local you_text =
            is_local_player == true
            and "[YOU]"
            or ""

        local bot_text =
            is_bot_player == true
            and "[BOT]"
            or ""

        local prediction_parts =
            build_prediction_parts(
                prediction_row
            )

        local base_value_width =
            math.max(
                72,
                tonumber(
                    ui.network.overlay_value_column_width
                ) or (detailed and 190 or 154)
            )

        local status_start_offset =
            detailed and 158 or 112

        local tag_reserved_width = 0

        if you_text ~= "" then
            tag_reserved_width =
                tag_reserved_width +
                ui.lobby.measure_text_width(you_text) + 4
        end

        if bot_text ~= "" then
            tag_reserved_width =
                tag_reserved_width +
                ui.lobby.measure_text_width(bot_text) + 4
        end

        if ui.network.rendering_overlay then
            local name_width_limit =
                prediction_parts
                and math.max(
                    24,
                    status_start_offset - tag_reserved_width - 8
                )
                or math.max(
                    32,
                    base_value_width - tag_reserved_width
                )

            name_text =
                ui.network.fit_overlay_text(
                    name_text,
                    name_width_limit
                )
        end

        theme_text_colored(
            player_value_color[1],
            player_value_color[2],
            player_value_color[3],
            1.0,
            name_text
        )

        if you_text ~= "" then
            imgui.same_line()

            theme_text_colored(
                you_tag_color[1],
                you_tag_color[2],
                you_tag_color[3],
                1.0,
                you_text
            )
        end

        if bot_text ~= "" then
            imgui.same_line()

            theme_text_colored(
                bot_color[1],
                bot_color[2],
                bot_color[3],
                1.0,
                bot_text
            )
        end

        if prediction_parts then
            imgui.same_line()

            if ui.network.rendering_overlay then
                ui.lobby.set_cursor_x(
                    value_start_x + status_start_offset
                )
            end

            local arrow_color =
                players_palette.text_disabled
                or { 0.56, 0.56, 0.58 }

            theme_text_colored(
                arrow_color[1],
                arrow_color[2],
                arrow_color[3],
                1.0,
                "→"
            )

            imgui.same_line()

            draw_prediction_parts(
                prediction_parts,
                value_start_x + status_start_offset
            )
        end

        if ui.network.rendering_overlay then
            imgui.separator()
        end
    end

    local previous_player_team = nil

    for _, player_record in ipairs(player_rows) do
        local player_name =
            tostring(player_record.name or "Unknown")

        local player_userid =
            tonumber(player_record.userid) or 0

        local player_team =
            resolved_player_team(
                player_record
            )

        if ui.network.rendering_overlay
            and previous_player_team ~= nil
            and previous_player_team ~= player_team then

            imgui.spacing()
        end

        previous_player_team = player_team

        local userid_text =
            player_userid > 0
            and tostring(math.floor(player_userid))
            or "N/A"

        local player_value_color =
            default_player_color

        if player_record.is_bot == true then
            player_value_color = bot_color
        elseif player_team == 2 then
            player_value_color = survivor_color
        elseif player_team == 3 then
            player_value_color = infected_color
        end

        local prediction_row =
            player_team == 3
            and find_player_prediction(
                player_record
            )
            or nil

        draw_player_id_row(
            "ID " .. userid_text,
            player_name,
            player_value_color,
            player_record.is_local == true,
            player_record.is_bot == true,
            prediction_row
        )
    end

    return true
end

