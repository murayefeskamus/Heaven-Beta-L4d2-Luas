            ui.lobby.settings_expanded =
                draw_collapsible_section(
                    "AUTOMATIC REFRESH",
                    ui.lobby.settings_expanded,
                    "LobbyRefresh"
                )

            if ui.lobby.settings_expanded then
                local changed_auto_refresh,
                    auto_refresh_value =
                        imgui.checkbox(
                            "Automatic Refresh",
                            ui.lobby.auto_refresh
                        )

                if changed_auto_refresh then
                    ui.lobby.auto_refresh =
                        auto_refresh_value == true

                    if ui.lobby.auto_refresh then
                        ui.lobby.force_refresh = true
                    end
                end

                imgui.text("Refresh interval (seconds):")
                imgui.same_line()
                imgui.push_item_width(180)

                local changed_interval,
                    interval_value =
                        imgui.slider_float(
                            "##LobbyRefreshInterval",
                            ui.lobby.refresh_interval,
