function ui.heaven_configs.push_current_config_combo_colors()
    if type(imgui) ~= "table"
        or type(imgui.push_style_color) ~= "function" then

        return 0
    end

    local palette = ui.enhancements.theme_palette()
    local active_green = { 0.25, 1.0, 0.35, 1.0 }
    local base = palette.combo or palette.frame or { 0.16, 0.16, 0.18 }

    local function blend(amount)
        return {
            (base[1] or 0.0) +
                ((active_green[1] or 0.0) - (base[1] or 0.0)) * amount,
            (base[2] or 0.0) +
                ((active_green[2] or 0.0) - (base[2] or 0.0)) * amount,
            (base[3] or 0.0) +
                ((active_green[3] or 0.0) - (base[3] or 0.0)) * amount,
            1.0
        }
    end

    local pushed = 0

    local function push(index, color)
        local ok = pcall(
            imgui.push_style_color,
            index,
            color[1] or 0.0,
            color[2] or 0.0,
            color[3] or 0.0,
            color[4] or 1.0
        )

        if ok then
            pushed = pushed + 1
        end
    end

    push(0, active_green)
    push(24, blend(palette.light == true and 0.12 or 0.20))
    push(25, blend(palette.light == true and 0.20 or 0.30))
    push(26, blend(palette.light == true and 0.28 or 0.42))

    return pushed
end

