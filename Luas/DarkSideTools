function ui.favourites.normalize_entries()
    local validated = {}
    local seen = {}

    for _, entry in ipairs(
        ui.favourites.entries
    ) do
        if type(entry) == "table" then
            local kind =
                tostring(
                    entry.kind
                    or "section"
                )

            local tab_key =
                tostring(
                    entry.tab_key
                    or ""
                )

            local section_key =
                tostring(
                    entry.section_key
                    or ""
                )

            local term =
                ui.favourites.clean_label(
                    entry.term
                )

            if tab_key == "settings"
                and section_key == "section_order"
                and kind == "setting"
                and ui.favourites.normalize_label(
                    term
                ) == "tab order" then

                section_key = "tab_order"
            end

            local valid_tab =
                ui.favourites.tool_indices[
                    tab_key
                ] ~= nil

            local tab_definition =
                ui.section_layout.get_tab(
                    tab_key
                )

            local valid_section = false

            if tab_definition then
                for _, section in ipairs(
                    tab_definition.sections
                    or {}
                ) do
                    if tostring(section.key) ==
                        section_key then

                        valid_section = true
                        break
                    end
                end
            end

            if (
                kind == "section"
                or kind == "setting"
            )
                and valid_tab
                and valid_section
                and (
                    kind ~= "setting"
                    or term ~= ""
                ) then

                local clean_entry = {
                    kind = kind,
                    tab_key = tab_key,
                    section_key = section_key,
                    term = term
                }

                local key =
                    ui.favourites.entry_key(
                        clean_entry
                    )

                if seen[key] ~= true then
                    validated[
                        #validated + 1
                    ] = clean_entry

                    seen[key] = true
                end
            end
        end
    end

    local whole_sections = {}

    for _, entry in ipairs(
        validated
    ) do
        if entry.kind == "section" then
            whole_sections[
                tostring(entry.tab_key) ..
                "|" ..
                tostring(entry.section_key)
            ] = true
        end
    end

    local normalized = {}

    for _, entry in ipairs(
        validated
    ) do
        local group_key =
            tostring(entry.tab_key) ..
            "|" ..
            tostring(entry.section_key)

        if entry.kind == "section"
            or whole_sections[group_key] ~= true then

            normalized[
                #normalized + 1
            ] = entry
        end
    end

    ui.favourites.entries = normalized
    return normalized
end

