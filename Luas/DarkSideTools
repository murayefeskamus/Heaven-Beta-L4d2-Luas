function chat_spammer.humanize_vote_text(
    value
)
    local text =
        chat_spammer.trim_vote_text(
            value
        )

    if text == "" then
        return ""
    end

    text =
        text:gsub(
            "^#",
            ""
        )

    text =
        text:gsub(
            "^[Ll]4[Dd]_?",
            ""
        )

    text =
        text:gsub(
            "^[Vv][Oo][Tt][Ee]_?",
            ""
        )

    text =
        text:gsub(
            "_",
            " "
        ):gsub(
            "%s+",
            " "
        )

    text =
        chat_spammer.trim_vote_text(
            text
        )

    return text
end

function chat_spammer.get_vote_kind_from_event(
    issue,
    event
)
    local parts = {
        tostring(issue or "")
    }

    local event_values =
        chat_spammer.get_vote_event_strings(
            event,
            {
                "issue",
                "vote_issue",
                "type",
                "display_string",
                "details",
                "param1",
                "param2",
                "subject",
                "target"
            }
        )

    for _, entry in ipairs(
        event_values
    ) do
        table.insert(
            parts,
            entry.value
        )
    end

    local compact =
        chat_spammer.normalize_vote_issue_key(
            table.concat(
                parts,
                " "
            )
        )

    local checks = {
        {
            kind = "kick",
            tokens = {
                "votekick",
                "kickplayer",
                "removeplayer",
                "kick"
            }
        },
        {
            kind = "change_alltalk",
            tokens = {
                "changealltalk",
                "alltalk"
            }
        },
        {
            kind = "change_campaign",
            tokens = {
                "changemission",
                "changecampaign",
                "newcampaign"
            }
        },
        {
            kind = "change_chapter",
            tokens = {
                "changechapter",
                "restartchapter"
            }
        },
        {
            kind = "change_map",
            tokens = {
                "changemap",
                "changelevel",
                "newmap"
            }
        },
        {
            kind = "return_lobby",
            tokens = {
                "returntolobby",
                "backtolobby"
            }
        },
        {
            kind = "restart",
            tokens = {
                "restartgame",
                "restartmatch",
                "restart"
            }
        },
        {
            kind = "difficulty",
            tokens = {
                "changedifficulty",
                "difficulty"
            }
        },
        {
            kind = "shuffle_teams",
            tokens = {
                "shuffleteams",
                "scrambleteams"
            }
        }
    }

    for _, check in ipairs(
        checks
    ) do
        for _, token in ipairs(
            check.tokens
        ) do
            if compact:find(
                token,
                1,
                true
            ) then

                return check.kind
            end
        end
    end

    return "unknown"
end

function chat_spammer.resolve_vote_player_name(
    userid,
    player_index
)
    userid =
        math.floor(
            tonumber(userid) or 0
        )

    player_index =
        math.floor(
            tonumber(player_index) or 0
        )

    local player_name = nil

    if userid > 0 then
        player_name =
            get_player_name_from_userid(
                userid
            )
    end

    if (not player_name
        or player_name == "")
        and player_index > 0 then

        local info_ok,
            player_info =
                pcall(
                    engine.get_player_info,
                    player_index
                )

        if info_ok
            and player_info
            and player_info.name then

            player_name =
                tostring(
                    player_info.name
                )
        end
    end

    return chat_spammer.trim_vote_text(
        player_name
    )
end

function chat_spammer.vote_value_is_metadata(
    value,
    issue
)
    value =
        chat_spammer.trim_vote_text(
            value
        )

    if value == ""
        or value:sub(1, 1) == "#"
        or tonumber(value) ~= nil then

        return true
    end

    local compact =
        chat_spammer.normalize_vote_issue_key(
            value
        )

    local issue_compact =
        chat_spammer.normalize_vote_issue_key(
            issue
        )

    if compact == ""
        or compact == issue_compact
        or compact == "yes"
        or compact == "no"
        or compact == "true"
        or compact == "false"
        or compact:find(
            "l4dvote",
            1,
            true
        ) then

        return true
    end

    local generic_values = {
        kick = true,
        votekick = true,
        kickplayer = true,
        removeplayer = true,
        changemap = true,
        changelevel = true,
        changemission = true,
        changecampaign = true,
        changechapter = true,
        changealltalk = true,
        alltalk = true,
        returntolobby = true,
        restart = true,
        restartgame = true,
        changedifficulty = true,
        difficulty = true
    }

    return generic_values[compact] == true
end

function chat_spammer.extract_kick_target_from_text(
    value
)
    local text =
        chat_spammer.trim_vote_text(
            value
        )

    if text == ""
        or text:sub(1, 1) == "#" then

        return ""
    end

    local lower =
        text:lower()

    local kick_position =
        lower:find(
            "kick",
            1,
            true
        )

    if not kick_position then
        return ""
    end

    local target =
        text:sub(
            kick_position + 4
        )

    target =
        target:gsub(
            "^%s*[:%-|]%s*",
            ""
        ):gsub(
            "^[Pp]layer%s*[:%-]?%s*",
            ""
        ):gsub(
            "^[Tt]arget%s*[:%-]?%s*",
            ""
        )

    target =
        chat_spammer.trim_vote_text(
            target
        )

    if target == ""
        or chat_spammer.vote_value_is_metadata(
            target,
            text
        ) then

        return ""
    end

    return target
end

function chat_spammer.get_vote_target_from_event(
    event,
    issue
)
    local target_userid =
        chat_spammer.get_event_int_any(
            event,
            {
                "target_userid",
                "targetuserid",
                "target_user_id",
                "kick_userid",
                "player_to_kick"
            }
        )

    local target_index =
        chat_spammer.get_event_int_any(
            event,
            {
                "target_entity",
                "target_entindex",
                "target_index",
                "target_player",
                "kick_entity"
            }
        )

    local resolved_name =
        chat_spammer.resolve_vote_player_name(
            target_userid,
            target_index
        )

    if resolved_name ~= "" then
        return resolved_name,
            target_userid,
            target_index,
            "target id"
    end

    local direct_values =
        chat_spammer.get_vote_event_strings(
            event,
            {
                "target_name",
                "target_player_name",
                "kick_target",
                "subject",
                "target"
            }
        )

    for _, entry in ipairs(
        direct_values
    ) do
        if not chat_spammer.vote_value_is_metadata(
            entry.value,
            issue
        ) then

            return entry.value,
                target_userid,
                target_index,
                entry.field
        end
    end

    local candidate_values =
        chat_spammer.get_vote_event_strings(
            event,
            {
                "param2",
                "details",
                "param1"
            }
        )

    for _, entry in ipairs(
        candidate_values
    ) do
        local extracted =
            chat_spammer.extract_kick_target_from_text(
                entry.value
            )

        if extracted ~= "" then
            return extracted,
                target_userid,
                target_index,
                entry.field
        end

        if not chat_spammer.vote_value_is_metadata(
            entry.value,
            issue
        ) then

            return entry.value,
                target_userid,
                target_index,
                entry.field
        end
    end

    local issue_target =
        chat_spammer.extract_kick_target_from_text(
            issue
        )

    if issue_target ~= "" then
        return issue_target,
            target_userid,
            target_index,
            "issue text"
    end

    return "",
        target_userid,
        target_index,
        ""
end

function chat_spammer.get_vote_subject_from_event(
    event,
    issue,
    vote_kind
)
    if vote_kind == "kick" then
        local target_name =
            chat_spammer.get_vote_target_from_event(
                event,
                issue
            )

        return target_name
    end

    local subject_values =
        chat_spammer.get_vote_event_strings(
            event,
            {
                "map",
                "map_name",
                "mission",
                "campaign",
                "chapter",
                "difficulty",
                "setting",
                "value",
                "param2",
                "details",
                "param1",
                "target",
                "subject"
            }
        )

    for _, entry in ipairs(
        subject_values
    ) do
        if not chat_spammer.vote_value_is_metadata(
            entry.value,
            issue
        ) then

            return entry.value
        end
    end

    return ""
end

function chat_spammer.update_vote_descriptor_from_event(
    session,
    event
)
    if type(session) ~= "table" then
        return
    end

    local event_issue =
        chat_spammer.get_vote_issue_from_event(
            event
        )

    if event_issue ~= ""
        and (
            session.issue == ""
            or session.issue == "Current vote"
            or session.issue == "Unknown vote"
        ) then

        session.issue = event_issue
    end

    local vote_kind =
        chat_spammer.get_vote_kind_from_event(
            session.issue,
            event
        )

    if vote_kind ~= "unknown"
        or tostring(
            session.vote_kind or ""
        ) == "" then

        session.vote_kind = vote_kind
    end

    if session.vote_kind == "kick" then
        local target_name,
            target_userid,
            target_index,
            target_source =
                chat_spammer.get_vote_target_from_event(
                    event,
                    session.issue
                )

        if target_name ~= "" then
            session.vote_target_name =
                target_name
            session.vote_subject =
                target_name
            session.vote_descriptor_source =
                target_source
        end

        if target_userid > 0 then
            session.vote_target_userid =
                target_userid
        end

        if target_index > 0 then
            session.vote_target_index =
                target_index
        end
    else
        local subject =
            chat_spammer.get_vote_subject_from_event(
                event,
                session.issue,
                session.vote_kind
            )

        if subject ~= "" then
            session.vote_subject =
                subject
        end
    end

    local inferred_scope,
        inferred_team,
        inferred_reason =
            chat_spammer.infer_vote_scope(
                session.issue,
                event,
                session.caller_team
            )

    if session.scope == "unknown"
        or inferred_scope == "lobby"
        or (
            session.vote_kind == "kick"
            and inferred_scope == "team"
        ) then

        session.scope =
            inferred_scope
        session.scope_team =
            inferred_team
        session.scope_reason =
            inferred_reason
    end
end

function chat_spammer.get_vote_map_display_name(
    value
)
    local raw_value =
        chat_spammer.trim_vote_text(
            value
        )

    if raw_value == "" then
        return ""
    end


    local normalized =
        raw_value:lower():gsub(
            "\\",
            "/"
        )

    normalized =
        normalized:gsub(
            "%.bsp",
            ""
        )

    local direct_code =
        normalized:gsub(
            "^maps/",
            ""
        )

    local direct_name =
        ui.lobby.map_names[
            direct_code
        ]

    if direct_name then
        return direct_name
    end


    for map_code,
        friendly_name in pairs(
            ui.lobby.map_names
        ) do

        if normalized:find(
            tostring(map_code),
            1,
            true
        ) then

            return tostring(
                friendly_name
            )
        end
    end

    return raw_value
end

