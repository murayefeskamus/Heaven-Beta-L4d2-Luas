function spammer_cfg.get_normalized_name_field_text(
    index
)
    local configured_name =
        sanitize_name(
            get_spammer_name(
                index
            )
        )


    configured_name =
        configured_name:gsub(
            "[%z\1-\31\127]",
            ""
        )

    local invisible_sequences = {
        DARKSIDE_CONFIG.ZERO_WIDTH_PREFIX,
        DARKSIDE_CONFIG.COLOR_ESCAPE_CHAR,
        "\194\173",
        "\205\143",
        "\216\156",
        "\225\160\142",
        "\226\128\139",
        "\226\128\140",
        "\226\128\141",
        "\226\128\142",
        "\226\128\143",
        "\226\128\170",
        "\226\128\171",
        "\226\128\172",
        "\226\128\173",
        "\226\128\174",
        "\226\129\160",
        "\226\129\161",
        "\226\129\162",
        "\226\129\163",
        "\226\129\164",
        "\226\129\166",
        "\226\129\167",
        "\226\129\168",
        "\226\129\169",
        "\239\187\191"
    }

    for _, sequence in ipairs(
        invisible_sequences
    ) do
        configured_name =
            configured_name:gsub(
                sequence,
                ""
            )
    end

    configured_name =
        configured_name:gsub(
            "^%s+",
            ""
        ):gsub(
            "%s+$",
            ""
        )

    return configured_name
end

