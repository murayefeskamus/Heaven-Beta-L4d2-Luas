function ui.lobby.format_kd_ratio(kills, deaths)
    kills = math.max(
        0,
        tonumber(kills) or 0
    )

    deaths = math.max(
        0,
        tonumber(deaths) or 0
    )


    local divisor =
        deaths > 0
        and deaths
        or 1

    return string.format(
        "%.2f",
        kills / divisor
    )
end


