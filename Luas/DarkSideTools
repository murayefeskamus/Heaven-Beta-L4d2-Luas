    local full_label =
        tostring(label or "Action") ..
        "##" ..
        tostring(unique_id or "HeavenConfigAction")

    local palette =
        ui.enhancements.theme_palette()

    local text_color =
        palette.button_text
        or palette.text
        or { 1.0, 1.0, 1.0 }

    local button_color =
        palette.button
        or palette.inactive_tab
        or { 0.18, 0.18, 0.18 }

    style_name = tostring(style_name or "secondary")

    local function blend_color(
        first,
        second,
        amount
    )
        first =
            type(first) == "table"
            and first
            or { 0.18, 0.18, 0.18 }

        second =
            type(second) == "table"
            and second
            or first

        amount =
            math.max(
                0.0,
                math.min(
                    1.0,
                    tonumber(amount) or 0.0
                )
            )

        return {
            (first[1] or 0.0) +
                (
                    (second[1] or 0.0) -
                    (first[1] or 0.0)
                ) * amount,
            (first[2] or 0.0) +
                (
                    (second[2] or 0.0) -
                    (first[2] or 0.0)
                ) * amount,
            (first[3] or 0.0) +
                (
                    (second[3] or 0.0) -
                    (first[3] or 0.0)
                ) * amount
        }
    end

    if style_name == "primary" then
        button_color =
            palette.active_tab
            or palette.accent
            or { 0.10, 0.42, 0.62 }

        text_color =
            palette.active_tab_text
            or { 1.0, 1.0, 1.0 }
    elseif style_name == "success" then
        button_color =
            palette.light == true
            and { 0.12, 0.62, 0.32 }
            or { 0.10, 0.48, 0.27 }

        text_color = { 1.0, 1.0, 1.0 }
    elseif style_name == "danger" then
        button_color =
            palette.light == true
            and { 0.68, 0.23, 0.23 }
            or { 0.46, 0.16, 0.16 }

        text_color = { 1.0, 1.0, 1.0 }
    elseif style_name == "current" then
        button_color =
            palette.light == true
            and { 0.14, 0.58, 0.31 }
            or { 0.08, 0.38, 0.21 }

        text_color = { 0.92, 1.0, 0.94 }
    elseif style_name == "key_unbound" then
        button_color =
            palette.active_tab
            or palette.accent
            or palette.button
            or { 0.10, 0.42, 0.62 }

        text_color =
            palette.active_tab_text
            or { 1.0, 1.0, 1.0 }
    elseif style_name == "key_bound" then
        button_color =
            blend_color(
                palette.button
                or palette.inactive_tab
                or { 0.16, 0.16, 0.18 },
                palette.accent
                or palette.active_tab
                or { 0.10, 0.42, 0.62 },
                palette.light == true
                and 0.24
                or 0.38
            )

        text_color =
            palette.text
            or palette.button_text
            or { 1.0, 1.0, 1.0 }
    elseif style_name == "key_waiting" then
        button_color =
            blend_color(
                palette.accent
                or palette.active_tab
                or { 0.10, 0.42, 0.62 },
                palette.light == true
                and { 0.0, 0.0, 0.0 }
                or { 1.0, 1.0, 1.0 },
                palette.light == true
                and 0.12
                or 0.20
            )

        text_color =
            palette.active_tab_text
            or { 1.0, 1.0, 1.0 }
    end

    if enabled == false then
        text_color =
            palette.text_disabled
            or { 0.55, 0.55, 0.55 }

        button_color =
            palette.inactive_tab
            or palette.button
            or { 0.16, 0.16, 0.16 }
    end

    local count =
        push_button_colors(
            text_color[1] or 1.0,
            text_color[2] or 1.0,
            text_color[3] or 1.0,
            button_color[1] or 0.18,
            button_color[2] or 0.18,
            button_color[3] or 0.18
        )

    local clicked = false

    if tonumber(fixed_width)
        and tonumber(fixed_width) > 0 then

        clicked =
            ui.heaven_configs.draw_sized_button(
                full_label,
                fixed_width
            )
    else
        clicked =
            imgui.button(
                full_label
            ) == true
    end

    pop_button_colors(count)


    if style_name == "current"
        or enabled == false then

        return false
    end

    return clicked == true
end

function ui.heaven_configs.normalize_settings()
    ui.heaven_configs.enabled =
        ui.heaven_configs.enabled == true

    ui.heaven_configs.auto_load_first_config =
        ui.heaven_configs.auto_load_first_config ~= false

    ui.heaven_configs.expanded =
        ui.heaven_configs.expanded ~= false

    ui.heaven_configs.max_slots = 10
    ui.heaven_configs.empty_slot_buffer = 0

    if type(
        ui.heaven_configs.slots
    ) ~= "table" then

        ui.heaven_configs.slots = {}
    end

    for index = 1,
        ui.heaven_configs.max_slots do

        local old_slot =
            ui.heaven_configs.slots[
                index
            ]

        local slot_existed =
            type(old_slot) == "table"

        if not slot_existed then
            old_slot =
                ui.heaven_configs.default_slot(
                    index
                )
        end

        local config_name =
            ui.heaven_configs.clean_config_name(
                old_slot.config_name
                or old_slot.selected_config
                or old_slot.file_name
                or ""
            )

        if config_name == "" then
            local legacy_name =
                ui.heaven_configs.clean_config_name(
                    old_slot.name or ""
                )

            if legacy_name ~= ""
                and legacy_name ~=
                    (
                        "Config " ..
                        tostring(index)
                    ) then

                config_name = legacy_name
            end
        end

        local slot_enabled =
            slot_existed
            and old_slot.enabled ~= false
            or false

        if config_name == "" then
            slot_enabled = false
        end

        ui.heaven_configs.slots[
            index
        ] = {
            enabled = slot_enabled,
            key =
                math.max(
                    0,
                    math.min(
                        255,
                        math.floor(
                            tonumber(
                                old_slot.key
                            ) or 0
                        )
                    )
                ),
            config_name = config_name
        }
    end

    while #ui.heaven_configs.slots >
        ui.heaven_configs.max_slots do

        table.remove(
            ui.heaven_configs.slots
        )
    end

    ui.heaven_configs.use_cycle_key =
        ui.heaven_configs.use_cycle_key == true

    local stored_cycle_key =
        tonumber(
            ui.heaven_configs.cycle_key
        )

    if stored_cycle_key == nil then
        stored_cycle_key = 0x78
    end

    ui.heaven_configs.cycle_key =
        math.max(
            0,
            math.min(
                255,
                math.floor(
                    stored_cycle_key
                )
            )
        )

    ui.heaven_configs.cycle_key_was_down =
        ui.heaven_configs.cycle_key_was_down == true

    ui.heaven_configs.waiting_for_cycle_key =
        ui.heaven_configs.waiting_for_cycle_key == true

    ui.heaven_configs.waiting_for_key_slot =
        math.max(
            0,
            math.min(
                ui.heaven_configs.max_slots,
                math.floor(
                    tonumber(
                        ui.heaven_configs.waiting_for_key_slot
                    ) or 0
                )
            )
        )

    if ui.heaven_configs.waiting_for_cycle_key then
        ui.heaven_configs.waiting_for_key_slot = 0
    end

    ui.heaven_configs.clear_confirmation_slot = 0

    if type(
        ui.heaven_configs.detected_configs
    ) ~= "table" then

        ui.heaven_configs.detected_configs = {}
    end

    if type(
        ui.heaven_configs.detected_lookup
    ) ~= "table" then

        ui.heaven_configs.detected_lookup = {}
    end

    if type(
        ui.heaven_configs.hotkey_was_down
    ) ~= "table" then

        ui.heaven_configs.hotkey_was_down = {}
    end

    for index = 1, ui.heaven_configs.max_slots do
        ui.heaven_configs.hotkey_was_down[index] =
            ui.heaven_configs.hotkey_was_down[index] == true
    end

    while #ui.heaven_configs.hotkey_was_down >
        ui.heaven_configs.max_slots do

        table.remove(
            ui.heaven_configs.hotkey_was_down
        )
    end

    if type(
        ui.heaven_configs.native
    ) ~= "table" then

        ui.heaven_configs.native = {}
    end
end

function ui.heaven_configs.save_settings_now()
    if type(ui.settings_io) == "table"
        and type(
            ui.settings_io.save
        ) == "function" then

        pcall(
            ui.settings_io.save
        )
    end
end

function ui.heaven_configs.config_path(
    config_name
)
    config_name =
        ui.heaven_configs.clean_config_name(
            config_name
        )

    if config_name == "" then
        return ""
    end

    return tostring(
        ui.heaven_configs.config_directory
    ) ..
        "\\" ..
        config_name ..
        tostring(
            ui.heaven_configs.config_extension
            or ".cfg"
        )
end

function ui.heaven_configs.config_is_detected(
    config_name
)
    config_name =
        ui.heaven_configs.clean_config_name(
            config_name
        )

    if config_name == "" then
        return false
    end

    return ui.heaven_configs.detected_lookup[
        config_name:lower()
    ] ~= nil
end

function ui.heaven_configs.config_file_exists(
    config_name
)
    local path =
        ui.heaven_configs.config_path(
            config_name
        )

    if path == ""
        or type(io) ~= "table"
        or type(io.open) ~= "function" then

        return false
    end

    local open_ok,
        file_handle =
            pcall(
                io.open,
                path,
                "rb"
            )

    if open_ok
        and file_handle then

        pcall(
            file_handle.close,
            file_handle
        )

        return true
    end

    return false
end

function ui.heaven_configs.native_write_c_string(
    address,
    text_value,
    max_bytes
)
    address = tonumber(address) or 0
    text_value = tostring(text_value or "")
    max_bytes = math.max(1, math.floor(tonumber(max_bytes) or 260))

    if address <= 0 or #text_value + 1 > max_bytes then
        return false
    end

    for offset = 0, #text_value, 4 do
        local packed_value = 0

        for byte_offset = 0, 3 do
            local string_index = offset + byte_offset + 1
            local byte_value =
                string_index <= #text_value
                and (string.byte(text_value, string_index) or 0)
                or 0

            packed_value =
                packed_value +
                byte_value * (256 ^ byte_offset)
        end

        if not ui.heaven_configs.native_write_u32(
            address + offset,
            packed_value
        ) then
            return false
        end
    end

    return true
end

function ui.heaven_configs.native_read_c_string(
    address,
    max_bytes
)
    address = tonumber(address) or 0
    max_bytes = math.max(1, math.min(260, math.floor(tonumber(max_bytes) or 260)))

    if address <= 0 then
        return nil
    end

    local characters = {}

    for offset = 0, max_bytes - 1, 4 do
        local packed_value =
            ui.heaven_configs.native_read_u32(
                address + offset
            )

        if packed_value == nil then
            return nil
        end

        for byte_offset = 0, 3 do
            if offset + byte_offset >= max_bytes then
                break
            end

            local byte_value =
                math.floor(
                    packed_value /
                    (256 ^ byte_offset)
                ) % 256

            if byte_value == 0 then
                return table.concat(characters)
            end

            characters[#characters + 1] =
                string.char(byte_value)
        end
    end

    return table.concat(characters)
end

function ui.heaven_configs.read_directory_lines(
    wildcard_path,
    force_retry
)
    local native = ui.heaven_configs.native
    local wildcard = tostring(wildcard_path or "")


    if not ui.heaven_configs.initialize_native_loader(
        force_retry == true
    ) then
        ui.heaven_configs.scan_backend = "Unavailable"

        return {},
            "Heaven config access is unavailable. Enable Insecure Lua once, then press Refresh."
    end

    if tonumber(native.find_first_file) == nil
        or tonumber(native.find_first_file) <= 0
        or tonumber(native.find_next_file) == nil
        or tonumber(native.find_next_file) <= 0
        or tonumber(native.find_close) == nil
        or tonumber(native.find_close) <= 0 then

        ui.heaven_configs.scan_backend = "Unavailable"

        return {},
            "The Windows config scanner could not be initialized."
    end

    local allocation_pointer =
        tonumber(native.allocation_pointer) or 0

    local pattern_pointer =
        allocation_pointer +
        (tonumber(native.scan_pattern_offset) or 384)

    local data_pointer =
        allocation_pointer +
        (tonumber(native.scan_data_offset) or 640)

    if allocation_pointer <= 0
        or not ui.heaven_configs.native_write_c_string(
            pattern_pointer,
            wildcard,
            260
        ) then

        ui.heaven_configs.scan_backend = "Unavailable"

        return {},
            "The config scan buffer could not be prepared."
    end

    local files = {}
    local handle = 0

    local scan_ok,
        scan_error =
            pcall(
                function()
                    local first_ok,
                        first_result =
                            pcall(
                                native.call_fn,
                                tonumber(native.find_first_file),
                                "stdcall",
                                pattern_pointer,
                                data_pointer
                            )

                    handle =
                        first_ok
                        and ui.heaven_configs.to_unsigned32(
                            first_result
                        )
                        or 0

                    if handle == 0
                        or handle == 0xFFFFFFFF then

                        return
                    end


                    for _ = 1, 256 do
                        local file_name =
                            ui.heaven_configs.native_read_c_string(
                                data_pointer +
                                (tonumber(native.scan_file_name_offset) or 44),
                                260
                            )

                        if file_name
                            and file_name ~= ""
                            and file_name ~= "."
                            and file_name ~= ".."
                            and file_name:lower():sub(-4) == ".cfg" then

                            files[#files + 1] = file_name
                        end

                        local next_ok,
                            next_result =
                                pcall(
                                    native.call_fn,
                                    tonumber(native.find_next_file),
                                    "stdcall",
                                    handle,
                                    data_pointer
                                )

                        if not next_ok
                            or tonumber(next_result) ~= 1 then

                            break
                        end
                    end
                end
            )

    if handle ~= 0
        and handle ~= 0xFFFFFFFF then

        pcall(
            native.call_fn,
            tonumber(native.find_close),
            "stdcall",
            handle
        )
    end

    if not scan_ok then
        ui.heaven_configs.scan_backend = "Unavailable"

        return {},
            "Config scan failed: " ..
            tostring(scan_error or "unknown error")
    end

    ui.heaven_configs.scan_backend = "Native Win32"

    return files,
        #files > 0
        and ""
        or "No Heaven configs were found."
end

function ui.heaven_configs.refresh_config_list(
    force_refresh
)
    if force_refresh ~= true
        and ui.heaven_configs.list_initialized == true then

        return #ui.heaven_configs.detected_configs
    end

    if ui.heaven_configs.scan_in_progress == true then
        return #ui.heaven_configs.detected_configs
    end

    ui.heaven_configs.scan_in_progress = true

    local scan_ok,
        raw_files,
        scan_error =
            pcall(
                ui.heaven_configs.read_directory_lines,
                tostring(
                    ui.heaven_configs.config_directory
                ) ..
                    "\\*.cfg",
                force_refresh == true
            )

    if not scan_ok then
        scan_error =
            tostring(
                raw_files
                or "Process-free config scan failed."
            )

        raw_files = {}
        ui.heaven_configs.scan_backend =
            "Unavailable"
    end

    local detected = {}
    local lookup = {}

    for _, file_name in ipairs(
        type(raw_files) == "table"
        and raw_files
        or {}
    ) do
        local clean_name =
            ui.heaven_configs.clean_config_name(
                file_name
            )

        local lookup_key =
            clean_name:lower()

        if clean_name ~= ""
            and lookup[lookup_key] == nil then

            detected[
                #detected + 1
            ] = {
                name = clean_name,
                file_name =
                    clean_name .. ".cfg"
            }

            lookup[lookup_key] = true
        end
    end

    table.sort(
        detected,
        function(left, right)
            return tostring(
                left.name or ""
            ):lower() <
                tostring(
                    right.name or ""
                ):lower()
        end
    )

    lookup = {}

    for index, entry in ipairs(
        detected
    ) do
        lookup[
            tostring(entry.name):lower()
        ] = index
    end

    ui.heaven_configs.detected_configs = detected
    ui.heaven_configs.detected_lookup = lookup
    ui.heaven_configs.list_initialized = true
    ui.heaven_configs.scan_in_progress = false


    local assignments_changed =
        ui.heaven_configs.reconcile_slot_assignments()

    if assignments_changed then
        ui.heaven_configs.save_settings_now()
    end
    ui.heaven_configs.scan_error =
        #detected > 0
        and ""
        or tostring(scan_error or "")

    if force_refresh == true then
        if #detected > 0 then
            ui.heaven_configs.last_status =
                string.format(
                    "Detected %d config%s.",
                    #detected,
                    #detected == 1
                        and ""
                        or "s"
                )

            ui.heaven_configs.last_status_error = false
            ui.heaven_configs.last_status_expires_at =
                get_time() + 3.0
        else
            ui.heaven_configs.last_status =
                ui.heaven_configs.scan_error ~= ""
                and ui.heaven_configs.scan_error
                or "No Heaven configs were detected."

            ui.heaven_configs.last_status_error = true
            ui.heaven_configs.last_status_expires_at = 0.0
        end
    end

    return #detected
end

function ui.heaven_configs.find_api_function(
    table_names,
    function_names
)
    if type(_G) ~= "table" then
        return nil
    end

    for _, table_name in ipairs(
        table_names or {}
    ) do
        local api_table =
            rawget(
                _G,
                table_name
            )

        if type(api_table) == "table" then
            for _, function_name in ipairs(
                function_names or {}
            ) do
                local candidate =
                    api_table[
                        function_name
                    ]

                if type(candidate) == "function" then
                    return candidate
                end
            end
        end
    end

    for _, function_name in ipairs(
        function_names or {}
    ) do
        local candidate =
            rawget(
                _G,
                function_name
            )

        if type(candidate) == "function" then
            return candidate
        end
    end

    return nil
end

function ui.heaven_configs.to_unsigned32(
    value
)
    value =
        tonumber(value) or 0

    if value < 0 then
        value =
            value + 4294967296
    end

    return value % 4294967296
end

function ui.heaven_configs.to_signed32(
    value
)
    value =
        ui.heaven_configs.to_unsigned32(
            value
        )

    if value >= 2147483648 then
        return value - 4294967296
    end

    return value
end

function ui.heaven_configs.native_read_u32(
    address
)
    local read_function =
        ui.heaven_configs.native.read_int

    if type(read_function) ~= "function"
        or tonumber(address) == nil
        or tonumber(address) <= 0 then

        return nil
    end

    local read_ok,
        value =
            pcall(
                read_function,
                tonumber(address)
            )

    if not read_ok
        or value == nil then

        return nil
    end

    return ui.heaven_configs.to_unsigned32(
        value
    )
end

function ui.heaven_configs.native_write_u32(
    address,
    value
)
    local write_function =
        ui.heaven_configs.native.write_int

    if type(write_function) ~= "function"
        or tonumber(address) == nil
        or tonumber(address) <= 0 then

        return false
    end

    local write_ok =
        pcall(
            write_function,
            tonumber(address),
            ui.heaven_configs.to_signed32(
                value
            ),
            true
        )

    return write_ok == true
end

function ui.heaven_configs.native_module_matches(
    module_base
)
    module_base =
        tonumber(module_base) or 0

    if module_base <= 0 then
        return false
    end

    local loader_rva =
        tonumber(
            ui.heaven_configs.native.loader_rva
        ) or 0x15450


    if ui.heaven_configs.native_read_u32(
        module_base + loader_rva
    ) ~= 0x6AEC8B55 then

        return false
    end


    if ui.heaven_configs.native_read_u32(
        module_base + loader_rva + 0x3D
    ) ~= 0x00107B83 then

        return false
    end


    if ui.heaven_configs.native_read_u32(
        module_base + 0x1CED68
    ) ~= 0x6766632E then

        return false
    end

    return true
end

function ui.heaven_configs.collect_module_candidates()
    local candidates = {}
    local seen = {}

    for _, name in ipairs(
        ui.heaven_configs.native.module_candidates
        or {}
    ) do
        name =
            tostring(name or "")
            :gsub("[\r\n]", "")
            :gsub("^%s+", "")
            :gsub("%s+$", "")

        local key =
            name:lower()

        if name ~= ""
            and not seen[key] then

            seen[key] = true
            candidates[
                #candidates + 1
            ] = name
        end
    end


    return candidates
end

function ui.heaven_configs.set_native_error(
    message
)
    ui.heaven_configs.native.ready = false
    ui.heaven_configs.native.state = "Unavailable"
    ui.heaven_configs.native.error =
        tostring(message or "Native loader unavailable.")

    return false
end

function ui.heaven_configs.initialize_native_loader(
    force_retry
)
    local native =
        ui.heaven_configs.native

    if native.ready == true then
        return true
    end

    if native.state == "Unavailable"
        and force_retry ~= true then

        return false
    end

    local now =
        get_time()

    if force_retry ~= true
        and now <
            (
                tonumber(
                    native.last_attempt
                ) or 0.0
            ) +
            math.max(
                0.5,
                tonumber(
                    native.retry_interval
                ) or 2.0
            ) then

        return false
    end

    native.last_attempt = now
    native.state = "Checking"
    native.error = ""

    native.call_fn =
        ui.heaven_configs.find_api_function(
            {
                "hooks",
                "Hooks"
            },
            {
                "call_fn",
                "CallFn"
            }
        )

    native.get_module_handle =
        ui.heaven_configs.find_api_function(
            {
                "ProcBind",
                "proc",
                "hooks",
                "Hooks"
            },
            {
                "GetModuleHandle",
                "get_module_handle"
            }
        )

    native.get_proc_address =
        ui.heaven_configs.find_api_function(
            {
                "hooks",
                "Hooks",
                "ProcBind",
                "proc"
            },
            {
                "GetProcAddress",
                "get_proc_address"
            }
        )

    native.get_module_base =
        ui.heaven_configs.find_api_function(
            {
                "ProcBind",
                "proc",
                "hooks",
                "Hooks"
            },
            {
                "GetModuleBase",
                "get_module_base",
                "GetModuleHandle",
                "get_module_handle"
            }
        )

    native.get_module_size =
        ui.heaven_configs.find_api_function(
            {
                "ProcBind",
                "proc"
            },
            {
                "GetModuleSize",
                "get_module_size"
            }
        )

    native.read_int =
        ui.heaven_configs.find_api_function(
            {
                "memory",
                "Memory"
            },
            {
                "read_int",
                "ReadInt"
            }
        )

    native.write_int =
        ui.heaven_configs.find_api_function(
            {
                "memory",
                "Memory"
            },
            {
                "write_int",
                "WriteInt"
            }
        )

    if type(native.call_fn) ~= "function"
        or type(native.get_proc_address) ~= "function"
        or type(native.read_int) ~= "function"
        or type(native.write_int) ~= "function"
        or (
            type(native.get_module_handle) ~= "function"
            and type(native.get_module_base) ~= "function"
        ) then

        return ui.heaven_configs.set_native_error(
            "Native Heaven APIs are unavailable. Enable Insecure Lua in Heaven > Lua, then press Recheck."
        )
    end

    local module_base = 0
    local module_name = ""

    for _, candidate_name in ipairs(
        ui.heaven_configs.collect_module_candidates()
    ) do
        local base_value = nil

        if type(native.get_module_handle) == "function" then
            local handle_ok,
                handle_value =
                    pcall(
                        native.get_module_handle,
                        candidate_name
                    )

            if handle_ok then
                base_value = handle_value
            end
        end

        if (
            tonumber(base_value) == nil
            or tonumber(base_value) == 0
        )
            and type(native.get_module_base) == "function" then

            local base_ok,
                fallback_base =
                    pcall(
                        native.get_module_base,
                        candidate_name
                    )

            if base_ok then
                base_value = fallback_base
            end
        end

        base_value =
            ui.heaven_configs.to_unsigned32(
                base_value
            )

        if base_value > 0
            and ui.heaven_configs.native_module_matches(
                base_value
            ) then

            module_base = base_value
            module_name = candidate_name
            break
        end
    end

    if module_base <= 0 then
        return ui.heaven_configs.set_native_error(
            "The loaded Heaven module was not found or does not match the supplied Heaven-beta(5).dll build."
        )
    end

    native.module_base = module_base
    native.module_name = module_name
    native.loader_pointer =
        module_base +
        (
            tonumber(native.loader_rva)
            or 0x15450
        )

    if type(native.get_module_size) == "function" then
        local size_ok,
            module_size =
                pcall(
                    native.get_module_size,
                    module_name
                )

        if size_ok then
            native.module_size =
                tonumber(module_size) or 0
        end
    end

    local kernel32 = 0

    if type(native.get_module_handle) == "function" then
        local kernel_ok,
            kernel_value =
                pcall(
                    native.get_module_handle,
                    "kernel32.dll"
                )

        if kernel_ok then
            kernel32 =
                ui.heaven_configs.to_unsigned32(
                    kernel_value
                )
        end
    end

    if kernel32 <= 0
        and type(native.get_module_base) == "function" then

        local kernel_ok,
            kernel_value =
                pcall(
                    native.get_module_base,
                    "kernel32.dll"
                )

        if kernel_ok then
            kernel32 =
                ui.heaven_configs.to_unsigned32(
                    kernel_value
                )
        end
    end

    if kernel32 <= 0 then
        return ui.heaven_configs.set_native_error(
            "kernel32.dll could not be resolved for the native config bridge."
        )
    end

    native.kernel32 = kernel32

    local function resolve_kernel32_function(function_name)
        local resolve_ok,
            function_pointer =
                pcall(
                    native.get_proc_address,
                    kernel32,
                    function_name
                )

        return resolve_ok
            and ui.heaven_configs.to_unsigned32(
                function_pointer
            )
            or 0
    end

    native.find_first_file =
        resolve_kernel32_function(
            "FindFirstFileA"
        )

    native.find_next_file =
        resolve_kernel32_function(
            "FindNextFileA"
        )

    native.find_close =
        resolve_kernel32_function(
            "FindClose"
        )

    local proc_ok,
        virtual_alloc =
            pcall(
                native.get_proc_address,
                kernel32,
                "VirtualAlloc"
            )

    virtual_alloc =
        proc_ok
        and ui.heaven_configs.to_unsigned32(
            virtual_alloc
        )
        or 0

    if virtual_alloc <= 0 then
        return ui.heaven_configs.set_native_error(
            "VirtualAlloc could not be resolved for the native config bridge."
        )
    end

    if tonumber(
        native.allocation_pointer
    ) == nil
        or tonumber(
            native.allocation_pointer
        ) <= 0 then

        local allocate_ok,
            allocated_pointer =
                pcall(
                    native.call_fn,
                    virtual_alloc,
                    "stdcall",
                    0,
                    tonumber(
                        native.allocation_size
                    ) or 1024,
                    0x3000,
                    0x04
                )

        allocated_pointer =
            allocate_ok
            and ui.heaven_configs.to_unsigned32(
                allocated_pointer
            )
            or 0

        if allocated_pointer <= 0 then
            return ui.heaven_configs.set_native_error(
                "The native config bridge could not allocate its small working buffer."
            )
        end

        native.allocation_pointer =
            allocated_pointer
    end

    native.ready = true
    native.state = "Ready"
    native.error = ""

    return true
end

function ui.heaven_configs.write_native_config_name(
    config_name
)
    local native =
        ui.heaven_configs.native

    config_name =
        ui.heaven_configs.clean_config_name(
            config_name
        )

    local byte_count =
        #config_name

    if native.ready ~= true
        or byte_count <= 0
        or byte_count >
            (
                tonumber(
                    native.string_capacity
                ) or 255
            ) then

        return nil,
            "The selected config name is invalid or too long."
    end

    local allocation_pointer =
        tonumber(
            native.allocation_pointer
        ) or 0

    local object_pointer =
        allocation_pointer +
        (
            tonumber(
                native.string_object_offset
            ) or 0
        )

    local buffer_pointer =
        allocation_pointer +
        (
            tonumber(
                native.string_buffer_offset
            ) or 64
        )

    if allocation_pointer <= 0
        or not ui.heaven_configs.native_write_u32(
            object_pointer,
            buffer_pointer
        )
        or not ui.heaven_configs.native_write_u32(
            object_pointer + 4,
            0
        )
        or not ui.heaven_configs.native_write_u32(
            object_pointer + 8,
            0
        )
        or not ui.heaven_configs.native_write_u32(
            object_pointer + 12,
            0
        )
        or not ui.heaven_configs.native_write_u32(
            object_pointer + 16,
            byte_count
        )
        or not ui.heaven_configs.native_write_u32(
            object_pointer + 20,
            tonumber(
                native.string_capacity
            ) or 255
        ) then

        return nil,
            "The native std::string object could not be prepared."
    end

    for offset = 0,
        byte_count,
        4 do

        local packed_value = 0

        for byte_offset = 0,
            3 do

            local string_index =
                offset +
                byte_offset +
                1

            local byte_value =
                string_index <= byte_count
                and (
                    string.byte(
                        config_name,
                        string_index
                    ) or 0
                )
                or 0

            packed_value =
                packed_value +
                byte_value *
                (
                    256 ^ byte_offset
                )
        end

        if not ui.heaven_configs.native_write_u32(
            buffer_pointer + offset,
            packed_value
        ) then

            return nil,
                "The selected config name could not be copied into the native buffer."
        end
    end

    return object_pointer, ""
end

function ui.heaven_configs.load_config_name(
    config_name,
    source
)
    config_name =
        ui.heaven_configs.clean_config_name(
            config_name
        )

    if config_name == "" then
        ui.heaven_configs.last_status =
            "Select a Heaven config first."

        ui.heaven_configs.last_status_error = true
        return false
    end

    local config_known =
        ui.heaven_configs.config_is_detected(
            config_name
        )
        or ui.heaven_configs.config_file_exists(
            config_name
        )

    if not config_known then
        ui.heaven_configs.last_status =
            "Config not found: " ..
            config_name ..
            ".cfg. Press Refresh."

        ui.heaven_configs.last_status_error = true
        return false
    end

    if not ui.heaven_configs.initialize_native_loader(
        false
    ) then
        ui.heaven_configs.last_status =
            tostring(
                ui.heaven_configs.native.error
                or "Native Heaven loader unavailable."
            )

        ui.heaven_configs.last_status_error = true
        return false
    end

    local object_pointer,
        prepare_error =
            ui.heaven_configs.write_native_config_name(
                config_name
            )

    if not object_pointer then
        ui.heaven_configs.last_status =
            tostring(prepare_error)

        ui.heaven_configs.last_status_error = true
        return false
    end

    local call_ok,
        load_result =
            pcall(
                ui.heaven_configs.native.call_fn,
                tonumber(
                    ui.heaven_configs.native.loader_pointer
                ),
                "thiscall",
                object_pointer
            )

    local loaded =
        call_ok
        and (
            load_result == true
            or tonumber(load_result) == 1
        )

    if not loaded then
        ui.heaven_configs.last_status =
            call_ok
            and (
                "Heaven rejected config: " ..
                config_name ..
                ".cfg"
            )
            or (
                "Native config call failed: " ..
                tostring(load_result)
            )

        ui.heaven_configs.last_status_error = true
        return false
    end

    ui.heaven_configs.last_loaded_config =
        config_name

    ui.heaven_configs.last_status =
        "Loaded Heaven config: " ..
        config_name ..
        ".cfg"

    ui.heaven_configs.last_status_error = false

    ui.console.print(
        "[DST Config Hotkeys] " ..
        ui.heaven_configs.last_status ..
        (
            source
            and source ~= ""
            and (
                " [" ..
                tostring(source) ..
                "]"
            )
            or ""
        )
    )

    return true
end

function ui.heaven_configs.apply_slot(
    slot_index,
    source
)
    ui.heaven_configs.normalize_settings()

    slot_index =
        math.floor(
            tonumber(slot_index) or 0
        )

    local slot =
        ui.heaven_configs.slots[
            slot_index
        ]

    if not slot then
        return false
    end

    local loaded =
        ui.heaven_configs.load_config_name(
            slot.config_name,
            source
        )

    if loaded then
        ui.heaven_configs.last_applied_slot =
            slot_index
    end

    return loaded
end

function ui.heaven_configs.first_startup_config_slot()
    ui.heaven_configs.normalize_settings()

    for index = 1, ui.heaven_configs.max_slots do
        local slot = ui.heaven_configs.slots[index]

        if slot
            and slot.enabled == true
            and ui.heaven_configs.clean_config_name(
                slot.config_name
            ) ~= "" then

            return index
        end
    end

    return 0
end

function ui.heaven_configs.finish_startup_auto_load(
    success,
    message
)
    ui.heaven_configs.startup_auto_load_completed = true
    ui.heaven_configs.startup_auto_load_next_attempt = 0.0

    if message and tostring(message) ~= "" then
        ui.heaven_configs.last_status = tostring(message)
        ui.heaven_configs.last_status_error = success ~= true
        ui.heaven_configs.last_status_expires_at =
            get_time() + (success == true and 3.0 or 5.0)
    end
end

function ui.heaven_configs.update_startup_auto_load()
    if ui.heaven_configs.startup_auto_load_completed == true then
        return
    end

    if ui.settings_io
        and ui.settings_io.loaded ~= true then

        return
    end

    if ui.heaven_configs.auto_load_first_config == false then
        ui.heaven_configs.finish_startup_auto_load(
            true,
            nil
        )
        return
    end

    local now = get_time()

    if ui.heaven_configs.startup_auto_load_initialized ~= true then
        ui.heaven_configs.startup_auto_load_initialized = true
        ui.heaven_configs.startup_auto_load_next_attempt = now + 0.75
        ui.heaven_configs.startup_auto_load_deadline = now + 12.0
        ui.heaven_configs.startup_auto_load_attempts = 0
        return
    end

    if now <
        (tonumber(
            ui.heaven_configs.startup_auto_load_next_attempt
        ) or 0.0) then

        return
    end

    local slot_index =
        ui.heaven_configs.first_startup_config_slot()

    if slot_index <= 0 then
        ui.heaven_configs.finish_startup_auto_load(
            true,
            nil
        )
        return
    end

    local slot = ui.heaven_configs.slots[slot_index]
    local config_name =
        ui.heaven_configs.clean_config_name(
            slot and slot.config_name or ""
        )

    ui.heaven_configs.startup_auto_load_attempts =
        (tonumber(
            ui.heaven_configs.startup_auto_load_attempts
        ) or 0) + 1

    local native_ready =
        ui.heaven_configs.initialize_native_loader(
            true
        )

    if native_ready
        and ui.heaven_configs.config_file_exists(
            config_name
        ) then

        if ui.heaven_configs.apply_slot(
            slot_index,
            "Lua startup"
        ) then

            ui.heaven_configs.finish_startup_auto_load(
                true,
                nil
            )
            return
        end
    end

    local deadline =
        tonumber(
            ui.heaven_configs.startup_auto_load_deadline
        ) or now

    if now >= deadline then
        ui.heaven_configs.finish_startup_auto_load(
            false,
            "Could not auto-load first Heaven config: " ..
                config_name ..
                ".cfg"
        )
        return
    end

    ui.heaven_configs.startup_auto_load_next_attempt =
        now + 1.0
end

function ui.heaven_configs.reserved_key_reason(
    key_value
)
    key_value =
        math.floor(
            tonumber(key_value) or 0
        )

    if key_value <= 0 then
        return nil
    end

    if key_value ==
        (keys.ESCAPE or 0x1B) then

        return "Escape cancels key capture."
    end

    if ui.network.f5_toggle_enabled == true
        and key_value ==
            (
                tonumber(
                    ui.network.toggle_key
                ) or 0x74
            ) then

        return ui.control.get_key_name(
            key_value
        ) .. " is used by Game & Net."
    end

    if type(ui.quotes) == "table"
        and type(
            ui.quotes.settings
        ) == "table"
        and ui.quotes.settings.f7_toggle_enabled == true
        and key_value ==
            (
                tonumber(
                    ui.quotes.settings.layout_toggle_key
                ) or 0x76
            ) then

        return ui.control.get_key_name(
            key_value
        ) .. " is used by Quotes."
    end

    if ui.control.f8_toggle_enabled == true
        and key_value ==
            (
                tonumber(
                    ui.control.toggle_key
                ) or 0x77
            ) then

        return "That key is used by the Gameplay tool cycle."
    end

    if key_value ==
        (
            tonumber(
                ui.control.action_key
            ) or 0
        ) then

        return "That key is the Gameplay hold key."
    end

    return nil
end

function ui.heaven_configs.key_used_by_other_slot(
    key_value,
    ignored_slot
)
    key_value =
        math.floor(
            tonumber(key_value) or 0
        )

    for index,
        slot in ipairs(
            ui.heaven_configs.slots
        ) do

        if index ~= ignored_slot
            and math.floor(
                tonumber(slot.key) or 0
            ) == key_value
            and key_value > 0 then

            return index
        end
    end

    return nil
end

function ui.heaven_configs.get_bindable_keys()
    if type(ui.heaven_configs.bindable_keys) == "table" then
        return ui.heaven_configs.bindable_keys
    end

    local keys_found = {}
    local seen = {}

    local function add_key(key_value, display_name)
        key_value = math.floor(tonumber(key_value) or 0)

        if key_value > 0
            and key_value <= 255
            and not seen[key_value] then

            seen[key_value] = true
            keys_found[#keys_found + 1] = key_value

            if display_name
                and type(ui.control.key_names) == "table"
                and ui.control.key_names[key_value] == nil then

                ui.control.key_names[key_value] = display_name
            end
        end
    end

    for key_value in pairs(
        type(ui.control.key_names) == "table"
        and ui.control.key_names
        or {}
    ) do
        add_key(key_value)
    end

    for number = 0, 9 do
        add_key(0x30 + number, tostring(number))
        add_key(0x60 + number, "NUM " .. tostring(number))
    end

    add_key(0x21, "PAGE UP")
    add_key(0x22, "PAGE DOWN")
    add_key(0x23, "END")
    add_key(0x24, "HOME")
    add_key(0x25, "LEFT")
    add_key(0x26, "UP")
    add_key(0x27, "RIGHT")
    add_key(0x28, "DOWN")
    add_key(0x2D, "INSERT")
    add_key(0x2E, "DELETE")

    add_key(0xBA, ";")
    add_key(0xBB, "=")
    add_key(0xBC, ",")
    add_key(0xBD, "-")
    add_key(0xBE, ".")
    add_key(0xBF, "/")
    add_key(0xC0, "`")
    add_key(0xDB, "[")
    add_key(0xDC, "\\")
    add_key(0xDD, "]")
    add_key(0xDE, "'")
    add_key(0xE2, "OEM 102")

    table.sort(keys_found)
    ui.heaven_configs.bindable_keys = keys_found

    return keys_found
end

function ui.heaven_configs.enabled_cycle_slots()
    local cycle_slots = {}

    for index = 1, ui.heaven_configs.max_slots do
        local slot =
            ui.heaven_configs.slots[index]

        local config_name =
            slot
            and ui.heaven_configs.clean_config_name(
                slot.config_name
            )
            or ""

        if slot
            and slot.enabled == true
            and config_name ~= ""
            and ui.heaven_configs.config_is_detected(
                config_name
            ) then

            cycle_slots[#cycle_slots + 1] = index
        end
    end

    return cycle_slots
end

function ui.heaven_configs.cycle_next_enabled_config()
    ui.heaven_configs.normalize_settings()

    local cycle_slots =
        ui.heaven_configs.enabled_cycle_slots()

    if #cycle_slots <= 0 then
        ui.heaven_configs.last_status =
            "No enabled configs to cycle."

        ui.heaven_configs.last_status_error = true
        return false
    end

    local current_name =
        ui.heaven_configs.clean_config_name(
            ui.heaven_configs.last_loaded_config
        ):lower()

    local next_position = 1

    if current_name ~= "" then
        for position, slot_index in ipairs(cycle_slots) do
            local slot_name =
                ui.heaven_configs.clean_config_name(
                    ui.heaven_configs.slots[
                        slot_index
                    ].config_name
                ):lower()

            if slot_name == current_name then
                next_position =
                    position % #cycle_slots + 1

                break
            end
        end
    end

    return ui.heaven_configs.apply_slot(
        cycle_slots[next_position],
        "cycle key"
    )
end

function ui.heaven_configs.begin_key_capture(
    slot_index
)
    ui.heaven_configs.waiting_for_cycle_key = false

    ui.heaven_configs.waiting_for_key_slot =
        math.max(
            1,
            math.min(
                ui.heaven_configs.max_slots,
                math.floor(
                    tonumber(slot_index) or 1
                )
            )
        )

    local now = get_time()

    ui.heaven_configs.key_capture_started_at = now
    ui.heaven_configs.key_capture_ready_at = now + 0.08
    ui.heaven_configs.key_capture_waiting_release = true

    if type(ui.control) == "table" then
        ui.control.waiting_for_key = false
        ui.control.waiting_for_pursuit_key = false
        ui.control.waiting_for_toggle_key = false
    end

    ui.heaven_configs.last_status =
        "Press a key. Esc cancels."

    ui.heaven_configs.last_status_error = false
end

function ui.heaven_configs.begin_cycle_key_capture()
    ui.heaven_configs.waiting_for_key_slot = 0
    ui.heaven_configs.waiting_for_cycle_key = true

    local now = get_time()

    ui.heaven_configs.key_capture_started_at = now
    ui.heaven_configs.key_capture_ready_at = now + 0.08
    ui.heaven_configs.key_capture_waiting_release = true

    if type(ui.control) == "table" then
        ui.control.waiting_for_key = false
        ui.control.waiting_for_pursuit_key = false
        ui.control.waiting_for_toggle_key = false
    end

    ui.heaven_configs.last_status =
        "Press the cycle key. Esc cancels."

    ui.heaven_configs.last_status_error = false
end

function ui.heaven_configs.cancel_key_capture()
    ui.heaven_configs.waiting_for_key_slot = 0
    ui.heaven_configs.waiting_for_cycle_key = false
    ui.heaven_configs.key_capture_waiting_release = false
end

function ui.heaven_configs.capture_keybind()
    if ui.input_safety.block_runtime_hotkeys() then
        return
    end

    local capture_cycle_key =
        ui.heaven_configs.waiting_for_cycle_key == true

    local slot_index =
        math.floor(
            tonumber(
                ui.heaven_configs.waiting_for_key_slot
            ) or 0
        )

    if not capture_cycle_key
        and slot_index <= 0 then

        return
    end

    if type(input) ~= "table"
        or type(input.is_key_pressed) ~= "function" then

        return
    end

    local now = get_time()

    if now -
        (tonumber(ui.heaven_configs.key_capture_started_at) or now) >=
        math.max(
            2.0,
            tonumber(ui.heaven_configs.key_capture_timeout) or 10.0
        ) then

        ui.heaven_configs.cancel_key_capture()
        ui.heaven_configs.last_status = "Key binding timed out."
        ui.heaven_configs.last_status_error = true
        return
    end

    if ui.heaven_configs.key_capture_waiting_release == true then
        if type(input.is_key_down) == "function" then
            local mouse_ok,
                mouse_down =
                    pcall(
                        input.is_key_down,
                        keys.MOUSE1 or 0x01
                    )

            if mouse_ok and mouse_down == true then
                return
            end
        end

        ui.heaven_configs.key_capture_waiting_release = false
        ui.heaven_configs.key_capture_ready_at = now + 0.04
        return
    end

    if now <
        (tonumber(ui.heaven_configs.key_capture_ready_at) or 0.0) then

        return
    end

    for _, key_value in ipairs(
        ui.heaven_configs.get_bindable_keys()
    ) do
        local pressed_ok,
            pressed =
                pcall(
                    input.is_key_pressed,
                    key_value
                )

        if pressed_ok and pressed == true then
            if key_value == (keys.ESCAPE or 0x1B) then
                ui.heaven_configs.cancel_key_capture()
                ui.heaven_configs.last_status = "Key binding cancelled."
                ui.heaven_configs.last_status_error = false
                return
            end

            local reserved_reason =
                ui.heaven_configs.reserved_key_reason(
                    key_value
                )

            if reserved_reason then
                ui.heaven_configs.cancel_key_capture()
                ui.heaven_configs.last_status = reserved_reason
                ui.heaven_configs.last_status_error = true
                return
            end

            if capture_cycle_key then
                ui.heaven_configs.cycle_key = key_value
                ui.heaven_configs.cycle_key_was_down = true
                ui.heaven_configs.last_status =
                    "Cycle key: " ..
                    ui.control.get_key_name(key_value)

                ui.heaven_configs.last_status_error = false
                ui.heaven_configs.save_settings_now()
            else
                local duplicate_slot =
                    ui.heaven_configs.key_used_by_other_slot(
                        key_value,
                        slot_index
                    )

                if duplicate_slot then
                    ui.heaven_configs.cancel_key_capture()
                    ui.heaven_configs.last_status =
                        "Already used by Hotkey " ..
                        tostring(duplicate_slot) ..
                        "."

                    ui.heaven_configs.last_status_error = true
                    return
                end

                local slot =
                    ui.heaven_configs.slots[slot_index]

                if slot then
                    slot.key = key_value
                    ui.heaven_configs.hotkey_was_down[slot_index] = true
                    ui.heaven_configs.last_status =
                        "Hotkey " ..
                        tostring(slot_index) ..
                        ": " ..
                        ui.control.get_key_name(key_value)

                    ui.heaven_configs.last_status_error = false
                    ui.heaven_configs.save_settings_now()
                end
            end

            ui.heaven_configs.cancel_key_capture()
            return
        end
    end
end

