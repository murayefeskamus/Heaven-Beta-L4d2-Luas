function ui.kill_tools.get_activity_rows()
    local feed =
        ui.kill_tools.kill_feed

    local settings =
        ui.kill_tools.message_on_kill

    local status_value =
        settings.enabled == true
        and tostring(
            settings.status or "IDLE"
        )
        or "IDLE"

    local status_color = {
        0.70,
        0.70,
        0.70,
        1.00
    }

    if settings.enabled == true then
        if status_value == "READY"
            or status_value == "SENT"
            or status_value == "QUEUED" then

            status_color = {
                0.20,
                1.00,
                0.20,
                1.00
            }
        elseif status_value == "COOLDOWN"
            or status_value == "WAITING FOR CHAT" then

            status_color = {
                1.00,
                0.75,
                0.20,
                1.00
            }
        else
            status_color = {
                1.00,
                0.45,
                0.25,
                1.00
            }
        end
    end

    local next_message_value = "None"

    if #settings.pending > 0 then
        next_message_value =
            truncate_preview(
                tostring(
                    settings.pending[1].text
                    or "None"
                ),
                DARKSIDE_CONFIG.CHAT_MESSAGE_PREVIEW_LENGTH
            )
    else
        local next_template =
            ui.kill_tools.peek_message_template()

        if next_template then
            next_message_value =
                truncate_preview(
                    next_template,
                    DARKSIDE_CONFIG.CHAT_MESSAGE_PREVIEW_LENGTH
                )
        end
    end

    return {
            {
                label = "Status",
                value = status_value,
                color = status_color
            },
            {
                label = "Next message",
                value = next_message_value,
                color = next_message_value ~= "None"
                    and {
                        0.25,
                        0.85,
                        1.00,
                        1.00
                    }
                    or {
                        0.70,
                        0.70,
                        0.70,
                        1.00
                    }
            },
            {
                label = "Last posted message",
                value = tostring(
                    settings.last_message
                    or "None"
                ) == "None"
                    and "None"
                    or truncate_preview(
                        tostring(settings.last_message),
                        DARKSIDE_CONFIG.CHAT_MESSAGE_PREVIEW_LENGTH
                    ),
                color = tostring(
                    settings.last_message
                    or "None"
                ) == "None"
                    and {
                        0.70,
                        0.70,
                        0.70,
                        1.00
                    }
                    or nil
            },
            {
                label = "Last kill-feed line",
                value = tostring(
                    feed.last_message
                    or "None"
                ) == "None"
                    and "None"
                    or truncate_preview(
                        tostring(feed.last_message),
