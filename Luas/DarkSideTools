function ui.setting_search.open_selected()
    ui.setting_search.refresh_matches()

    if ui.setting_search.query == "" then
        ui.setting_search.set_status("Enter a setting keyword first.", true)
        return false
    end

    local result =
        ui.setting_search.matches[ui.setting_search.selected_match]

    if not result then
        ui.setting_search.set_status(
            "No setting matches '" .. tostring(ui.setting_search.query) .. "'.",
            true
        )
        return false
    end

    local tool_index = ui.setting_search.tool_indices[result.tab_key]
    if tool_index == nil then
        ui.setting_search.set_status("The matched tab is unavailable.", true)
        return false
    end

    ui.selected_tool = tool_index
    if tool_index == 4 then
        ui.lobby.force_refresh = true
    end

    ui.setting_search.expand_section(result.tab_key, result.section_key)
    ui.setting_search.pending_tab = tostring(result.tab_key)
    ui.setting_search.pending_section = tostring(result.section_key)
    ui.setting_search.pending_frames = 1

    ui.setting_search.set_status(
        "Opened " .. tostring(result.tab_label) .. " > " ..
            tostring(result.section_label) .. ".",
        false
    )

    return true
end

function ui.section_layout.draw_sections(tab_key, renderers)
    renderers = type(renderers) == "table" and renderers or {}

    local rendered_count = 0
    for _, section_key in ipairs(ui.section_layout.normalize_order(tab_key)) do
        local renderer = renderers[section_key]

        if type(renderer) == "function" then
            if rendered_count > 0 then
                draw_compact_gap()
            end

            local is_search_target =
                ui.setting_search.pending_frames > 0 and
                tostring(ui.setting_search.pending_tab) == tostring(tab_key) and
                tostring(ui.setting_search.pending_section) == tostring(section_key)

            if is_search_target then
                ui.setting_search.expand_section(tab_key, section_key)

                if type(imgui.set_scroll_here_y) == "function" then
                    pcall(imgui.set_scroll_here_y, 0.0)
                elseif type(imgui.set_scroll_here) == "function" then
                    pcall(imgui.set_scroll_here, 0.0)
                end

                ui.setting_search.pending_frames = 0
                ui.setting_search.pending_tab = ""
                ui.setting_search.pending_section = ""
            end

            renderer()
            rendered_count = rendered_count + 1
        end
    end
end

function ui.setting_search.draw_header_controls()
    local window_width = 0.0
    if type(imgui.get_window_width) == "function" then
        local ok, value = pcall(imgui.get_window_width)
        if ok then
            window_width = tonumber(value) or 0.0
        end
    end

    local search_label_width = 48
    local search_input_width = 205
    local go_button_width = ui.lobby.measure_text_width("GO") + 18
    local clear_button_width = ui.lobby.measure_text_width("CLEAR") + 18
    local total_width =
        search_label_width +
        search_input_width +
        go_button_width +
        clear_button_width +
        24
    local current_x = ui.lobby.get_cursor_x()
    local desired_x = window_width > 0
        and math.max(current_x + 18, window_width - total_width - 18)
        or current_x + 220

    imgui.same_line()
    ui.lobby.set_cursor_x(desired_x)
    imgui.text("Search:")
    imgui.same_line()
    imgui.push_item_width(search_input_width)

    local changed, query_value = imgui.input_text(
        "##DSTGlobalSettingSearch",
        ui.setting_search.query,
        96
    )

    imgui.pop_item_width()

    local now = get_time()
    local input_is_active = false

    for _, method_name in ipairs({
        "is_item_active",
        "is_item_focused"
    }) do
        local method = imgui[method_name]
        if type(method) == "function" then
            local ok, value = pcall(method)
            if ok and value == true then
                input_is_active = true
                break
            end
        end
    end

    if changed then
        ui.setting_search.query = tostring(query_value or "")
        ui.setting_search.selected_match = 1
        ui.setting_search.refresh_matches()
        ui.setting_search.input_active_until = now + 4.0
    elseif input_is_active then
        ui.setting_search.input_active_until = now + 0.35
    end

    local enter_pressed = false
    if type(input) == "table"
        and type(input.is_key_pressed) == "function" then

        local ok, pressed = pcall(
            input.is_key_pressed,
            keys.ENTER or 0x0D
        )

        enter_pressed = ok and pressed == true
    end

    local submitted_with_enter =
        enter_pressed
        and now >= ui.setting_search.last_enter_at + 0.20
        and (
            input_is_active
            or now <= ui.setting_search.input_active_until
        )

    if submitted_with_enter then
        ui.setting_search.last_enter_at = now
        ui.setting_search.open_selected()
    end

    imgui.same_line()
    if colored_button(
        "GO##DSTGlobalSettingSearchGo",
        1.0, 1.0, 1.0,
        0.10, 0.38, 0.70
    ) then
        ui.setting_search.open_selected()
    end

    imgui.same_line()
    if ui.setting_search.normalize(ui.setting_search.query) == "" then
        disabled_button("CLEAR##DSTGlobalSettingSearchClear")
    elseif colored_button(
        "CLEAR##DSTGlobalSettingSearchClear",
        1.0, 1.0, 1.0,
        0.42, 0.12, 0.12
    ) then
        ui.setting_search.clear()
    end
end

