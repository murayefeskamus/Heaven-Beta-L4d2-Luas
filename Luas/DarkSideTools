    local scale = 1.0

    if theme.font_preset_index == 1 then
        scale = 0.88
    elseif theme.font_preset_index == 2 then
        scale = 1.18
    elseif theme.font_preset_index == 3 then
        scale =
            math.max(
                0.70,
                math.min(
                    1.50,
                    tonumber(theme.font_scale) or 1.0
                )
            )
    end

    pcall(
        imgui.set_window_font_scale,
        scale
    )
end

function ui.network.draw_overlay()
    if not ui.network.overlay_visible then
        return
    end

    local overlay_palette =
        ui.enhancements.theme_palette()

    local network_opacity_colors = 0
    local network_overlay_opacity =
        math.max(
            0.0,
            math.min(
                1.0,
                tonumber(
                    ui.network.background_opacity
                ) or 1.0
            )
        )

    if type(imgui.push_style_color) == "function" then
        local function push_network_opacity_color(
            color_index,
            source_color,
            alpha_multiplier,
            preserve_alpha
        )
            source_color =
                type(source_color) == "table"
                and source_color
                or { 0.0, 0.0, 0.0, 1.0 }

            imgui.push_style_color(
                color_index,
                tonumber(source_color[1]) or 0.0,
                tonumber(source_color[2]) or 0.0,
                tonumber(source_color[3]) or 0.0,
                (tonumber(source_color[4]) or 1.0) *
                    (preserve_alpha == true
                        and 1.0
                        or network_overlay_opacity) *
                    (tonumber(alpha_multiplier) or 1.0)
            )

            network_opacity_colors =
                network_opacity_colors + 1
        end

        push_network_opacity_color(0, overlay_palette.text, 1.0, true)
        push_network_opacity_color(1, overlay_palette.text_disabled, 1.0, true)
        push_network_opacity_color(2, overlay_palette.background)
        push_network_opacity_color(3, overlay_palette.child or overlay_palette.background)
        push_network_opacity_color(5, overlay_palette.border or overlay_palette.separator or overlay_palette.accent)
        local standalone_title_background =
            overlay_palette.title_active or
            overlay_palette.accent or
            overlay_palette.title or
            overlay_palette.background

        push_network_opacity_color(10, standalone_title_background)
        push_network_opacity_color(11, standalone_title_background)
        push_network_opacity_color(12, standalone_title_background)
        push_network_opacity_color(14, overlay_palette.scrollbar_bg or overlay_palette.background)
        push_network_opacity_color(15, overlay_palette.scrollbar_grab or overlay_palette.frame)
        push_network_opacity_color(16, overlay_palette.scrollbar_hovered or overlay_palette.scrollbar_grab)
        push_network_opacity_color(17, overlay_palette.scrollbar_active or overlay_palette.scrollbar_grab)
        push_network_opacity_color(21, overlay_palette.button)
        push_network_opacity_color(22, overlay_palette.button_hovered or overlay_palette.button)
        push_network_opacity_color(23, overlay_palette.button_active or overlay_palette.button)
        push_network_opacity_color(27, overlay_palette.separator or overlay_palette.border)
        push_network_opacity_color(28, overlay_palette.separator_hovered or overlay_palette.accent)
        push_network_opacity_color(29, overlay_palette.separator_active or overlay_palette.accent)
        push_network_opacity_color(30, overlay_palette.resize or overlay_palette.frame)
        push_network_opacity_color(31, overlay_palette.resize_hovered or overlay_palette.accent)
        push_network_opacity_color(32, overlay_palette.resize_active or overlay_palette.accent)
    end

    local overlay_view_name =
        ui.network.details_expanded
        and "Detailed"
        or "Compact"

    local overlay_view_key =
        ui.network.details_expanded
        and "detailed"
        or "compact"

    ui.network.overlay_resize_frames =
        type(ui.network.overlay_resize_frames) == "table"
        and ui.network.overlay_resize_frames
        or {
            compact = 2,
            detailed = 2
        }

    local network_resize_frames =
        math.max(
            0,
            math.floor(
                tonumber(
                    ui.network.overlay_resize_frames[
                        overlay_view_key
                    ]
                ) or 0
            )
        )

    local position_slot =
        ui.window_positions.get_slot(
            ui.network.window_positions,
            ui.network.details_expanded
        )

    local size_slot =
        ui.window_sizes.get_slot(
            ui.network.window_sizes,
            ui.network.details_expanded
        )

    local network_window_flags =
        network_resize_frames > 0
        and size_slot.valid ~= true
        and 64
        or 0

    if ui.network.position_restore_pending
        or ui.network.last_overlay_view ~= overlay_view_key then

        ui.window_positions.apply(
            position_slot
        )

        ui.window_sizes.apply(
            size_slot
        )

        ui.network.position_restore_pending = false
        ui.network.last_overlay_view = overlay_view_key
    end

    local network_title_text_pushed = false

    if type(imgui.push_style_color) == "function" then
        local standalone_title_background =
            overlay_palette.title_active or
            overlay_palette.accent or
            overlay_palette.title or
            overlay_palette.background

        local standalone_title_text =
            ui.control.contrast_text_color(
                standalone_title_background
            )

        local title_push_ok,
            title_push_result =
                pcall(
                    imgui.push_style_color,
                    0,
                    standalone_title_text[1],
                    standalone_title_text[2],
                    standalone_title_text[3],
                    1.0
                )

        network_title_text_pushed =
            title_push_ok
            and title_push_result ~= false
    end

    local window_open =
        imgui.begin(
            "Game & Net [" ..
                ui.control.get_key_name(
                    ui.network.toggle_key
                ) ..
                ": " ..
                overlay_view_name ..
                "]###DarkSideToolsGameNetworkOverlay" ..
                overlay_view_name,
            network_window_flags
        )

    if network_title_text_pushed
        and type(imgui.pop_style_color) == "function" then

        pcall(
            imgui.pop_style_color
        )
    end

    ui.network.rendering_overlay = true
    ui.network.overlay_label_column_width =
        ui.network.calculate_overlay_label_width(
            ui.network.details_expanded == true
        )

    ui.network.overlay_value_column_width =
        ui.network.details_expanded == true
        and 190
        or 154

    if ui.performance.should_capture_window_state(
        "network_" .. overlay_view_key,
        network_resize_frames > 0
    ) then
        ui.window_positions.capture(
            position_slot
        )

        ui.window_sizes.capture(
            size_slot
        )
    end

    if window_open then
        ui.network.apply_overlay_font_scale()

        if ui.network.details_expanded then
            ui.network.draw_detailed_overlay()
        else
            ui.network.draw_compact_overlay()
        end
    end

    ui.network.rendering_overlay = false

    imgui["end"]()

    if network_resize_frames > 0 then
        ui.network.overlay_resize_frames[
            overlay_view_key
        ] = network_resize_frames - 1
    end

    ui.performance.pop_style_colors(
        network_opacity_colors
    )

end


function ui.control.clamp(
    value,
    minimum,
    maximum
)
    value = tonumber(value) or minimum

    return math.max(
        minimum,
        math.min(
            maximum,
            value
        )
    )
end

function ui.control.normalize_angle(
    angle
)
    angle = tonumber(angle) or 0.0

    while angle > 180.0 do
        angle = angle - 360.0
    end

    while angle < -180.0 do
        angle = angle + 360.0
    end

    return angle
end

function ui.control.calculate_angle(
    source,
    destination
)
    if not source
        or not destination then

        return nil
    end

    local delta =
        vector.new(
            destination.x - source.x,
            destination.y - source.y,
            destination.z - source.z
        )

    local horizontal =
        math.sqrt(
            delta.x * delta.x +
            delta.y * delta.y
        )

    return vector.new(
        math.deg(
            math.atan2(
                -delta.z,
                horizontal
            )
        ),
        math.deg(
            math.atan2(
                delta.y,
                delta.x
            )
        ),
        0.0
    )
end

function ui.control.get_fov(
    view_angles,
    aim_angles
)
    if not view_angles
        or not aim_angles then

        return math.huge
    end

    local pitch_delta =
        ui.control.normalize_angle(
            aim_angles.x -
            view_angles.x
        )

    local yaw_delta =
        ui.control.normalize_angle(
            aim_angles.y -
            view_angles.y
        )

    return math.sqrt(
        pitch_delta * pitch_delta +
        yaw_delta * yaw_delta
    )
end

function ui.control.smooth_angles_v1(
    current,
    target,
    smooth
)
    smooth = tonumber(smooth) or 1.0

    if smooth <= 0.0 then
        return target
    end

    local factor =
        1.0 / smooth

    return vector.new(
        current.x +
            ui.control.normalize_angle(
                target.x - current.x
            ) * factor,
        current.y +
            ui.control.normalize_angle(
                target.y - current.y
            ) * factor,
        0.0
    )
end

function ui.control.smooth_angles_v2(
    current,
    target,
    smooth
)
    smooth =
        math.max(
            1.0,
            tonumber(smooth) or 1.0
        )

    local factor =
        math.min(
            1.0,
            1.0 / smooth
        )

    return vector.new(
        ui.control.clamp(
            current.x +
                ui.control.normalize_angle(
                    target.x - current.x
                ) * factor,
            -89.0,
            89.0
        ),
        ui.control.normalize_angle(
            current.y +
                ui.control.normalize_angle(
                    target.y - current.y
                ) * factor
        ),
        0.0
    )
end


