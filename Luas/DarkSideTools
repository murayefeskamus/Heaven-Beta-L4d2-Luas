function ui.control.aim_guided_wrap_lines(text_value, maximum_width)
    text_value = tostring(text_value or "")
    maximum_width = math.max(180.0, tonumber(maximum_width) or 720.0)

    local output = {}

    for paragraph in (text_value .. "\n"):gmatch("(.-)\n") do
        if paragraph == "" then
            table.insert(output, "")
        else
            local line = ""

            for word in paragraph:gmatch("%S+") do
                local candidate = line == "" and word or (line .. " " .. word)
                local width = ui.lobby.measure_text_width(candidate)

                if line ~= "" and width > maximum_width then
                    table.insert(output, line)
                    line = word
                else
                    line = candidate
                end
            end

            if line ~= "" then
                table.insert(output, line)
            end
        end
    end

    if #output == 0 then output[1] = "" end
    return output
end

