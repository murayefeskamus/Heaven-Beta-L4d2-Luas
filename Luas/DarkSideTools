function ui.control.aim_v2_simple_get_userid(player)
    if not player then return 0 end

    local candidates = {
        ui.lobby.call_method(player, "get_user_id"),
        ui.lobby.call_method(player, "get_userid"),
        ui.lobby.call_method(player, "get_prop", "m_iUserID")
    }

    for _, value in ipairs(candidates) do
        value = tonumber(value)
        if value and value > 0 then
            return math.floor(value)
        end
    end

    return 0
end

function ui.control.aim_v2_simple_get_eye_position(player)
    if not player then return nil end

    local eye = ui.lobby.call_method(player, "get_eye_position")
    if eye then return eye end

    local origin = ui.lobby.call_method(player, "get_origin")
    if not origin then return nil end

    return vector.new(
        tonumber(origin.x) or 0.0,
        tonumber(origin.y) or 0.0,
        (tonumber(origin.z) or 0.0) + 48.0
    )
end

function ui.control.aim_v2_simple_build_target(local_player, target_index, settings, current_angles, held)
    local player = entity.get_by_index(target_index)
    if not player then return nil end

    local local_index = tonumber(ui.lobby.call_method(local_player, "get_index")) or -1
    local player_index = tonumber(ui.lobby.call_method(player, "get_index")) or -1
    local team = tonumber(ui.lobby.call_method(player, "get_team")) or 0

    if player_index ~= tonumber(target_index)
        or player_index == local_index
        or team ~= 2 then
        return nil
    end

    local incapacitated, hanging = ui.control.get_survivor_state(player)

    if held ~= true then
        local valid = ui.control.is_valid_survivor(
            player,
            local_index,
            settings.target_incapacitated == true,
            settings.target_hanging == true
        )
        if valid ~= true then return nil end
    end

    local eye_position = ui.control.aim_v2_simple_get_eye_position(local_player)
    local target_origin = ui.lobby.call_method(player, "get_origin")
    if not eye_position or not target_origin then return nil end

    local aim_position = ui.control.get_target_point_position(
        player,
        settings.target_point,
        incapacitated,
        settings
    )
    if not aim_position then return nil end

    local distance = vector.distance(eye_position, target_origin)
    if held ~= true and distance > settings.max_distance then return nil end

    if settings.visible_only == true and held ~= true then
        local visible = ui.control.is_target_visible(
            local_player,
            player,
            eye_position,
            aim_position,
            target_index
        )
        if visible ~= true then return nil end
    end

    local prediction_time = 0.0
    if settings.prediction == true and settings.prediction_time > 0.0 then
        local target_velocity = ui.lobby.call_method(player, "get_velocity")
        if target_velocity then
            local velocity_x = tonumber(target_velocity.x) or 0.0
            local velocity_y = tonumber(target_velocity.y) or 0.0
            local velocity_z = tonumber(target_velocity.z) or 0.0

            if settings.relative_prediction == true then
                local local_velocity = ui.lobby.call_method(local_player, "get_velocity")
                if local_velocity then
                    velocity_x = velocity_x - (tonumber(local_velocity.x) or 0.0)
                    velocity_y = velocity_y - (tonumber(local_velocity.y) or 0.0)
                end
            end

            prediction_time = settings.prediction_time
            aim_position = vector.new(
                (tonumber(aim_position.x) or 0.0) + velocity_x * prediction_time,
                (tonumber(aim_position.y) or 0.0) + velocity_y * prediction_time,
                tonumber(aim_position.z) or 0.0
            )
        end
    end

    local aim_angle = ui.control.calculate_angle(eye_position, aim_position)
    if not aim_angle then return nil end

    local target_fov = ui.control.get_fov(current_angles, aim_angle)
    if held ~= true and target_fov > settings.fov then return nil end

    return {
        player = player,
        index = target_index,
        userid = ui.control.aim_v2_simple_get_userid(player),
        aim_position = aim_position,
        target_origin = target_origin,
        aim_angle = aim_angle,
        distance = distance,
        fov = target_fov,
        prediction_time = prediction_time,
        incapacitated = incapacitated == true,
        hanging = hanging == true,
        held = held == true,
        score = target_fov + math.min(distance / 1000.0, 8.0) * 0.35
    }
end

function ui.control.get_best_target_v2(local_player, settings, current_angles)
    local runtime = ui.control.runtime
    local held_index = math.floor(tonumber(runtime.lock_session_target_index) or 0)

    if runtime.lock_session_active == true and held_index > 0 then
        local target = ui.control.aim_v2_simple_build_target(
            local_player,
            held_index,
            settings,
            current_angles,
            true
        )

        if target then
            local expected_userid = math.floor(tonumber(runtime.lock_session_target_userid) or 0)
            if expected_userid <= 0 or target.userid <= 0 or expected_userid == target.userid then
                return target
            end
        end

        local cached_position = runtime.simple_cached_aim_position
        local eye_position = ui.control.aim_v2_simple_get_eye_position(local_player)
        if cached_position and eye_position then
            local aim_angle = ui.control.calculate_angle(eye_position, cached_position)
            if aim_angle then
                return {
                    player = nil,
                    index = held_index,
                    userid = runtime.lock_session_target_userid or 0,
                    aim_position = cached_position,
                    target_origin = runtime.simple_cached_target_origin or cached_position,
                    aim_angle = aim_angle,
                    distance = vector.distance(eye_position, runtime.simple_cached_target_origin or cached_position),
                    fov = ui.control.get_fov(current_angles, aim_angle),
                    prediction_time = 0.0,
                    incapacitated = false,
                    hanging = false,
                    held = true,
                    cached = true,
                    score = 0.0
                }
            end
        end

        return nil
    end

    local best_target = nil
    local best_score = math.huge
    local maximum_clients = engine.get_max_clients()

    for player_index = 1, maximum_clients do
        local target = ui.control.aim_v2_simple_build_target(
            local_player,
            player_index,
            settings,
            current_angles,
            false
        )

        if target and target.score < best_score then
            best_target = target
            best_score = target.score
        end
    end

    return best_target
end

function ui.control.stabilize_aim_v2_angles(current_angles, target, settings)
    local delta_time = ui.control.aim_v2_simple_frame_delta()
    local smooth = settings.smooth

    local factor
    if smooth <= 1.001 then
        factor = 1.0
    else
        factor = ui.control.clamp((delta_time * 60.0) / smooth, 0.0, 1.0)
    end

    local pitch_delta = ui.control.normalize_angle(target.aim_angle.x - current_angles.x)
    local yaw_delta = ui.control.normalize_angle(target.aim_angle.y - current_angles.y)

    return vector.new(
        ui.control.clamp(current_angles.x + pitch_delta * factor, -89.0, 89.0),
        ui.control.normalize_angle(current_angles.y + yaw_delta * factor),
        0.0
    )
end

function ui.control.apply_aim_infected(command, local_player)
    local settings = ui.control.normalize_aim_v2_rebuilt_settings()
    local runtime = ui.control.runtime

    if ui.control.aim.enabled ~= true then
        ui.control.aim_v2_simple_reset(true)
        return false
    end

    if tonumber(ui.control.aim.mode) ~= 1 then
        if not ui.control.is_action_key_down() then return false end

        local current_angles = command:get_viewangles()
        local target = ui.control.get_best_target_v1(local_player, ui.control.aim.v1)
        if not target then return false end

        local final_angles = ui.control.smooth_angles_v1(
            current_angles,
            target.aim_angle,
            ui.control.aim.v1.smooth
        )
        final_angles.x = ui.control.normalize_angle(final_angles.x)
        final_angles.y = ui.control.normalize_angle(final_angles.y)
        command:set_viewangles(final_angles)
        if ui.control.aim.v1.silent_aim ~= true then engine.set_view_angles(final_angles) end
        return true
    end

    local supported, _, _, spawn_state = ui.control.get_special_infected_identity(local_player)
    runtime.aim_v2_spawn_state = spawn_state

    if supported ~= true then
        runtime.status = "Infected team only"
        ui.control.aim_v2_simple_reset(true)
        return false
    end

    local key_down = ui.control.is_action_key_down()
    if not key_down then
        if runtime.lock_session_active == true then
            ui.control.finish_aim_v2_lock_session()
            runtime.lock_session_status = "Released"
        end
        return false
    end

    ui.control.begin_aim_v2_lock_session()

    local current_ok, current_angles = pcall(function()
        return command:get_viewangles()
    end)
    if not current_ok or not current_angles then
        runtime.status = "View angles unavailable"
        return false
    end

    local target = ui.control.get_best_target_v2(local_player, settings, current_angles)
    if not target then
        if tonumber(runtime.lock_session_target_index) > 0 then
            runtime.status = "Holding target - waiting for position"
            runtime.lock_session_status = "Held until key release"
        else
            runtime.status = "Searching target"
            runtime.lock_session_status = "Searching"
        end
        return false
    end

    if tonumber(runtime.lock_session_target_index) <= 0 then
        runtime.lock_session_target_index = target.index
        runtime.lock_session_target_userid = target.userid or 0
        runtime.lock_session_target_name = ui.control.get_target_name(target.index)
        runtime.lock_session_status = "Held until key release"
    end

    runtime.locked_target_index = runtime.lock_session_target_index

    if target.cached ~= true then
        runtime.simple_cached_aim_position = vector.new(
            tonumber(target.aim_position.x) or 0.0,
            tonumber(target.aim_position.y) or 0.0,
            tonumber(target.aim_position.z) or 0.0
        )
        runtime.simple_cached_target_origin = vector.new(
            tonumber(target.target_origin.x) or 0.0,
            tonumber(target.target_origin.y) or 0.0,
            tonumber(target.target_origin.z) or 0.0
        )
    end

    local final_angles = ui.control.stabilize_aim_v2_angles(current_angles, target, settings)
    command:set_viewangles(final_angles)
    if settings.silent_aim ~= true then
        engine.set_view_angles(final_angles)
    end

    runtime.target_name = runtime.lock_session_target_name
    runtime.target_fov = tonumber(target.fov) or 0.0
    runtime.target_distance = tonumber(target.distance) or 0.0
    runtime.prediction_time_used = tonumber(target.prediction_time) or 0.0
    runtime.target_state = target.cached and "Cached"
        or target.hanging and "Hanging"
        or target.incapacitated and "Incapacitated"
        or "Standing"
    runtime.status = string.format(
        "%s | Locked: %s | %.0f u",
        tostring(spawn_state),
        tostring(runtime.target_name),
        runtime.target_distance
    )

    ui.control.mark_engaged(runtime.status)
    return true
end

function ui.control.aim_v2_simple_manual_movement_down()
    if type(input) ~= "table" or type(input.is_key_down) ~= "function" then
        return false
    end

    local movement_keys = {
        keys.KEY_W or 0x57,
        keys.KEY_A or 0x41,
        keys.KEY_S or 0x53,
        keys.KEY_D or 0x44
    }

    for _, key_value in ipairs(movement_keys) do
        local ok, down = pcall(input.is_key_down, key_value)
        if ok and down == true then return true end
    end

    return false
end

function ui.control.apply_pursuit_bot(command, local_player)
    local settings = ui.control.normalize_aim_v2_rebuilt_settings()
    local runtime = ui.control.runtime

    if tonumber(ui.control.aim.mode) ~= 1
        or settings.pursuit_enabled ~= true then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Disabled"
        return false
    end

    if not ui.control.is_action_key_down()
        or runtime.lock_session_active ~= true
        or tonumber(runtime.lock_session_target_index) <= 0 then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Waiting for lock"
        return false
    end

    if settings.pursuit_manual_override == true
        and ui.control.aim_v2_simple_manual_movement_down() then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Manual movement override"
        return false
    end

    local target_position = runtime.simple_cached_target_origin
        or runtime.simple_cached_aim_position
    local eye_position = ui.control.aim_v2_simple_get_eye_position(local_player)
    if not target_position or not eye_position then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Waiting for target position"
        return false
    end

    local target_angle = ui.control.calculate_angle(eye_position, target_position)
    local view_angles = command:get_viewangles()
    if not target_angle or not view_angles then
        runtime.pursuit_active = false
        runtime.pursuit_status = "Direction unavailable"
        return false
    end

    local yaw_delta = math.rad(ui.control.normalize_angle(target_angle.y - view_angles.y))
    local strength = settings.pursuit_move_speed

    command:set_forwardmove(math.cos(yaw_delta) * strength)
    command:set_sidemove(-math.sin(yaw_delta) * strength)

    runtime.pursuit_active = true
    runtime.pursuit_distance = vector.distance(eye_position, target_position)
    runtime.pursuit_heading_offset = math.deg(yaw_delta)
    runtime.pursuit_status = string.format("Following locked target | %.0f u", runtime.pursuit_distance)
    return true
end

