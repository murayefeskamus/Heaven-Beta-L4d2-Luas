local config = {
    enabled = true,
    aimkey = keys.MOUSE5,
    fov = 180.0,
    smooth = 1.0,
    target_head = true,
    max_distance = 8192,
    silent_aim = false,
}

if client.get_shared_bool("aim_player_lock_enabled", nil) == nil then
    client.set_shared_bool("aim_player_lock_enabled", false)
    client.set_shared_int("aim_selected_player_idx", 0)
end

local function calcAngle(src, dst)
    local delta = vector.new(
        dst.x - src.x,
        dst.y - src.y,
        dst.z - src.z
    )
    
    local hyp = math.sqrt(delta.x * delta.x + delta.y * delta.y)
    
    local pitch = math.deg(math.atan2(-delta.z, hyp))
    local yaw = math.deg(math.atan2(delta.y, delta.x))
    
    return vector.new(pitch, yaw, 0)
end

local function normalizeAngle(angle)
    while angle > 180 do angle = angle - 360 end
    while angle < -180 do angle = angle + 360 end
    return angle
end

local function getFOV(viewAngles, aimAngles)
    local delta = vector.new(
        normalizeAngle(aimAngles.x - viewAngles.x),
        normalizeAngle(aimAngles.y - viewAngles.y),
        0
    )
    
    return math.sqrt(delta.x * delta.x + delta.y * delta.y)
end

local function smoothAngles(current, target, smooth)
    local delta = vector.new(
        normalizeAngle(target.x - current.x),
        normalizeAngle(target.y - current.y),
        0
    )
    
    local smoothFactor = 1.0 / smooth
    
    return vector.new(
        current.x + delta.x * smoothFactor,
        current.y + delta.y * smoothFactor,
        0
    )
end

local function getBestTarget(localPlayer)
    local eyePos = localPlayer:get_eye_position()
    local viewAngles = localPlayer:get_eye_angles()
    
    local localIndex = localPlayer:get_index()
    
    local lock_enabled = client.get_shared_bool("aim_player_lock_enabled", false)
    local locked_idx = client.get_shared_int("aim_selected_player_idx", 0)

    if lock_enabled and locked_idx > 0 then
        local player = entity.get_by_index(locked_idx)
        if player and player:is_alive() and not player:is_incapacitated() then
            local targetPos = player:get_origin()
            local distance = vector.distance(eyePos, targetPos)
            
            if distance <= config.max_distance then
                local aimPos = config.target_head and player:get_eye_position() or targetPos
                local aimAngle = calcAngle(eyePos, aimPos)
                local fov = getFOV(viewAngles, aimAngle)
                
                if fov <= config.fov then
                    return {
                        player = player,
                        aimPos = aimPos,
                        aimAngle = aimAngle,
                        distance = distance,
                        fov = fov
                    }
                end
            end
        end
        return nil 
    end

    local bestTarget = nil
    local bestFov = config.fov
    local maxEntities = engine.get_max_clients()
    
    for i = 1, maxEntities do
        local player = entity.get_by_index(i)
        
        if not player or i == localIndex or not player:is_alive() then
            goto continue
        end
        
        if player:get_team() ~= 2 or player:is_incapacitated() then
            goto continue
        end
        
        local targetPos = player:get_origin()
        local distance = vector.distance(eyePos, targetPos)
        if distance > config.max_distance then
            goto continue
        end
        
        local aimPos = config.target_head and player:get_eye_position() or targetPos
        local aimAngle = calcAngle(eyePos, aimPos)
        local fov = getFOV(viewAngles, aimAngle)

        if fov < bestFov then
            bestFov = fov
            bestTarget = {
                player = player,
                aimPos = aimPos,
                aimAngle = aimAngle,
                distance = distance,
                fov = fov
            }
        end
        
        ::continue::
    end
    
    return bestTarget
end

function on_create_move(cmd, local_player)
    if not config.enabled then return end
    if not local_player or not local_player:is_alive() then return end
    if not engine.is_in_game() then return end

    local team = local_player:get_team()
    if team ~= 3 then return end
    
    if not input.is_key_down(config.aimkey) then return end
    
    local target = getBestTarget(local_player)
    if not target then return end
    
    local currentAngles = cmd:get_viewangles()
    local targetAngles = target.aimAngle
    
    local finalAngles = currentAngles
    if config.smooth > 0 then
        finalAngles = smoothAngles(currentAngles, targetAngles, config.smooth)
    else
        finalAngles = targetAngles
    end
    
    finalAngles.x = normalizeAngle(finalAngles.x)
    finalAngles.y = normalizeAngle(finalAngles.y)
    
    cmd:set_viewangles(finalAngles)
    
    if not config.silent_aim then
        engine.set_view_angles(finalAngles)
    end
end


menu.add_main_tab("Aim Infected", function()
    imgui.text("Infected Aimbot Custom Targets")
    imgui.separator()

    local changed, val = imgui.checkbox("Enable Player Specific Lock", client.get_shared_bool("aim_player_lock_enabled", false))
    if changed then client.set_shared_bool("aim_player_lock_enabled", val) end

    imgui.separator()
    imgui.text("Target Selector:")

    local player_names = {"[ None ]"}
    local player_indices = {0}
    local maxEntities = engine.get_max_clients()
    local current_selection_idx = 0
    local saved_idx = client.get_shared_int("aim_selected_player_idx", 0)

    for i = 1, maxEntities do
        local player = entity.get_by_index(i)
        if player and player:get_team() == 2 then 
            local info = engine.get_player_info(i)
            if info and info.name then
                table.insert(player_names, info.name)
                table.insert(player_indices, i)
                

                if i == saved_idx then
                    current_selection_idx = #player_names - 1
                end
            end
        end
    end


    local changed, idx = imgui.combo("Select Player", current_selection_idx, player_names)
    if changed then

        local real_player_index = player_indices[idx + 1]
        client.set_shared_int("aim_selected_player_idx", real_player_index)
    end

    imgui.separator()
    imgui["end"]()
end)

